# Auth (Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# AUTH_PASSWORD_RESET_REDIRECT_URL=https://fastt-five.vercel.app/auth/reset-password

# Local-only auth bypass for provider/dashboard development.
# LOCAL_QA_AUTH_ENABLED=true
# LOCAL_QA_AUTH_USER_ID=qa-user-ellaggon-gmail-com
# LOCAL_QA_AUTH_EMAIL=ellaggon@gmail.com
# LOCAL_QA_PROVIDER_ID=qa-financial-provider-ellaggon

# Internal admin RBAC. Comma-separated emails allowed to access /admin and /api/admin surfaces.
INTERNAL_ADMIN_EMAILS=

# Astro DB (libsql/Turso)
ASTRO_DB_REMOTE_URL=
ASTRO_DB_APP_TOKEN=

# Supabase Postgres (business database, migration target)
# Runtime/serverless traffic should use the Supabase transaction pooler URL.
DATABASE_URL=
SUPABASE_DB_POOLER_URL=
# Direct database URL is reserved for migrations, dumps, restores, and admin tasks.
DIRECT_URL=

# Shared cache (Redis/Upstash). Use REDIS_URL=redis:// or rediss:// for Redis.
# For Upstash REST, use UPSTASH_REDIS_REST_URL=https://... plus UPSTASH_REDIS_REST_TOKEN=...
# Choose the Redis region close to Vercel SSR execution. If Vercel runs in gru1,
# prefer Upstash/AWS sa-east-1. If the fallback is iad1, prefer us-east-1.
REDIS_URL=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Protects /api/internal/observability/infra-region in deployed environments.
# Use this for regional DB/cache latency checks from preview/production.
# FASTT_INFRA_HEALTH_TOKEN=

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Payout account encryption (AES-256-GCM). Generate locally — do NOT reuse app passwords.
#   openssl rand -base64 48
# Put the output as the value. Required in production; local/test has a deterministic fallback.
PROVIDER_PAYOUT_SECRETS_KEY=

# TOKEN_VALUE=
# ASTRO_STUDIO_APP_TOKEN=

# AI agents (opcional)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Search shadow comparison / rollout
SEARCH_SHADOW_COMPARE=false
SEARCH_SHADOW_SAMPLING_RATE=0.1

# Search health thresholds
SEARCH_MAX_SELLABLE_MISMATCH_RATE=0.01
SEARCH_MAX_REASON_MISMATCH_RATE=0.05
SEARCH_MAX_PRICE_MISMATCH_RATE=0.02
SEARCH_MAX_CRITICAL_MISMATCH_RATE=0.005

# Rollout percentage for the rules/policies UI. 0 disables, 100 enables for everyone.
RULES_UI_ENABLED=100
