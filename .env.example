# Astro DB (libsql/Turso)
ASTRO_DB_REMOTE_URL=
ASTRO_DB_APP_TOKEN=

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# TOKEN_VALUE=
# ASTRO_STUDIO_APP_TOKEN=

# DATABASE_URL=
