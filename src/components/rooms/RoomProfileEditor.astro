---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import FormSection from "@/components/ui/FormSection.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import Textarea from "@/components/ui/Textarea.astro"
import { BED_TYPES } from "@/data/room/room-beds"
import { routes } from "@/lib/routes"
import {
	Bath,
	BedDouble,
	ClipboardList,
	Hotel,
	Sparkles,
	UserRound,
	WandSparkles,
} from "@lucide/astro"

type RoomTypeOption = { id: string; name: string; maxOccupancy: number | null }
type AmenityOption = { id: string; name: string; category: string | null }
type BedRow = { bedType: string; count: number; roomLabel?: string | null }
type RoomProfileValue = {
	roomTypeId?: string | null
	totalRooms?: number | null
	sizeM2?: number | null
	viewType?: string | null
	bathroomCount?: number | null
	bathroomType?: string | null
	hasBalcony?: boolean | null
	guestFacingNotes?: string | null
	beds?: BedRow[]
}

interface Props {
	productId: string
	variantId?: string | null
	mode: "create" | "edit"
	roomName?: string | null
	roomDescription?: string | null
	roomCode?: string | null
	capacity?: {
		minOccupancy?: number | null
		maxOccupancy?: number | null
		maxAdults?: number | null
		maxChildren?: number | null
	} | null
	profile?: RoomProfileValue | null
	roomTypes: RoomTypeOption[]
	amenities: AmenityOption[]
	selectedAmenityIds?: string[]
}

const {
	productId,
	variantId = null,
	mode,
	roomName = "",
	roomDescription = "",
	roomCode = "",
	capacity = null,
	profile = null,
	roomTypes,
	amenities,
	selectedAmenityIds = [],
} = Astro.props

const selectedAmenitySet = new Set(selectedAmenityIds.map((id) => String(id)))
const groupedAmenities = amenities.reduce<Record<string, AmenityOption[]>>((acc, amenity) => {
	const category = String(amenity.category ?? "General").trim() || "General"
	acc[category] = acc[category] ?? []
	acc[category].push(amenity)
	return acc
}, {})

const bedRows =
	Array.isArray(profile?.beds) && profile.beds.length > 0
		? profile.beds
		: [{ bedType: "queen", count: 1, roomLabel: "" }]

const initial = {
	name: String(roomName ?? ""),
	description: String(roomDescription ?? ""),
	roomCode: String(roomCode ?? ""),
	minOccupancy: capacity?.minOccupancy != null ? String(capacity.minOccupancy) : "1",
	maxOccupancy: capacity?.maxOccupancy != null ? String(capacity.maxOccupancy) : "",
	maxAdults: capacity?.maxAdults != null ? String(capacity.maxAdults) : "",
	maxChildren: capacity?.maxChildren != null ? String(capacity.maxChildren) : "",
	roomTypeId: String(profile?.roomTypeId ?? ""),
	totalRooms: profile?.totalRooms != null ? String(profile.totalRooms) : "1",
	sizeM2: profile?.sizeM2 != null ? String(profile.sizeM2) : "",
	viewType: String(profile?.viewType ?? ""),
	bathroomCount: profile?.bathroomCount != null ? String(profile.bathroomCount) : "1",
	bathroomType: String(profile?.bathroomType ?? "private"),
	hasBalcony:
		profile?.hasBalcony === true ? "true" : profile?.hasBalcony === false ? "false" : "unknown",
	guestFacingNotes: String(profile?.guestFacingNotes ?? ""),
}

const submitLabel = mode === "create" ? "Crear habitación" : "Guardar habitación"
const introTitle =
	mode === "create" ? "Crea una habitación lista para huéspedes" : "Editar habitación"
const introCopy =
	"Define lo que el huésped verá antes de reservar: nombre, capacidad, camas, baño, vista, comodidades y notas importantes."
const bedTypeLabels = Object.fromEntries(BED_TYPES.map((bedType) => [bedType.id, bedType.name]))
const guideSteps = [
	{
		id: "nombre-tipo",
		label: "Nombre y tipo",
		summary: "Identidad visible e identificador interno.",
	},
	{ id: "capacidad", label: "Capacidad", summary: "Cuántos huéspedes pueden alojarse." },
	{ id: "dormir", label: "Dónde dormirán", summary: "Camas y ambientes de descanso." },
	{ id: "bano-espacio", label: "Baño y espacio", summary: "Baño, tamaño, vista y balcón." },
	{ id: "comodidades", label: "Comodidades", summary: "Amenities propias de la habitación." },
	{ id: "preview", label: "Preview", summary: "Revisión final antes de guardar." },
]
---

<Card class="bg-slate-100">
	<form id="roomProfileForm" class="space-y-8">
		<Input type="hidden" name="productId" value={productId} />
		<Input type="hidden" name="variantId" value={variantId ?? ""} />
		<Input type="hidden" name="kind" value="hotel_room" />

		<div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_380px]">
			<div class="min-w-0 space-y-8">
				<div class="rounded-2xl border border-blue-200 bg-blue-50 p-5 text-sm text-blue-950">
					<div class="flex items-start gap-3">
						<div
							class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white text-blue-800 ring-1 ring-blue-100"
						>
							<Hotel class="h-5 w-5" />
						</div>
						<div>
							<p class="font-semibold">{introTitle}</p>
							<p class="mt-1 leading-6">{introCopy}</p>
						</div>
					</div>
				</div>

				<div
					class="rounded-2xl border border-slate-200 bg-white p-4"
					aria-label="Guía de configuración de habitación"
				>
					<div class="flex flex-wrap items-start justify-between gap-3">
						<div>
							<p class="flex items-center gap-2 text-sm font-semibold text-slate-900">
								<Sparkles class="h-4 w-4 text-blue-800" />
								Setup guiado de habitación
							</p>
							<p class="mt-1 text-sm leading-6 text-slate-600">
								Completa la ficha como un recorrido: primero identidad, luego capacidad, descanso,
								baño, comodidades y preview.
							</p>
						</div>
						<span
							id="roomGuideProgress"
							class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-700"
						>
							0/6 listo
						</span>
					</div>
					<div class="mt-4 h-2 overflow-hidden rounded-full bg-slate-100">
						<div id="roomGuideProgressBar" class="h-full w-0 bg-blue-700"></div>
					</div>
					<div class="mt-4 grid gap-2 md:grid-cols-2 xl:grid-cols-3">
						{
							guideSteps.map((step, index) => (
								<button
									type="button"
									data-guide-nav={step.id}
									class="roomGuideNav rounded-xl border border-slate-200 bg-slate-50 p-3 text-left transition hover:border-blue-300 hover:bg-blue-50"
								>
									<span class="flex items-center justify-between gap-3">
										<span class="text-sm font-semibold text-slate-900">
											{index + 1}. {step.label}
										</span>
										<span
											data-guide-state={step.id}
											class="rounded-full bg-white px-2 py-0.5 text-[11px] font-semibold text-slate-500"
										>
											Pendiente
										</span>
									</span>
									<span class="mt-1 block text-xs leading-5 text-slate-600">{step.summary}</span>
								</button>
							))
						}
					</div>
				</div>

				<div class="rounded-2xl border border-slate-200 bg-white p-4">
					<div class="flex flex-wrap items-start justify-between gap-3">
						<div>
							<p class="flex items-center gap-2 text-sm font-semibold text-slate-900">
								<WandSparkles class="h-4 w-4 text-blue-800" />
								Configuración rápida
							</p>
							<p class="mt-1 text-sm text-slate-600">
								Usa un punto de partida y ajusta los detalles. No cambia precios ni disponibilidad.
							</p>
						</div>
					</div>
					<div class="mt-4 grid gap-3 md:grid-cols-3">
						<button
							type="button"
							class="roomPreset rounded-2xl border border-slate-200 bg-slate-50 p-4 text-left transition hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50 hover:shadow-sm"
							data-preset="couple"
						>
							<span class="flex items-center gap-2 text-sm font-semibold text-slate-900">
								<BedDouble class="h-4 w-4 text-blue-800" />
								Pareja
							</span>
							<span class="mt-1 block text-xs leading-5 text-slate-600">
								1-2 huéspedes, cama queen, baño privado.
							</span>
							<span
								class="mt-3 block rounded-xl bg-white px-3 py-2 text-xs font-medium text-slate-700"
							>
								Impacto: capacidad 2, baño privado y cama queen.
							</span>
						</button>
						<button
							type="button"
							class="roomPreset rounded-2xl border border-slate-200 bg-slate-50 p-4 text-left transition hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50 hover:shadow-sm"
							data-preset="family"
						>
							<span class="flex items-center gap-2 text-sm font-semibold text-slate-900">
								<UserRound class="h-4 w-4 text-blue-800" />
								Familiar
							</span>
							<span class="mt-1 block text-xs leading-5 text-slate-600">
								Hasta 4 huéspedes, cama doble y camas simples.
							</span>
							<span
								class="mt-3 block rounded-xl bg-white px-3 py-2 text-xs font-medium text-slate-700"
							>
								Impacto: capacidad 4, cama doble y camas simples.
							</span>
						</button>
						<button
							type="button"
							class="roomPreset rounded-2xl border border-slate-200 bg-slate-50 p-4 text-left transition hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50 hover:shadow-sm"
							data-preset="shared"
						>
							<span class="flex items-center gap-2 text-sm font-semibold text-slate-900">
								<Bath class="h-4 w-4 text-blue-800" />
								Económica
							</span>
							<span class="mt-1 block text-xs leading-5 text-slate-600">
								1 huésped, cama simple, baño compartido o dedicado.
							</span>
							<span
								class="mt-3 block rounded-xl bg-white px-3 py-2 text-xs font-medium text-slate-700"
							>
								Impacto: capacidad 1, cama simple y baño compartido.
							</span>
						</button>
					</div>
					<div
						id="presetImpact"
						class="mt-4 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-3 text-sm leading-6 text-slate-600"
					>
						Selecciona un preset para ver qué campos se completarán antes de guardar.
					</div>
				</div>

				<div id="nombre-tipo" data-guide-section="nombre-tipo" class="scroll-mt-24">
					<FormSection title="Nombre y tipo" class="text-neutral-800">
						<p class="-mt-2 mb-4 text-sm leading-6 text-slate-600">
							Define cómo reconocerán esta habitación el huésped y tu operación interna.
						</p>
						<div class="grid gap-4 md:grid-cols-2">
							<FormField label="Nombre de la habitación" htmlFor="name" required>
								<Input
									id="name"
									name="name"
									value={initial.name}
									required
									minlength="1"
									placeholder="Suite jardín, Habitación familiar..."
								/>
							</FormField>
							<FormField
								label="Código interno"
								htmlFor="roomCode"
								description="Identificador operativo para recepción, reportes o channel managers. No se muestra al huésped."
							>
								<Input
									id="roomCode"
									name="roomCode"
									value={initial.roomCode}
									placeholder="STD-101, DLX-KING, FAM-02..."
								/>
							</FormField>
							<FormField label="Tipo de habitación" htmlFor="roomTypeId">
								<Select id="roomTypeId" name="roomTypeId" value={initial.roomTypeId}>
									<option value="">Selecciona una opción</option>
									{
										roomTypes.map((roomType) => (
											<option value={roomType.id}>
												{roomType.name}
												{roomType.maxOccupancy != null ? ` · hasta ${roomType.maxOccupancy}` : ""}
											</option>
										))
									}
								</Select>
							</FormField>
						</div>
						<FormField label="Descripción breve para huésped" htmlFor="description">
							<Textarea
								id="description"
								name="description"
								value={initial.description}
								rows="3"
								placeholder="Describe el ambiente, la luz, la vista o para quién es ideal."
							/>
						</FormField>
						<FormField label="Notas visibles para huésped" htmlFor="guestFacingNotes">
							<Textarea
								id="guestFacingNotes"
								name="guestFacingNotes"
								value={initial.guestFacingNotes}
								rows="3"
								placeholder="Ej. Vista al jardín, acceso por escalera, ideal para parejas."
							/>
						</FormField>
					</FormSection>
				</div>

				<div id="capacidad" data-guide-section="capacidad" class="scroll-mt-24">
					<FormSection title="Capacidad" class="text-neutral-800">
						<p class="-mt-2 mb-4 text-sm leading-6 text-slate-600">
							Indica el rango real de huéspedes. Esto alimenta búsqueda, disponibilidad y claridad
							de reserva.
						</p>
						<div class="grid gap-4 md:grid-cols-4">
							<FormField label="Mínimo huéspedes" htmlFor="minOccupancy" required>
								<Input
									id="minOccupancy"
									name="minOccupancy"
									type="number"
									min="1"
									step="1"
									value={initial.minOccupancy}
									required
								/>
							</FormField>
							<FormField label="Máximo huéspedes" htmlFor="maxOccupancy" required>
								<Input
									id="maxOccupancy"
									name="maxOccupancy"
									type="number"
									min="1"
									step="1"
									value={initial.maxOccupancy}
									required
								/>
							</FormField>
							<FormField label="Máximo adultos" htmlFor="maxAdults">
								<Input
									id="maxAdults"
									name="maxAdults"
									type="number"
									min="0"
									step="1"
									value={initial.maxAdults}
								/>
							</FormField>
							<FormField label="Máximo niños" htmlFor="maxChildren">
								<Input
									id="maxChildren"
									name="maxChildren"
									type="number"
									min="0"
									step="1"
									value={initial.maxChildren}
								/>
							</FormField>
						</div>
					</FormSection>
				</div>

				<div id="dormir" data-guide-section="dormir" class="scroll-mt-24">
					<FormSection title="Dónde dormirán" class="text-neutral-800">
						<p class="-mt-2 mb-4 text-sm leading-6 text-slate-600">
							Configura camas por ambiente para que el huésped entienda exactamente dónde dormirá.
						</p>
						<div class="space-y-3" id="bedRows">
							{
								bedRows.map((bed, index) => (
									<div class="grid gap-3 rounded-lg border border-slate-200 bg-white p-3 md:grid-cols-[2fr_1fr_2fr_auto]">
										<FormField label="Tipo" htmlFor={`bedType_${index}`} required>
											<Select
												id={`bedType_${index}`}
												name="bedType"
												value={String(bed.bedType ?? "")}
												required
											>
												{BED_TYPES.map((bedType) => (
													<option value={bedType.id}>{bedType.name}</option>
												))}
											</Select>
										</FormField>
										<FormField label="Cantidad" htmlFor={`bedCount_${index}`} required>
											<Input
												id={`bedCount_${index}`}
												name="bedCount"
												type="number"
												min="1"
												step="1"
												value={String(bed.count ?? 1)}
												required
											/>
										</FormField>
										<FormField label="Ambiente" htmlFor={`bedRoomLabel_${index}`}>
											<Input
												id={`bedRoomLabel_${index}`}
												name="bedRoomLabel"
												value={String(bed.roomLabel ?? "")}
												placeholder="Dormitorio principal"
											/>
										</FormField>
										<button
											type="button"
											class="removeBedRow mt-7 inline-flex h-10 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 text-sm text-slate-700 hover:bg-slate-50"
											aria-label="Eliminar cama"
										>
											Quitar
										</button>
									</div>
								))
							}
						</div>
						<Button id="addBedRow" type="button" variant="secondary">Agregar cama</Button>
					</FormSection>
				</div>

				<div id="bano-espacio" data-guide-section="bano-espacio" class="scroll-mt-24">
					<FormSection title="Baño y espacio" class="text-neutral-800">
						<p class="-mt-2 mb-4 text-sm leading-6 text-slate-600">
							Explica condiciones físicas que suelen definir la confianza del huésped: baño, tamaño,
							vista y balcón.
						</p>
						<div class="grid gap-4 md:grid-cols-4">
							<FormField
								label="Unidades disponibles de esta configuración"
								htmlFor="totalRooms"
								description="Cuántas habitaciones físicas comparten este mismo perfil de camas, baño y comodidades."
								required
							>
								<Input
									id="totalRooms"
									name="totalRooms"
									type="number"
									min="1"
									step="1"
									value={initial.totalRooms}
									required
								/>
							</FormField>
							<FormField label="Tamaño aprox. (m²)" htmlFor="sizeM2">
								<Input
									id="sizeM2"
									name="sizeM2"
									type="number"
									min="0"
									step="1"
									value={initial.sizeM2}
								/>
							</FormField>
							<FormField label="Vista" htmlFor="viewType">
								<Input
									id="viewType"
									name="viewType"
									value={initial.viewType}
									placeholder="Mar, jardín, ciudad..."
								/>
							</FormField>
							<FormField label="Balcón" htmlFor="hasBalcony">
								<Select id="hasBalcony" name="hasBalcony" value={initial.hasBalcony}>
									<option value="unknown">Sin especificar</option>
									<option value="true">Sí</option>
									<option value="false">No</option>
								</Select>
							</FormField>
						</div>
						<div class="grid gap-4 md:grid-cols-2">
							<FormField label="Cantidad de baños" htmlFor="bathroomCount">
								<Input
									id="bathroomCount"
									name="bathroomCount"
									type="number"
									min="0"
									step="1"
									value={initial.bathroomCount}
								/>
							</FormField>
							<FormField label="Tipo de baño" htmlFor="bathroomType">
								<Select id="bathroomType" name="bathroomType" value={initial.bathroomType}>
									<option value="unknown">Sin especificar</option>
									<option value="private">Privado</option>
									<option value="ensuite">En suite</option>
									<option value="dedicated">Dedicado fuera de la habitación</option>
									<option value="shared">Compartido</option>
								</Select>
							</FormField>
						</div>
					</FormSection>
				</div>

				<div id="comodidades" data-guide-section="comodidades" class="scroll-mt-24">
					<FormSection title="Comodidades" class="text-neutral-800">
						<p class="-mt-2 mb-4 text-sm leading-6 text-slate-600">
							Selecciona solo amenities propias de esta habitación. Servicios generales del
							alojamiento viven fuera de esta ficha.
						</p>
						{
							amenities.length > 0 ? (
								<div class="grid gap-4 md:grid-cols-2">
									{Object.entries(groupedAmenities).map(([category, items]) => (
										<div class="rounded-lg border border-slate-200 bg-white p-4">
											<p class="mb-3 text-sm font-semibold text-slate-900">{category}</p>
											<div class="space-y-2">
												{items.map((amenity) => (
													<label class="flex items-center gap-2 text-sm text-slate-700">
														<input
															type="checkbox"
															name="amenityId"
															value={amenity.id}
															checked={selectedAmenitySet.has(String(amenity.id))}
															class="h-4 w-4 rounded border-slate-300 text-blue-700"
														/>
														<span>{amenity.name}</span>
													</label>
												))}
											</div>
										</div>
									))}
								</div>
							) : (
								<div class="rounded-2xl border border-dashed border-slate-300 bg-white p-5">
									<p class="flex items-center gap-2 text-sm font-semibold text-slate-900">
										<ClipboardList class="h-4 w-4" />
										Aún no hay comodidades configuradas
									</p>
									<p class="mt-1 text-sm leading-6 text-slate-600">
										Guarda la habitación ahora. Luego podrás sumar Wi-Fi, minibar, climatización u
										otras comodidades visibles para huéspedes.
									</p>
								</div>
							)
						}
					</FormSection>
				</div>

				<div
					id="preview"
					data-guide-section="preview"
					class="scroll-mt-24 rounded-2xl border border-blue-200 bg-blue-50 p-5"
				>
					<p class="flex items-center gap-2 text-sm font-semibold text-blue-950">
						<BedDouble class="h-4 w-4" />
						Preview
					</p>
					<p class="mt-1 text-sm leading-6 text-blue-950">
						Revisa la tarjeta lateral “Preview huésped”. Si nombre, capacidad, camas, baño y notas
						se entienden sin explicación extra, la habitación está lista para guardar.
					</p>
				</div>

				<p id="roomProfileFeedback" class="whitespace-pre-wrap text-sm text-slate-600"></p>

				<div class="flex flex-wrap items-center justify-between gap-3">
					<a
						href={variantId
							? routes.productRoomDetail(productId, variantId)
							: routes.productRoomsForProduct(productId)}
						class="inline-flex h-10 items-center justify-center rounded-lg border border-neutral-300 bg-neutral-100 px-4 text-sm font-medium text-neutral-900 hover:bg-neutral-200"
					>
						Volver
					</a>
					<Button
						id="roomProfileSubmit"
						type="submit"
						className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
					>
						<Sparkles class="mr-2 h-4 w-4" />
						{submitLabel}
					</Button>
				</div>
			</div>

			<aside class="xl:sticky xl:top-4 xl:self-start">
				<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
					<div class="flex min-h-[180px] items-center justify-center bg-slate-100 p-6">
						<div
							class="flex h-20 w-20 items-center justify-center rounded-2xl bg-blue-50 text-blue-800"
						>
							<BedDouble class="h-10 w-10" />
						</div>
					</div>
					<div class="space-y-5 p-5">
						<div class="space-y-1">
							<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
								Preview huésped
							</p>
							<h2 id="roomEditorPreviewTitle" class="text-xl font-semibold text-slate-950">
								Habitación por nombrar
							</h2>
							<p id="roomEditorPreviewDescription" class="text-sm leading-6 text-slate-600">
								La descripción aparecerá aquí mientras editas.
							</p>
						</div>

						<div class="grid gap-2 text-sm sm:grid-cols-2 xl:grid-cols-1">
							<div class="rounded-xl bg-slate-50 p-3">
								<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
									Capacidad
								</p>
								<p id="roomEditorPreviewOccupancy" class="mt-1 font-semibold text-slate-900">
									Por confirmar
								</p>
							</div>
							<div class="rounded-xl bg-slate-50 p-3">
								<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Baño</p>
								<p id="roomEditorPreviewBathroom" class="mt-1 font-semibold text-slate-900">
									Por confirmar
								</p>
							</div>
						</div>

						<div>
							<h3 class="flex items-center gap-2 text-sm font-semibold text-slate-900">
								<BedDouble class="h-4 w-4 text-blue-800" />
								Dónde dormirás
							</h3>
							<div id="roomEditorPreviewBeds" class="mt-3 space-y-2">
								<p
									class="rounded-xl border border-dashed border-slate-300 p-3 text-sm text-slate-500"
								>
									Agrega camas para completar esta sección.
								</p>
							</div>
						</div>

						<div>
							<h3 class="text-sm font-semibold text-slate-900">Comodidades visibles</h3>
							<div id="roomEditorPreviewAmenities" class="mt-3 flex flex-wrap gap-2">
								<span class="text-sm text-slate-500">Selecciona comodidades propias.</span>
							</div>
						</div>

						<p
							id="roomEditorPreviewNotes"
							class="rounded-xl bg-blue-50 p-3 text-sm leading-6 text-blue-950"
						>
							Las notas importantes para huéspedes aparecerán aquí.
						</p>
					</div>
				</div>
			</aside>
		</div>
	</form>

	<template id="bedRowTemplate">
		<div
			class="grid gap-3 rounded-lg border border-slate-200 bg-white p-3 md:grid-cols-[2fr_1fr_2fr_auto]"
		>
			<label class="block space-y-1 text-sm">
				<span class="font-medium text-slate-700">Tipo</span>
				<select
					name="bedType"
					required
					class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm text-slate-900"
				>
					{BED_TYPES.map((bedType) => <option value={bedType.id}>{bedType.name}</option>)}
				</select>
			</label>
			<label class="block space-y-1 text-sm">
				<span class="font-medium text-slate-700">Cantidad</span>
				<input
					name="bedCount"
					type="number"
					min="1"
					step="1"
					value="1"
					required
					class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm text-slate-900"
				/>
			</label>
			<label class="block space-y-1 text-sm">
				<span class="font-medium text-slate-700">Ambiente</span>
				<input
					name="bedRoomLabel"
					placeholder="Dormitorio principal"
					class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm text-slate-900"
				/>
			</label>
			<button
				type="button"
				class="removeBedRow mt-7 inline-flex h-10 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 text-sm text-slate-700 hover:bg-slate-50"
			>
				Quitar
			</button>
		</div>
	</template>
</Card>

<script type="module" define:vars={{ productId, fallbackVariantId: variantId ?? "", bedTypeLabels }}
>
	const form = document.getElementById("roomProfileForm")
	const submitBtn = document.getElementById("roomProfileSubmit")
	const feedback = document.getElementById("roomProfileFeedback")
	const addBedRow = document.getElementById("addBedRow")
	const bedRows = document.getElementById("bedRows")
	const bedRowTemplate = document.getElementById("bedRowTemplate")
	const previewTitle = document.getElementById("roomEditorPreviewTitle")
	const previewDescription = document.getElementById("roomEditorPreviewDescription")
	const previewOccupancy = document.getElementById("roomEditorPreviewOccupancy")
	const previewBathroom = document.getElementById("roomEditorPreviewBathroom")
	const previewBeds = document.getElementById("roomEditorPreviewBeds")
	const previewAmenities = document.getElementById("roomEditorPreviewAmenities")
	const previewNotes = document.getElementById("roomEditorPreviewNotes")
	const guideProgress = document.getElementById("roomGuideProgress")
	const guideProgressBar = document.getElementById("roomGuideProgressBar")
	const guideNavButtons = Array.from(document.querySelectorAll("[data-guide-nav]"))
	const guideStateBadges = Array.from(document.querySelectorAll("[data-guide-state]"))
	const presetImpact = document.getElementById("presetImpact")

	const bathroomLabels = {
		unknown: "Baño por confirmar",
		private: "baño privado",
		ensuite: "baño en suite",
		dedicated: "baño dedicado",
		shared: "baño compartido",
	}

	function setState(state, detail = "") {
		const labels = {
			loading: "Guardando habitación...",
			success: "Habitación guardada correctamente.",
			error: "No se pudo guardar la habitación.",
		}
		if (feedback) feedback.textContent = `${labels[state] ?? ""}${detail ? `\n${detail}` : ""}`
	}

	function bindRemoveButtons() {
		for (const button of document.querySelectorAll(".removeBedRow")) {
			if (button.dataset.bound === "true") continue
			button.dataset.bound = "true"
			button.addEventListener("click", () => {
				const row = button.closest(".grid")
				const totalRows = document.querySelectorAll("#bedRows > .grid").length
				if (row && totalRows > 1) row.remove()
				renderEditorPreview()
			})
		}
	}

	function getField(name) {
		const field = form?.querySelector(`[name="${name}"]`)
		if (
			field instanceof HTMLInputElement ||
			field instanceof HTMLTextAreaElement ||
			field instanceof HTMLSelectElement
		) {
			return field.value.trim()
		}
		return ""
	}

	function setField(name, value) {
		const field = form?.querySelector(`[name="${name}"]`)
		if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
			field.value = String(value ?? "")
		}
		if (field instanceof HTMLSelectElement) {
			field.value = String(value ?? "")
		}
	}

	function addBedPresetRow(bedType, count, roomLabel) {
		const content = bedRowTemplate?.content?.cloneNode(true)
		if (!content || !bedRows) return
		bedRows.appendChild(content)
		const row = bedRows.lastElementChild
		const bedTypeInput = row?.querySelector('[name="bedType"]')
		const bedCountInput = row?.querySelector('[name="bedCount"]')
		const bedRoomLabelInput = row?.querySelector('[name="bedRoomLabel"]')
		if (bedTypeInput instanceof HTMLSelectElement) bedTypeInput.value = bedType
		if (bedCountInput instanceof HTMLInputElement) bedCountInput.value = String(count)
		if (bedRoomLabelInput instanceof HTMLInputElement) bedRoomLabelInput.value = roomLabel
	}

	function pluralize(count, singular, plural) {
		return `${count} ${count === 1 ? singular : plural}`
	}

	function escapeHtml(value) {
		return String(value ?? "")
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
			.replaceAll("'", "&#039;")
	}

	function formatOccupancy() {
		const minOccupancy = Number(getField("minOccupancy"))
		const maxOccupancy = Number(getField("maxOccupancy"))
		if (Number.isFinite(maxOccupancy) && maxOccupancy > 0) {
			if (Number.isFinite(minOccupancy) && minOccupancy > 0 && minOccupancy !== maxOccupancy) {
				return `${minOccupancy}-${maxOccupancy} huéspedes`
			}
			return pluralize(maxOccupancy, "huésped", "huéspedes")
		}
		return "Por confirmar"
	}

	function formatBathroom() {
		const count = Number(getField("bathroomCount"))
		const type = getField("bathroomType") || "unknown"
		const typeLabel = bathroomLabels[type] ?? "baño"
		if (!Number.isFinite(count) || count <= 0) return typeLabel
		return `${pluralize(count, "baño", "baños")} · ${typeLabel}`
	}

	function collectBeds() {
		return Array.from(document.querySelectorAll("#bedRows > .grid"))
			.map((row) => {
				const bedTypeInput = row.querySelector('[name="bedType"]')
				const bedCountInput = row.querySelector('[name="bedCount"]')
				const bedRoomLabelInput = row.querySelector('[name="bedRoomLabel"]')
				const bedType = bedTypeInput instanceof HTMLSelectElement ? bedTypeInput.value : ""
				const countValue =
					bedCountInput instanceof HTMLInputElement ? Number(bedCountInput.value) : 1
				const roomLabel =
					bedRoomLabelInput instanceof HTMLInputElement ? bedRoomLabelInput.value.trim() : ""
				return {
					bedType,
					count: Number.isFinite(countValue) && countValue > 0 ? countValue : 1,
					roomLabel: roomLabel || "Dormitorio",
				}
			})
			.filter((bed) => bed.bedType)
	}

	function collectAmenityLabels() {
		return Array.from(form?.querySelectorAll('input[name="amenityId"]:checked') ?? [])
			.map((input) => {
				const label = input.closest("label")
				return label?.innerText?.trim() ?? ""
			})
			.filter(Boolean)
	}

	function hasPositiveNumber(name) {
		const value = Number(getField(name))
		return Number.isFinite(value) && value > 0
	}

	function computeGuideState() {
		const nameReady = Boolean(getField("name")) && Boolean(getField("roomTypeId"))
		const capacityReady = hasPositiveNumber("minOccupancy") && hasPositiveNumber("maxOccupancy")
		const sleepReady = collectBeds().length > 0
		const bathReady = hasPositiveNumber("bathroomCount") && Boolean(getField("bathroomType"))
		const amenitiesReady = collectAmenityLabels().length > 0
		const previewReady = nameReady && capacityReady && sleepReady && bathReady
		return {
			"nombre-tipo": nameReady,
			"capacidad": capacityReady,
			"dormir": sleepReady,
			"bano-espacio": bathReady,
			"comodidades": amenitiesReady,
			"preview": previewReady,
		}
	}

	function renderGuideProgress() {
		const state = computeGuideState()
		const entries = Object.entries(state)
		const completed = entries.filter(([, ready]) => ready).length
		const total = entries.length
		const percent = Math.round((completed / total) * 100)
		if (guideProgress) guideProgress.textContent = `${completed}/${total} listo`
		if (guideProgressBar) guideProgressBar.style.width = `${percent}%`
		for (const badge of guideStateBadges) {
			const id = badge.getAttribute("data-guide-state")
			const ready = Boolean(state[id])
			badge.textContent = ready ? "Listo" : "Pendiente"
			badge.className = ready
				? "rounded-full bg-emerald-50 px-2 py-0.5 text-[11px] font-semibold text-emerald-700"
				: "rounded-full bg-white px-2 py-0.5 text-[11px] font-semibold text-slate-500"
		}
		for (const button of guideNavButtons) {
			const id = button.getAttribute("data-guide-nav")
			const ready = Boolean(state[id])
			button.classList.toggle("border-emerald-300", ready)
			button.classList.toggle("bg-emerald-50", ready)
		}
	}

	function renderEditorPreview() {
		const name = getField("name")
		const description = getField("description")
		const guestNotes = getField("guestFacingNotes")
		const beds = collectBeds()
		const amenities = collectAmenityLabels()

		if (previewTitle) previewTitle.textContent = name || "Habitación por nombrar"
		if (previewDescription) {
			previewDescription.textContent =
				description || "La descripción aparecerá aquí mientras editas."
		}
		if (previewOccupancy) previewOccupancy.textContent = formatOccupancy()
		if (previewBathroom) previewBathroom.textContent = formatBathroom()
		if (previewNotes) {
			previewNotes.textContent =
				guestNotes || "Las notas importantes para huéspedes aparecerán aquí."
		}

		if (previewBeds) {
			if (beds.length === 0) {
				previewBeds.innerHTML =
					'<p class="rounded-xl border border-dashed border-slate-300 p-3 text-sm text-slate-500">Agrega camas para completar esta sección.</p>'
			} else {
				previewBeds.innerHTML = beds
					.map((bed) => {
						const bedName = bedTypeLabels?.[bed.bedType] ?? bed.bedType
						return `<div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
							<p class="text-sm font-semibold text-slate-900">${escapeHtml(bed.roomLabel)}</p>
							<p class="mt-1 text-sm text-slate-600">${bed.count} x ${escapeHtml(bedName)}</p>
						</div>`
					})
					.join("")
			}
		}

		if (previewAmenities) {
			if (amenities.length === 0) {
				previewAmenities.innerHTML =
					'<span class="text-sm text-slate-500">Selecciona comodidades propias.</span>'
			} else {
				previewAmenities.innerHTML = amenities
					.slice(0, 8)
					.map(
						(label) =>
							`<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">${escapeHtml(label)}</span>`
					)
					.join("")
			}
		}
		renderGuideProgress()
	}

	function applyPreset(name) {
		if (!bedRows) return
		const presets = {
			couple: {
				maxOccupancy: 2,
				maxAdults: 2,
				maxChildren: 0,
				totalRooms: 1,
				bathroomCount: 1,
				bathroomType: "private",
				beds: [{ bedType: "queen", count: 1, roomLabel: "Dormitorio" }],
				notes: "Habitación ideal para parejas, con baño privado.",
			},
			family: {
				maxOccupancy: 4,
				maxAdults: 2,
				maxChildren: 2,
				totalRooms: 1,
				bathroomCount: 1,
				bathroomType: "private",
				beds: [
					{ bedType: "double", count: 1, roomLabel: "Dormitorio principal" },
					{ bedType: "single", count: 2, roomLabel: "Área secundaria" },
				],
				notes: "Habitación pensada para familias o grupos pequeños.",
			},
			shared: {
				maxOccupancy: 1,
				maxAdults: 1,
				maxChildren: 0,
				totalRooms: 1,
				bathroomCount: 1,
				bathroomType: "shared",
				beds: [{ bedType: "single", count: 1, roomLabel: "Dormitorio" }],
				notes: "Habitación simple con baño compartido o dedicado según disponibilidad.",
			},
		}
		const preset = presets[name]
		if (!preset) return
		setField("minOccupancy", 1)
		setField("maxOccupancy", preset.maxOccupancy)
		setField("maxAdults", preset.maxAdults)
		setField("maxChildren", preset.maxChildren)
		setField("totalRooms", preset.totalRooms)
		setField("bathroomCount", preset.bathroomCount)
		setField("bathroomType", preset.bathroomType)
		const notes = form?.querySelector('[name="guestFacingNotes"]')
		if (notes instanceof HTMLTextAreaElement && !notes.value.trim()) notes.value = preset.notes
		bedRows.innerHTML = ""
		for (const bed of preset.beds) addBedPresetRow(bed.bedType, bed.count, bed.roomLabel)
		bindRemoveButtons()
		renderEditorPreview()
		if (presetImpact) {
			presetImpact.textContent = `Preset aplicado: ${preset.maxOccupancy} huésped(es), ${preset.beds
				.map((bed) => `${bed.count} ${bedTypeLabels?.[bed.bedType] ?? bed.bedType}`)
				.join(" + ")}, ${bathroomLabels[preset.bathroomType] ?? "baño definido"}.`
		}
		setState("success", "Configuración rápida aplicada. Revisa y ajusta antes de guardar.")
	}

	for (const button of guideNavButtons) {
		button.addEventListener("click", () => {
			const target = document.getElementById(String(button.getAttribute("data-guide-nav") ?? ""))
			target?.scrollIntoView({ behavior: "smooth", block: "start" })
		})
	}

	addBedRow?.addEventListener("click", () => {
		const content = bedRowTemplate?.content?.cloneNode(true)
		if (content && bedRows) {
			bedRows.appendChild(content)
			bindRemoveButtons()
			renderEditorPreview()
		}
	})

	bindRemoveButtons()
	form?.addEventListener("input", renderEditorPreview)
	form?.addEventListener("change", renderEditorPreview)
	renderEditorPreview()

	for (const preset of document.querySelectorAll(".roomPreset")) {
		preset.addEventListener("click", () => {
			applyPreset(String(preset.dataset?.preset ?? ""))
		})
	}

	form?.addEventListener("submit", async (event) => {
		event.preventDefault()
		if (!submitBtn) return
		submitBtn.disabled = true
		setState("loading")

		try {
			const formData = new FormData(form)
			const response = await fetch("/api/variant/room-profile", {
				method: "POST",
				body: formData,
			})

			if (response.status === 401) {
				window.location.href = "/SignInPage"
				return
			}

			let payload = null
			try {
				payload = await response.json()
			} catch {
				payload = null
			}

			if (!response.ok) {
				submitBtn.disabled = false
				const message =
					payload?.error === "validation_error" && Array.isArray(payload?.details)
						? payload.details
								.map((item) => String(item?.message || ""))
								.filter(Boolean)
								.join("\n") || "Error de validación"
						: String(payload?.error || `status=${response.status}`)
				setState("error", message)
				return
			}

			const variantId = String(payload?.variantId || fallbackVariantId || "").trim()
			if (!variantId) {
				submitBtn.disabled = false
				setState("error", "No recibimos el identificador de la habitación.")
				return
			}
			setState("success")
			window.location.href = `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(variantId)}`
		} catch (error) {
			submitBtn.disabled = false
			setState("error", `Error de red: ${String(error)}`)
		}
	})
</script>
