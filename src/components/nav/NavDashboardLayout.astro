---
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { ensureUserForSession } from "@/modules/identity/public"
import ProfileHover from "./ProfileHover.astro"

const user = await getUserFromRequest(Astro.request)

// Use identity module to ensure user is persisted
if (user?.email) {
	await ensureUserForSession({ email: user.email })
}
---

<nav
	class="fixed top-0 z-20 w-full bg-neutral-900/50 text-neutral-300 backdrop-blur-md transition-colors duration-300"
>
	<section class="my-2 flex items-center justify-between px-6">
		<div class="flex items-center gap-6 md:gap-8">
			<a href="/" class="group flex items-center gap-x-2 transition hover:text-white">
				<img
					src="/favicon-sbg.webp"
					alt="icon-company"
					class="h-6 w-6 transition-all duration-300 group-hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)]"
				/>
			</a>
		</div>

		<div class="flex items-center gap-x-4">
			{
				user ? (
					<>
						<ProfileHover />
						{/* <a
							href="/product/create"
							class="flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-black shadow-md transition-transform duration-300 hover:scale-95"
						>
							Publicar
						</a> */}
					</>
				) : (
					<>
						<a
							href="/SignInPage"
							class="hidden items-center justify-center rounded-lg bg-white/10 px-4 py-2 text-sm font-medium text-neutral-200 transition-colors duration-200 hover:bg-white/20 md:flex"
						>
							Ingresar
						</a>
					</>
				)
			}
		</div>
	</section>
	<div class="hidden grid-cols-5 text-center text-xs font-medium sm:grid md:text-sm">
		<a href="/" class="dashboard-link">Inicio</a>
		<a href="/dashboard" class="dashboard-link">Dashboard</a>
		<a href="/product/create" class="dashboard-link">Productos</a>
		<a href="/provider/policies" class="dashboard-link">Políticas</a>
		<a href="/provider/tax-fees" class="dashboard-link">Impuestos y cargos</a>
	</div>
</nav>
<div class="absolute top-9 h-2 w-full bg-white"></div>

<script>
	let lastScrollY = window.scrollY
	const nav = document.querySelector("nav")

	const handleScroll = () => {
		const currentScrollY = window.scrollY
		if (lastScrollY < currentScrollY && currentScrollY > 50) {
			nav?.classList.add("-translate-y-full")
		} else {
			nav?.classList.remove("-translate-y-full")
		}
		lastScrollY = currentScrollY
	}

	window.addEventListener("scroll", handleScroll)
</script>
<style>
	.dashboard-link {
		@apply flex justify-center py-3 text-neutral-300 transition lg:px-8;
	}
	.dashboard-link:hover {
		@apply text-white;
	}
</style>
