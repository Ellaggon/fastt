						Ingresar
					</SignIn>
					{/* <SignIn
						id="fixedSessionPost"
						provider="google"
						class="flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-black shadow-md transition-transform duration-300 hover:scale-95"
					>
						Publicar
					</SignIn> */}
				</>
			)
		}
	</div>
</nav>
<div class="absolute top-9 h-2 w-full bg-white"></div>

<script>
	let lastScrollY = window.scrollY
	const nav = document.querySelector("nav")

	const handleScroll = () => {
		const currentScrollY = window.scrollY
		if (lastScrollY < currentScrollY && currentScrollY > 50) {
			nav?.classList.add("-translate-y-full")
		} else {
			nav?.classList.remove("-translate-y-full")
		}
		lastScrollY = currentScrollY
	}

	window.addEventListener("scroll", handleScroll)
</script>
