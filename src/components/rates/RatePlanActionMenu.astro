---
import {
	CalendarDays,
	CirclePause,
	CirclePlay,
	ClipboardList,
	Ellipsis,
	Pencil,
	Trash2,
} from "@lucide/astro"

import { routes } from "@/lib/routes"

interface Props {
	ratePlanId: string
	name: string
	description?: string | null
	isActive: boolean
	isDefault: boolean
}

const { ratePlanId, name, description = "", isActive, isDefault } = Astro.props
---

<details class="relative" data-rate-plan-action-menu>
	<summary
		class="calendar-control inline-flex size-8 cursor-pointer list-none items-center justify-center rounded-md text-slate-500 hover:bg-slate-100 hover:text-slate-900"
		aria-label={`Acciones para ${name}`}
		data-rate-plan-action-trigger
	>
		<Ellipsis class="size-4" />
	</summary>
	<div
		class="fixed z-[60] hidden w-44 overflow-hidden rounded-md border border-slate-200 bg-white p-1 text-left shadow-lg"
		data-rate-plan-action-panel
	>
		<a
			href={`${routes.calendar()}?ratePlanId=${encodeURIComponent(ratePlanId)}&focus=price`}
			class="calendar-control flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
		>
			<CalendarDays class="size-4 text-slate-400" /> Calendario
		</a>
		<a
			href={`${routes.ratePlanDetail(ratePlanId)}?vista=conditions`}
			class="calendar-control flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
		>
			<ClipboardList class="size-4 text-slate-400" /> Condiciones
		</a>
		<a
			href={`${routes.ratePlanDetail(ratePlanId)}?vista=details`}
			class="calendar-control flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
		>
			<Pencil class="size-4 text-slate-400" /> Editar datos
		</a>
		<button
			type="button"
			class="calendar-control flex w-full items-center gap-2 rounded-md px-3 py-2 text-left text-sm font-medium text-slate-700 hover:bg-slate-50"
			data-rate-plan-toggle-inline
			data-rate-plan-id={ratePlanId}
			data-rate-plan-name={name}
			data-rate-plan-description={description}
			data-rate-plan-is-default={String(isDefault)}
			data-next-active={String(!isActive)}
		>
			{
				isActive ? (
					<CirclePause class="size-4 text-slate-400" />
				) : (
					<CirclePlay class="size-4 text-slate-400" />
				)
			}
			{isActive ? "Desactivar" : "Activar"}
		</button>
		<a
			href={`${routes.ratePlanDetail(ratePlanId)}?vista=details&accion=eliminar#eliminar-tarifa`}
			class="calendar-control flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-rose-700 hover:bg-rose-50"
		>
			<Trash2 class="size-4" /> Eliminar
		</a>
	</div>
</details>

<script>
	const actionMenuSelector = "[data-rate-plan-action-menu]"

	function positionRatePlanActionMenu(menu: HTMLDetailsElement) {
		const trigger = menu.querySelector<HTMLElement>("[data-rate-plan-action-trigger]")
		const panel = menu.querySelector<HTMLElement>("[data-rate-plan-action-panel]")
		if (!menu.open || !trigger || !panel) return

		panel.classList.remove("hidden")

		const gap = 6
		const viewportPadding = 12
		const triggerRect = trigger.getBoundingClientRect()
		const panelRect = panel.getBoundingClientRect()
		const left = Math.min(
			window.innerWidth - panelRect.width - viewportPadding,
			Math.max(viewportPadding, triggerRect.right - panelRect.width)
		)
		const fitsBelow =
			triggerRect.bottom + gap + panelRect.height <= window.innerHeight - viewportPadding
		const top = fitsBelow
			? triggerRect.bottom + gap
			: Math.max(viewportPadding, triggerRect.top - panelRect.height - gap)

		panel.style.left = `${left}px`
		panel.style.top = `${top}px`
	}

	document.addEventListener(
		"toggle",
		(event) => {
			const menu = event.target
			if (!(menu instanceof HTMLDetailsElement) || !menu.matches(actionMenuSelector)) return

			const panel = menu.querySelector<HTMLElement>("[data-rate-plan-action-panel]")
			if (!menu.open) {
				panel?.classList.add("hidden")
				return
			}

			document.querySelectorAll<HTMLDetailsElement>(actionMenuSelector).forEach((otherMenu) => {
				if (otherMenu !== menu) otherMenu.removeAttribute("open")
			})
			requestAnimationFrame(() => positionRatePlanActionMenu(menu))
		},
		true
	)

	function repositionOpenRatePlanActionMenus() {
		document
			.querySelectorAll<HTMLDetailsElement>(`${actionMenuSelector}[open]`)
			.forEach(positionRatePlanActionMenu)
	}

	window.addEventListener("resize", repositionOpenRatePlanActionMenus)
	document.addEventListener("scroll", repositionOpenRatePlanActionMenus, true)
</script>
