---
import { routes } from "@/lib/routes"

type Props = {
	isProfessionalCalendar: boolean
	ratePlanId?: string
}

const { isProfessionalCalendar, ratePlanId = "" } = Astro.props
---

<aside
	class="sticky top-3 z-20 h-fit rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm shadow-sm"
	aria-live="polite"
	data-operational-calendar-panel
>
	<div class="flex flex-wrap items-start justify-between gap-3">
		<div class="min-w-0 space-y-1">
			<h3 class="text-base font-semibold text-slate-950 md:text-lg" data-operational-panel-title>
				Selecciona una fecha o rango
			</h3>
			<p class="text-xs leading-5 text-slate-600" data-operational-panel-summary>
				Elige una fecha para operar precio, disponibilidad, venta y condiciones.
			</p>
		</div>
		<div class="flex max-w-full flex-wrap gap-1.5" aria-label="Atajos de rango">
			<button
				type="button"
				data-pricing-range-preset="visible_weekend"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Fin de semana
			</button>
			<button
				type="button"
				data-pricing-range-preset="visible_month"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Vista visible
			</button>
			<button
				type="button"
				data-pricing-range-preset="next_7"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Prox. 7 dias
			</button>
			<button
				type="button"
				data-pricing-range-preset="next_30"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Prox. 30 dias
			</button>
		</div>
	</div>
	<div
		class="mt-4 grid grid-cols-2 gap-1 rounded-lg bg-white p-1 text-xs font-semibold text-slate-600"
		role="tablist"
		aria-label="Detalle operativo"
	>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="price"
			data-active="true"
		>
			Precio
		</button>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="availability"
		>
			Disponibilidad
		</button>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="restrictions"
		>
			Venta
		</button>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="policies"
		>
			Condiciones
		</button>
		{
			isProfessionalCalendar ? (
				<button
					type="button"
					class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
					data-operational-tab="pro"
				>
					Pro
				</button>
			) : null
		}
	</div>
	<div class="mt-4 space-y-3" data-operational-panel-body>
		<div data-operational-panel-section="price" class="space-y-2">
			<div class="grid gap-2 sm:grid-cols-2">
				<button
					type="button"
					class="hidden h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-manual-price-action
					data-selection-required-action
				>
					Cambio manual de precio
				</button>
				{
					isProfessionalCalendar ? (
						<button
							id="pricingAppliedAidToggle"
							type="button"
							class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
							aria-pressed="false"
						>
							Mostrar ajustes
						</button>
					) : null
				}
			</div>
		</div>
		<div data-operational-panel-section="availability" class="hidden space-y-2">
			<div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
				<button
					type="button"
					class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-inventory-action
				>
					Cambiar cupo
				</button>
				<button
					id="inventoryPhysicalDetailToggle"
					type="button"
					class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					aria-pressed="false"
				>
					Mostrar detalle físico
				</button>
			</div>
		</div>
		<div data-operational-panel-section="restrictions" class="hidden space-y-3">
			<div class="grid gap-2 sm:grid-cols-2">
				<button
					type="button"
					class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-restrictions-action
				>
					Crear regla de venta
				</button>
			</div>
		</div>
		<div data-operational-panel-section="policies" class="hidden space-y-2">
			<div class="grid grid-cols-2 gap-2 md:flex md:flex-wrap">
				<a
					href={ratePlanId ? routes.ratePlanPolicies(ratePlanId) : routes.ratePlansList()}
					class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-policies-action
				>
					Revisar contrato
				</a>
			</div>
			<p class="hidden" data-panel-policies></p>
			<p class="hidden" data-panel-policies-missing></p>
		</div>
		{
			isProfessionalCalendar ? (
				<div data-operational-panel-section="pro" class="hidden space-y-3">
					<p class="text-xs leading-5 text-slate-600">
						Abre herramientas Pro para automatizar reglas o extender cambios.
					</p>
					<div class="grid gap-2 md:grid-cols-3">
						<a
							href={`${routes.ratesMultiCalendar()}?tab=rules`}
							class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
							data-panel-recurring-action
						>
							Reglas aplicadas
						</a>
						<button
							type="button"
							class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
							data-pricing-open-extension
							data-panel-bulk-action
						>
							Extender cambio
						</button>
						<button
							type="button"
							class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-center text-xs font-semibold text-slate-800 hover:bg-slate-50"
							data-panel-calendar-history
						>
							Historial
						</button>
					</div>
				</div>
			) : null
		}
	</div>
</aside>

<div id="inventoryPhysicalBackdrop" class="pricing-extension-backdrop hidden" aria-hidden="true">
</div>
<aside
	id="inventoryPhysicalDrawer"
	class="pricing-extension-drawer hidden bg-white text-slate-800"
	aria-labelledby="inventoryPhysicalTitle"
	aria-modal="true"
	role="dialog"
>
	<div class="flex items-start justify-between gap-3 border-b border-slate-200 p-4">
		<div class="space-y-1">
			<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">Cambio de cupo</p>
			<h2
				id="inventoryPhysicalTitle"
				class="text-lg font-semibold text-slate-950"
				data-inventory-range-label
			>
				Selecciona una fecha o rango
			</h2>
			<p class="text-sm leading-5 text-slate-600">
				Ajusta el cupo físico para la disponibilidad seleccionada.
			</p>
		</div>
		<button
			id="inventoryPhysicalCloseBtn"
			type="button"
			class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
		>
			Cerrar
		</button>
	</div>
	<div class="space-y-4 overflow-y-auto p-4">
		<label class="block space-y-1">
			<span class="text-xs font-semibold text-slate-700">Cupo físico total</span>
			<input
				type="number"
				min="0"
				step="1"
				class="h-11 w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900"
				placeholder="Ej. 4"
				data-panel-inventory-value
			/>
		</label>
		<div class="grid gap-2 sm:grid-cols-2">
			<button
				type="button"
				class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
				data-panel-inventory-preview
			>
				Revisar cupo
			</button>
			<button
				type="button"
				class="h-10 rounded-md bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800 disabled:opacity-50"
				data-panel-inventory-apply
				disabled
			>
				Guardar cupo
			</button>
		</div>
		<p class="text-xs leading-5 text-slate-500" data-panel-inventory-feedback>
			Revisa el impacto de inventario antes de guardar.
		</p>
	</div>
</aside>

<div id="pricingManualPriceBackdrop" class="pricing-extension-backdrop hidden" aria-hidden="true">
</div>
<aside
	id="pricingManualPriceDrawer"
	class="pricing-extension-drawer hidden bg-white text-slate-800"
	aria-labelledby="pricingManualPriceTitle"
	aria-modal="true"
	role="dialog"
>
	<div class="flex items-start justify-between gap-3 border-b border-slate-200 p-4">
		<div class="space-y-1">
			<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
				Cambio manual de precio
			</p>
			<h2
				id="pricingManualPriceTitle"
				class="text-lg font-semibold text-slate-950"
				data-manual-price-range-label
			>
				Selecciona una fecha o rango
			</h2>
			<p id="pricingRangePreview" class="text-sm leading-5 text-slate-600">
				Selecciona una fecha o rango para revisar el impacto antes de guardar.
			</p>
		</div>
		<button
			id="pricingManualPriceCloseBtn"
			type="button"
			class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
		>
			Cerrar
		</button>
	</div>
	<div id="pricingRangePanel" class="overflow-y-auto p-4">
		<input id="pricingRangeOperationType" type="hidden" value="fixed_override" />
		<div class="space-y-4">
			<label class="block space-y-1">
				<span id="pricingRangeValueLabel" class="text-xs font-semibold text-slate-700">
					Precio final
				</span>
				<input
					id="pricingRangeValue"
					type="number"
					min="0"
					step="1"
					placeholder="Precio"
					class="h-11 w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900"
				/>
			</label>
			<div class="grid gap-2 sm:grid-cols-2">
				<button
					id="pricingRangePreviewBtn"
					type="button"
					class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
				>
					Revisar cambio puntual
				</button>
				<button
					id="pricingRangeApplyBtn"
					type="button"
					class="h-10 rounded-md bg-blue-700 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-800 disabled:opacity-60"
				>
					Guardar cambio manual
				</button>
				<button
					id="pricingRangeGenerateBtn"
					type="button"
					class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
				>
					Actualizar
				</button>
				<button
					id="pricingRangeClearBtn"
					type="button"
					class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
				>
					Limpiar
				</button>
			</div>
		</div>
	</div>
</aside>
