---
import { routes } from "@/lib/routes"

type Props = {
	isProfessionalCalendar: boolean
	selectedVariantId: string
	selectedRatePlanName: string
}

const { isProfessionalCalendar, selectedVariantId, selectedRatePlanName } = Astro.props
---

<aside
	class="sticky top-3 z-20 h-fit rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm shadow-sm"
	aria-live="polite"
	data-operational-calendar-panel
>
	<div class="flex flex-wrap items-start justify-between gap-3">
		<div class="min-w-0 space-y-1">
			<h3 class="text-base font-semibold text-slate-950 md:text-lg" data-operational-panel-title>
				Selecciona una fecha o rango
			</h3>
			<p class="text-xs leading-5 text-slate-600" data-operational-panel-summary>
				Elige una fecha para operar precio, disponibilidad, venta y condiciones.
			</p>
		</div>
		<div class="flex max-w-full flex-wrap gap-1.5" aria-label="Atajos de rango">
			<button
				type="button"
				data-pricing-range-preset="visible_weekend"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Fin de semana
			</button>
			<button
				type="button"
				data-pricing-range-preset="visible_month"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Vista visible
			</button>
			<button
				type="button"
				data-pricing-range-preset="next_7"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Prox. 7 dias
			</button>
			<button
				type="button"
				data-pricing-range-preset="next_30"
				class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[11px] font-medium text-slate-700 hover:bg-slate-100"
			>
				Prox. 30 dias
			</button>
		</div>
	</div>
	<div
		class="mt-4 grid grid-cols-2 gap-1 rounded-lg bg-white p-1 text-xs font-semibold text-slate-600"
		role="tablist"
		aria-label="Detalle operativo"
	>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="price"
			data-active="true"
		>
			Precio
		</button>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="availability"
		>
			Disponibilidad
		</button>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="restrictions"
		>
			Venta
		</button>
		<button
			type="button"
			class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
			data-operational-tab="policies"
		>
			Condiciones
		</button>
		{
			isProfessionalCalendar ? (
				<button
					type="button"
					class="rounded-md px-2 py-1.5 text-left data-[active=true]:bg-blue-100 data-[active=true]:text-blue-900"
					data-operational-tab="pro"
				>
					Pro
				</button>
			) : null
		}
	</div>
	<div class="mt-4 space-y-3" data-operational-panel-body>
		<div data-operational-panel-section="price" class="space-y-2">
			<div
				id="pricingRangePanel"
				data-mobile-calendar-action-sheet
				data-sheet-state="compact"
				class="mobile-calendar-action-sheet hidden rounded-lg border border-blue-200 bg-blue-50 p-3 text-blue-950"
			>
				<div
					data-mobile-sheet-handle
					class="mobile-sheet-handle mx-auto mb-3 hidden h-1 w-12 rounded-full bg-blue-200"
				>
				</div>
				<div class="space-y-3">
					<div class="space-y-1">
						<div class="flex items-start justify-between gap-2">
							<p class="text-sm font-semibold leading-5">Cambio manual de precio</p>
							<div class="flex items-center gap-1 md:hidden">
								<button
									id="pricingSheetExpandBtn"
									type="button"
									class="rounded border border-blue-200 bg-white px-2 py-1 text-[11px] font-semibold text-blue-900"
								>
									Expandir
								</button>
								<button
									id="pricingSheetCloseBtn"
									type="button"
									class="rounded border border-blue-200 bg-white px-2 py-1 text-[11px] font-semibold text-blue-900"
								>
									Cerrar
								</button>
							</div>
						</div>
						<p id="pricingRangePreview" class="hidden text-xs leading-5 text-blue-800"></p>
					</div>

					<input id="pricingRangeOperationType" type="hidden" value="fixed_override" />
					<div
						class="grid grid-cols-2 gap-2 md:grid-cols-[minmax(10rem,14rem)_repeat(4,minmax(0,1fr))] md:items-end"
					>
						<label class="col-span-2 block space-y-1 md:col-span-1">
							<span id="pricingRangeValueLabel" class="text-xs font-medium text-blue-950">
								Precio final
							</span>
							<input
								id="pricingRangeValue"
								type="number"
								min="0"
								step="1"
								placeholder="Precio"
								class="h-10 w-full rounded border border-blue-200 px-3 py-2 text-sm text-slate-900"
							/>
						</label>
						<button
							id="pricingRangePreviewBtn"
							type="button"
							class="h-10 rounded border border-blue-300 bg-white px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100"
						>
							Revisar cambio puntual
						</button>
						<button
							id="pricingRangeApplyBtn"
							type="button"
							class="h-10 rounded bg-blue-700 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-800 disabled:opacity-60"
						>
							Guardar cambio manual
						</button>
						<button
							id="pricingRangeGenerateBtn"
							type="button"
							class="h-10 rounded border border-blue-300 bg-white px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100"
						>
							Actualizar
						</button>
						<button
							id="pricingRangeClearBtn"
							type="button"
							class="h-10 rounded border border-blue-300 bg-white px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100"
						>
							Limpiar
						</button>
					</div>

					<div class="flex flex-wrap gap-2">
						<button
							type="button"
							data-pricing-open-extension
							class:list={[
								"text-xs font-medium text-blue-800 underline-offset-2 hover:underline",
								!isProfessionalCalendar && "hidden",
							]}
						>
							Extender este cambio
						</button>
						<button
							type="button"
							data-pricing-make-recurring
							class:list={[
								"text-xs font-medium text-blue-800 underline-offset-2 hover:underline",
								!isProfessionalCalendar && "hidden",
							]}
						>
							Hacer recurrente
						</button>
					</div>
				</div>
			</div>
		</div>
		<div data-operational-panel-section="availability" class="hidden space-y-2">
			<div
				class="grid grid-cols-2 gap-2 md:grid-cols-[minmax(10rem,14rem)_repeat(3,minmax(0,1fr))] md:items-end"
			>
				<label
					class="col-span-2 block space-y-1 text-xs font-semibold text-slate-700 md:col-span-1"
				>
					<span>Cupo físico total</span>
					<input
						type="number"
						min="0"
						step="1"
						class="h-10 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900"
						placeholder="Ej. 4"
						data-panel-inventory-value
					/>
				</label>
				<button
					type="button"
					class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-inventory-preview
				>
					Revisar cupo
				</button>
				<button
					type="button"
					class="h-10 rounded-md bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800 disabled:opacity-50"
					data-panel-inventory-apply
					disabled
				>
					Guardar cupo
				</button>
				<a
					href={`${routes.inventory()}?variantId=${encodeURIComponent(selectedVariantId)}&source=professional`}
					class="hidden h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-center text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-inventory-detail
				>
					Ver detalle físico
				</a>
			</div>
			<p class="text-xs leading-5 text-slate-500" data-panel-inventory-feedback></p>
		</div>
		<div data-operational-panel-section="restrictions" class="hidden space-y-2">
			<div class="grid grid-cols-2 gap-2 md:flex md:flex-wrap">
				<button
					type="button"
					class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-restrictions-action
				>
					Crear regla de venta
				</button>
				<a
					href={routes.rateRestrictions()}
					class:list={[
						"inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50",
						!isProfessionalCalendar && "hidden",
					]}
					data-panel-restrictions-advanced
				>
					Reglas de venta
				</a>
			</div>
			<div class="hidden flex-wrap gap-1.5" data-panel-restriction-chips></div>
		</div>
		<div data-operational-panel-section="policies" class="hidden space-y-2">
			<div class="grid grid-cols-2 gap-2 md:flex md:flex-wrap">
				<a
					href={routes.providerPolicies()}
					class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
					data-panel-policies-action
				>
					Abrir matriz de condiciones
				</a>
			</div>
			<p class="hidden" data-panel-policies></p>
			<p class="hidden" data-panel-policies-missing></p>
		</div>
		{
			isProfessionalCalendar ? (
				<div data-operational-panel-section="pro" class="hidden space-y-3">
					<p class="text-xs leading-5 text-slate-600">
						Automatiza reglas, extiende cambios y revisa el diagnóstico de esta selección.
					</p>
					<div class="grid gap-2 md:grid-cols-2">
						<button
							type="button"
							class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
							data-pricing-make-recurring
							data-panel-recurring-action
						>
							Crear regla automática
						</button>
						<button
							type="button"
							class="h-10 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-800 hover:bg-slate-50"
							data-pricing-open-extension
							data-panel-bulk-action
						>
							Extender cambio
						</button>
					</div>
					<dl class="grid gap-2 text-xs md:grid-cols-3">
						<div class="rounded-md bg-white px-3 py-2">
							<dt class="text-slate-500">Estado</dt>
							<dd class="font-semibold text-slate-900" data-panel-status>
								—
							</dd>
						</div>
						<div class="rounded-md bg-white px-3 py-2">
							<dt class="text-slate-500">Fecha</dt>
							<dd class="font-semibold text-slate-900" data-panel-date>
								—
							</dd>
						</div>
						<div class="rounded-md bg-white px-3 py-2">
							<dt class="text-slate-500">Tarifa</dt>
							<dd class="font-semibold text-slate-900">{selectedRatePlanName || "—"}</dd>
						</div>
					</dl>
				</div>
			) : null
		}
	</div>
</aside>
