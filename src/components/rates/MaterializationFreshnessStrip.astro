---
import Badge from "@/components/ui/Badge.astro"
import {
	formatFreshnessAge,
	type MaterializationFreshness,
} from "@/lib/rates/materializationFreshness"

const {
	title = "Materializaciones",
	description = "Confianza operacional del calendario visible.",
	items = [],
} = Astro.props as {
	title?: string
	description?: string
	items: MaterializationFreshness[]
}

function badgeVariant(state: MaterializationFreshness["state"]) {
	if (state === "fresh") return "success"
	if (state === "delayed") return "warning"
	if (state === "stale") return "error"
	return "neutral"
}

function stateLabel(state: MaterializationFreshness["state"]) {
	if (state === "fresh") return "Al dia"
	if (state === "delayed") return "Con retraso"
	if (state === "stale") return "Desactualizado"
	return "Sin datos"
}
---

<div
	data-materialization-freshness-strip
	class="rounded-lg border border-slate-200 bg-white p-2.5 text-xs text-slate-600 sm:p-3"
>
	<div class="flex flex-wrap items-start justify-between gap-2">
		<div>
			<p class="font-semibold text-slate-900">{title}</p>
			<p class="mt-0.5 hidden sm:block">{description}</p>
		</div>
		<div class="flex flex-wrap gap-1">
			{
				items.map((item) => (
					<Badge variant={badgeVariant(item.state)}>
						{item.label}: {stateLabel(item.state)}
					</Badge>
				))
			}
		</div>
	</div>
	<div class="mt-3 hidden gap-2 sm:grid md:grid-cols-3">
		{
			items.map((item) => (
				<div class="rounded border border-slate-100 bg-slate-50 px-3 py-2">
					<div class="flex items-center justify-between gap-2">
						<p class="font-semibold text-slate-900">{item.label}</p>
						<span class="text-slate-500">{formatFreshnessAge(item.ageMinutes)}</span>
					</div>
					<p class="mt-1">{item.summary}</p>
				</div>
			))
		}
	</div>
</div>
