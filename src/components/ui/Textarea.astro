---
const {
	value = "",
	hasError = false,
	error = null,
	className = "",
	class: classProp = "",
	...props
} = Astro.props

const baseClass =
	"fastt-field block min-h-24 w-full bg-white px-3 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none"

const showError = Boolean(hasError || error)

const stateClass = showError
	? "border-red-500 focus:border-red-500 focus:shadow-[0_0_0_2px_rgb(254_202_202)]"
	: "border-slate-300"

const finalClass = `${baseClass} ${stateClass} ${className} ${classProp}`.trim()
const normalizedValue = value == null ? "" : String(value)
---

<textarea class={finalClass} {...props}>{normalizedValue}</textarea>
