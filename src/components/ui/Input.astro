---
const {
	hasError = false,
	error = null,
	className = "",
	class: classProp = "",
	...props
} = Astro.props

const baseClass =
	"block w-full rounded-lg border bg-white px-3 py-2 text-sm text-neutral-900 placeholder:text-neutral-400 focus:outline-none focus:ring-2"

const showError = Boolean(hasError || error)

const stateClass = showError
	? "border-red-500 focus:border-red-500 focus:ring-red-200"
	: "border-neutral-300 focus:border-blue-500 focus:ring-blue-200"

const finalClass = `${baseClass} ${stateClass} ${className} ${classProp}`.trim()
---

<input class={finalClass} {...props} />
