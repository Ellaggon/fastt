---
const { className = "", class: classProp = "", ...props } = Astro.props
const finalClass =
	`fastt-tabs-outside-panel inline-flex gap-1 overflow-x-auto rounded-[var(--fastt-radius-pill)] bg-sky-50 p-1 text-sm font-semibold text-slate-600 ring-1 ring-sky-100 ${className} ${classProp}`.trim()
---

<nav class={finalClass} {...props}>
	<slot />
</nav>

<style is:global>
	.fastt-tabs-outside-panel {
		box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.7);
	}

	.fastt-tabs-outside-panel__item {
		border: 0;
		border-radius: var(--fastt-radius-pill);
		transition:
			background-color var(--fastt-motion-fast) ease,
			color var(--fastt-motion-fast) ease,
			box-shadow var(--fastt-motion-fast) ease;
	}

	.fastt-tabs-outside-panel__item[data-active="true"] {
		background: rgb(255 255 255);
		color: rgb(12 74 110);
		box-shadow:
			inset 0 0 0 1px rgb(186 230 253),
			0 1px 2px rgb(15 23 42 / 0.08);
	}

	.fastt-tabs-outside-panel__item[data-active="true"]:hover {
		background: rgb(255 255 255);
		color: rgb(12 74 110);
	}
</style>
