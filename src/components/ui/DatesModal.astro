---
interface Props {
	id: string
	name: string
	value?: string
	required?: boolean
	min?: string
	max?: string
	placeholder?: string
	class?: string
	className?: string
}

const {
	id,
	name,
	value = "",
	required = false,
	min,
	max,
	placeholder = "Seleccionar fecha",
	class: classProp = "",
	className = "",
} = Astro.props as Props

const triggerClass =
	`flex h-10 w-full items-center justify-between rounded-lg border border-neutral-300 bg-white px-3 text-left text-sm text-neutral-900 transition hover:border-blue-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-200 ${className} ${classProp}`.trim()
---

<div class="relative" data-date-modal-root>
	<input
		id={id}
		name={name}
		type="hidden"
		value={value}
		data-date-modal-input
		data-min={min}
		data-max={max}
		required={required}
	/>
	<button type="button" class={triggerClass} data-date-modal-trigger aria-haspopup="dialog">
		<span data-date-modal-label>{value || placeholder}</span>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			class="h-4 w-4 text-slate-500"
			viewBox="0 0 20 20"
			fill="currentColor"
		>
			<path
				fill-rule="evenodd"
				d="M6 2a1 1 0 112 0v1h4V2a1 1 0 112 0v1h1a2 2 0 012 2v2H3V5a2 2 0 012-2h1V2zm11 7H3v6a2 2 0 002 2h10a2 2 0 002-2V9z"
				clip-rule="evenodd"></path>
		</svg>
	</button>

	<div
		class="absolute left-0 z-50 mt-2 hidden w-72 rounded-xl border border-slate-200 bg-white p-3 shadow-xl"
		data-date-modal-panel
		role="dialog"
		aria-modal="false"
	>
		<div class="mb-2 flex items-center justify-between gap-2">
			<button
				type="button"
				class="rounded p-1 text-slate-600 hover:bg-slate-100"
				data-date-modal-prev>‹</button
			>
			<p class="text-sm font-semibold text-slate-900" data-date-modal-month></p>
			<button
				type="button"
				class="rounded p-1 text-slate-600 hover:bg-slate-100"
				data-date-modal-next>›</button
			>
		</div>
		<div class="mb-1 grid grid-cols-7 gap-1 text-center text-[11px] font-medium text-slate-500">
			<span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span><span
				>D</span
			>
		</div>
		<div class="grid grid-cols-7 gap-1" data-date-modal-grid></div>
		<div class="mt-3 flex items-center justify-between gap-2">
			<button
				type="button"
				class="rounded px-2 py-1 text-xs text-slate-600 hover:bg-slate-100"
				data-date-modal-clear
			>
				Limpiar
			</button>
			<button
				type="button"
				class="rounded bg-slate-900 px-2 py-1 text-xs font-medium text-white hover:bg-slate-800"
				data-date-modal-close
			>
				Listo
			</button>
		</div>
	</div>

	<input
		type="text"
		class="sr-only"
		tabindex="-1"
		aria-hidden="true"
		data-date-modal-required-proxy
		required={required}
		value={value}
	/>
</div>

<script type="module">
	const formatIsoDate = (date) => date.toISOString().slice(0, 10)
	const parseIsoDate = (value) => {
		if (!/^\d{4}-\d{2}-\d{2}$/.test(String(value || ""))) return null
		const parsed = new Date(`${value}T00:00:00.000Z`)
		if (Number.isNaN(parsed.getTime())) return null
		if (formatIsoDate(parsed) !== value) return null
		return parsed
	}
	const monthLabel = (date) =>
		date.toLocaleDateString("es-CL", { month: "long", year: "numeric", timeZone: "UTC" })
	const mondayStartOffset = (date) => {
		const sundayBased = new Date(Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), 1)).getUTCDay()
		return (sundayBased + 6) % 7
	}

	document.querySelectorAll("[data-date-modal-root]").forEach((root) => {
		if (!(root instanceof HTMLElement) || root.dataset.boundDateModal === "1") return
		root.dataset.boundDateModal = "1"

		const input = root.querySelector("[data-date-modal-input]")
		const trigger = root.querySelector("[data-date-modal-trigger]")
		const label = root.querySelector("[data-date-modal-label]")
		const panel = root.querySelector("[data-date-modal-panel]")
		const monthNode = root.querySelector("[data-date-modal-month]")
		const grid = root.querySelector("[data-date-modal-grid]")
		const btnPrev = root.querySelector("[data-date-modal-prev]")
		const btnNext = root.querySelector("[data-date-modal-next]")
		const btnClear = root.querySelector("[data-date-modal-clear]")
		const btnClose = root.querySelector("[data-date-modal-close]")
		const requiredProxy = root.querySelector("[data-date-modal-required-proxy]")
		if (
			!(input instanceof HTMLInputElement) ||
			!(trigger instanceof HTMLButtonElement) ||
			!(label instanceof HTMLElement) ||
			!(panel instanceof HTMLElement) ||
			!(monthNode instanceof HTMLElement) ||
			!(grid instanceof HTMLElement) ||
			!(btnPrev instanceof HTMLButtonElement) ||
			!(btnNext instanceof HTMLButtonElement) ||
			!(btnClear instanceof HTMLButtonElement) ||
			!(btnClose instanceof HTMLButtonElement)
		) {
			return
		}

		const placeholder = label.textContent || "Seleccionar fecha"
		const minDate = parseIsoDate(input.dataset.min || "") || null
		const maxDate = parseIsoDate(input.dataset.max || "") || null
		const today = new Date()
		let selected = parseIsoDate(input.value)
		let currentMonth = selected
			? new Date(Date.UTC(selected.getUTCFullYear(), selected.getUTCMonth(), 1))
			: new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), 1))

		const syncRequiredProxy = () => {
			if (!(requiredProxy instanceof HTMLInputElement)) return
			requiredProxy.value = input.value || ""
		}

		const setDisplay = () => {
			if (!selected) {
				label.textContent = placeholder
				syncRequiredProxy()
				return
			}
			label.textContent = selected.toLocaleDateString("es-CL", {
				day: "2-digit",
				month: "short",
				year: "numeric",
				timeZone: "UTC",
			})
			syncRequiredProxy()
		}

		const isDisabled = (date) => {
			if (minDate && date < minDate) return true
			if (maxDate && date > maxDate) return true
			return false
		}

		const render = () => {
			monthNode.textContent = monthLabel(currentMonth)
			grid.innerHTML = ""
			const year = currentMonth.getUTCFullYear()
			const month = currentMonth.getUTCMonth()
			const totalDays = new Date(Date.UTC(year, month + 1, 0)).getUTCDate()
			const offset = mondayStartOffset(currentMonth)

			for (let i = 0; i < offset; i++) {
				const pad = document.createElement("span")
				pad.className = "h-8"
				grid.appendChild(pad)
			}

			for (let day = 1; day <= totalDays; day++) {
				const value = new Date(Date.UTC(year, month, day))
				const iso = formatIsoDate(value)
				const button = document.createElement("button")
				button.type = "button"
				button.textContent = String(day)
				button.className =
					"h-8 rounded text-xs text-slate-700 transition hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-30"

				if (selected && formatIsoDate(selected) === iso) {
					button.classList.add("bg-blue-600", "text-white", "hover:bg-blue-600")
				}
				if (isDisabled(value)) button.disabled = true
				button.addEventListener("click", () => {
					selected = value
					input.value = iso
					input.dispatchEvent(new Event("input", { bubbles: true }))
					input.dispatchEvent(new Event("change", { bubbles: true }))
					setDisplay()
					render()
				})
				grid.appendChild(button)
			}
		}

		const close = () => panel.classList.add("hidden")
		const open = () => panel.classList.remove("hidden")

		trigger.addEventListener("click", () => {
			if (panel.classList.contains("hidden")) open()
			else close()
		})
		btnPrev.addEventListener("click", () => {
			currentMonth = new Date(
				Date.UTC(currentMonth.getUTCFullYear(), currentMonth.getUTCMonth() - 1, 1)
			)
			render()
		})
		btnNext.addEventListener("click", () => {
			currentMonth = new Date(
				Date.UTC(currentMonth.getUTCFullYear(), currentMonth.getUTCMonth() + 1, 1)
			)
			render()
		})
		btnClear.addEventListener("click", () => {
			selected = null
			input.value = ""
			input.dispatchEvent(new Event("input", { bubbles: true }))
			input.dispatchEvent(new Event("change", { bubbles: true }))
			setDisplay()
			render()
		})
		btnClose.addEventListener("click", close)

		document.addEventListener("click", (event) => {
			if (!root.contains(event.target)) close()
		})

		input.addEventListener("change", () => {
			const parsed = parseIsoDate(input.value)
			selected = parsed
			if (parsed) {
				currentMonth = new Date(Date.UTC(parsed.getUTCFullYear(), parsed.getUTCMonth(), 1))
			}
			setDisplay()
			render()
		})

		setDisplay()
		render()
	})
</script>
