---
const {
	value = 0,
	max = 100,
	label,
	showValue = false,
	variant = "primary",
	className = "",
	class: classProp = "",
	...props
} = Astro.props

const numericValue = Number(value)
const numericMax = Number(max) || 100
const percent = Math.min(100, Math.max(0, (numericValue / numericMax) * 100))
const variantClass = {
	primary: "bg-slate-950",
	success: "bg-emerald-600",
	warning: "bg-amber-500",
	error: "bg-red-600",
	info: "bg-sky-600",
}
const isValidVariant = typeof variant === "string" && Object.hasOwn(variantClass, variant)
const resolvedVariant = (isValidVariant ? variant : "primary") as keyof typeof variantClass
const finalClass =
	`fastt-progress-track h-2 w-full overflow-hidden bg-slate-100 ${className} ${classProp}`.trim()
---

<div class="space-y-2">
	{
		label || showValue ? (
			<div class="flex items-center justify-between gap-3 text-xs font-semibold text-slate-600">
				{label ? <span>{label}</span> : <span />}
				{showValue ? <span>{Math.round(percent)}%</span> : null}
			</div>
		) : null
	}
	<div
		class={finalClass}
		role="progressbar"
		aria-valuenow={numericValue}
		aria-valuemin="0"
		aria-valuemax={numericMax}
		{...props}
	>
		<div
			class={`fastt-progress-value h-full ${variantClass[resolvedVariant]}`}
			style={`width: ${percent}%`}
		>
		</div>
	</div>
</div>
