---
const { variant = "panel", className = "", class: classProp = "", ...props } = Astro.props

const variantClass = {
	panel: "fastt-card border bg-white p-3 md:p-6 text-slate-900",
	row: "rounded-[20px] border border-slate-200 bg-white p-4 text-slate-900 shadow-[var(--fastt-shadow-row)]",
	soft: "rounded-2xl bg-slate-50 p-4 text-slate-900 ring-1 ring-slate-900/[0.06]",
	plain: "rounded-2xl border border-slate-200 bg-white p-6 text-slate-900 shadow-sm",
}

const isValidVariant = typeof variant === "string" && Object.hasOwn(variantClass, variant)
const resolvedVariant = (isValidVariant ? variant : "panel") as keyof typeof variantClass
const finalClass = `${variantClass[resolvedVariant]} ${className} ${classProp}`.trim()
---

<div class={finalClass} {...props}>
	<slot />
</div>
