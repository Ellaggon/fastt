---
interface RadioOption {
	id?: string
	value: string | number
	label: string
	description?: string
	disabled?: boolean
}

const {
	name,
	legend,
	options = [],
	value,
	orientation = "vertical",
	className = "",
	class: classProp = "",
	...props
} = Astro.props

const radioOptions = options as RadioOption[]
const groupClass =
	orientation === "horizontal"
		? "grid gap-3 sm:grid-cols-[repeat(auto-fit,minmax(180px,1fr))]"
		: "space-y-3"
const finalClass = `space-y-3 ${className} ${classProp}`.trim()
---

<fieldset class={finalClass} {...props}>
	{legend ? <legend class="text-sm font-semibold text-slate-800">{legend}</legend> : null}
	<div class={groupClass}>
		{
			radioOptions.map((option) => {
				const optionValue = String(option.value)
				const optionId = option.id ?? `${name}-${optionValue.replace(/[^a-z0-9_-]/gi, "-")}`
				const checked = value !== undefined && String(value) === optionValue
				return (
					<label class="fastt-check-option flex cursor-pointer items-start gap-3">
						<input
							id={optionId}
							type="radio"
							name={name}
							value={option.value}
							checked={checked}
							disabled={option.disabled}
							class="fastt-radio-input mt-0.5 size-4 shrink-0"
						/>
						<span class="min-w-0">
							<span class="block text-sm font-semibold text-slate-800">{option.label}</span>
							{option.description ? (
								<span class="mt-1 block text-sm leading-5 text-slate-500">
									{option.description}
								</span>
							) : null}
						</span>
					</label>
				)
			})
		}
		<slot />
	</div>
</fieldset>
