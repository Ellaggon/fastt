---
const { variant = "info", title, className = "", class: classProp = "", ...props } = Astro.props

const variantClass = {
	info: "border-sky-200 bg-sky-50 text-sky-900",
	success: "border-emerald-200 bg-emerald-50 text-emerald-900",
	warning: "border-amber-200 bg-amber-50 text-amber-950",
	error: "border-red-200 bg-red-50 text-red-900",
	neutral: "border-slate-200 bg-slate-50 text-slate-800",
}

const isValidVariant = typeof variant === "string" && Object.hasOwn(variantClass, variant)
const resolvedVariant = (isValidVariant ? variant : "info") as keyof typeof variantClass
const finalClass =
	`fastt-notice rounded-[var(--fastt-radius-card)] border p-4 text-sm leading-6 ${variantClass[resolvedVariant]} ${className} ${classProp}`.trim()
---

<div class={finalClass} role={resolvedVariant === "error" ? "alert" : "status"} {...props}>
	{title ? <p class="mb-1 font-semibold">{title}</p> : null}
	<div class="text-current/85">
		<slot />
	</div>
</div>
