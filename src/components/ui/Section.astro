---
const { title, description, className = "", class: classProp = "", ...props } = Astro.props
const finalClass = `space-y-4 ${className} ${classProp}`.trim()
---

<section class={finalClass} {...props}>
	<header class="space-y-1">
		<h2 class="text-lg font-semibold text-neutral-900">{title}</h2>
		{description ? <p class="text-sm text-neutral-600">{description}</p> : null}
	</header>
	<div class="space-y-4">
		<slot />
	</div>
</section>
