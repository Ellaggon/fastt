---
import { routes } from "@/lib/routes"
import { ChevronDown, Hotel } from "@lucide/astro"
import { and, db, eq, Product, sql } from "astro:db"

interface Props {
	providerId: string
	productId: string
	currentName: string
	target?: "detail" | "rooms" | "house-rules" | "financial"
}

const { providerId, productId, currentName, target = "detail" } = Astro.props
const buildAccommodationHref = (id: string) => {
	if (target === "rooms") return routes.productRoomsForProduct(id)
	if (target === "house-rules") {
		return `${routes.providerHouseRules()}?productId=${encodeURIComponent(id)}`
	}
	if (target === "financial") {
		const params = new URLSearchParams(Astro.url.search)
		params.set("productId", id)
		const query = params.toString()
		return `${Astro.url.pathname}${query ? `?${query}` : ""}`
	}
	return routes.productDetail(id)
}
const accommodations = providerId
	? (
			await db
				.select({ id: Product.id, name: Product.name })
				.from(Product)
				.where(
					and(eq(Product.providerId, providerId), sql`lower(${Product.productType}) = 'hotel'`)
				)
				.all()
		)
			.map((product) => {
				const id = String(product.id)
				return {
					id,
					name: String(product.name || "Alojamiento"),
					href: buildAccommodationHref(id),
				}
			})
			.sort((left, right) => left.name.localeCompare(right.name, "es"))
	: []
const currentAccommodation = accommodations.find((item) => item.id === productId) ?? {
	id: productId,
	name: currentName,
	href: buildAccommodationHref(productId),
}
const hasAccommodationOptions = accommodations.length > 0
const hasOtherAccommodations = accommodations.some((item) => item.id !== productId)
---

<div class="accommodation-context-switcher gap-1">
	<span class="accommodation-context-switcher__label">
		<Hotel class="h-4 w-4 shrink-0" aria-hidden="true" />
		Alojamiento
	</span>
	{
		hasAccommodationOptions ? (
			<details class="accommodation-switcher" data-accommodation-switcher>
				<summary class="accommodation-switcher__trigger" aria-label="Cambiar alojamiento actual">
					<ChevronDown class="h-4 w-4 shrink-0" aria-hidden="true" />
					<span class="inline-flex min-w-0 items-center gap-2">
						<span class="truncate text-xs font-semibold tracking-wide uppercase">
							{currentAccommodation.name}
						</span>
					</span>
				</summary>
				<div class="accommodation-switcher__menu">
					<p class="px-2 pb-2 text-xs font-semibold tracking-wide text-slate-400 uppercase">
						Cambiar alojamiento
					</p>
					<div class="space-y-1">
						{accommodations.map((item) => {
							const active = item.id === productId
							return (
								<a
									href={item.href}
									data-workspace-nav
									data-astro-prefetch="viewport"
									aria-current={active ? "page" : undefined}
									class={`accommodation-switcher__option ${
										active ? "accommodation-switcher__option--active" : ""
									}`}
								>
									<span class="truncate">{item.name}</span>
									{active ? <span class="accommodation-switcher__current">Actual</span> : null}
								</a>
							)
						})}
						{!hasOtherAccommodations ? (
							<p class="px-2 py-2 text-xs leading-5 text-slate-500">
								No hay otros alojamientos disponibles.
							</p>
						) : null}
					</div>
				</div>
			</details>
		) : (
			<p class="inline-flex items-center gap-2 text-sm font-semibold text-slate-100">
				{currentAccommodation.name}
			</p>
		)
	}
</div>

<style is:global>
	.accommodation-context-switcher {
		display: flex;
		max-width: 100%;
		flex-wrap: wrap;
		align-items: center;
	}

	.accommodation-context-switcher__label {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		color: rgb(148 163 184);
		font-size: 0.75rem;
		font-weight: 650;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}

	.accommodation-switcher {
		position: relative;
		max-width: min(100%, 24rem);
	}

	.accommodation-switcher__trigger {
		display: inline-flex;
		min-height: 2.125rem;
		max-width: min(100vw - 2rem, 24rem);
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		cursor: pointer;
		list-style: none;
		border: 1px solid rgb(0 0 0);
		border-radius: var(--fastt-radius-pill);
		background: rgb(0 0 0);
		padding: 0.38rem 0.6rem 0.38rem 0.38rem;
		color: rgb(241 245 249);
		font-size: 0.875rem;
		font-weight: 650;
		box-shadow: none;
		transition:
			border-color var(--fastt-motion-standard) ease,
			background-color var(--fastt-motion-standard) ease,
			box-shadow var(--fastt-motion-standard) ease;
	}

	.accommodation-switcher__trigger:focus-visible {
		outline: 2px solid rgb(255 255 255 / 0.92);
		outline-offset: 2px;
	}

	.accommodation-switcher__trigger::-webkit-details-marker {
		display: none;
	}

	.accommodation-switcher[open] > .accommodation-switcher__trigger,
	.accommodation-switcher__trigger:hover {
		border-color: rgb(15 23 42);
		background: rgb(15 23 42);
		box-shadow: 0 10px 24px rgb(0 0 0 / 0.16);
	}

	.accommodation-switcher__menu {
		position: absolute;
		top: calc(100% + 0.5rem);
		left: 0;
		z-index: 30;
		width: min(22rem, calc(100vw - 2rem));
		border: 1px solid rgb(226 232 240 / 0.9);
		border-radius: 1.1rem;
		background: rgb(255 255 255 / 0.98);
		padding: 0.65rem;
		box-shadow: 0 22px 55px rgb(15 23 42 / 0.16);
		backdrop-filter: blur(18px);
	}

	.accommodation-switcher__option {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		border-radius: 0.8rem;
		padding: 0.65rem 0.7rem;
		color: rgb(71 85 105);
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
	}

	.accommodation-switcher__option:hover {
		background: rgb(248 250 252);
		color: rgb(15 23 42);
	}

	.accommodation-switcher__option--active {
		background: rgb(241 245 249);
		color: rgb(15 23 42);
	}

	.accommodation-switcher__current {
		flex: none;
		border-radius: var(--fastt-radius-pill);
		background: rgb(15 23 42 / 0.08);
		padding: 0.16rem 0.45rem;
		font-size: 0.6875rem;
		font-weight: 700;
		color: rgb(51 65 85);
	}

	@media (max-width: 639px) {
		.accommodation-switcher {
			max-width: 100%;
		}

		.accommodation-switcher__trigger {
			max-width: min(100%, 18rem);
		}
	}
</style>

<script>
	function closeAccommodationSwitchers() {
		document
			.querySelectorAll("[data-accommodation-switcher]")
			.forEach((switcher) => switcher.removeAttribute("open"))
	}

	document.addEventListener(
		"click",
		(event) => {
			const target = event.target
			if (!(target instanceof Element)) return
			if (target.closest("[data-accommodation-switcher]")) return
			closeAccommodationSwitchers()
		},
		true
	)

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeAccommodationSwitchers()
	})
</script>
