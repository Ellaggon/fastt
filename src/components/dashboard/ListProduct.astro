---
const { products } = Astro.props

const getTypePath = (type: any) =>
	type === "Hotel" ? "hotels" : type === "Tour" ? "tours" : "packages"
---

{
	products.map((el: any) => (
		<div class="flex flex-col gap-9 border-b border-neutral-800 pb-3 md:gap-20">
			<div class="rounded-lg px-3 py-2 transition-colors hover:bg-black/40 mt-8 my-12">
				<a href={`/${getTypePath(el.productType)}/${el.id}`}>
					<p class="font-medium text-neutral-100 lg:text-xl">{el.name}</p>
					<small class="text-neutral-400">{el.productType}</small>
				</a>
			</div>

			<div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-xs md:gap-6 md:text-base lg:grid-cols-4 text-neutral-400 md:gap-9">
				<a href={`/products/${el.id}/edit`} class="hover:text-white border border-neutral-800 rounded-lg p-2 md:px-3 text-center">
					Cambiar Información General del Negocio
				</a>
				<a href={`/products/${el.id}/edit/subtype`} class="hover:text-white border border-neutral-800 rounded-lg p-2 md:px-3 text-center">
					Cambiar Detalles del Negocio
				</a>
				<a href={`/products/${el.id}/edit/images`} class="hover:text-white border border-neutral-800 rounded-lg p-2 md:px-3 text-center">
					Editar Imágenes
				</a>
			</div>
		</div>
	))
}

