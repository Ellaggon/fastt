---
const { products } = Astro.props
---

{
	products.map((el: any) => (
		<div class="flex flex-col gap-9 border-b border-neutral-800 pb-3 md:gap-20">
			<div class="my-12 mt-8 px-3 py-2">
				<p class="font-medium text-neutral-100 lg:text-xl">{el.name}</p>
				<small class="text-neutral-400">{el.productType}</small>
			</div>

			<div class="grid grid-cols-2 gap-3 text-xs text-neutral-400 md:grid-cols-3 md:gap-6 md:gap-9 md:text-base lg:grid-cols-4">
				<a
					href={`/product/${el.id}/review`}
					class="flex items-center justify-center rounded-lg border border-neutral-700 px-3 py-2 text-center text-blue-400 transition-colors hover:border-neutral-500 hover:text-blue-300"
				>
					Servicios Generales
				</a>
				<a
					href={`/product/${el.id}/review`}
					class="flex items-center justify-center rounded-lg border border-neutral-700 px-3 py-2 text-center text-blue-400 transition-colors hover:border-neutral-500 hover:text-blue-300"
				>
					Políticas
				</a>
				<a
					href={`/product/${el.id}/review`}
					class="flex items-center justify-center rounded-lg border border-neutral-700 px-3 py-2 text-center text-blue-400 transition-colors hover:border-neutral-500 hover:text-blue-300"
				>
					Restricciones
				</a>
			</div>
		</div>
	))
}
