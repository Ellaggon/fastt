---
import DashboardSidebarItem from "@/components/dashboard/DashboardSidebarItem.astro"
import DashboardSidebarSection from "@/components/dashboard/DashboardSidebarSection.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import {
	enterpriseNavigation,
	filterEnterpriseNavigationForDisclosure,
	type SidebarDisclosureMode,
} from "@/lib/backoffice-governance"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import {
	getProviderSidebarData,
	type ProviderSidebarReadiness,
} from "@/lib/dashboard/providerSidebarReadiness"
import { routes } from "@/lib/routes"

interface Props {
	pathname?: string
}

const { pathname = "" } = Astro.props
const isRoomSurface = (value: string) =>
	/^\/catalog\/accommodations\/rooms(?:\/|$)/.test(value) ||
	/^\/product\/[^/]+\/rooms(?:\/|$)/.test(value)
const isActive = (href: string) => {
	if (href === routes.productRooms() && isRoomSurface(pathname)) return true
	return pathname === href || pathname.startsWith(`${href}/`) || pathname.startsWith(`${href}?`)
}
const activeHref =
	enterpriseNavigation
		.flatMap((section) => section.items.map((item) => item.href))
		.filter((href) => isActive(href))
		.sort((a, b) => b.length - a.length)[0] ?? ""

let sidebarReadiness: ProviderSidebarReadiness = {}
let disclosureMode: SidebarDisclosureMode = "small-provider"
const professionalToolsEnabledFromCookie = getProfessionalModeCookiePreference(Astro.request)
try {
	const user = await getUserFromRequest(Astro.request)
	const providerId = await getProviderIdFromRequest(Astro.request, user)
	if (providerId) {
		const sidebarData = await getProviderSidebarData(providerId, {
			userId: user?.id,
			professionalToolsEnabled:
				typeof professionalToolsEnabledFromCookie === "boolean"
					? professionalToolsEnabledFromCookie
					: undefined,
		})
		sidebarReadiness = sidebarData.summaries
		disclosureMode = sidebarData.disclosureMode
	}
} catch {
	disclosureMode = professionalToolsEnabledFromCookie ? "professional-tools" : "small-provider"
	sidebarReadiness = {
		[routes.ratePlansList()]: "Estado no disponible",
		[routes.pricing()]: "Estado no disponible",
		[routes.ratesMultiCalendar()]: "Estado no disponible",
	}
}
const visibleNavigation = filterEnterpriseNavigationForDisclosure(enterpriseNavigation, {
	mode: disclosureMode,
	activeHref,
})
const isSectionActive = (items: (typeof visibleNavigation)[number]["items"]) =>
	items.some((item) => item.href === activeHref || isActive(item.href))

function itemSummary(item: (typeof enterpriseNavigation)[number]["items"][number]) {
	return sidebarReadiness[item.href] ?? ""
}

function summaryTone(summary: string): "neutral" | "success" | "warning" | "danger" {
	const value = summary.toLocaleLowerCase("es")
	if (
		value.includes("sin precio") ||
		value.includes("incompleto") ||
		value.includes("no disponible")
	) {
		return "danger"
	}
	if (value.includes("requiere atención") || value.includes("pendiente")) return "warning"
	if (value.includes("lista") && !value.includes("incomplet")) return "success"
	return "neutral"
}

const sectionByTitle = new Map(visibleNavigation.map((section) => [section.title, section]))
const navigationGroups = [
	{
		title: "Operación",
		sections: ["Inicio", "Reservas", "Habitaciones y tarifas"],
		collapsible: false,
	},
	{
		title: "Alojamiento",
		sections: ["Alojamientos y contenido"],
		collapsible: false,
	},
	{
		title: "Finanzas",
		sections: ["Finanzas"],
		collapsible: true,
	},
	{
		title: "Análisis",
		sections: ["Analítica"],
		collapsible: true,
	},
	{
		title: "Sistema",
		sections: ["Administración"],
		collapsible: true,
	},
]
	.map((group) => ({
		...group,
		items: group.sections.flatMap((title) => sectionByTitle.get(title)?.items ?? []),
	}))
	.filter((group) => group.items.length > 0)

function shouldShowNavGroupHeading(
	item: (typeof enterpriseNavigation)[number]["items"][number],
	index: number,
	items: (typeof enterpriseNavigation)[number]["items"]
) {
	if (!item.navGroup) return false
	return index === 0 || items[index - 1]?.navGroup !== item.navGroup
}
---

<nav class="space-y-4 pb-5" aria-label="Navegación principal del proveedor">
	{
		navigationGroups.map((group) => (
			<DashboardSidebarSection
				title={group.title}
				active={isSectionActive(group.items)}
				collapsible={group.collapsible}
				defaultOpen={!group.collapsible}
			>
				{group.items.map((item, index) => {
					const summary = itemSummary(item)
					return (
						<>
							{shouldShowNavGroupHeading(item, index, group.items) ? (
								<p class="px-2.5 pt-2 text-[10px] font-semibold tracking-[0.12em] text-slate-600 uppercase first:pt-0">
									{item.navGroup}
								</p>
							) : null}
							<DashboardSidebarItem
								href={item.href}
								label={item.label}
								status={item.status}
								summary={summary}
								summaryTone={summaryTone(summary)}
								active={item.href === activeHref}
								prefetch={true}
							/>
						</>
					)
				})}
			</DashboardSidebarSection>
		))
	}
</nav>
