---
import DashboardSidebarItem from "@/components/dashboard/DashboardSidebarItem.astro"
import DashboardSidebarSection from "@/components/dashboard/DashboardSidebarSection.astro"
import { routes } from "@/lib/routes"

interface Props {
	pathname?: string
}

const { pathname = "" } = Astro.props
const isActive = (href: string) =>
	pathname === href || pathname.startsWith(`${href}/`) || pathname.startsWith(`${href}?`)

const isInventoryActive =
	isActive(routes.ratePlansHub()) ||
	isActive(routes.productList()) ||
	isActive(routes.bookingList())
const isPricingActive =
	isActive(routes.pricingRules()) ||
	isActive(routes.pricingBulk()) ||
	isActive(routes.pricingCalendar())
const isAnalyticsActive =
	isActive(routes.analyticsPerformance()) ||
	isActive(routes.analyticsRevenue()) ||
	isActive(routes.analyticsOccupancy())
const isSystemActive =
	isActive(routes.provider()) ||
	isActive(routes.providerPolicies()) ||
	isActive(routes.providerPoliciesAudit()) ||
	isActive(routes.systemIntegrations())
---

<nav class="space-y-4">
	<DashboardSidebarSection
		title="Inventory"
		subtitle={isInventoryActive ? "Sección activa" : "Operación diaria"}
	>
		<DashboardSidebarItem
			href={routes.ratePlansHub()}
			label="Rate Plans"
			active={isActive(routes.ratePlansHub())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.productList()}
			label="Availability"
			active={isActive(routes.productList())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.bookingList()}
			label="Reservas"
			active={isActive(routes.bookingList())}
			prefetch={true}
			level={2}
		/>
	</DashboardSidebarSection>

	<DashboardSidebarSection
		title="Pricing"
		subtitle={isPricingActive ? "Sección activa" : "Revenue controls"}
	>
		<DashboardSidebarItem
			href={routes.pricingRules()}
			label="Rules"
			active={isActive(routes.pricingRules())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.pricingBulk()}
			label="Bulk Operations"
			active={isActive(routes.pricingBulk())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.pricingCalendar()}
			label="Calendar"
			active={isActive(routes.pricingCalendar())}
			prefetch={true}
			level={1}
		/>
	</DashboardSidebarSection>

	<DashboardSidebarSection
		title="Analytics"
		subtitle={isAnalyticsActive ? "Sección activa" : "Visibilidad de negocio"}
	>
		<DashboardSidebarItem
			href={routes.analyticsPerformance()}
			label="Performance"
			active={isActive(routes.analyticsPerformance())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.analyticsRevenue()}
			label="Revenue"
			active={isActive(routes.analyticsRevenue())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.analyticsOccupancy()}
			label="Occupancy"
			active={isActive(routes.analyticsOccupancy())}
			prefetch={true}
			level={1}
		/>
	</DashboardSidebarSection>

	<DashboardSidebarSection
		title="System"
		subtitle={isSystemActive ? "Sección activa" : "Configuración"}
	>
		<DashboardSidebarItem
			href={routes.provider()}
			label="Settings"
			active={isActive(routes.provider())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.providerPolicies()}
			label="Policies"
			active={isActive(routes.providerPolicies())}
			prefetch={true}
			level={1}
		/>
		<DashboardSidebarItem
			href={routes.providerPoliciesAudit()}
			label="Auditoría"
			active={isActive(routes.providerPoliciesAudit())}
			prefetch={true}
			level={2}
		/>
		<DashboardSidebarItem
			href={routes.systemIntegrations()}
			label="Integrations"
			active={isActive(routes.systemIntegrations())}
			prefetch={true}
			level={1}
		/>
	</DashboardSidebarSection>
</nav>
