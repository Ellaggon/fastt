---
import DashboardSidebarItem from "@/components/dashboard/DashboardSidebarItem.astro"
import DashboardSidebarSection from "@/components/dashboard/DashboardSidebarSection.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import {
	enterpriseNavigation,
	filterEnterpriseNavigationForDisclosure,
	type SidebarDisclosureMode,
} from "@/lib/backoffice-governance"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import {
	getProviderSidebarData,
	type ProviderSidebarReadiness,
} from "@/lib/dashboard/providerSidebarReadiness"
import { routes } from "@/lib/routes"

interface Props {
	pathname?: string
}

const { pathname = "" } = Astro.props
const isRoomSurface = (value: string) =>
	/^\/catalog\/accommodations\/rooms(?:\/|$)/.test(value) ||
	/^\/product\/[^/]+\/rooms(?:\/|$)/.test(value)
const isActive = (href: string) => {
	if (href === routes.productRooms() && isRoomSurface(pathname)) return true
	return pathname === href || pathname.startsWith(`${href}/`) || pathname.startsWith(`${href}?`)
}
const activeHref =
	enterpriseNavigation
		.flatMap((section) => section.items.map((item) => item.href))
		.filter((href) => isActive(href))
		.sort((a, b) => b.length - a.length)[0] ?? ""

let sidebarReadiness: ProviderSidebarReadiness = {}
let disclosureMode: SidebarDisclosureMode = "small-provider"
const professionalToolsEnabledFromCookie = getProfessionalModeCookiePreference(Astro.request)
try {
	const user = await getUserFromRequest(Astro.request)
	const providerId = await getProviderIdFromRequest(Astro.request, user)
	if (providerId) {
		const sidebarData = await getProviderSidebarData(providerId, {
			userId: user?.id,
			professionalToolsEnabled:
				typeof professionalToolsEnabledFromCookie === "boolean"
					? professionalToolsEnabledFromCookie
					: undefined,
		})
		sidebarReadiness = sidebarData.summaries
		disclosureMode = sidebarData.disclosureMode
	}
} catch {
	disclosureMode = professionalToolsEnabledFromCookie ? "professional-tools" : "small-provider"
	sidebarReadiness = {
		[routes.ratePlansList()]: "Tarifas: readiness no disponible.",
		[routes.pricing()]: "Calendario: readiness no disponible.",
		[routes.inventory()]: "Inventario físico: readiness no disponible.",
		[routes.rateRestrictions()]: "Reglas de venta: readiness no disponible.",
		[routes.providerPolicies()]: "Condiciones: readiness no disponible.",
	}
}
const visibleNavigation = filterEnterpriseNavigationForDisclosure(enterpriseNavigation, {
	mode: disclosureMode,
	activeHref,
})
const isSectionActive = (items: (typeof visibleNavigation)[number]["items"]) =>
	items.some((item) => item.href === activeHref || isActive(item.href))

function itemSummary(item: (typeof enterpriseNavigation)[number]["items"][number]) {
	if (sidebarReadiness[item.href]) return sidebarReadiness[item.href]
	return item.summary
}
---

<nav class="space-y-4" aria-label="Enterprise backoffice navigation">
	<div class="rounded-2xl border border-slate-800 bg-slate-950/70 p-3">
		<p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-300">
			Panel del proveedor
		</p>
		<p class="mt-1 text-xs leading-5 text-slate-400">
			Gestiona alojamiento, habitaciones, tarifas, inventario, reservas y finanzas desde sus
			secciones principales.
		</p>
	</div>
	{
		visibleNavigation.map((section) => (
			<DashboardSidebarSection
				title={section.title}
				owner={section.owner}
				active={isSectionActive(section.items)}
				subtitle={isSectionActive(section.items) ? "Sección activa" : section.subtitle}
			>
				{section.items.map((item) => (
					<DashboardSidebarItem
						href={item.href}
						label={item.label}
						status={item.status}
						summary={itemSummary(item)}
						active={item.href === activeHref}
						prefetch={true}
						level={item.level ?? 1}
					/>
				))}
				{section.planned?.length ? (
					<details class="border-t border-slate-800/80 px-3 pt-2">
						<summary class="cursor-pointer text-[10px] font-semibold tracking-[0.08em] text-slate-600 uppercase hover:text-slate-400">
							Próximamente ({section.planned.length})
						</summary>
						<div class="mt-2 flex flex-wrap gap-1.5">
							{section.planned.map((label) => (
								<span class="rounded-full border border-slate-700/80 px-2 py-1 text-[10px] font-medium text-slate-500">
									{label}
								</span>
							))}
						</div>
					</details>
				) : null}
			</DashboardSidebarSection>
		))
	}
</nav>
