---
const { products } = Astro.props
---

{
	products.map((el: any) => (
		<div class="flex flex-col gap-9 border-b border-neutral-800 pb-3 md:gap-9">
			<div class="my-12 mt-8 rounded-lg px-3 py-2 transition-colors hover:bg-black/40">
				<a href={`/product/${el.id}/review`}>
					<p class="font-medium text-neutral-100 lg:text-xl">{el.name}</p>
					<small class="text-neutral-400">{el.productType}</small>
				</a>
			</div>
		</div>
	))
}
