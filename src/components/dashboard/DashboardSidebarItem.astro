---
import {
	BadgeCheck,
	BarChart3,
	BedDouble,
	BookOpen,
	Building2,
	CalendarDays,
	CalendarRange,
	CarFront,
	ChartNoAxesColumnIncreasing,
	CircleDollarSign,
	ClipboardList,
	Gauge,
	House,
	Layers3,
	Map,
	Package,
	ReceiptText,
	Settings,
	WalletCards,
} from "@lucide/astro"

interface Props {
	href: string
	label: string
	status?: "canonical" | "transitional"
	summary?: string
	summaryTone?: "neutral" | "success" | "warning" | "danger"
	active?: boolean
	prefetch?: boolean
	level?: 1 | 2 | 3 | 4
	compact?: boolean
}

const {
	href,
	label,
	status = "canonical",
	summary = "",
	summaryTone = "neutral",
	active = false,
	prefetch = false,
	level = 1,
	compact = false,
} = Astro.props

const iconByLabel = {
	"Resumen": House,
	"Reservas": ClipboardList,
	"Tarifas": Layers3,
	"Calendario": CalendarDays,
	"Calendario de precios": CalendarDays,
	"Condiciones": ClipboardList,
	"Multicalendario": CalendarRange,
	"Servicios": Building2,
	"Servicio": Building2,
	"Alojamiento": Building2,
	"Alojamientos": Building2,
	"Habitaciones": BedDouble,
	"Reglas para huéspedes": BookOpen,
	"Tours": Map,
	"Paquetes": Package,
	"Traslados": CarFront,
	"Finanzas": WalletCards,
	"Bandeja financiera": WalletCards,
	"Cobros": CircleDollarSign,
	"Liquidaciones": ReceiptText,
	"Pagos a proveedores": WalletCards,
	"Reembolsos": ReceiptText,
	"Impuestos y cargos": ReceiptText,
	"Integraciones": Settings,
	"Ingresos": CircleDollarSign,
	"Rendimiento": ChartNoAxesColumnIncreasing,
	"Ocupación": BarChart3,
	"Configuración": Settings,
	"Perfil del proveedor": Settings,
	"Verificación": BadgeCheck,
} as const
const Icon = iconByLabel[label as keyof typeof iconByLabel] ?? Gauge
const compactClass = compact ? "py-0.5" : "py-1"
const summaryToneClass = {
	neutral: "text-slate-400",
	success: "text-emerald-300",
	warning: "text-amber-300",
	danger: "text-rose-300",
}[summaryTone]
const shouldShowSummary =
	Boolean(summary) && (active || summaryTone === "warning" || summaryTone === "danger")
---

<div
	class={`group rounded-lg ${compactClass} transition-colors ${
		active ? "bg-white text-slate-950" : "text-slate-200 hover:bg-white/[0.08] hover:text-white"
	}`}
>
	<a
		href={href}
		data-workspace-nav
		aria-current={active ? "page" : undefined}
		data-astro-prefetch={prefetch ? true : undefined}
		data-governance-status={status}
		class="flex min-h-10 items-center gap-3 rounded-lg px-3 text-sm font-semibold text-inherit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/70"
	>
		<Icon
			size={20}
			stroke-width={active ? 2.2 : 1.8}
			class={`shrink-0 ${active ? "text-slate-950" : "text-slate-400 group-hover:text-white"}`}
			aria-hidden="true"
		/>
		<span class="min-w-0 flex-1 truncate">{label}</span>
	</a>
	{
		shouldShowSummary ? (
			<p
				class={`-mt-0.5 truncate pr-3 pb-1 pl-11 text-xs leading-4 ${active ? "text-slate-600" : summaryToneClass}`}
			>
				{summary}
			</p>
		) : null
	}
</div>
