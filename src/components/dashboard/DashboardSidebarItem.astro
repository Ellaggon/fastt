---
import {
	BadgeCheck,
	BarChart3,
	BedDouble,
	BookOpen,
	Building2,
	CalendarDays,
	CalendarRange,
	ChartNoAxesColumnIncreasing,
	CircleDollarSign,
	ClipboardList,
	Gauge,
	House,
	Layers3,
	ReceiptText,
	Settings,
	WalletCards,
} from "@lucide/astro"

interface Props {
	href: string
	label: string
	status?: "canonical" | "transitional"
	summary?: string
	summaryTone?: "neutral" | "success" | "warning" | "danger"
	active?: boolean
	prefetch?: boolean
	level?: 1 | 2 | 3 | 4
	compact?: boolean
}

const {
	href,
	label,
	status = "canonical",
	summary = "",
	summaryTone = "neutral",
	active = false,
	prefetch = false,
	level = 1,
	compact = false,
} = Astro.props

const iconByLabel = {
	"Resumen": House,
	"Reservas": ClipboardList,
	"Tarifas": Layers3,
	"Calendario": CalendarDays,
	"Multicalendario": CalendarRange,
	"Catálogo": Building2,
	"Habitaciones": BedDouble,
	"Reglas para huéspedes": BookOpen,
	"Finanzas": WalletCards,
	"Bandeja financiera": WalletCards,
	"Cobros": CircleDollarSign,
	"Liquidaciones": ReceiptText,
	"Pagos a proveedores": WalletCards,
	"Reembolsos": ReceiptText,
	"Impuestos y cargos": ReceiptText,
	"Ingresos": CircleDollarSign,
	"Rendimiento": ChartNoAxesColumnIncreasing,
	"Ocupación": BarChart3,
	"Configuración": Settings,
	"Verificación": BadgeCheck,
} as const
const Icon = iconByLabel[label as keyof typeof iconByLabel] ?? Gauge
const compactClass = compact ? "py-1.5" : "py-2"
const summaryToneClass = {
	neutral: "text-slate-400",
	success: "text-emerald-300",
	warning: "text-amber-300",
	danger: "text-rose-300",
}[summaryTone]
---

<div
	class={`group rounded-lg ${compactClass} transition-colors ${
		active ? "bg-white/10 text-white" : "text-slate-300 hover:bg-white/[0.055] hover:text-white"
	}`}
>
	<a
		href={href}
		data-workspace-nav
		aria-current={active ? "page" : undefined}
		data-astro-prefetch={prefetch ? true : undefined}
		data-governance-status={status}
		class="flex min-h-9 items-center gap-3 rounded-lg px-2.5 text-[13px] font-medium text-inherit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400/70"
	>
		<Icon
			size={17}
			stroke-width={active ? 2.2 : 1.8}
			class={`shrink-0 ${active ? "text-white" : "text-slate-500 group-hover:text-slate-300"}`}
			aria-hidden="true"
		/>
		<span class="min-w-0 flex-1 truncate">{label}</span>
	</a>
	{
		summary ? (
			<p class={`-mt-0.5 truncate pr-2.5 pb-1 pl-[38px] text-xs leading-4 ${summaryToneClass}`}>
				{summary}
			</p>
		) : null
	}
</div>
