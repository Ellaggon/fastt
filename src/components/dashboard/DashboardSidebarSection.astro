---
interface Props {
	title: string
	active?: boolean
	collapsible?: boolean
	defaultOpen?: boolean
}

const { title, active = false, collapsible = false, defaultOpen = false } = Astro.props
const isStartSection = title === "Inicio"
---

{
	collapsible ? (
		<details
			open={defaultOpen || active}
			data-nav-section
			data-active={active ? "true" : "false"}
			class="group/section border-t border-white/[0.08] pt-4"
		>
			<summary class="flex cursor-pointer list-none items-center justify-between px-2.5 text-[11px] font-semibold tracking-[0.08em] text-slate-400 uppercase transition-colors hover:text-white [&::-webkit-details-marker]:hidden">
				<span>{title}</span>
				<svg
					class="h-3.5 w-3.5 text-slate-500 transition-transform group-open/section:rotate-90"
					viewBox="0 0 20 20"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="m7.5 5 5 5-5 5"
						stroke="currentColor"
						stroke-width="1.7"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
			</summary>
			<div class="mt-2 space-y-0.5">
				<slot />
			</div>
		</details>
	) : (
		<section
			data-nav-section
			data-active={active ? "true" : "false"}
			class={isStartSection ? "pt-1" : "border-t border-white/[0.08] pt-4"}
		>
			{isStartSection ? null : (
				<p class="px-2.5 text-[11px] font-semibold tracking-[0.08em] text-slate-400 uppercase">
					{title}
				</p>
			)}
			<div class={isStartSection ? "space-y-0.5" : "mt-2 space-y-0.5"}>
				<slot />
			</div>
		</section>
	)
}
