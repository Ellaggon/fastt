---
import { routes } from "@/lib/routes"

interface Props {
	productId: string
	variantId: string
	pathname: string
	currentPath?: string
}

const { pathname, currentPath = pathname } = Astro.props
const items = [
	{ href: routes.rates(), label: "Tarifas" },
	{ href: routes.calendar(), label: "Calendario de precios" },
	{ href: routes.conditions(), label: "Condiciones" },
	{ href: routes.ratesMultiCalendar(), label: "Multicalendario" },
]
const hrefPath = (href: string) => href.split(/[?#]/)[0] ?? href
const isActive = (href: string) => {
	if (href.includes("?") || href.includes("#")) return currentPath === href
	return pathname === hrefPath(href) || pathname.startsWith(`${hrefPath(href)}/`)
}
---

<nav class="flex flex-wrap gap-2">
	{
		items.map((item) => (
			<a
				href={item.href}
				data-astro-prefetch
				class={`inline-flex h-9 items-center rounded-lg border px-3 text-sm font-medium ${
					isActive(item.href)
						? "border-blue-200 bg-blue-100 text-blue-800"
						: "border-slate-300 bg-white text-slate-700 hover:bg-slate-100"
				}`}
			>
				{item.label}
			</a>
		))
	}
</nav>
