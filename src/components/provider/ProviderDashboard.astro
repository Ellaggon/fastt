---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"

const {
	provider,
	profile,
	latestVerification,
	ownerEmail,
	progressMessage,
	badgeVariant,
	stateLabel,
	derivedState,
	primaryCtaAction,
	primaryCtaLabel,
	identityComplete,
	operationalComplete,
	verificationComplete,
	progressPercent,
} = Astro.props
---

<header class="space-y-6">
	<div class="flex flex-wrap items-start justify-between gap-6">
		<div class="space-y-2">
			<h1 class="text-3xl font-semibold uppercase tracking-wide text-slate-100">
				{provider.displayName || provider.legalName || "Proveedor"}
			</h1>
			<p class="text-sm text-slate-300">{progressMessage}</p>
			<p class="text-xs text-slate-400">Propietario: {ownerEmail}</p>
		</div>
		<div class="flex items-center gap-3">
			<span
				class={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
					badgeVariant === "success"
						? "bg-green-100 text-green-800 border-green-200"
						: badgeVariant === "warning"
							? "bg-orange-100 text-orange-800 border-orange-200"
							: badgeVariant === "info"
								? "bg-blue-100 text-blue-800 border-blue-200"
								: "bg-neutral-100 text-neutral-800 border-neutral-200"
				}`}
			>
				{stateLabel}
			</span>
			{
				derivedState === "active" ? (
					<Button disabled className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]">
						Cuenta activa
					</Button>
				) : (
					<Button href={primaryCtaAction} className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]">
						{primaryCtaLabel}
					</Button>
				)
			}
		</div>
	</div>
</header>

<div class="mx-auto max-w-7xl space-y-8">
	<section class="space-y-4">
		<Card class="border-slate-700 bg-slate-900 text-white">
			<div class="space-y-4">
				<h2 class="text-xl font-semibold text-white">Lista de verificación de activación</h2>
				<div class="h-2 w-full overflow-hidden rounded-full bg-slate-700">
					<div
						class="h-full bg-[#1E3A8A]"
						style={`width: ${Math.max(0, Math.min(100, Number(progressPercent ?? 0)))}%`}
					>
					</div>
				</div>
				<p class="text-sm text-slate-200">
					Complete todos los pasos a continuación para activar su cuenta.
				</p>
			</div>
		</Card>
		<div class="space-y-4">
			<Card class="bg-slate-100">
				<div class="space-y-6">
					<div class="flex items-start justify-between gap-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Identidad del proveedor</h2>
							<p class="text-sm text-slate-600">Nombre comercial y razón social.</p>
						</div>
						<div class="flex items-center gap-3">
							<span
								class={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
									identityComplete
										? "bg-green-100 text-green-800 border-green-200"
										: "bg-orange-100 text-orange-800 border-orange-200"
								}`}
							>
								{identityComplete ? "✅ Completo" : "⚠️ Incompleto"}
							</span>
							<Button
								href="/provider?step=register"
								className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
							>
								Editar
							</Button>
						</div>
					</div>
					<div class="grid gap-4 md:grid-cols-2">
						<div class="space-y-2">
							<p class="text-sm text-slate-500">Nombre comercial</p>
							<p class="text-sm text-slate-900">{provider.displayName || "Falta completar"}</p>
						</div>
						<div class="space-y-2 md:col-span-2">
							<p class="text-sm text-slate-500">Razón social</p>
							<p class="text-sm text-slate-900">{provider.legalName || "Falta completar"}</p>
						</div>
					</div>
				</div>
			</Card>

			<Card class="bg-slate-100">
				<div class="space-y-6">
					<div class="flex items-start justify-between gap-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Perfil operativo</h2>
							<p class="text-sm text-slate-600">
								Zona horaria, moneda por defecto y contacto de soporte.
							</p>
						</div>
						<div class="flex items-center gap-3">
							<span
								class={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
									operationalComplete
										? "bg-green-100 text-green-800 border-green-200"
										: "bg-orange-100 text-orange-800 border-orange-200"
								}`}
							>
								{operationalComplete ? "✅ Completo" : "⚠️ Incompleto"}
							</span>
							<Button
								href="/provider?step=profile"
								className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
							>
								Editar
							</Button>
						</div>
					</div>
					<div class="grid gap-4 md:grid-cols-2">
						<div class="space-y-2">
							<p class="text-sm text-slate-500">Zona horaria</p>
							<p class="text-sm text-slate-900">{profile?.timezone || "Falta completar"}</p>
						</div>
						<div class="space-y-2">
							<p class="text-sm text-slate-500">Moneda por defecto</p>
							<p class="text-sm text-slate-900">{profile?.defaultCurrency || "Falta completar"}</p>
						</div>
						<div class="space-y-2 md:col-span-2">
							<p class="text-sm text-slate-500">Correo de soporte</p>
							<p class="text-sm text-slate-900">{profile?.supportEmail || "Falta completar"}</p>
						</div>
					</div>
				</div>
			</Card>

			<Card class="bg-slate-100">
				<div class="space-y-6">
					<div class="flex items-start justify-between gap-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Estado de verificación</h2>
							<p class="text-sm text-slate-600">Estado de verificación de solo lectura.</p>
						</div>
						<div class="flex items-center gap-3">
							<span
								class={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
									verificationComplete
										? "bg-green-100 text-green-800 border-green-200"
										: "bg-orange-100 text-orange-800 border-orange-200"
								}`}
							>
								{verificationComplete ? "✅ Aprobado" : "⚠️ Incompleto"}
							</span>
							<Button
								href="/provider?step=verification"
								className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
							>
								Ver detalles
							</Button>
						</div>
					</div>
					<div class="grid gap-4 md:grid-cols-2">
						<div class="space-y-2">
							<p class="text-sm text-slate-500">Estado</p>
							<p class="text-sm text-slate-900">
								{
									latestVerification?.status === "approved"
										? "Aprobado"
										: latestVerification?.status || "Pendiente"
								}
							</p>
						</div>
						<div class="space-y-2">
							<p class="text-sm text-slate-500">Motivo</p>
							<p class="text-sm text-slate-900">
								{latestVerification?.reason || "Sin motivo informado"}
							</p>
						</div>
					</div>
				</div>
			</Card>
		</div>
	</section>

	<section class="space-y-4">
		<header class="space-y-1">
			<h2 class="text-lg font-semibold text-slate-100">Equipo y acceso</h2>
			<p class="text-sm text-slate-300">
				Próximamente se habilitará la gestión de accesos del equipo.
			</p>
		</header>
		<Card class="bg-slate-100">
			<div class="flex items-start justify-between gap-4">
				<div class="space-y-2">
					<p class="text-xl font-semibold text-slate-900">Próximamente</p>
					<p class="text-sm text-slate-600">
						Los roles y permisos del equipo se gestionarán en esta sección.
					</p>
				</div>
				<span
					class="inline-flex items-center rounded-full border border-blue-200 bg-blue-100 px-2.5 py-1 text-xs font-medium text-blue-800"
				>
					Planificado
				</span>
			</div>
		</Card>
	</section>
</div>
