---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"

const { isProviderAvailable, profile } = Astro.props
---

<section class="space-y-4">
	<header class="space-y-1">
		<h2 class="text-lg font-semibold text-slate-100">Perfil operativo</h2>
		<p class="text-sm text-slate-300">
			Configure los valores operativos por defecto del proveedor.
		</p>
	</header>
	<Card>
		{
			!isProviderAvailable && (
				<div class="space-y-4">
					<p class="text-sm text-slate-600">
						Complete primero la identidad para habilitar el perfil operativo.
					</p>
					<Button href="/provider?step=register">Ir a identidad</Button>
				</div>
			)
		}
		{
			isProviderAvailable && (
				<form method="POST" action="/api/providers/profile" class="max-w-3xl space-y-6">
					<div class="space-y-4">
						<div class="space-y-1">
							<h3 class="text-xl font-semibold text-slate-900">Operación</h3>
							<p class="text-sm text-slate-600">
								Estos campos son obligatorios para alcanzar estado listo.
							</p>
						</div>
						<FormField label="Zona horaria" htmlFor="timezone" required>
							<Select id="timezone" name="timezone" required>
								<option
									value="America/Santiago"
									selected={(profile?.timezone ?? "America/Santiago") === "America/Santiago"}
								>
									America/Santiago
								</option>
								<option
									value="America/New_York"
									selected={profile?.timezone === "America/New_York"}
								>
									America/New_York
								</option>
								<option value="Europe/Madrid" selected={profile?.timezone === "Europe/Madrid"}>
									Europe/Madrid
								</option>
							</Select>
						</FormField>
						<FormField label="Moneda por defecto" htmlFor="defaultCurrency" required>
							<Select id="defaultCurrency" name="defaultCurrency" required>
								<option value="USD" selected={(profile?.defaultCurrency ?? "USD") === "USD"}>
									USD
								</option>
								<option value="EUR" selected={profile?.defaultCurrency === "EUR"}>
									EUR
								</option>
								<option value="CLP" selected={profile?.defaultCurrency === "CLP"}>
									CLP
								</option>
							</Select>
						</FormField>
						<FormField
							label="Correo de soporte"
							htmlFor="supportEmail"
							description="Opcional si ya existe un correo de contacto configurado."
						>
							<Input
								id="supportEmail"
								type="email"
								name="supportEmail"
								value={profile?.supportEmail ?? ""}
							/>
						</FormField>
						<FormField label="Teléfono de soporte" htmlFor="supportPhone">
							<Input id="supportPhone" name="supportPhone" value={profile?.supportPhone ?? ""} />
						</FormField>
					</div>
					<div class="flex items-center justify-end gap-3">
						<Button href="/provider" variant="secondary">
							Volver
						</Button>
						<Button type="submit">Guardar perfil</Button>
					</div>
				</form>
			)
		}
	</Card>
</section>
