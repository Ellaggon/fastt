---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"

const { isProviderAvailable, profile } = Astro.props
---

<section class="space-y-4">
	<header class="space-y-1">
		<h2 class="text-lg font-semibold text-slate-100">Perfil operativo</h2>
		<p class="text-sm text-slate-300">
			Configure los valores operativos por defecto del proveedor.
		</p>
	</header>
	<Card class="bg-slate-100">
		{
			!isProviderAvailable && (
				<div class="space-y-4">
					<p class="text-sm text-slate-600">
						Complete primero la identidad para habilitar el perfil operativo.
					</p>
					<Button
						href="/provider?step=register"
						className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
					>
						Ir a identidad
					</Button>
				</div>
			)
		}
		{
			isProviderAvailable && (
				<form method="POST" action="/api/providers/profile" class="max-w-3xl space-y-6">
					<div class="space-y-4">
						<div class="space-y-1">
							<h3 class="text-xl font-semibold text-slate-900">Operación</h3>
							<p class="text-sm text-slate-600">
								Estos campos son obligatorios para alcanzar estado listo.
							</p>
						</div>
						<div class="space-y-2">
							<label for="timezone" class="text-sm font-medium text-slate-700">
								Zona horaria *
							</label>
							<select
								id="timezone"
								name="timezone"
								required
								class="block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
							>
								<option
									value="America/Santiago"
									selected={(profile?.timezone ?? "America/Santiago") === "America/Santiago"}
								>
									America/Santiago
								</option>
								<option
									value="America/New_York"
									selected={profile?.timezone === "America/New_York"}
								>
									America/New_York
								</option>
								<option value="Europe/Madrid" selected={profile?.timezone === "Europe/Madrid"}>
									Europe/Madrid
								</option>
							</select>
						</div>
						<div class="space-y-2">
							<label for="defaultCurrency" class="text-sm font-medium text-slate-700">
								Moneda por defecto *
							</label>
							<select
								id="defaultCurrency"
								name="defaultCurrency"
								required
								class="block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
							>
								<option value="USD" selected={(profile?.defaultCurrency ?? "USD") === "USD"}>
									USD
								</option>
								<option value="EUR" selected={profile?.defaultCurrency === "EUR"}>
									EUR
								</option>
								<option value="CLP" selected={profile?.defaultCurrency === "CLP"}>
									CLP
								</option>
							</select>
						</div>
						<div class="space-y-2">
							<label for="supportEmail" class="text-sm font-medium text-slate-700">
								Correo de soporte
							</label>
							<p class="text-xs text-slate-600">
								Opcional si ya existe un correo de contacto configurado.
							</p>
							<input
								id="supportEmail"
								type="email"
								name="supportEmail"
								value={profile?.supportEmail ?? ""}
								class="block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
							/>
						</div>
						<div class="space-y-2">
							<label for="supportPhone" class="text-sm font-medium text-slate-700">
								Teléfono de soporte
							</label>
							<input
								id="supportPhone"
								name="supportPhone"
								value={profile?.supportPhone ?? ""}
								class="block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
							/>
						</div>
					</div>
					<div class="flex items-center justify-end gap-3">
						<a
							href="/provider"
							class="inline-flex h-10 items-center justify-center rounded-lg border border-neutral-300 bg-neutral-100 px-4 text-sm font-medium text-neutral-900 hover:bg-neutral-200"
						>
							Volver
						</a>
						<button
							type="submit"
							class="inline-flex h-10 items-center justify-center rounded-lg bg-[#1E3A8A] px-4 text-sm font-medium text-white hover:bg-[#1e40af]"
						>
							Guardar perfil
						</button>
					</div>
				</form>
			)
		}
	</Card>
</section>
