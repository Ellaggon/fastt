---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import { routes } from "@/lib/routes"

const { isProviderAvailable, profile } = Astro.props
---

<section class="space-y-4">
	<header class="space-y-1">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
			Configuración del proveedor
		</p>
		<h2 class="text-lg font-semibold text-slate-100">Perfil operativo</h2>
		<p class="text-sm text-slate-300">
			Configura los valores que usan reservas, calendario, comunicaciones y precios por defecto.
		</p>
	</header>
	<Card>
		{
			!isProviderAvailable && (
				<div class="space-y-4">
					<p class="text-sm text-slate-600">
						Complete primero la identidad para habilitar el perfil operativo.
					</p>
					<Button href={routes.providerSettingsProfile()}>Ir a identidad</Button>
				</div>
			)
		}
		{
			isProviderAvailable && (
				<form method="POST" action="/api/providers/profile" class="max-w-3xl space-y-6">
					<div class="space-y-4">
						<div class="space-y-1">
							<h3 class="text-xl font-semibold text-slate-900">Operación</h3>
							<p class="text-sm text-slate-600">
								Estos campos habilitan una operación consistente entre zonas horarias, moneda y
								soporte.
							</p>
						</div>
						<FormField label="Zona horaria" htmlFor="timezone" required>
							<Select id="timezone" name="timezone" required>
								<option
									value="America/Santiago"
									selected={(profile?.timezone ?? "America/Santiago") === "America/Santiago"}
								>
									America/Santiago
								</option>
								<option
									value="America/New_York"
									selected={profile?.timezone === "America/New_York"}
								>
									America/New_York
								</option>
								<option value="Europe/Madrid" selected={profile?.timezone === "Europe/Madrid"}>
									Europe/Madrid
								</option>
							</Select>
						</FormField>
						<FormField label="Moneda por defecto" htmlFor="defaultCurrency" required>
							<Select id="defaultCurrency" name="defaultCurrency" required>
								<option value="USD" selected={(profile?.defaultCurrency ?? "USD") === "USD"}>
									USD
								</option>
								<option value="EUR" selected={profile?.defaultCurrency === "EUR"}>
									EUR
								</option>
								<option value="CLP" selected={profile?.defaultCurrency === "CLP"}>
									CLP
								</option>
							</Select>
						</FormField>
						<FormField
							label="Correo de soporte"
							htmlFor="supportEmail"
							description="Opcional si ya existe un correo de contacto configurado."
						>
							<Input
								id="supportEmail"
								type="email"
								name="supportEmail"
								value={profile?.supportEmail ?? ""}
							/>
						</FormField>
						<FormField label="Teléfono de soporte" htmlFor="supportPhone">
							<Input id="supportPhone" name="supportPhone" value={profile?.supportPhone ?? ""} />
						</FormField>
						<div class="space-y-1 pt-2">
							<h3 class="text-xl font-semibold text-slate-900">Gobernanza</h3>
							<p class="text-sm text-slate-600">
								Estos datos alimentan los controles de fiscalidad, pagos e integraciones.
							</p>
						</div>
						<FormField label="País de residencia fiscal" htmlFor="taxResidenceCountry">
							<Select id="taxResidenceCountry" name="taxResidenceCountry">
								<option value="">Sin definir</option>
								<option value="BO" selected={profile?.taxResidenceCountry === "BO"}>
									Bolivia
								</option>
								<option value="CL" selected={profile?.taxResidenceCountry === "CL"}>
									Chile
								</option>
								<option value="US" selected={profile?.taxResidenceCountry === "US"}>
									Estados Unidos
								</option>
								<option value="ES" selected={profile?.taxResidenceCountry === "ES"}>
									España
								</option>
							</Select>
						</FormField>
						<FormField label="Registro comercial o fiscal" htmlFor="businessRegistrationNumber">
							<Input
								id="businessRegistrationNumber"
								name="businessRegistrationNumber"
								value={profile?.businessRegistrationNumber ?? ""}
							/>
						</FormField>
						<FormField label="Estado fiscal" htmlFor="fiscalStatus">
							<Select id="fiscalStatus" name="fiscalStatus">
								<option
									value="not_configured"
									selected={(profile?.fiscalStatus ?? "not_configured") === "not_configured"}
								>
									No configurado
								</option>
								<option value="pending" selected={profile?.fiscalStatus === "pending"}>
									Pendiente
								</option>
								<option value="verified" selected={profile?.fiscalStatus === "verified"}>
									Verificado
								</option>
								<option
									value="requires_attention"
									selected={profile?.fiscalStatus === "requires_attention"}
								>
									Requiere atención
								</option>
							</Select>
						</FormField>
						<FormField label="Estado de pagos" htmlFor="paymentReadinessStatus">
							<Select id="paymentReadinessStatus" name="paymentReadinessStatus">
								<option
									value="not_configured"
									selected={
										(profile?.paymentReadinessStatus ?? "not_configured") === "not_configured"
									}
								>
									No configurado
								</option>
								<option value="pending" selected={profile?.paymentReadinessStatus === "pending"}>
									Pendiente
								</option>
								<option value="verified" selected={profile?.paymentReadinessStatus === "verified"}>
									Verificado
								</option>
								<option
									value="requires_attention"
									selected={profile?.paymentReadinessStatus === "requires_attention"}
								>
									Requiere atención
								</option>
							</Select>
						</FormField>
						<FormField label="Estado de integraciones" htmlFor="integrationReadinessStatus">
							<Select id="integrationReadinessStatus" name="integrationReadinessStatus">
								<option
									value="not_configured"
									selected={
										(profile?.integrationReadinessStatus ?? "not_configured") === "not_configured"
									}
								>
									No configurado
								</option>
								<option
									value="pending"
									selected={profile?.integrationReadinessStatus === "pending"}
								>
									Pendiente
								</option>
								<option value="ready" selected={profile?.integrationReadinessStatus === "ready"}>
									Listo
								</option>
								<option
									value="requires_attention"
									selected={profile?.integrationReadinessStatus === "requires_attention"}
								>
									Requiere atención
								</option>
							</Select>
						</FormField>
					</div>
					<div class="flex items-center justify-end gap-3">
						<Button href={routes.providerSettings()} variant="secondary">
							Volver
						</Button>
						<Button type="submit">Guardar perfil</Button>
					</div>
				</form>
			)
		}
	</Card>
</section>
