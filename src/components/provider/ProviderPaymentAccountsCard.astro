---
import ProviderPayoutVerificationTimeline from "@/components/provider/ProviderPayoutVerificationTimeline.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import type { ProviderPaymentAccountRecord } from "@/lib/provider-payment-accounts"
import {
	buildPayoutVerificationTimeline,
	providerPayoutMethods,
	providerPayoutSchedules,
} from "@/lib/provider-payment-accounts"

type Props = {
	accounts?: ProviderPaymentAccountRecord[]
	canManagePayments?: boolean
	defaultCurrency?: string
}

const { accounts = [], canManagePayments = false, defaultCurrency = "USD" } = Astro.props as Props

const pending = accounts.filter((row) => row.status === "pending")
const verified = accounts.filter((row) => row.status === "verified")

function badgeVariantForPhase(phaseLabel: string) {
	if (phaseLabel === "Lista") return "success" as const
	if (phaseLabel === "Requiere atención") return "error" as const
	if (phaseLabel === "Confirmar montos" || phaseLabel === "Esperando depósitos") {
		return "warning" as const
	}
	return "neutral" as const
}
---

<section class="space-y-6">
	<Card>
		<div class="space-y-5">
			<div class="flex flex-wrap items-start justify-between gap-3">
				<div>
					<p class="text-xs font-semibold tracking-[0.14em] text-slate-500 uppercase">
						Métodos de cobro
					</p>
					<h2 class="mt-2 text-xl font-semibold text-slate-950">Cuentas de payout</h2>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						Agrega la cuenta donde quieres recibir liquidaciones. El proceso es: enviada → esperando
						depósitos → confirmar montos → lista.
					</p>
				</div>
				<div class="flex flex-wrap gap-2">
					<Badge variant={verified.length ? "success" : "neutral"}>
						{verified.length} lista{verified.length === 1 ? "" : "s"}
					</Badge>
					<Badge variant={pending.length ? "warning" : "neutral"}>
						{pending.length} en proceso
					</Badge>
				</div>
			</div>

			<div class="space-y-3">
				{
					accounts.length ? (
						accounts.map((account) => {
							const timeline = buildPayoutVerificationTimeline(account)
							return (
								<Card variant="soft" class="space-y-3">
									<div class="flex flex-wrap items-start justify-between gap-3">
										<div>
											<p class="text-sm font-semibold text-slate-950">
												{account.bankName || "Banco"} · {account.accountReference || "••••"}
											</p>
											<p class="mt-1 text-sm text-slate-600">
												{account.accountHolderName || "Sin titular"} · {account.country || "—"} ·{" "}
												{account.currency} · {account.methodLabel}
											</p>
											<p class="mt-1 text-xs text-slate-500">
												Calendario: {account.payoutScheduleLabel}
												{account.routingOrSwift
													? ` · SWIFT/routing: ${account.routingOrSwift}`
													: ""}
											</p>
										</div>
										<Badge variant={badgeVariantForPhase(timeline.phaseLabel)}>
											{timeline.phaseLabel}
										</Badge>
									</div>

									{account.status !== "superseded" ? (
										<div class="border-t border-slate-200 pt-3">
											<ProviderPayoutVerificationTimeline timeline={timeline} />
										</div>
									) : (
										<p class="border-t border-slate-200 pt-3 text-sm leading-6 text-slate-600">
											Esta cuenta fue reemplazada por un envío más reciente.
										</p>
									)}

									{timeline.showConfirmForm ? (
										<div class="space-y-3 border-t border-slate-200 pt-3">
											{canManagePayments ? (
												<form
													method="post"
													action="/api/provider/settings/payment-accounts"
													class="grid gap-3 sm:grid-cols-3"
												>
													<input type="hidden" name="action" value="confirm_micro_deposit" />
													<input type="hidden" name="accountId" value={account.id} />
													<FormField
														label="Monto 1 (centavos)"
														htmlFor={`amount1-${account.id}`}
														required
													>
														<Input
															id={`amount1-${account.id}`}
															name="amount1Cents"
															type="number"
															min="1"
															max="99"
															required
														/>
													</FormField>
													<FormField
														label="Monto 2 (centavos)"
														htmlFor={`amount2-${account.id}`}
														required
													>
														<Input
															id={`amount2-${account.id}`}
															name="amount2Cents"
															type="number"
															min="1"
															max="99"
															required
														/>
													</FormField>
													<div class="flex items-end">
														<Button type="submit">Confirmar montos</Button>
													</div>
												</form>
											) : (
												<p class="text-sm text-slate-600">
													Tu rol no puede confirmar montos. Pide a un administrador del proveedor.
												</p>
											)}
										</div>
									) : null}
								</Card>
							)
						})
					) : (
						<Card variant="soft" class="text-sm text-slate-600">
							Aún no hay cuentas de payout. Agrega una cuenta bancaria para habilitar liquidaciones.
						</Card>
					)
				}
			</div>
		</div>
	</Card>

	<Card>
		{
			canManagePayments ? (
				<form method="post" action="/api/provider/settings/payment-accounts" class="space-y-4">
					<div>
						<p class="text-xs font-semibold tracking-[0.14em] text-slate-500 uppercase">
							Agregar cuenta
						</p>
						<h3 class="mt-2 text-lg font-semibold text-slate-950">Nueva cuenta bancaria</h3>
						<p class="mt-1 text-sm text-slate-600">
							Al guardar, la cuenta queda en <strong>Enviada</strong>. Después Fastt inicia los
							depósitos de prueba para que confirmes titularidad.
						</p>
					</div>

					<div class="grid gap-4 md:grid-cols-2">
						<FormField label="Titular de la cuenta" htmlFor="accountHolderName" required>
							<Input
								id="accountHolderName"
								name="accountHolderName"
								required
								placeholder="Hotel Sol S.R.L."
							/>
						</FormField>
						<FormField label="Nombre del banco" htmlFor="bankName" required>
							<Input id="bankName" name="bankName" required placeholder="Banco Nacional" />
						</FormField>
						<FormField
							label="País de la cuenta"
							htmlFor="country"
							description="Código de país (2 letras)."
							required
						>
							<Select id="country" name="country" required>
								<option value="">Selecciona</option>
								<option value="BO">Bolivia (BO)</option>
								<option value="CL">Chile (CL)</option>
								<option value="US">Estados Unidos (US)</option>
								<option value="ES">España (ES)</option>
								<option value="PE">Perú (PE)</option>
								<option value="AR">Argentina (AR)</option>
							</Select>
						</FormField>
						<FormField label="Moneda" htmlFor="currency" required>
							<Select id="currency" name="currency" required>
								<option value="USD" selected={defaultCurrency === "USD"}>
									USD
								</option>
								<option value="EUR" selected={defaultCurrency === "EUR"}>
									EUR
								</option>
								<option value="CLP" selected={defaultCurrency === "CLP"}>
									CLP
								</option>
								<option value="BOB" selected={defaultCurrency === "BOB"}>
									BOB
								</option>
							</Select>
						</FormField>
						<FormField label="Tipo de método" htmlFor="method" required>
							<Select id="method" name="method" required>
								{providerPayoutMethods.map((item) => (
									<option value={item.value}>{item.label}</option>
								))}
							</Select>
						</FormField>
						<FormField label="Calendario de payout" htmlFor="payoutSchedule" required>
							<Select id="payoutSchedule" name="payoutSchedule" required>
								{providerPayoutSchedules.map((item) => (
									<option value={item.value}>{item.label}</option>
								))}
							</Select>
						</FormField>
						<FormField
							label="Número de cuenta / IBAN"
							htmlFor="accountIdentifier"
							description="Se guarda para revisión; en tu vista solo verás los últimos 4 dígitos."
							required
						>
							<Input
								id="accountIdentifier"
								name="accountIdentifier"
								required
								autocomplete="off"
								placeholder="ES9121000418450200051332 / 1234567890"
							/>
						</FormField>
						<FormField
							label="Routing / SWIFT-BIC"
							htmlFor="routingOrSwift"
							description="Obligatorio para transferencias internacionales."
						>
							<Input id="routingOrSwift" name="routingOrSwift" placeholder="BSCHESMMXXX" />
						</FormField>
					</div>

					<FormField label="Notas de envío (opcional)" htmlFor="submissionNotes">
						<Input
							id="submissionNotes"
							name="submissionNotes"
							placeholder="Cuenta principal de liquidaciones"
						/>
					</FormField>

					<div class="flex justify-end">
						<Button type="submit">Enviar cuenta</Button>
					</div>
				</form>
			) : (
				<p class="text-sm text-slate-600">
					Tu rol actual no puede gestionar cuentas de payout del proveedor.
				</p>
			)
		}
	</Card>
</section>
