---
import TabsInsidePanel from "@/components/ui/TabsInsidePanel.astro"
import { routes } from "@/lib/routes"

type FiscalDomain = "hub" | "identity" | "sales"

type Props = {
	active?: FiscalDomain
}

const { active = "hub" } = Astro.props as Props

const items = [
	{
		id: "hub" as const,
		label: "Resumen fiscal",
		href: routes.providerSettingsTaxFees(),
	},
	{
		id: "identity" as const,
		label: "Tu registro fiscal",
		href: routes.providerSettingsTaxIdentity(),
	},
	{
		id: "sales" as const,
		label: "Impuestos al huésped",
		href: routes.providerSettingsTaxSales(),
	},
]
---

<TabsInsidePanel
	class="provider-fiscal-domain-tabs max-w-full flex-nowrap bg-slate-950"
	aria-label="Dominios de fiscalidad"
>
	{
		items.map((item) => {
			const isActive = item.id === active
			return (
				<a
					href={item.href}
					data-astro-prefetch="viewport"
					data-active={isActive ? "true" : "false"}
					aria-current={isActive ? "page" : undefined}
					class={`fastt-tabs-inside-panel__item inline-flex min-w-max shrink-0 items-center px-4 py-2 text-sm font-semibold whitespace-nowrap ${
						isActive ? "" : "bg-slate-950 text-slate-300 hover:bg-slate-800 hover:text-white"
					}`}
				>
					{item.label}
				</a>
			)
		})
	}
</TabsInsidePanel>

<style>
	.provider-fiscal-domain-tabs {
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
	}

	.provider-fiscal-domain-tabs::-webkit-scrollbar {
		display: none;
	}
</style>
