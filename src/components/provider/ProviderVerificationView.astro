---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import { routes } from "@/lib/routes"

const { latestVerification, showHeader = true } = Astro.props
const status = String(latestVerification?.status ?? "pending")
const isApproved = status === "approved"
const statusLabel =
	status === "approved" ? "Aprobado" : status === "rejected" ? "Requiere cambios" : "Pendiente"
const reviewedLabel = latestVerification?.createdAt
	? new Date(latestVerification.createdAt).toLocaleString("es-BO", {
			day: "2-digit",
			month: "short",
			year: "numeric",
			hour: "2-digit",
			minute: "2-digit",
		})
	: "Sin registro de revisión"
const checks = [
	{
		title: "Identidad comercial",
		description: "Nombre comercial y razón social del proveedor.",
		complete: Boolean(isApproved),
	},
	{
		title: "Revisión interna",
		description: "Validación manual para habilitar operación con confianza.",
		complete: Boolean(isApproved),
	},
	{
		title: "Documentos y respaldo",
		description: "Preparado para incorporar documentos legales y fiscales.",
		complete: false,
		planned: true,
	},
]
---

<section class="space-y-4">
	{
		showHeader && (
			<header class="space-y-1">
				<p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">
					Configuración del proveedor
				</p>
				<h2 class="text-lg font-semibold text-slate-100">Verificación y cumplimiento</h2>
				<p class="text-sm text-slate-300">
					Controla si el proveedor puede operar, cobrar y conectar servicios sensibles.
				</p>
			</header>
		)
	}
	<div class="grid gap-4 xl:grid-cols-[0.9fr_1.1fr]">
		<Card>
			<div class="space-y-6">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div class="space-y-2">
						<p class="text-sm font-medium text-slate-500">Estado actual</p>
						<h3 class="text-2xl font-semibold text-slate-950">{statusLabel}</h3>
						<p class="text-sm leading-6 text-slate-600">
							{
								isApproved
									? "La cuenta está aprobada para operar con los controles actuales."
									: "La cuenta todavía necesita revisión antes de considerarse completamente confiable."
							}
						</p>
					</div>
					<Badge variant={isApproved ? "success" : status === "rejected" ? "error" : "warning"}>
						{statusLabel}
					</Badge>
				</div>

				<div class="grid gap-4 md:grid-cols-2">
					<Card variant="soft">
						<p class="text-sm font-medium text-slate-700">Última actualización</p>
						<p class="mt-1 text-sm text-slate-950">{reviewedLabel}</p>
					</Card>
					<Card variant="soft">
						<p class="text-sm font-medium text-slate-700">Dependencias</p>
						<p class="mt-1 text-sm text-slate-950">Publicación, cobros e integraciones sensibles</p>
					</Card>
				</div>

				<Card variant="plain">
					<p class="text-sm font-medium text-slate-700">Motivo o nota de revisión</p>
					<p class="mt-1 text-sm leading-6 text-slate-600">
						{latestVerification?.reason || "No hay observaciones registradas por revisión interna."}
					</p>
				</Card>

				<div class="flex justify-end">
					<Button href={routes.providerSettings()} variant="secondary">Volver al resumen</Button>
				</div>
			</div>
		</Card>

		<Card>
			<div class="space-y-5">
				<div>
					<h3 class="text-xl font-semibold text-slate-950">Matriz de revisión</h3>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						La verificación debe evolucionar por dimensiones, no como un único texto de estado.
					</p>
				</div>
				<div class="space-y-3">
					{
						checks.map((check) => (
							<Card variant="soft" class="flex items-start justify-between gap-4">
								<div>
									<p class="text-sm font-semibold text-slate-950">{check.title}</p>
									<p class="mt-1 text-sm leading-6 text-slate-600">{check.description}</p>
								</div>
								<Badge variant={check.complete ? "success" : check.planned ? "neutral" : "warning"}>
									{check.complete ? "Completo" : check.planned ? "Planificado" : "Pendiente"}
								</Badge>
							</Card>
						))
					}
				</div>
			</div>
		</Card>
	</div>
</section>
