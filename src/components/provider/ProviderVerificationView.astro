---
import ProviderReviewWaitNotice from "@/components/provider/ProviderReviewWaitNotice.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import type { ProviderDocumentRecord } from "@/lib/provider-documents"
import {
	evaluateRequiredKycDocumentsComplete,
	providerDocumentTypes,
} from "@/lib/provider-documents"
import { resolveProviderRejectCategory } from "@/lib/provider-reject-categories"
import { routes } from "@/lib/routes"

type Props = {
	latestVerification?: {
		status?: string | null
		reason?: string | null
		createdAt?: Date | string | null
	} | null
	documents?: ProviderDocumentRecord[]
	showHeader?: boolean
	reviewAssignment?: {
		slaDueAt: Date | string | null
		slaState: "ok" | "due_soon" | "overdue" | "done"
	} | null
}

const {
	latestVerification,
	documents = [],
	showHeader = true,
	reviewAssignment = null,
} = Astro.props as Props
const status = String(latestVerification?.status ?? "pending")
const isApproved = status === "approved"
const isPending = !isApproved && status !== "rejected"
const statusLabel =
	status === "approved" ? "Aprobado" : status === "rejected" ? "Requiere cambios" : "Pendiente"
const reviewedLabel = latestVerification?.createdAt
	? new Date(latestVerification.createdAt).toLocaleString("es-BO", {
			day: "2-digit",
			month: "short",
			year: "numeric",
			hour: "2-digit",
			minute: "2-digit",
		})
	: "Sin registro de revisión"

const rejectCategory =
	status === "rejected"
		? resolveProviderRejectCategory(latestVerification?.reason, "verification")
		: null

const verifiedDocuments = documents.filter((doc) => doc.status === "verified")
const pendingDocuments = documents.filter((doc) => doc.status === "pending")
const kyc = evaluateRequiredKycDocumentsComplete(documents)
const documentsComplete = kyc.complete

const checks = [
	{
		title: "Identidad comercial",
		description: "Nombre comercial y razón social del proveedor (revisión global).",
		complete: Boolean(isApproved),
	},
	{
		title: "Revisión interna",
		description: "Validación manual para habilitar operación con confianza.",
		complete: Boolean(isApproved),
	},
	{
		title: "Documentos mínimos",
		description: kyc.complete
			? "Identidad, registro mercantil y documento fiscal verificados."
			: `Faltan: ${
					kyc.missingRequiredTypes
						.map((type) => providerDocumentTypes.find((item) => item.value === type)?.label ?? type)
						.join(", ") || "identidad, registro mercantil y documento fiscal"
				}.`,
		complete: documentsComplete,
		pending: !documentsComplete && pendingDocuments.length > 0,
	},
]
---

<section class="space-y-4">
	{
		showHeader && (
			<header class="space-y-1">
				<p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">
					Configuración del proveedor
				</p>
				<h2 class="text-lg font-semibold text-slate-100">Verificación y cumplimiento</h2>
				<p class="text-sm text-slate-300">
					Controla si el proveedor puede operar, cobrar y conectar servicios sensibles.
				</p>
			</header>
		)
	}
	<div class="grid gap-4 xl:grid-cols-[0.9fr_1.1fr]">
		<Card>
			<div class="space-y-6">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div class="space-y-2">
						<p class="text-sm font-medium text-slate-500">Estado actual</p>
						<h3 class="text-2xl font-semibold text-slate-950">{statusLabel}</h3>
						<p class="text-sm leading-6 text-slate-600">
							{
								isApproved
									? "La cuenta está aprobada para operar con los controles actuales."
									: "La cuenta todavía necesita revisión antes de considerarse completamente confiable."
							}
						</p>
					</div>
					<Badge variant={isApproved ? "success" : status === "rejected" ? "error" : "warning"}>
						{statusLabel}
					</Badge>
				</div>

				<div class="grid gap-4 md:grid-cols-2">
					<Card variant="soft">
						<p class="text-sm font-medium text-slate-700">Última actualización</p>
						<p class="mt-1 text-sm text-slate-950">{reviewedLabel}</p>
					</Card>
					<Card variant="soft">
						<p class="text-sm font-medium text-slate-700">Documentos</p>
						<p class="mt-1 text-sm text-slate-950">
							{verifiedDocuments.length} verificados · {pendingDocuments.length} pendientes
						</p>
					</Card>
				</div>

				<Card variant="plain">
					<p class="text-sm font-medium text-slate-700">Motivo o nota de revisión</p>
					{
						rejectCategory?.matched ? (
							<Badge variant="error" class="mt-2" data-reject-category>
								{rejectCategory.label}
							</Badge>
						) : null
					}
					<p class="mt-1 text-sm leading-6 text-slate-600">
						{latestVerification?.reason || "No hay observaciones registradas por revisión interna."}
					</p>
				</Card>

				{
					isPending ? (
						<ProviderReviewWaitNotice domain="verification" assignment={reviewAssignment} />
					) : null
				}

				<div class="flex justify-end">
					<Button href={routes.providerSettings()} variant="secondary">Volver al resumen</Button>
				</div>
			</div>
		</Card>

		<Card>
			<div class="space-y-5">
				<div>
					<h3 class="text-xl font-semibold text-slate-950">Matriz de revisión</h3>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						La verificación avanza por dimensiones independientes: la aprobación de la cuenta no
						completa sola el checklist de documentos.
					</p>
				</div>
				<div class="space-y-3">
					{
						checks.map((check) => (
							<Card variant="soft" class="flex items-start justify-between gap-4">
								<div>
									<p class="text-sm font-semibold text-slate-950">{check.title}</p>
									<p class="mt-1 text-sm leading-6 text-slate-600">{check.description}</p>
								</div>
								<Badge variant={check.complete ? "success" : check.pending ? "warning" : "neutral"}>
									{check.complete ? "Completo" : check.pending ? "En revisión" : "Pendiente"}
								</Badge>
							</Card>
						))
					}
				</div>
			</div>
		</Card>
	</div>
</section>
