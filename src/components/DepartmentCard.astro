---
interface Props {
	id: string
	name: string
	description: string
	imageUrl?: string
	producType?: string
}

const { id, name, description, imageUrl, producType } = Astro.props
---

<figure
	class="fastt-row-card overflow-hidden rounded-[var(--fastt-radius-card)] bg-white shadow-sm"
>
	<img
		src={imageUrl ?? `https://picsum.photos/290/183?random=${id}`}
		alt={name}
		width="290"
		height="183"
		class="h-48 w-full object-cover"
	/>
	<figcaption class="p-4">
		<h2 class="mb-2 text-xl font-semibold text-gray-900">
			<a href={`/${producType}/depts/${id}`} class="transition hover:text-slate-950">{name}</a>
		</h2>
		<p class="desc mb-4 line-clamp-3 text-sm text-gray-700">{description}</p>
		<ul class="flex justify-end">
			<li>
				<a
					href={`/${producType}/depts/${id}`}
					class="fastt-button inline-flex h-9 items-center justify-center rounded-[var(--fastt-radius-pill)] bg-slate-950 px-4 text-sm font-semibold text-white transition hover:bg-slate-800"
					>Ver {producType}</a
				>
			</li>
		</ul>
	</figcaption>
</figure>
