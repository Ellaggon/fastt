---
import PolicyAssignmentFlow from "@/components/policy/PolicyAssignmentFlow.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import { POLICY_CATEGORY_ORDER } from "@/modules/policies/public"

interface PolicyPlanView {
	ratePlanId: string
	ratePlanName: string
	isDefault: boolean
	isActive: boolean
	priceLabel: string
	coverageCount: number
	missingCategories: string[]
	isSellableByContract: boolean
	sellabilityLabel: string
	sellabilityBlockers: string[]
	policySummary: string
	policyPreviewByCategory: Record<string, string>
	inheritanceByCategory: Record<string, string>
	overrideSummaryByCategory: Record<string, string>
	snapshotPreviewByCategory: Record<string, string>
	snapshotVersionIds: string[]
	snapshotResolvedAt: string
}

interface WizardPlanView {
	ratePlanId: string
	ratePlanName: string
	variantName: string
	policyIdByCategory: Record<string, string | null>
	policySummary: string
	missingCategories: string[]
}

interface Props {
	title?: string
	description: string
	policyPlans: PolicyPlanView[]
	wizardPlans?: WizardPlanView[]
	checkIn: string
	checkOut: string
	requiredCategories: readonly string[]
}

const { title = "Condiciones de reserva", description, policyPlans } = Astro.props

const orderedCategories = ["Cancellation", "Payment", "NoShow", "CheckIn"] as const
---

<Section title={title} description={description}>
	<div class="space-y-4">
		{
			policyPlans.map((plan) => (
				<Card className="space-y-4 bg-white" data-plan-id={plan.ratePlanId}>
					<div class="space-y-3">
						<div class="flex flex-wrap items-start justify-between gap-3">
							<div class="space-y-1">
								<p class="text-base font-semibold text-slate-900">{plan.ratePlanName}</p>
								<div class="flex flex-wrap items-center gap-2">
									<Badge variant={plan.isActive ? "success" : "neutral"}>
										{plan.isActive ? "Activo" : "Inactivo"}
									</Badge>
									{plan.isDefault && <Badge variant="info">Por defecto</Badge>}
								</div>
							</div>
							<div
								class:list={[
									"rounded-full border px-3 py-1 text-sm font-semibold",
									plan.isSellableByContract
										? "border-emerald-200 bg-emerald-50 text-emerald-800"
										: "border-rose-200 bg-rose-50 text-rose-800",
								]}
								data-role="status-badge"
								data-contract-sellability={plan.isSellableByContract ? "ready" : "blocked"}
							>
								{plan.sellabilityLabel}
							</div>
						</div>
						<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
							<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">Precio</p>
							<p class="mt-1 text-sm text-slate-700">{plan.priceLabel}</p>
						</div>
					</div>
					<div
						class:list={[
							"rounded-lg border p-3",
							plan.isSellableByContract
								? "border-emerald-200 bg-emerald-50"
								: "border-rose-200 bg-rose-50",
						]}
						data-role="contract-readiness"
					>
						<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
							Bloqueo contractual
						</p>
						<p
							class:list={[
								"mt-1 text-sm font-semibold",
								plan.isSellableByContract ? "text-emerald-900" : "text-rose-900",
							]}
							data-role="sellability-lock"
						>
							{plan.isSellableByContract
								? "Lista para vender: cobertura contractual completa."
								: "No lista para vender: venta bloqueada hasta completar contrato."}
						</p>
						{plan.sellabilityBlockers.length > 0 ? (
							<div class="mt-2 text-sm text-rose-800">
								<p class="font-medium">Bloqueadores:</p>
								<ul class="mt-1 list-disc space-y-1 pl-5">
									{plan.sellabilityBlockers.map((blocker) => (
										<li>{blocker}</li>
									))}
								</ul>
							</div>
						) : (
							<p class="mt-2 text-sm text-emerald-800">
								El contrato puede pasar a búsqueda/reserva con snapshot resoluble.
							</p>
						)}
					</div>
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
						<div class="mb-2 flex flex-wrap items-center justify-between gap-2">
							<p class="text-sm font-semibold text-slate-900">Contrato aplicable</p>
							<p class="rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs font-semibold text-slate-600">
								Cobertura {plan.coverageCount}/4
							</p>
						</div>
						<p class="mb-2 text-sm text-slate-600" data-role="policy-summary">
							{plan.policySummary}
						</p>
						<div class="grid gap-3" data-role="contract-matrix">
							{orderedCategories.map((category) => (
								<div class="rounded-lg border border-slate-200 bg-white p-3">
									<div class="flex flex-wrap items-center justify-between gap-2">
										<p class="text-sm font-semibold text-slate-950">
											{POLICY_CATEGORY_ORDER[category] ?? category}
										</p>
										<span
											class:list={[
												"rounded-full border px-2.5 py-1 text-xs font-semibold",
												plan.missingCategories.includes(category)
													? "border-amber-200 bg-amber-50 text-amber-800"
													: "border-emerald-200 bg-emerald-50 text-emerald-800",
											]}
										>
											{plan.missingCategories.includes(category) ? "Falta" : "Aplicable"}
										</span>
									</div>
									<div class="mt-3 grid gap-2 text-sm text-slate-700 md:grid-cols-2">
										<p>
											<strong>Condición:</strong> {plan.policyPreviewByCategory[category]}
										</p>
										<p>
											<strong>Herencia:</strong> {plan.inheritanceByCategory[category]}
										</p>
										<p>
											<strong>Override:</strong> {plan.overrideSummaryByCategory[category]}
										</p>
										<p>
											<strong>Snapshot:</strong> {plan.snapshotPreviewByCategory[category]}
										</p>
									</div>
								</div>
							))}
						</div>
					</div>
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
						<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
							Snapshot preview
						</p>
						<p class="mt-1 text-sm text-slate-700">
							Fuente/versiones:{" "}
							{plan.snapshotVersionIds.length
								? plan.snapshotVersionIds.join(" · ")
								: "sin versiones"}
						</p>
						<p class="mt-1 text-xs text-slate-500">Resolución: {plan.snapshotResolvedAt}</p>
					</div>
					<div class="grid gap-2 sm:grid-cols-2">
						<Button
							type="button"
							variant="primary"
							size="sm"
							class="policy-assignment-open w-full justify-center"
							data-assignment-mode="existing"
							data-assignment-scope="rate_plan"
							data-assignment-scope-id={plan.ratePlanId}
						>
							Usar condición existente
						</Button>
						<Button
							type="button"
							variant="secondary"
							size="sm"
							class="policy-assignment-open w-full justify-center"
							data-assignment-mode="preset"
							data-assignment-scope="rate_plan"
							data-assignment-scope-id={plan.ratePlanId}
							data-assignment-category={plan.missingCategories[0] ?? "Cancellation"}
						>
							Crear desde plantilla
						</Button>
					</div>
				</Card>
			))
		}
	</div>
</Section>

<PolicyAssignmentFlow defaultScope="rate_plan" />
