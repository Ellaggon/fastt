---
import PolicyAssignmentFlow from "@/components/policy/PolicyAssignmentFlow.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import { ArrowRight, Check, TriangleAlert } from "@lucide/astro"

interface PolicyPlanView {
	ratePlanId: string
	ratePlanName: string
	isDefault: boolean
	isActive: boolean
	priceLabel: string
	coverageCount: number
	missingCategories: string[]
	isSellableByContract: boolean
	sellabilityLabel: string
	sellabilityBlockers: string[]
	policySummary: string
	policyIdByCategory: Record<string, string | null>
	policyPreviewByCategory: Record<string, string>
	inheritanceByCategory: Record<string, string>
	overrideSummaryByCategory: Record<string, string>
	snapshotPreviewByCategory: Record<string, string>
	snapshotVersionIds: string[]
	snapshotResolvedAt: string
}

interface WizardPlanView {
	ratePlanId: string
	ratePlanName: string
	variantName: string
	policyIdByCategory: Record<string, string | null>
	policySummary: string
	missingCategories: string[]
}

interface Props {
	title?: string
	description: string
	policyPlans: PolicyPlanView[]
	wizardPlans?: WizardPlanView[]
	checkIn: string
	checkOut: string
	requiredCategories: readonly string[]
	productId?: string
	isProfessionalMode?: boolean
}

const {
	title = "Condiciones de la tarifa",
	description,
	policyPlans,
	isProfessionalMode = false,
} = Astro.props

const categoryConfig = {
	Cancellation: {
		label: "Cancelación",
		helper: "Define hasta cuándo puede cancelar el huésped y cuánto se reembolsa.",
	},
	Payment: {
		label: "Pago y depósito",
		helper: "Indica cuándo paga el huésped y qué importe debe anticipar.",
	},
	NoShow: {
		label: "No presentación",
		helper: "Define el cargo cuando el huésped no llega y no cancela.",
	},
	CheckIn: {
		label: "Llegada y salida",
		helper: "Define horarios contractuales de llegada y salida para esta tarifa.",
	},
} as const

const orderedCategories = ["Cancellation", "Payment", "NoShow", "CheckIn"] as const
---

<section class="space-y-5" aria-labelledby="rate-plan-contract-title">
	<header class="flex flex-wrap items-end justify-between gap-4">
		<div class="space-y-1.5">
			<p class="text-xs font-semibold tracking-wide text-slate-400 uppercase">Condiciones base</p>
			<h2 id="rate-plan-contract-title" class="text-2xl font-semibold text-white">{title}</h2>
			<p class="max-w-3xl text-sm leading-6 text-slate-400">{description}</p>
		</div>
	</header>

	{
		policyPlans.map((plan) => (
			<article class="fastt-row-card overflow-hidden text-slate-900" data-plan-id={plan.ratePlanId}>
				<div class="flex flex-wrap items-start justify-between gap-4 border-b border-slate-100 px-5 py-4">
					<div class="space-y-1">
						<div class="flex flex-wrap items-center gap-2">
							<h3 class="text-lg font-semibold text-slate-950">{plan.ratePlanName}</h3>
							{plan.isDefault && <Badge variant="info">Principal</Badge>}
						</div>
						<p class="text-sm text-slate-500">{plan.policySummary}</p>
					</div>
					<Badge
						variant={plan.isSellableByContract ? "success" : "warning"}
						class="gap-2 px-3 py-1.5 text-sm"
						data-role="status-badge"
						data-contract-sellability={plan.isSellableByContract ? "ready" : "blocked"}
					>
						{plan.isSellableByContract ? (
							<Check class="h-4 w-4" />
						) : (
							<TriangleAlert class="h-4 w-4" />
						)}
						{plan.isSellableByContract
							? "Condiciones completas"
							: `${plan.coverageCount}/4 completas`}
					</Badge>
				</div>

				<div class="divide-y divide-slate-100" data-role="contract-matrix">
					{orderedCategories.map((category) => {
						const config = categoryConfig[category]
						const missing = plan.missingCategories.includes(category)
						const inherited = plan.inheritanceByCategory[category]
						return (
							<section class="grid gap-4 px-5 py-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
								<div class="min-w-0">
									<div class="flex flex-wrap items-center gap-2">
										<p class="font-semibold text-slate-950">{config.label}</p>
										<Badge
											variant={missing ? "warning" : "success"}
											class="px-2 py-0.5 text-[11px]"
										>
											{missing
												? "Falta completar"
												: inherited === "Tarifa"
													? "Propia"
													: `Heredada de ${inherited.toLowerCase()}`}
										</Badge>
									</div>
									<p class="mt-1 text-sm leading-5 text-slate-500">{config.helper}</p>
									<p class:list={["mt-2 text-sm", missing ? "text-amber-800" : "text-slate-800"]}>
										{missing
											? "Todavía no hay una condición aplicable."
											: plan.policyPreviewByCategory[category]}
									</p>
								</div>

								<div class="flex flex-wrap gap-2 md:justify-end">
									{missing ? (
										<Button
											type="button"
											variant="primary"
											size="sm"
											class="policy-assignment-open"
											data-assignment-mode="preset"
											data-assignment-scope="rate_plan"
											data-assignment-scope-id={plan.ratePlanId}
											data-assignment-category={category}
										>
											Elegir plantilla
											<ArrowRight class="h-4 w-4" />
										</Button>
									) : (
										<>
											<Button
												type="button"
												variant="secondary"
												size="sm"
												class="policy-assignment-open"
												data-assignment-mode="preset"
												data-assignment-scope="rate_plan"
												data-assignment-scope-id={plan.ratePlanId}
												data-assignment-category={category}
											>
												Cambiar
											</Button>
										</>
									)}
								</div>
							</section>
						)
					})}
				</div>

				<details class="border-t border-slate-100 bg-slate-50/70 px-5 py-4 text-sm">
					<summary class="cursor-pointer font-semibold text-slate-700">
						Detalle técnico y versiones
					</summary>
					<div class="mt-3 grid gap-3 text-slate-600 md:grid-cols-2" data-role="contract-readiness">
						<p>
							<strong>Condiciones aplicables:</strong> {plan.coverageCount}/4 categorías.
						</p>
						<p>
							<strong>Snapshot preview:</strong> {plan.snapshotResolvedAt}
						</p>
						<p>
							<strong>Versiones:</strong> {plan.snapshotVersionIds.join(" · ") || "Sin versiones"}
						</p>
						<p data-role="sellability-lock">
							<strong>Estado:</strong> {plan.sellabilityLabel}
						</p>
					</div>
					{isProfessionalMode && (
						<div class="mt-3 flex flex-wrap gap-2">
							<Button
								type="button"
								variant="secondary"
								size="sm"
								class="policy-assignment-open"
								data-assignment-mode="existing"
								data-assignment-scope="rate_plan"
								data-assignment-scope-id={plan.ratePlanId}
							>
								Usar condición existente
							</Button>
							<span class="sr-only">Crear desde plantilla</span>
						</div>
					)}
				</details>
			</article>
		))
	}
</section>

<PolicyAssignmentFlow defaultScope="rate_plan" isProfessionalMode={isProfessionalMode} />
