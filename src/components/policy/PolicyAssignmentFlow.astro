	function renderExistingCardsState() {
		if (!existingCards || !policySelect) return
		for (const card of existingCards.querySelectorAll(".policy-existing-card")) {
			const selected = String(card.dataset.policyId || "") === String(policySelect.value || "")
			card.setAttribute("aria-pressed", selected ? "true" : "false")
			card.classList.toggle("border-slate-950", selected)
			card.classList.toggle("bg-slate-50", selected)
			card.querySelector(".policy-existing-check")?.classList.toggle("hidden", !selected)
		}
	}

	function renderCustomFieldsState(category = categorySelect?.value) {
		for (const panel of customCategoryPanels) {
			panel.classList.toggle(
				"hidden",
				String(panel.dataset.assignmentCustomCategory || "") !== String(category || "")
			)
		}
		const paymentIsPrepayment = paymentTypeInput?.value === "prepayment"
		prepaymentPercentageInput
			?.closest("label")
			?.classList.toggle("opacity-50", !paymentIsPrepayment)
		prepaymentDaysInput?.closest("label")?.classList.toggle("opacity-50", !paymentIsPrepayment)
		const noShowIsPercentage = noShowPenaltyTypeInput?.value === "percentage"
		noShowPenaltyAmountInput?.closest("label")?.classList.toggle("opacity-50", !noShowIsPercentage)
	}

	function renderCustomHelp(category = categorySelect?.value) {
		if (!customHelp) return
		customHelp.innerHTML = ""
	}

	function renderScopeOptions(preferredId = "") {
		if (!scopeSelect || !scopeIdSelect) return
		const scope = scopeSelect.value
		const items = assignmentState.options.scopes?.[scope] || []
		scopeIdSelect.innerHTML = items.length
			? items
					.map(
						(item) =>
							`<option value="${assignmentEscape(item.id)}">${assignmentEscape(item.label)}${item.helper ? ` · ${assignmentEscape(item.helper)}` : ""}</option>`
					)
					.join("")
			: '<option value="">Sin destinos disponibles</option>'
		if (preferredId && items.some((item) => String(item.id) === String(preferredId))) {
			scopeIdSelect.value = preferredId
		}
	}

	function currentSelection() {
		const mode = selectedMode()
		const policy = (assignmentState.options.policies || []).find(
			(item) => String(item.id) === String(policySelect?.value || "")
		)
		const preset = (assignmentState.options.presets || []).find(
			(item) => String(item.key) === String(presetSelect?.value || "")
		)
		const scope = scopeSelect?.value || "rate_plan"
		const scopeId = scopeIdSelect?.value || ""
		const scopeOption = (assignmentState.options.scopes?.[scope] || []).find(
			(item) => String(item.id) === String(scopeId)
		)
		const category =
			mode === "existing"
				? policy?.category || categorySelect?.value
				: mode === "draft"
					? categorySelect?.value
					: categorySelect?.value
		return { mode, policy, preset, scope, scopeId, scopeOption, category }
	}

	function previewPayload(selected = currentSelection()) {
		if (selected.mode === "existing") {
			return {
				mode: "existing",
				policyId: selected.policy?.id || "",
				scope: selected.scope,
				scopeId: selected.scopeId,
				channel: channelSelect?.value || null,
			}
		}
		if (selected.mode === "draft") {
			return {
				mode: "draft",
				category: selected.category,
				description: draftDescription(selected.category),
				rules: draftRules(selected.category),
				cancellationTiers: draftCancellationTiers(),
				scope: selected.scope,
				scopeId: selected.scopeId,
				channel: channelSelect?.value || null,
			}
		}
		return {
			mode: "preset",
			category: categorySelect?.value,
			policyPresetKey: selected.preset?.key || "",
			scope: selected.scope,
			scopeId: selected.scopeId,
			channel: channelSelect?.value || null,
		}
	}

	function numberValue(input, fallback) {
		const parsed = Number(input?.value ?? fallback)
		return Number.isFinite(parsed) ? parsed : fallback
	}

	function draftCancellationTiers() {
		const freeDays = Math.max(0, Math.round(numberValue(cancellationFreeDaysInput, 1)))
		const penalty = Math.max(0, Math.min(100, numberValue(cancellationPenaltyInput, 100)))
		const tiers = [{ daysBeforeArrival: freeDays, penaltyType: "percentage", penaltyAmount: 0 }]
		if (freeDays === 0)
			return [{ daysBeforeArrival: 0, penaltyType: "percentage", penaltyAmount: penalty }]
		tiers.push({ daysBeforeArrival: 0, penaltyType: "percentage", penaltyAmount: penalty })
		return tiers
	}

	function draftRules(category = categorySelect?.value) {
		if (category === "Payment") {
			const paymentType = paymentTypeInput?.value || "pay_at_property"
			const rules = { paymentType }
			if (paymentType === "prepayment") {
				rules.prepaymentPercentage = Math.max(
					1,
					Math.min(100, numberValue(prepaymentPercentageInput, 50))
				)
				rules.prepaymentDaysBeforeArrival = Math.max(
					0,
					Math.round(numberValue(prepaymentDaysInput, 0))
				)
			}
			return rules
		}
		if (category === "CheckIn") {
			return {
				checkInFrom: checkInFromInput?.value || "15:00",
				checkInUntil: checkInUntilInput?.value || "22:00",
				checkOutUntil: checkOutUntilInput?.value || "11:00",
			}
		}
		if (category === "NoShow") {
			const penaltyType = noShowPenaltyTypeInput?.value || "first_night"
			const rules = { penaltyType }
			if (penaltyType === "percentage") {
				rules.penaltyAmount = Math.max(0, Math.min(100, numberValue(noShowPenaltyAmountInput, 100)))
			}
			return rules
		}
		return {}
	}

	function draftDescription(category = categorySelect?.value) {
		if (category === "Cancellation") {
			const freeDays = Math.max(0, Math.round(numberValue(cancellationFreeDaysInput, 1)))
			const penalty = Math.max(0, Math.min(100, numberValue(cancellationPenaltyInput, 100)))
			return `Cancelación gratis hasta ${freeDays} día(s) antes · penalidad ${penalty}%`
		}
		if (category === "Payment") {
			if ((paymentTypeInput?.value || "pay_at_property") === "prepayment") {
				return `Prepago ${numberValue(prepaymentPercentageInput, 50)}%`
			}
			return "Pago al llegar"
		}
		if (category === "CheckIn") {
			const rules = draftRules("CheckIn")
			return `Llegada ${rules.checkInFrom}–${rules.checkInUntil} · salida hasta ${rules.checkOutUntil}`
		}
		if (category === "NoShow") {
			const type = noShowPenaltyTypeInput?.value || "first_night"
			if (type === "full") return "No presentación: estadía completa"
			if (type === "percentage")
				return `No presentación: ${numberValue(noShowPenaltyAmountInput, 100)}%`
			return "No presentación: primera noche"
		}
		return "Condición personalizada"
	}

	async function renderBackendPreview() {
		if (!guestPreviewBox) return false
		const selected = currentSelection()
		const pendingCopy = previewCopy(selected.category)
		if (previewTitle) {
			previewTitle.textContent = isProfessionalMode
				? pendingCopy.title
				: modalCopy(selected.category).previewLabel
		}
		if (previewDescription) previewDescription.textContent = pendingCopy.description
		if (previewDescription && !isProfessionalMode) {
			previewDescription.textContent =
				modalCopy(selected.category).previewDescription || "Resumen visible antes de reservar."
		}
		assignmentState.previewReady = false
		if (!selected.scopeId) {
			guestPreviewBox.innerHTML =
				'<div class="fastt-soft-box border border-slate-200 bg-white/80 p-2">Selecciona un destino para calcular el preview real.</div>'
			return false
		}
		if (selected.mode === "existing" && !selected.policy?.id) {
			guestPreviewBox.innerHTML =
				'<div class="fastt-soft-box border border-slate-200 bg-white/80 p-2">Selecciona una condición publicada para calcular el preview real.</div>'
			return false
		}
		if (selected.mode === "preset" && !selected.preset?.key) {
			guestPreviewBox.innerHTML =
				'<div class="fastt-soft-box border border-slate-200 bg-white/80 p-2">Selecciona una plantilla para calcular el preview real.</div>'
			return false
		}
		if (selected.mode === "draft") {
			const rules = draftRules(selected.category)
			if (
				(selected.category === "CheckIn" &&
					(!rules.checkInFrom || !rules.checkInUntil || !rules.checkOutUntil)) ||
				(selected.category === "Payment" && !rules.paymentType) ||
				(selected.category === "NoShow" && !rules.penaltyType) ||
				(selected.category === "Cancellation" && !draftCancellationTiers().length)
			) {
				guestPreviewBox.innerHTML =
					'<div class="fastt-soft-box border border-slate-200 bg-white/80 p-2">Completa los datos para calcular el preview.</div>'
				return false
			}
		}

		const seq = ++previewRequestSeq
		guestPreviewBox.innerHTML =
			'<div class="rounded-lg border border-slate-200 bg-white px-3 py-3 text-slate-600">Calculando consecuencias...</div>'
		try {
			const response = await fetch("/api/policies/preview", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(previewPayload(selected)),
			})
			const payload = await response.json().catch(() => null)
			if (seq !== previewRequestSeq) return false
			if (!response.ok || !payload?.success) {
				guestPreviewBox.innerHTML = `
					<div class="rounded-md border border-rose-200 bg-rose-50 p-2 text-rose-800">
						No se pudo calcular el preview real: ${assignmentEscape(payload?.error || "error")}
					</div>
				`
				return false
			}
			const items = Array.isArray(payload.preview) ? payload.preview : []
			if (previewTitle) {
				previewTitle.textContent = isProfessionalMode
					? payload?.presentation?.title || `Vista previa de ${categoryLabel(selected.category)}`
					: modalCopy(selected.category).previewLabel
			}
			if (previewDescription) {
				previewDescription.textContent = !isProfessionalMode
					? modalCopy(selected.category).previewDescription || "Resumen visible antes de reservar."
					: payload?.presentation?.description ||
						"Consecuencias visibles antes de confirmar la asignación."
			}
			const previewItemsHtml = items.length
				? `
					<div class="fastt-policy-preview-list overflow-hidden rounded-md border border-slate-200 bg-white">
						${items
							.map(
								(item) => `
									<div class="border-b border-slate-100 px-3 py-2 last:border-b-0" data-preview-key="${assignmentEscape(item.key)}">
										<p class="text-xs font-medium text-slate-500">${assignmentEscape(item.label)}</p>
										<p class="mt-0.5 font-semibold text-slate-950">${assignmentEscape(item.value)}</p>
										${item.detail ? `<p class="mt-0.5 text-xs leading-5 text-slate-600">${assignmentEscape(item.detail)}</p>` : ""}
									</div>
								`
							)
							.join("")}
					</div>
				`
				: '<div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-3 text-amber-900">Esta condición todavía no produce una vista previa calculable.</div>'
			const incompletePreviewHtml =
				items.length > 0 && payload.previewReady !== true
					? '<div class="mt-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs leading-5 text-amber-900">Faltan datos contractuales para confirmar esta condición.</div>'
					: ""
			guestPreviewBox.innerHTML = `${previewItemsHtml}${incompletePreviewHtml}`
			assignmentState.previewReady = payload.previewReady === true && items.length > 0
			return assignmentState.previewReady
		} catch (error) {
			if (seq !== previewRequestSeq) return false
			guestPreviewBox.innerHTML = `
				<div class="rounded-md border border-rose-200 bg-rose-50 p-2 text-rose-800">
					No se pudo contactar el backend para calcular el preview obligatorio.
				</div>
			`
			return false
		}
	}

	function renderImpact() {
		if (!impactBox && !professionalImpactBox) return
		const selected = currentSelection()
		const channel = channelSelect?.value || "Todos los canales"
		const source =
			selected.mode === "existing"
				? selected.policy?.label || "Selecciona una condición publicada"
				: selected.mode === "draft"
					? "Horario personalizado"
					: selected.preset?.label || "Selecciona una plantilla"
		const destination = selected.scopeOption
			? `${scopeLabel(selected.scope)}: ${selected.scopeOption.label}`
			: `${scopeLabel(selected.scope)} sin seleccionar`
		const technicalHtml = `
			<div class="rounded-lg border border-slate-200 bg-white p-3">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Origen</p>
				<p class="mt-1 font-medium text-slate-900">${assignmentEscape(source)}</p>
			</div>
			<div class="rounded-lg border border-slate-200 bg-white p-3">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Destino</p>
				<p class="mt-1 font-medium text-slate-900">${assignmentEscape(destination)}</p>
				${isProfessionalMode ? `<p class="mt-1 text-xs text-slate-500">Canal: ${assignmentEscape(channel)}</p>` : `<p class="mt-1 text-xs text-slate-500">Canal: Todos los canales</p>`}
			</div>
			<div class="rounded-lg border border-amber-200 bg-amber-50 p-3 text-amber-900">
				<p class="font-medium">Impacto contractual</p>
				<p class="mt-1">Reemplazará la condición activa de ${assignmentEscape(categoryLabel(selected.category))} para este alcance y canal, manteniendo historial y auditoría.</p>
			</div>
		`
		if (impactBox) {
			const copy = modalCopy(selected.category)
			impactBox.innerHTML = isProfessionalMode
				? technicalHtml
				: `
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
						<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">${assignmentEscape(copy.impactLabel)}</p>
						<p class="mt-1 text-sm leading-5 text-slate-700">${assignmentEscape(copy.impactText)}</p>
						${selected.scopeOption ? `<p class="mt-2 text-xs text-slate-500">Destino: ${assignmentEscape(selected.scopeOption.label)}</p>` : ""}
					</div>
				`
		}
		if (professionalImpactBox) professionalImpactBox.innerHTML = technicalHtml
		renderBackendPreview()
	}

	function setMode(mode) {
		if (!isProfessionalMode) {
			simpleAssignmentMode =
				mode === "existing" ? "existing" : mode === "draft" ? "draft" : "preset"
		}
		document.querySelectorAll('input[name="assignmentMode"]').forEach((input) => {
			input.checked = input.value === mode
		})
		existingFields?.classList.toggle("hidden", !isProfessionalMode || mode !== "existing")
		presetFields?.classList.toggle("hidden", mode !== "preset")
		customFields?.classList.toggle("hidden", mode !== "draft")
		existingCards?.classList.toggle("hidden", mode !== "existing")
		presetCards?.classList.toggle("hidden", mode !== "preset")
		customHelp?.classList.toggle("hidden", mode !== "preset")
		for (const button of simpleModeButtons) {
			const isDraftButton = button.dataset.assignmentSimpleMode === "draft"
			const canDraft = !isProfessionalMode
			button.classList.toggle("hidden", isDraftButton && !canDraft)
			const active = button.dataset.assignmentSimpleMode === selectedMode()
			button.setAttribute("aria-pressed", active ? "true" : "false")
			button.classList.toggle("bg-white", active)
			button.classList.toggle("text-slate-950", active)
			button.classList.toggle("shadow-sm", active)
			button.classList.toggle("text-slate-500", !active)
		}
		simpleModeGrid?.classList.toggle("sm:grid-cols-3", !isProfessionalMode)
		simpleModeGrid?.classList.toggle("sm:grid-cols-2", isProfessionalMode)
		renderCustomFieldsState(categorySelect?.value)
		renderExistingCardsState()
		renderPresetCardsState()
		renderImpact()
	}

	async function openAssignmentFlow(trigger) {
		await loadAssignmentOptions()
		const defaultScope =
			trigger?.dataset.assignmentScope || assignmentOverlay?.dataset.defaultScope || "rate_plan"
		const defaultScopeId =
			trigger?.dataset.assignmentScopeId || assignmentOverlay?.dataset.defaultScopeId || ""
		const defaultPolicyId = trigger?.dataset.assignmentPolicyId || ""
		const defaultCategory = trigger?.dataset.assignmentCategory || ""
		const defaultChannel =
			trigger?.dataset.assignmentChannel || assignmentOverlay?.dataset.defaultChannel || ""
		const defaultMode =
			isProfessionalMode && defaultPolicyId
				? "existing"
				: trigger?.dataset.assignmentMode || "preset"

		if (scopeSelect) scopeSelect.value = defaultScope
		renderScopeOptions(defaultScopeId)
		if (isProfessionalMode && defaultPolicyId && policySelect) policySelect.value = defaultPolicyId
		if (defaultCategory && categorySelect) categorySelect.value = defaultCategory
		if (channelSelect) {
			channelSelect.value = defaultChannel
			if (!isProfessionalMode) channelSelect.value = ""
		}
		renderPresetOptions()
		renderExistingCards()
		renderPresetCardsState()
		renderModalChrome(categorySelect?.value || defaultCategory)
		setMode(defaultMode)
		statusBox?.classList.add("hidden")
		assignmentOverlay?.classList.remove("hidden")
		assignmentClose?.focus()
		renderImpact()
	}

	function closeAssignmentFlow() {
		assignmentOverlay?.classList.add("hidden")
	}

	async function submitAssignment() {
		const selected = currentSelection()
		if (!selected.scopeId) {
			showStatus("error", "Selecciona un destino válido.")
			return
		}
		if (selected.mode === "existing" && !selected.policy?.id) {
			showStatus("error", "Selecciona una condición publicada.")
			return
		}
		if (selected.mode === "preset" && !selected.preset?.key) {
			showStatus("error", "Selecciona una plantilla.")
			return
		}
		if (!assignmentState.previewReady) {
			const previewReady = await renderBackendPreview()
			if (!previewReady) {
				showStatus("error", "Calcula y revisa el preview obligatorio antes de confirmar.")
				return
			}
		}

		if (isProfessionalMode) {
			const sourceLabel =
				selected.mode === "existing" ? selected.policy.label : `${selected.preset.label} nuevo`
			const channelLabel = `canal ${channelSelect?.value || "Todos los canales"}`
			const confirmText = `Vas a asignar "${sourceLabel}" a ${scopeLabel(selected.scope)} "${selected.scopeOption?.label || selected.scopeId}". Esto reemplaza la condición activa de la misma categoría para ${channelLabel}.`
			if (!window.confirm(confirmText)) return
		}

		assignmentSubmit.disabled = true
		const body =
			selected.mode === "existing"
				? {
						mode: "existing",
						policyId: selected.policy.id,
						scope: selected.scope,
						scopeId: selected.scopeId,
						channel: channelSelect?.value || null,
					}
				: selected.mode === "draft"
					? {
							mode: "draft",
							category: selected.category,
							description: draftDescription(selected.category),
							rules: draftRules(selected.category),
							cancellationTiers:
								selected.category === "Cancellation" ? draftCancellationTiers() : undefined,
							scope: selected.scope,
							scopeId: selected.scopeId,
							channel: channelSelect?.value || null,
						}
					: {
							mode: "preset",
							category: categorySelect?.value,
							policyPresetKey: selected.preset.key,
							description:
								descriptionInput?.value ||
								`${categoryLabel(categorySelect?.value)} ${selected.preset.label}`,
							scope: selected.scope,
							scopeId: selected.scopeId,
							channel: channelSelect?.value || null,
						}
		const response = await fetch("/api/policies/assign", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(body),
		})
		const payload = await response.json().catch(() => ({}))
		assignmentSubmit.disabled = false
		if (!response.ok) {
			showStatus("error", `No se pudo asignar: ${payload?.error || "error"}`)
			return
		}
		showStatus(
			"ok",
			payload?.replaced
				? "Condición asignada. Se reemplazó una asignación activa."
				: "Condición asignada. No había asignación previa para este alcance."
		)
		const savedEvent = new CustomEvent("policy-assignment-saved", {
			cancelable: true,
			detail: {
				scope: selected.scope,
				scopeId: selected.scopeId,
				category: selected.category,
				policyId: payload?.policyId,
			},
		})
		const shouldReload = document.dispatchEvent(savedEvent)
		if (shouldReload) window.setTimeout(() => window.location.reload(), 700)
	}

	document.addEventListener("click", (event) => {
		const target = event.target instanceof HTMLElement ? event.target : null
		const arrivalTrigger = target?.closest(".policy-arrival-open")
		if (arrivalTrigger instanceof HTMLElement) {
			openAssignmentFlow({
				dataset: {
					assignmentScope: "product",
					assignmentScopeId: arrivalTrigger.dataset.arrivalScopeId || "",
					assignmentCategory: "CheckIn",
					assignmentMode: "draft",
				},
			})
			return
		}
		const trigger = target?.closest(".policy-assignment-open")
		if (trigger instanceof HTMLElement) {
			openAssignmentFlow(trigger)
		}
	})
	assignmentClose?.addEventListener("click", closeAssignmentFlow)
	assignmentOverlay?.addEventListener("click", (event) => {
		if (event.target === assignmentOverlay) closeAssignmentFlow()
	})
	document.querySelectorAll('input[name="assignmentMode"]').forEach((input) => {
		input.addEventListener("change", () => setMode(input.value))
	})
	categorySelect?.addEventListener("change", () => {
		renderPresetOptions()
		renderExistingCards()
		renderPresetCardsState()
		renderModalChrome(categorySelect.value)
		renderCustomFieldsState(categorySelect.value)
		renderImpact()
	})
	presetSelect?.addEventListener("change", () => {
		renderPresetCardsState()
		renderImpact()
	})
	policySelect?.addEventListener("change", () => {
		renderExistingCardsState()
		renderImpact()
	})
	scopeSelect?.addEventListener("change", () => {
		renderScopeOptions()
		renderCustomHelp(categorySelect?.value)
		renderImpact()
	})
	scopeIdSelect?.addEventListener("change", () => {
		renderCustomHelp(categorySelect?.value)
		renderImpact()
	})
	channelSelect?.addEventListener("change", renderImpact)
	for (const input of [
		cancellationFreeDaysInput,
		cancellationPenaltyInput,
		paymentTypeInput,
		prepaymentPercentageInput,
		prepaymentDaysInput,
		checkInFromInput,
		checkInUntilInput,
		checkOutUntilInput,
		noShowPenaltyTypeInput,
		noShowPenaltyAmountInput,
	]) {
		input?.addEventListener("input", renderImpact)
		input?.addEventListener("change", () => {
			renderCustomFieldsState(categorySelect?.value)
			renderImpact()
		})
	}
	for (const button of simpleModeButtons) {
		button.addEventListener("click", () => setMode(button.dataset.assignmentSimpleMode || "preset"))
	}
	assignmentSubmit?.addEventListener("click", submitAssignment)
</script>
