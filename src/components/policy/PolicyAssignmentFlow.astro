			(policy) => String(policy.category) === category
		)
		existingCards.innerHTML = policies.length
			? `<div class="fastt-policy-option-list space-y-2">${policies
					.map(
						(policy, index) => `
							<button
								type="button"
								class="policy-existing-card fastt-button fastt-row-card flex w-full items-start justify-between gap-3 p-3 text-left"
								data-policy-id="${assignmentEscape(policy.id)}"
								aria-pressed="${index === 0 ? "true" : "false"}"
							>
								<span class="min-w-0">
									<span class="block text-sm font-semibold text-slate-950">${assignmentEscape(policy.label)}</span>
									<span class="mt-1 block text-xs leading-5 text-slate-600">${assignmentEscape(policy.helper || "Condición publicada disponible para este proveedor.")}</span>
								</span>
								<span class="policy-existing-check ${index === 0 ? "" : "hidden"} shrink-0 rounded-full bg-slate-950 px-2 py-0.5 text-xs font-semibold text-white">✓</span>
							</button>
						`
					)
					.join("")}</div>`
			: `
				<div class="fastt-soft-box border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
					No hay condiciones publicadas para ${assignmentEscape(categoryLabel(category)).toLowerCase()}.
				</div>
			`
