---
import { X } from "@lucide/astro"
import Button from "@/components/ui/Button.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import {
	POLICY_CATEGORY_OPTIONS,
	POLICY_CATEGORY_PREVIEW_COPY,
} from "@/data/policy/policy-categories"

type Props = {
	defaultScope?: "product" | "variant" | "rate_plan"
	defaultScopeId?: string
	defaultChannel?: string
	isProfessionalMode?: boolean
}

const {
	defaultScope = "rate_plan",
	defaultScopeId = "",
	defaultChannel = "",
	isProfessionalMode = false,
} = Astro.props

const policyCategoryLabels = Object.fromEntries(
	POLICY_CATEGORY_OPTIONS.map((category) => [category.value, category.label])
)
const policyModalCopy = {
	Cancellation: {
		eyebrow: "Condición de reserva",
		title: "Cancelación",
		description: "Elige o personaliza qué ocurre si el huésped cancela antes de llegar.",
		choiceLabel: "Política de cancelación",
		previewLabel: "Así lo verá el huésped",
		previewDescription: "Resumen visible antes de reservar.",
		impactLabel: "Impacto",
		impactText: "Esta política reemplazará la cancelación actual de esta tarifa.",
	},
	NoShow: {
		eyebrow: "Condición de reserva",
		title: "No presentación",
		description: "Define qué se cobra cuando el huésped no llega a la reserva.",
		choiceLabel: "Política de no presentación",
		previewLabel: "Así lo verá el huésped",
		previewDescription: "Resumen visible antes de reservar.",
		impactLabel: "Impacto",
		impactText: "Esta regla reemplazará la no presentación actual de esta tarifa.",
	},
	Payment: {
		eyebrow: "Condición de pago",
		title: "Pago",
		description: "Define cuándo paga el huésped y qué importe asegura la reserva.",
		choiceLabel: "Forma de pago",
		previewLabel: "Así lo verá el huésped",
		previewDescription: "Resumen visible antes de reservar.",
		impactLabel: "Impacto",
		impactText: "Esta regla reemplazará el pago actual de esta tarifa.",
	},
	CheckIn: {
		eyebrow: "Regla del alojamiento",
		title: "Llegada y salida",
		description: "Define los horarios que verá el huésped antes de reservar.",
		choiceLabel: "Horario de llegada y salida",
		previewLabel: "Así lo verá el huésped",
		previewDescription: "Horarios visibles antes de reservar.",
		impactLabel: "Impacto",
		impactText: "Estos horarios se aplicarán al alojamiento y a sus tarifas futuras.",
	},
}
---

<div
	id="policyAssignmentOverlay"
	class="fixed inset-0 z-[70] hidden flex items-center justify-center overflow-y-auto bg-slate-950/40 p-4 backdrop-blur-sm"
	data-default-scope={defaultScope}
	data-default-scope-id={defaultScopeId}
	data-default-channel={defaultChannel}
>
	<div
		class:list={[
			"fastt-modal-panel fastt-dialog mx-auto flex max-h-[92vh] w-full flex-col border bg-white text-slate-900",
			"max-w-5xl",
		]}
	>
		<div class="flex items-start justify-between gap-4 border-b border-slate-200 px-6 py-4">
			<div>
				<p
					id="policyAssignmentEyebrow"
					class="text-xs font-semibold uppercase tracking-wide text-slate-500"
				>
					Asignación de condiciones
				</p>
				<h2 id="policyAssignmentTitle" class="mt-1 text-xl font-semibold">Asignar condición</h2>
				<p id="policyAssignmentDescription" class="mt-1 text-sm text-slate-600">
					Crea y asigna desde una plantilla. Revisa el impacto antes de confirmar.
				</p>
			</div>
			<Button
				type="button"
				id="policyAssignmentClose"
				variant="ghost"
				size="sm"
				class="fastt-modal-close px-2"
				aria-label="Cerrar"
			>
				<X class="size-5" />
			</Button>
		</div>

		<div class="min-h-0 flex-1 overflow-y-auto px-6 py-5">
			<div
				class:list={[
					"grid gap-5",
					isProfessionalMode ? "md:grid-cols-[1fr_340px]" : "md:grid-cols-[minmax(0,1fr)_360px]",
				]}
			>
				<form id="policyAssignmentForm" class="space-y-5">
					<section
						class:list={[
							"fastt-soft-box border border-slate-200 p-4",
							!isProfessionalMode && "hidden",
						]}
						data-assignment-origin-section
					>
						<p class="text-sm font-semibold text-slate-900">1. Origen</p>
						<div class="mt-3 grid gap-2 sm:grid-cols-2">
							<label class="fastt-row-card cursor-pointer p-3 text-sm">
								<input type="radio" name="assignmentMode" value="existing" />
								<span class="ml-2 font-medium">Condición existente</span>
								<span class="sr-only">Usar condición existente</span>
								<span class="mt-1 block text-slate-500">Selecciona una condición publicada.</span>
							</label>
							<label class="fastt-row-card cursor-pointer p-3 text-sm">
								<input type="radio" name="assignmentMode" value="preset" checked />
								<span class="ml-2 font-medium">Plantillas</span>
								<span class="mt-1 block text-slate-500">Crea y asigna una condición publicada.</span
								>
							</label>
						</div>
					</section>

					<section
						class:list={[isProfessionalMode && "fastt-soft-box border border-slate-200 p-4"]}
					>
						<p
							class:list={["text-sm font-semibold text-slate-900", !isProfessionalMode && "hidden"]}
						>
							{isProfessionalMode ? "2. Condición" : "Política"}
						</p>
						<div
							class:list={[
								"fastt-soft-box mt-3 border border-slate-200 bg-slate-50 p-1",
								isProfessionalMode && "hidden",
							]}
							aria-label="Origen de la condición"
						>
							<div id="assignmentSimpleModeGrid" class="grid gap-1 sm:grid-cols-2">
								<button
									type="button"
									class="assignment-simple-mode fastt-button justify-center rounded-md px-3 py-2 text-center text-sm font-medium"
									data-assignment-simple-mode="preset"
									aria-pressed="true"
								>
									Plantillas
								</button>
								<button
									type="button"
									class="assignment-simple-mode fastt-button justify-center rounded-md px-3 py-2 text-center text-sm font-medium text-slate-500"
									data-assignment-simple-mode="existing"
									aria-pressed="false"
								>
									Existente
								</button>
								<button
									type="button"
									class="assignment-simple-mode fastt-button hidden justify-center rounded-md px-3 py-2 text-center text-sm font-medium text-slate-500"
									data-assignment-simple-mode="draft"
									aria-pressed="false"
								>
									Personalizar
								</button>
							</div>
						</div>
						<div
							id="assignmentExistingFields"
							class:list={["mt-3 space-y-3", !isProfessionalMode && "hidden"]}
						>
							<label class="block text-sm font-medium text-slate-700" for="assignmentPolicyId">
								Condición publicada
							</label>
							<Select id="assignmentPolicyId" />
						</div>
						<div
							id="assignmentPresetFields"
							class:list={[
								"mt-3 grid gap-3",
								isProfessionalMode ? "hidden sm:grid-cols-2" : "grid-cols-1",
							]}
						>
							<label
								class:list={[
									"block text-sm font-medium text-slate-700",
									!isProfessionalMode && "hidden",
								]}
							>
								Categoría
								<Select id="assignmentCategory" class="mt-1">
									{
										POLICY_CATEGORY_OPTIONS.map((category) => (
											<option value={category.value}>{category.label}</option>
										))
									}
								</Select>
							</label>
							<label
								class:list={[
									"block text-sm font-medium text-slate-700",
									!isProfessionalMode && "sr-only",
								]}
							>
								<span id="assignmentPresetLabel">Plantilla</span>
								<Select
									id="assignmentPreset"
									class:list={["mt-1", !isProfessionalMode && "sr-only"]}
								/>
							</label>
							<div id="assignmentPresetCards" class:list={[isProfessionalMode && "hidden"]}></div>
							<label
								class:list={[
									"block text-sm font-medium text-slate-700 sm:col-span-2",
									!isProfessionalMode && "hidden",
								]}
							>
								Nombre de la condición
								<Input
									id="assignmentDescription"
									class="mt-1"
									placeholder="Ej. Cancelación flexible para tarifa estándar"
								/>
							</label>
						</div>
						<div id="assignmentCustomFields" class="mt-3 hidden space-y-4">
							<div class="space-y-4" data-assignment-custom-category="Cancellation">
								<div class="grid gap-3 sm:grid-cols-2">
									<label class="block text-sm font-medium text-slate-700">
										Cancelación gratis hasta
										<div class="mt-1 flex items-center gap-2">
											<Input id="assignmentCancellationFreeDays" type="number" min="0" value="1" />
											<span class="text-sm text-slate-500">día(s) antes</span>
										</div>
									</label>
									<label class="block text-sm font-medium text-slate-700">
										Penalidad después
										<div class="mt-1 flex items-center gap-2">
											<Input
												id="assignmentCancellationPenalty"
												type="number"
												min="0"
												max="100"
												value="100"
											/>
											<span class="text-sm text-slate-500">% de la reserva</span>
										</div>
									</label>
								</div>
							</div>
							<div class="space-y-4" data-assignment-custom-category="Payment">
								<div class="grid gap-3 sm:grid-cols-3">
									<label class="block text-sm font-medium text-slate-700">
										Cuándo paga
										<Select id="assignmentPaymentType" class="mt-1">
											<option value="pay_at_property">Al llegar</option>
											<option value="prepayment">Prepago</option>
										</Select>
									</label>
									<label class="block text-sm font-medium text-slate-700">
										Porcentaje
										<div class="mt-1 flex items-center gap-2">
											<Input
												id="assignmentPrepaymentPercentage"
												type="number"
												min="1"
												max="100"
												value="50"
											/>
											<span class="text-sm text-slate-500">%</span>
										</div>
									</label>
									<label class="block text-sm font-medium text-slate-700">
										Días antes
										<Input
											id="assignmentPrepaymentDays"
											type="number"
											min="0"
											value="0"
											class="mt-1"
										/>
									</label>
								</div>
							</div>
							<div class="space-y-4" data-assignment-custom-category="CheckIn">
								<div class="grid gap-3 sm:grid-cols-3">
									<label class="block text-sm font-medium text-slate-700">
										Llegada desde
										<Input id="assignmentCheckInFrom" type="time" value="15:00" class="mt-1" />
									</label>
									<label class="block text-sm font-medium text-slate-700">
										Llegada hasta
										<Input id="assignmentCheckInUntil" type="time" value="22:00" class="mt-1" />
									</label>
									<label class="block text-sm font-medium text-slate-700">
										Salida hasta
										<Input id="assignmentCheckOutUntil" type="time" value="11:00" class="mt-1" />
									</label>
								</div>
							</div>
							<div class="space-y-4" data-assignment-custom-category="NoShow">
								<div class="grid gap-3 sm:grid-cols-2">
									<label class="block text-sm font-medium text-slate-700">
										Si no llega
										<Select id="assignmentNoShowPenaltyType" class="mt-1">
											<option value="first_night">Cobrar primera noche</option>
											<option value="full">Cobrar estadía completa</option>
											<option value="percentage">Cobrar porcentaje</option>
										</Select>
									</label>
									<label class="block text-sm font-medium text-slate-700">
										Porcentaje
										<div class="mt-1 flex items-center gap-2">
											<Input
												id="assignmentNoShowPenaltyAmount"
												type="number"
												min="0"
												max="100"
												value="100"
											/>
											<span class="text-sm text-slate-500">%</span>
										</div>
									</label>
								</div>
							</div>
							<div
								class="fastt-soft-box border border-slate-200 bg-slate-50 px-3 py-2 text-sm leading-5 text-slate-600"
							>
								La condición personalizada se guardará y reemplazará la condición actual del alcance
								seleccionado.
							</div>
						</div>
						<div id="assignmentExistingCards" class:list={["mt-3", isProfessionalMode && "hidden"]}>
						</div>
						<div id="assignmentCustomHelp" class:list={["mt-3", isProfessionalMode && "hidden"]}>
						</div>
					</section>

					<section
						class:list={[
							"fastt-soft-box border border-slate-200 p-4",
							!isProfessionalMode && "hidden",
						]}
					>
						<p class="text-sm font-semibold text-slate-900">
							{isProfessionalMode ? "3. Alcance" : "2. Alcance"}
						</p>
						<div class="mt-3 grid gap-3 sm:grid-cols-2">
							<label class="block text-sm font-medium text-slate-700">
								Aplicar a
								<Select id="assignmentScope" class="mt-1">
									<option value="rate_plan">Tarifa</option>
									<option value="variant">Habitación</option>
									<option value="product">Hotel</option>
								</Select>
							</label>
							<label class="block text-sm font-medium text-slate-700">
								Selecciona destino
								<Select id="assignmentScopeId" class="mt-1" />
							</label>
							<label
								class:list={[
									"block text-sm font-medium text-slate-700 sm:col-span-2",
									!isProfessionalMode && "hidden",
								]}
								data-assignment-channel-row
							>
								Canal avanzado
								<Select id="assignmentChannel" class="mt-1">
									<option value="">Todos los canales</option>
									<option value="web">Web</option>
									<option value="mobile">Móvil</option>
									<option value="b2b">B2B</option>
									<option value="direct">Directo</option>
								</Select>
							</label>
							{
								!isProfessionalMode && (
									<p class="fastt-soft-box border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-600 sm:col-span-2">
										Canal: <span class="font-semibold text-slate-900">Todos los canales</span>
									</p>
								)
							}
						</div>
					</section>
				</form>

				<aside
					class:list={[
						isProfessionalMode
							? "fastt-drawer-soft-card space-y-3 p-4"
							: "space-y-4 border-t border-slate-200 pt-4 md:border-t-0 md:border-l md:pt-0 md:pl-5",
					]}
				>
					<div>
						<p id="assignmentPreviewTitle" class="text-sm font-semibold text-slate-950">
							Vista previa de la condición
						</p>
						<p id="assignmentPreviewDescription" class="mt-1 text-xs text-slate-700">
							Consecuencias visibles para operar sin leer reglas técnicas.
						</p>
					</div>
					<div id="assignmentGuestPreview" class="space-y-2 text-sm text-slate-950"></div>
					<details class:list={[isProfessionalMode && "hidden"]}>
						<summary class="cursor-pointer text-sm font-medium text-slate-600 hover:text-slate-950">
							Detalle técnico
						</summary>
						<div id="assignmentImpact" class="mt-3 space-y-2 text-sm text-slate-700">
							Cargando opciones...
						</div>
					</details>
					<div
						id="assignmentProfessionalImpact"
						class:list={["space-y-2 text-sm text-slate-700", !isProfessionalMode && "hidden"]}
					>
						Cargando opciones...
					</div>
					<div id="assignmentStatus" class="hidden rounded-lg border px-3 py-2 text-sm"></div>
				</aside>
			</div>
		</div>

		<div
			class:list={[
				"flex flex-wrap items-center gap-3 border-t border-slate-200 px-6 py-4",
				isProfessionalMode ? "justify-between" : "justify-end",
			]}
		>
			<p class:list={["text-sm text-slate-600", !isProfessionalMode && "hidden"]}>
				La asignación reemplaza la condición activa de la misma categoría para este alcance y canal.
			</p>
			<Button type="button" id="policyAssignmentSubmit"> Guardar cambios </Button>
		</div>
	</div>
</div>

<script
	is:inline
	define:vars={{
		isProfessionalMode,
		policyCategoryLabels,
		policyCategoryPreviewCopy: POLICY_CATEGORY_PREVIEW_COPY,
		policyModalCopy,
	}}
>
	// @ts-nocheck
	const assignmentOverlay = document.getElementById("policyAssignmentOverlay")
	const assignmentClose = document.getElementById("policyAssignmentClose")
	const assignmentSubmit = document.getElementById("policyAssignmentSubmit")
	const assignmentEyebrow = document.getElementById("policyAssignmentEyebrow")
	const assignmentTitle = document.getElementById("policyAssignmentTitle")
	const assignmentDescription = document.getElementById("policyAssignmentDescription")
	const existingFields = document.getElementById("assignmentExistingFields")
	const presetFields = document.getElementById("assignmentPresetFields")
	const policySelect = document.getElementById("assignmentPolicyId")
	const categorySelect = document.getElementById("assignmentCategory")
	const presetSelect = document.getElementById("assignmentPreset")
	const presetCards = document.getElementById("assignmentPresetCards")
	const existingCards = document.getElementById("assignmentExistingCards")
	const customHelp = document.getElementById("assignmentCustomHelp")
	const customFields = document.getElementById("assignmentCustomFields")
	const customCategoryPanels = Array.from(
		document.querySelectorAll("[data-assignment-custom-category]")
	)
	const cancellationFreeDaysInput = document.getElementById("assignmentCancellationFreeDays")
	const cancellationPenaltyInput = document.getElementById("assignmentCancellationPenalty")
	const paymentTypeInput = document.getElementById("assignmentPaymentType")
	const prepaymentPercentageInput = document.getElementById("assignmentPrepaymentPercentage")
	const prepaymentDaysInput = document.getElementById("assignmentPrepaymentDays")
	const checkInFromInput = document.getElementById("assignmentCheckInFrom")
	const checkInUntilInput = document.getElementById("assignmentCheckInUntil")
	const checkOutUntilInput = document.getElementById("assignmentCheckOutUntil")
	const noShowPenaltyTypeInput = document.getElementById("assignmentNoShowPenaltyType")
	const noShowPenaltyAmountInput = document.getElementById("assignmentNoShowPenaltyAmount")
	const presetLabel = document.getElementById("assignmentPresetLabel")
	const descriptionInput = document.getElementById("assignmentDescription")
	const scopeSelect = document.getElementById("assignmentScope")
	const scopeIdSelect = document.getElementById("assignmentScopeId")
	const channelSelect = document.getElementById("assignmentChannel")
	const impactBox = document.getElementById("assignmentImpact")
	const professionalImpactBox = document.getElementById("assignmentProfessionalImpact")
	const guestPreviewBox = document.getElementById("assignmentGuestPreview")
	const previewTitle = document.getElementById("assignmentPreviewTitle")
	const previewDescription = document.getElementById("assignmentPreviewDescription")
	const statusBox = document.getElementById("assignmentStatus")
	const simpleModeGrid = document.getElementById("assignmentSimpleModeGrid")
	const simpleModeButtons = Array.from(document.querySelectorAll("[data-assignment-simple-mode]"))

	const assignmentState = {
		loaded: false,
		loading: false,
		previewReady: false,
		options: { policies: [], presets: [], scopes: { product: [], variant: [], rate_plan: [] } },
	}
	let previewRequestSeq = 0
	let simpleAssignmentMode = "preset"

	function assignmentEscape(value) {
		return String(value ?? "")
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
	}

	function selectedMode() {
		if (!isProfessionalMode) return simpleAssignmentMode
		return document.querySelector('input[name="assignmentMode"]:checked')?.value || "preset"
	}

	function scopeLabel(scope) {
		if (scope === "product") return "Hotel"
		if (scope === "variant") return "Habitación"
		return "Tarifa"
	}

	function categoryLabel(category) {
		return policyCategoryLabels?.[category] || category || "Condición"
	}

	function previewCopy(category) {
		return (
			policyCategoryPreviewCopy?.[category] || {
				title: "Vista previa de la condición",
				description: "Consecuencias visibles antes de confirmar la asignación.",
			}
		)
	}

	function modalCopy(category) {
		return (
			policyModalCopy?.[category] || {
				eyebrow: "Condición de reserva",
				title: `Editar ${String(categoryLabel(category)).toLowerCase()}`,
				description: "Define la condición que verá el huésped antes de reservar.",
				choiceLabel: "Plantilla",
				previewLabel: "Así lo verá el huésped",
				previewDescription: "Resumen visible antes de reservar.",
				impactLabel: "Impacto",
				impactText: "Esta condición reemplazará la configuración actual.",
			}
		)
	}

	function renderModalChrome(category) {
		const copy = modalCopy(category)
		if (assignmentEyebrow)
			assignmentEyebrow.textContent = isProfessionalMode
				? "Asignación de condiciones"
				: copy.eyebrow
		if (assignmentTitle)
			assignmentTitle.textContent = isProfessionalMode ? "Asignar condición" : copy.title
		if (assignmentDescription) {
			assignmentDescription.textContent = isProfessionalMode
				? "Crea y asigna desde una plantilla. Revisa el impacto antes de confirmar."
				: copy.description
		}
		if (presetLabel) presetLabel.textContent = copy.choiceLabel || "Plantilla"
		if (previewTitle && !isProfessionalMode) previewTitle.textContent = copy.previewLabel
		if (previewDescription && !isProfessionalMode) {
			previewDescription.textContent =
				copy.previewDescription || "Resumen visible antes de reservar."
		}
	}

	function showStatus(kind, message) {
		if (!statusBox) return
		statusBox.classList.remove("hidden")
		statusBox.className =
			kind === "ok"
				? "rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800"
				: "rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800"
		statusBox.textContent = message
	}

	async function loadAssignmentOptions() {
		if (assignmentState.loaded || assignmentState.loading) return
		assignmentState.loading = true
		const response = await fetch("/api/policies/assignment-options")
		const payload = await response.json().catch(() => null)
		assignmentState.loading = false
		if (!response.ok || !payload) {
			showStatus("error", "No se pudieron cargar las opciones de asignación.")
			return
		}
		assignmentState.options = payload
		assignmentState.loaded = true
		renderPolicyOptions()
		renderPresetOptions()
		renderExistingCards()
		renderScopeOptions()
		renderImpact()
	}

	function renderPolicyOptions() {
		const policies = assignmentState.options.policies || []
		if (!policySelect) return
		policySelect.innerHTML = policies.length
			? policies
					.map(
						(policy) =>
							`<option value="${assignmentEscape(policy.id)}" data-category="${assignmentEscape(policy.category)}">${assignmentEscape(policy.label)}</option>`
					)
					.join("")
			: '<option value="">No hay condiciones publicadas</option>'
