---
import Button from "@/components/ui/Button.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"

type Props = {
	defaultScope?: "product" | "variant" | "rate_plan"
	defaultScopeId?: string
	defaultChannel?: string
	isProfessionalMode?: boolean
}

const {
	defaultScope = "rate_plan",
	defaultScopeId = "",
	defaultChannel = "",
	isProfessionalMode = false,
} = Astro.props
---

<div
	id="policyAssignmentOverlay"
	class="fixed inset-0 z-[70] hidden bg-slate-950/40 p-4 backdrop-blur-sm"
	data-default-scope={defaultScope}
	data-default-scope-id={defaultScopeId}
	data-default-channel={defaultChannel}
>
	<div
		class="fastt-dialog mx-auto flex max-h-[92vh] w-full max-w-4xl flex-col border bg-white text-slate-900"
	>
		<div class="flex items-start justify-between gap-4 border-b border-slate-200 px-6 py-4">
			<div>
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
					Asignación de condiciones
				</p>
				<h2 class="mt-1 text-xl font-semibold">Asignar condición</h2>
				<p class="mt-1 text-sm text-slate-600">
					Crea y asigna desde una plantilla. Revisa el impacto antes de confirmar.
				</p>
			</div>
			<Button type="button" id="policyAssignmentClose" variant="secondary"> Cerrar </Button>
		</div>

		<div class="min-h-0 flex-1 overflow-y-auto px-6 py-5">
			<div class="grid gap-4 md:grid-cols-[1fr_320px]">
				<form id="policyAssignmentForm" class="space-y-5">
					<section
						class:list={[
							"fastt-soft-box border border-slate-200 p-4",
							!isProfessionalMode && "hidden",
						]}
						data-assignment-origin-section
					>
						<p class="text-sm font-semibold text-slate-900">1. Origen</p>
						<div class="mt-3 grid gap-2 sm:grid-cols-2">
							<label class="fastt-row-card cursor-pointer p-3 text-sm">
								<input type="radio" name="assignmentMode" value="existing" />
								<span class="ml-2 font-medium">Usar condición existente</span>
								<span class="mt-1 block text-slate-500">Selecciona una condición publicada.</span>
							</label>
							<label class="fastt-row-card cursor-pointer p-3 text-sm">
								<input type="radio" name="assignmentMode" value="preset" checked />
								<span class="ml-2 font-medium">Crear desde plantilla</span>
								<span class="mt-1 block text-slate-500">Crea y asigna una condición publicada.</span
								>
							</label>
						</div>
					</section>

					<section class="fastt-soft-box border border-slate-200 p-4">
						<p class="text-sm font-semibold text-slate-900">
							{isProfessionalMode ? "2. Condición" : "1. Condición"}
						</p>
						<div
							id="assignmentExistingFields"
							class:list={["mt-3 space-y-3", !isProfessionalMode && "hidden"]}
						>
							<label class="block text-sm font-medium text-slate-700" for="assignmentPolicyId">
								Condición publicada
							</label>
							<Select id="assignmentPolicyId" />
						</div>
						<div
							id="assignmentPresetFields"
							class:list={["mt-3 grid gap-3 sm:grid-cols-2", isProfessionalMode && "hidden"]}
						>
							<label class="block text-sm font-medium text-slate-700">
								Categoría
								<Select id="assignmentCategory" class="mt-1">
									<option value="Cancellation">Cancelación</option>
									<option value="Payment">Pago</option>
									<option value="CheckIn">Llegada y salida</option>
									<option value="NoShow">No presentación</option>
								</Select>
							</label>
							<label class="block text-sm font-medium text-slate-700">
								Plantilla
								<Select id="assignmentPreset" class="mt-1" />
							</label>
							<label class="block text-sm font-medium text-slate-700 sm:col-span-2">
								Nombre de la condición
								<Input
									id="assignmentDescription"
									class="mt-1"
									placeholder="Ej. Cancelación flexible para tarifa estándar"
								/>
							</label>
						</div>
					</section>

					<section class="fastt-soft-box border border-slate-200 p-4">
						<p class="text-sm font-semibold text-slate-900">
							{isProfessionalMode ? "3. Alcance" : "2. Alcance"}
						</p>
						<div class="mt-3 grid gap-3 sm:grid-cols-2">
							<label class="block text-sm font-medium text-slate-700">
								Aplicar a
								<Select id="assignmentScope" class="mt-1">
									<option value="rate_plan">Tarifa</option>
									<option value="variant">Habitación</option>
									<option value="product">Hotel</option>
								</Select>
							</label>
							<label class="block text-sm font-medium text-slate-700">
								Selecciona destino
								<Select id="assignmentScopeId" class="mt-1" />
							</label>
							<label
								class:list={[
									"block text-sm font-medium text-slate-700 sm:col-span-2",
									!isProfessionalMode && "hidden",
								]}
								data-assignment-channel-row
							>
								Canal avanzado
								<Select id="assignmentChannel" class="mt-1">
									<option value="">Todos los canales</option>
									<option value="web">Web</option>
									<option value="mobile">Móvil</option>
									<option value="b2b">B2B</option>
									<option value="direct">Directo</option>
								</Select>
							</label>
							{
								!isProfessionalMode && (
									<p class="fastt-soft-box border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-600 sm:col-span-2">
										Canal: <span class="font-semibold text-slate-900">Todos los canales</span>
									</p>
								)
							}
						</div>
					</section>
				</form>

				<aside class="fastt-drawer-soft-card space-y-3 p-4">
					<p class="text-sm font-semibold text-slate-900">Impacto antes de confirmar</p>
					<div id="assignmentImpact" class="space-y-2 text-sm text-slate-700">
						Cargando opciones...
					</div>
					<div class="fastt-drawer-secondary-card p-3">
						<p id="assignmentPreviewTitle" class="text-sm font-semibold text-slate-950">
							Vista previa de la condición
						</p>
						<p id="assignmentPreviewDescription" class="mt-1 text-xs text-slate-700">
							Consecuencias visibles para operar sin leer reglas técnicas.
						</p>
						<div id="assignmentGuestPreview" class="mt-3 space-y-2 text-sm text-slate-950"></div>
					</div>
					<div id="assignmentStatus" class="hidden rounded-lg border px-3 py-2 text-sm"></div>
				</aside>
			</div>
		</div>

		<div
			class="flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 px-6 py-4"
		>
			<p class="text-sm text-slate-600">
				La asignación reemplaza la condición activa de la misma categoría para este alcance y canal.
			</p>
			<Button type="button" id="policyAssignmentSubmit"> Confirmar asignación </Button>
		</div>
	</div>
</div>

<script is:inline define:vars={{ isProfessionalMode }}>
	// @ts-nocheck
	const assignmentOverlay = document.getElementById("policyAssignmentOverlay")
	const assignmentClose = document.getElementById("policyAssignmentClose")
	const assignmentSubmit = document.getElementById("policyAssignmentSubmit")
	const existingFields = document.getElementById("assignmentExistingFields")
	const presetFields = document.getElementById("assignmentPresetFields")
	const policySelect = document.getElementById("assignmentPolicyId")
	const categorySelect = document.getElementById("assignmentCategory")
	const presetSelect = document.getElementById("assignmentPreset")
	const descriptionInput = document.getElementById("assignmentDescription")
	const scopeSelect = document.getElementById("assignmentScope")
	const scopeIdSelect = document.getElementById("assignmentScopeId")
	const channelSelect = document.getElementById("assignmentChannel")
	const impactBox = document.getElementById("assignmentImpact")
	const guestPreviewBox = document.getElementById("assignmentGuestPreview")
	const previewTitle = document.getElementById("assignmentPreviewTitle")
	const previewDescription = document.getElementById("assignmentPreviewDescription")
	const statusBox = document.getElementById("assignmentStatus")

	const assignmentState = {
		loaded: false,
		loading: false,
		previewReady: false,
		options: { policies: [], presets: [], scopes: { product: [], variant: [], rate_plan: [] } },
	}
	let previewRequestSeq = 0

	function assignmentEscape(value) {
		return String(value ?? "")
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
	}

	function selectedMode() {
		if (!isProfessionalMode) return "preset"
		return document.querySelector('input[name="assignmentMode"]:checked')?.value || "preset"
	}

	function scopeLabel(scope) {
		if (scope === "product") return "Hotel"
		if (scope === "variant") return "Habitación"
		return "Tarifa"
	}

	function categoryLabel(category) {
		if (category === "Cancellation") return "Cancelación"
		if (category === "Payment") return "Pago"
		if (category === "CheckIn") return "Llegada y salida"
		if (category === "NoShow") return "No presentación"
		return category || "Condición"
	}

	function previewCopy(category) {
		if (category === "Cancellation") {
			return {
				title: "Vista previa de cancelación",
				description: "Plazos y consecuencias que verá el huésped antes de reservar.",
			}
		}
		if (category === "Payment") {
			return {
				title: "Vista previa de pago y garantía",
				description: "Cuándo paga el huésped y qué importe asegura la reserva.",
			}
		}
		if (category === "NoShow") {
			return {
				title: "Vista previa de no presentación",
				description: "Qué se cobra cuando el huésped no llega y no cancela.",
			}
		}
		if (category === "CheckIn") {
			return {
				title: "Vista previa de llegada y salida",
				description: "Horarios que verán el huésped y el equipo de recepción.",
			}
		}
		return {
			title: "Vista previa de la condición",
			description: "Consecuencias visibles antes de confirmar la asignación.",
		}
	}

	function showStatus(kind, message) {
		if (!statusBox) return
		statusBox.classList.remove("hidden")
		statusBox.className =
			kind === "ok"
				? "rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800"
				: "rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800"
		statusBox.textContent = message
	}

	async function loadAssignmentOptions() {
		if (assignmentState.loaded || assignmentState.loading) return
		assignmentState.loading = true
		const response = await fetch("/api/policies/assignment-options")
		const payload = await response.json().catch(() => null)
		assignmentState.loading = false
		if (!response.ok || !payload) {
			showStatus("error", "No se pudieron cargar las opciones de asignación.")
			return
		}
		assignmentState.options = payload
		assignmentState.loaded = true
		renderPolicyOptions()
		renderPresetOptions()
		renderScopeOptions()
		renderImpact()
	}

	function renderPolicyOptions() {
		const policies = assignmentState.options.policies || []
		if (!policySelect) return
		policySelect.innerHTML = policies.length
			? policies
					.map(
						(policy) =>
							`<option value="${assignmentEscape(policy.id)}" data-category="${assignmentEscape(policy.category)}">${assignmentEscape(policy.label)}</option>`
					)
					.join("")
			: '<option value="">No hay condiciones publicadas</option>'
	}

	function renderPresetOptions() {
		if (!presetSelect || !categorySelect) return
		const category = categorySelect.value
		const presets = (assignmentState.options.presets || []).filter(
			(preset) => String(preset.category) === category
		)
		presetSelect.innerHTML = presets.length
			? presets
					.map(
						(preset) =>
							`<option value="${assignmentEscape(preset.key)}" data-description="${assignmentEscape(preset.description)}">${assignmentEscape(preset.label)}</option>`
					)
					.join("")
			: '<option value="">Sin plantillas para esta categoría</option>'
	}

	function renderScopeOptions(preferredId = "") {
		if (!scopeSelect || !scopeIdSelect) return
		const scope = scopeSelect.value
		const items = assignmentState.options.scopes?.[scope] || []
		scopeIdSelect.innerHTML = items.length
			? items
					.map(
						(item) =>
							`<option value="${assignmentEscape(item.id)}">${assignmentEscape(item.label)}${item.helper ? ` · ${assignmentEscape(item.helper)}` : ""}</option>`
					)
					.join("")
			: '<option value="">Sin destinos disponibles</option>'
		if (preferredId && items.some((item) => String(item.id) === String(preferredId))) {
			scopeIdSelect.value = preferredId
		}
	}

	function currentSelection() {
		const mode = selectedMode()
		const policy = (assignmentState.options.policies || []).find(
			(item) => String(item.id) === String(policySelect?.value || "")
		)
		const preset = (assignmentState.options.presets || []).find(
			(item) => String(item.key) === String(presetSelect?.value || "")
		)
		const scope = scopeSelect?.value || "rate_plan"
		const scopeId = scopeIdSelect?.value || ""
		const scopeOption = (assignmentState.options.scopes?.[scope] || []).find(
			(item) => String(item.id) === String(scopeId)
		)
		const category = mode === "existing" ? policy?.category : categorySelect?.value
		return { mode, policy, preset, scope, scopeId, scopeOption, category }
	}

	function previewPayload(selected = currentSelection()) {
		return selected.mode === "existing"
			? {
					mode: "existing",
					policyId: selected.policy?.id || "",
					scope: selected.scope,
					scopeId: selected.scopeId,
					channel: channelSelect?.value || null,
				}
			: {
					mode: "preset",
					category: categorySelect?.value,
					policyPresetKey: selected.preset?.key || "",
					scope: selected.scope,
					scopeId: selected.scopeId,
					channel: channelSelect?.value || null,
				}
	}

	async function renderBackendPreview() {
		if (!guestPreviewBox) return false
		const selected = currentSelection()
		const pendingCopy = previewCopy(selected.category)
		if (previewTitle) previewTitle.textContent = pendingCopy.title
		if (previewDescription) previewDescription.textContent = pendingCopy.description
		assignmentState.previewReady = false
		if (!selected.scopeId) {
			guestPreviewBox.innerHTML =
				'<div class="fastt-soft-box border border-slate-200 bg-white/80 p-2">Selecciona un destino para calcular el preview real.</div>'
			return false
		}
		if (selected.mode === "existing" && !selected.policy?.id) {
			guestPreviewBox.innerHTML =
				'<div class="fastt-soft-box border border-slate-200 bg-white/80 p-2">Selecciona una condición publicada para calcular el preview real.</div>'
			return false
		}
		if (selected.mode === "preset" && !selected.preset?.key) {
			guestPreviewBox.innerHTML =
				'<div class="fastt-soft-box border border-slate-200 bg-white/80 p-2">Selecciona una plantilla para calcular el preview real.</div>'
			return false
		}

		const seq = ++previewRequestSeq
		guestPreviewBox.innerHTML =
			'<div class="rounded-lg border border-slate-200 bg-white px-3 py-3 text-slate-600">Calculando consecuencias...</div>'
		try {
			const response = await fetch("/api/policies/preview", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(previewPayload(selected)),
			})
			const payload = await response.json().catch(() => null)
			if (seq !== previewRequestSeq) return false
			if (!response.ok || !payload?.success) {
				guestPreviewBox.innerHTML = `
					<div class="rounded-md border border-rose-200 bg-rose-50 p-2 text-rose-800">
						No se pudo calcular el preview real: ${assignmentEscape(payload?.error || "error")}
					</div>
				`
				return false
			}
			const items = Array.isArray(payload.preview) ? payload.preview : []
			if (previewTitle) {
				previewTitle.textContent =
					payload?.presentation?.title || `Vista previa de ${categoryLabel(selected.category)}`
			}
			if (previewDescription) {
				previewDescription.textContent =
					payload?.presentation?.description ||
					"Consecuencias visibles antes de confirmar la asignación."
			}
			const previewItemsHtml = items.length
				? `
					<div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
						${items
							.map(
								(item) => `
									<div class="border-b border-slate-100 px-3 py-2.5 last:border-b-0" data-preview-key="${assignmentEscape(item.key)}">
										<p class="text-xs font-medium text-slate-500">${assignmentEscape(item.label)}</p>
										<p class="mt-0.5 font-semibold text-slate-950">${assignmentEscape(item.value)}</p>
										${item.detail ? `<p class="mt-0.5 text-xs leading-5 text-slate-600">${assignmentEscape(item.detail)}</p>` : ""}
									</div>
								`
							)
							.join("")}
					</div>
				`
				: '<div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-3 text-amber-900">Esta condición todavía no produce una vista previa calculable.</div>'
			const incompletePreviewHtml =
				items.length > 0 && payload.previewReady !== true
					? '<div class="mt-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs leading-5 text-amber-900">Faltan datos contractuales para confirmar esta condición.</div>'
					: ""
			guestPreviewBox.innerHTML = `${previewItemsHtml}${incompletePreviewHtml}`
			assignmentState.previewReady = payload.previewReady === true && items.length > 0
			return assignmentState.previewReady
		} catch (error) {
			if (seq !== previewRequestSeq) return false
			guestPreviewBox.innerHTML = `
				<div class="rounded-md border border-rose-200 bg-rose-50 p-2 text-rose-800">
					No se pudo contactar el backend para calcular el preview obligatorio.
				</div>
			`
			return false
		}
	}

	function renderImpact() {
		if (!impactBox) return
		const selected = currentSelection()
		const channel = channelSelect?.value || "Todos los canales"
		const source =
			selected.mode === "existing"
				? selected.policy?.label || "Selecciona una condición publicada"
				: selected.preset?.label || "Selecciona una plantilla"
		const destination = selected.scopeOption
			? `${scopeLabel(selected.scope)}: ${selected.scopeOption.label}`
			: `${scopeLabel(selected.scope)} sin seleccionar`
		impactBox.innerHTML = `
			<div class="rounded-lg border border-slate-200 bg-white p-3">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Origen</p>
				<p class="mt-1 font-medium text-slate-900">${assignmentEscape(source)}</p>
			</div>
			<div class="rounded-lg border border-slate-200 bg-white p-3">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Destino</p>
				<p class="mt-1 font-medium text-slate-900">${assignmentEscape(destination)}</p>
				${isProfessionalMode ? `<p class="mt-1 text-xs text-slate-500">Canal: ${assignmentEscape(channel)}</p>` : `<p class="mt-1 text-xs text-slate-500">Canal: Todos los canales</p>`}
			</div>
			<div class="rounded-lg border border-amber-200 bg-amber-50 p-3 text-amber-900">
				<p class="font-medium">Impacto contractual</p>
				<p class="mt-1">Reemplazará la condición activa de ${assignmentEscape(categoryLabel(selected.category))} para este alcance y canal, manteniendo historial y auditoría.</p>
			</div>
		`
		renderBackendPreview()
	}

	function setMode(mode) {
		document.querySelectorAll('input[name="assignmentMode"]').forEach((input) => {
			input.checked = input.value === mode
		})
		existingFields?.classList.toggle("hidden", mode !== "existing")
		presetFields?.classList.toggle("hidden", mode !== "preset")
		renderImpact()
	}

	async function openAssignmentFlow(trigger) {
		await loadAssignmentOptions()
		const defaultScope =
			trigger?.dataset.assignmentScope || assignmentOverlay?.dataset.defaultScope || "rate_plan"
		const defaultScopeId =
			trigger?.dataset.assignmentScopeId || assignmentOverlay?.dataset.defaultScopeId || ""
		const defaultPolicyId = trigger?.dataset.assignmentPolicyId || ""
		const defaultCategory = trigger?.dataset.assignmentCategory || ""
		const defaultChannel =
			trigger?.dataset.assignmentChannel || assignmentOverlay?.dataset.defaultChannel || ""
		const defaultMode =
			isProfessionalMode && defaultPolicyId
				? "existing"
				: trigger?.dataset.assignmentMode || "preset"

		if (scopeSelect) scopeSelect.value = defaultScope
		renderScopeOptions(defaultScopeId)
		if (isProfessionalMode && defaultPolicyId && policySelect) policySelect.value = defaultPolicyId
		if (defaultCategory && categorySelect) categorySelect.value = defaultCategory
		if (channelSelect) {
			channelSelect.value = defaultChannel
			if (!isProfessionalMode) channelSelect.value = ""
		}
		renderPresetOptions()
		setMode(defaultMode)
		statusBox?.classList.add("hidden")
		assignmentOverlay?.classList.remove("hidden")
		renderImpact()
	}

	function closeAssignmentFlow() {
		assignmentOverlay?.classList.add("hidden")
	}

	async function submitAssignment() {
		const selected = currentSelection()
		if (!selected.scopeId) {
			showStatus("error", "Selecciona un destino válido.")
			return
		}
		if (selected.mode === "existing" && !selected.policy?.id) {
			showStatus("error", "Selecciona una condición publicada.")
			return
		}
		if (selected.mode === "preset" && !selected.preset?.key) {
			showStatus("error", "Selecciona una plantilla.")
			return
		}
		if (!assignmentState.previewReady) {
			const previewReady = await renderBackendPreview()
			if (!previewReady) {
				showStatus("error", "Calcula y revisa el preview obligatorio antes de confirmar.")
				return
			}
		}

		const sourceLabel =
			selected.mode === "existing" ? selected.policy.label : `${selected.preset.label} nuevo`
		const channelLabel = isProfessionalMode
			? `canal ${channelSelect?.value || "Todos los canales"}`
			: "Todos los canales"
		const confirmText = `Vas a asignar "${sourceLabel}" a ${scopeLabel(selected.scope)} "${selected.scopeOption?.label || selected.scopeId}". Esto reemplaza la condición activa de la misma categoría para ${channelLabel}.`
		if (!window.confirm(confirmText)) return

		assignmentSubmit.disabled = true
		const body =
			selected.mode === "existing"
				? {
						mode: "existing",
						policyId: selected.policy.id,
						scope: selected.scope,
						scopeId: selected.scopeId,
						channel: channelSelect?.value || null,
					}
				: {
						mode: "preset",
						category: categorySelect?.value,
						policyPresetKey: selected.preset.key,
						description:
							descriptionInput?.value ||
							`${categoryLabel(categorySelect?.value)} ${selected.preset.label}`,
						scope: selected.scope,
						scopeId: selected.scopeId,
						channel: channelSelect?.value || null,
					}
		const response = await fetch("/api/policies/assign", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(body),
		})
		const payload = await response.json().catch(() => ({}))
		assignmentSubmit.disabled = false
		if (!response.ok) {
			showStatus("error", `No se pudo asignar: ${payload?.error || "error"}`)
			return
		}
		showStatus(
			"ok",
			payload?.replaced
				? "Condición asignada. Se reemplazó una asignación activa."
				: "Condición asignada. No había asignación previa para este alcance."
		)
		const savedEvent = new CustomEvent("policy-assignment-saved", {
			cancelable: true,
			detail: {
				scope: selected.scope,
				scopeId: selected.scopeId,
				category: selected.category,
				policyId: payload?.policyId,
			},
		})
		const shouldReload = document.dispatchEvent(savedEvent)
		if (shouldReload) window.setTimeout(() => window.location.reload(), 700)
	}

	document.addEventListener("click", (event) => {
		const target = event.target instanceof HTMLElement ? event.target : null
		const trigger = target?.closest(".policy-assignment-open")
		if (trigger instanceof HTMLElement) {
			openAssignmentFlow(trigger)
		}
	})
	assignmentClose?.addEventListener("click", closeAssignmentFlow)
	assignmentOverlay?.addEventListener("click", (event) => {
		if (event.target === assignmentOverlay) closeAssignmentFlow()
	})
	document.querySelectorAll('input[name="assignmentMode"]').forEach((input) => {
		input.addEventListener("change", () => setMode(input.value))
	})
	categorySelect?.addEventListener("change", () => {
		renderPresetOptions()
		renderImpact()
	})
	presetSelect?.addEventListener("change", renderImpact)
	policySelect?.addEventListener("change", renderImpact)
	scopeSelect?.addEventListener("change", () => {
		renderScopeOptions()
		renderImpact()
	})
	scopeIdSelect?.addEventListener("change", renderImpact)
	channelSelect?.addEventListener("change", renderImpact)
	assignmentSubmit?.addEventListener("click", submitAssignment)
</script>
