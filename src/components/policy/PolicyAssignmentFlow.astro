			(preset) => String(preset.category) === category
		)
		presetSelect.innerHTML = presets.length
			? presets
					.map(
						(preset) =>
							`<option value="${assignmentEscape(preset.key)}" data-description="${assignmentEscape(preset.description)}">${assignmentEscape(preset.label)}</option>`
					)
					.join("")
			: '<option value="">Sin plantillas para esta categoría</option>'
