	function renderPresetCardsState() {
		if (!presetCards || !presetSelect) return
		for (const card of presetCards.querySelectorAll(".policy-preset-card")) {
			const selected = String(card.dataset.presetKey || "") === String(presetSelect.value || "")
			card.setAttribute("aria-pressed", selected ? "true" : "false")
			card.classList.toggle("border-slate-950", selected)
			card.classList.toggle("bg-slate-50", selected)
			card.querySelector(".policy-preset-check")?.classList.toggle("hidden", !selected)
		}
	}

	function renderExistingCards() {
