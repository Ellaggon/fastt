			presetCards.innerHTML = presets.length
				? `<div class="fastt-policy-option-list space-y-2">${presets
						.map(
							(preset, index) => `
								<button
									type="button"
									class="policy-preset-card fastt-button fastt-row-card flex w-full items-start justify-between gap-3 p-3 text-left"
									data-preset-key="${assignmentEscape(preset.key)}"
									aria-pressed="${index === 0 ? "true" : "false"}"
								>
									<span class="min-w-0">
										<span class="block text-sm font-semibold text-slate-950">${assignmentEscape(preset.label)}</span>
										<span class="mt-1 block text-xs leading-5 text-slate-600">${assignmentEscape(preset.description || "")}</span>
									</span>
									<span class="policy-preset-check ${index === 0 ? "" : "hidden"} shrink-0 rounded-full bg-slate-950 px-2 py-0.5 text-xs font-semibold text-white">✓</span>
								</button>
							`
