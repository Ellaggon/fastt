---
import { POLICY_CATEGORY_ORDER } from "@/data/policy/policy-categories"
import { POLICY_PRESETS } from "@/data/policy/policy-presets"

interface Props {
	title: string
	scope: "hotel" | "product" | "variant"
	scopeId: string
	resolveParams: Record<string, string>
}

const { title, scope, scopeId, resolveParams } = Astro.props
---

<section class="h-full w-full pt-6 md:pt-20">
	<article
		class="space-y-8 mx-auto w-[98%] rounded-3xl border border-neutral-300 bg-neutral-200 p-8 text-neutral-800 shadow-lg sm:p-10 md:w-[80%] md:max-w-3xl lg:p-20"
	>
		<h1 class="mb-2 text-2xl font-semibold uppercase">{title}</h1>

		<div class="mt-6 flex justify-end">
			<button id="btnAdd" class="rounded-xl bg-blue-600 px-4 py-2 text-white">
				Nueva Política
			</button>
			<div class="mt-6 flex justify-end" id="createContainer"></div>
		</div>

		<div id="policyList" class="mt-8 space-y-4">Cargando...</div>

		<dialog id="policyModal" class="w-[720px] max-w-[95%] rounded-2xl p-6">
			<form id="policyForm" class="space-y-6">
				<input type="hidden" id="policyId" />

				<div id="categoryRow" class="flex flex-wrap gap-2"></div>

				<div>
					<p class="mb-2 text-sm font-semibold">Plantillas</p>
					<div id="presetGrid" class="grid grid-cols-2 gap-3"></div>
				</div>

				<textarea
					id="policyDescription"
					rows="5"
					class="w-full rounded-xl border px-3 py-2"
					placeholder="Descripción editable..."></textarea>

				<div class="flex justify-end gap-3">
					<button type="button" id="btnCancel">Cancelar</button>
					<button type="submit" class="rounded-xl bg-blue-600 px-4 py-2 text-white">
						Guardar
					</button>
				</div>
			</form>
		</dialog>
		<dialog id="historyModal" class="w-[600px] rounded-2xl p-6">
			<h2 class="mb-4 text-lg font-semibold">Historial</h2>

			<div id="historyContent" class="space-y-3"></div>

			<div class="mt-6 flex justify-end">
				<button onclick="document.getElementById('historyModal').close()">Cerrar</button>
			</div>
		</dialog>
	</article>
</section>

<script define:vars={{ scope, scopeId, resolveParams, POLICY_PRESETS, POLICY_CATEGORY_ORDER }}>
	const list = document.getElementById("policyList")
	const modal = document.getElementById("policyModal")
	const form = document.getElementById("policyForm")

	const idInput = document.getElementById("policyId")
	const descInput = document.getElementById("policyDescription")

	/* ================= UI ACTIONS ================= */

	document.getElementById("btnAdd").onclick = openCreateModal
	document.getElementById("btnCancel").onclick = () => modal.close()

	form.onsubmit = submitPolicy

	/* ================= CREATE ================= */

	const categories = Object.keys(POLICY_CATEGORY_ORDER).filter((cat) => cat !== "Cancellation")

	let currentCategory = null
	let assigned = []

	function openCreateModal() {
		renderCategoryRow()
		modal.showModal()
	}

	async function submitPolicy(e) {
		e.preventDefault()

		if (!currentCategory) {
			alert("Selecciona una categoría")
			return
		}

		const isEditing = !!idInput.value
		const endpoint = isEditing ? "/api/policies/create-version" : "/api/policies/create"

		const res = await fetch(endpoint, {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({
				previousPolicyId: idInput.value || null,
				description: descInput.value,
				scope,
				scopeId,
				category: currentCategory,
			}),
		})

		if (!res.ok) {
			alert("Error al guardar política")
			return
		}

		const data = await res.json()

		if (!isEditing) {
			idInput.value = data.id
		}

		modal.close()
		loadPolicies()
	}

	/* ================= PRESETS ================= */

	function renderCategoryRow() {
		const row = document.getElementById("categoryRow")
		row.innerHTML = ""

		const existingCategories = new Set(assigned.map((a) => a.category))

		categories.forEach((cat) => {
			const exists = existingCategories.has(cat)

			const btn = document.createElement("button")
			btn.type = "button"
			btn.className =
				"px-3 py-2 rounded-xl text-xs " +
				(exists ? "bg-neutral-900 text-white" : "bg-blue-600 text-white")

			const label = POLICY_CATEGORY_ORDER[cat]

			btn.textContent = exists ? `Editar ${label}` : `Crear ${label}`

			btn.onclick = async () => {
				currentCategory = cat

				const existing = assigned.find((a) => a.category === cat)

				if (!existing) {
					// Nueva policy
					idInput.value = ""
					descInput.value = ""
					renderPresets(cat)
					highlightSelectedCategory(btn)
					return
				}

				if (!existing) {
					idInput.value = ""
					descInput.value = ""
				} else {
					idInput.value = existing.id
					descInput.value = existing.description
				}

				renderPresets(cat)
				highlightSelectedCategory(btn)
			}

			row.appendChild(btn)
		})
	}

	function highlightSelectedCategory(activeBtn) {
		document.querySelectorAll("#categoryRow button").forEach((b) => {
			b.classList.add("opacity-40")
		})
		activeBtn.classList.remove("opacity-40")
	}

	function renderPresets(category) {
		const presets = POLICY_PRESETS[category] ?? []
		const grid = document.getElementById("presetGrid")
		grid.innerHTML = ""

		presets.forEach((p) => {
			const btn = document.createElement("button")
			btn.type = "button"
			btn.className = "p-3 bg-blue-50 border rounded-xl text-sm"
			btn.textContent = p.name

			btn.addEventListener("click", async () => {
				descInput.value += (descInput.value ? "\n" : "") + p.description
			})

			grid.appendChild(btn)
		})
	}

	/* ================= LOAD ================= */

	async function loadPolicies() {
		const res = await fetch(`/api/policies/assigned?scopeId=${scopeId}`)
		assigned = await res.json()
		assigned = assigned.filter(p => p.category !== "Cancellation")

		if (!assigned.length) {
			list.innerHTML = `<div class="text-sm text-neutral-500">No hay políticas aún.</div>`
			return
		}

		const grouped = {}

		assigned.forEach((p) => {
			if (!grouped[p.groupId]) {
				grouped[p.groupId] = []
			}
			grouped[p.groupId].push(p)
		})

		const html = Object.values(grouped)
			.map((versions) => {
				const active = versions.find((v) => v.status === "active")
				const draft = versions.find((v) => v.status === "draft")

				if (draft) return renderDraftPolicy(draft)
				if (active) return renderActivePolicy(active)
				return ""
			})
			.join("")

		list.innerHTML = html

		attachHistoryButtons()
		attachActivateButtons()
		attachDeleteButtons()
	}

	/* ================= RENDER ================= */

	function renderActivePolicy(p) {
		const label = POLICY_CATEGORY_ORDER[p.category]
		return `
		<div class="p-4 bg-white rounded-xl border">
			<p class="font-semibold">${label}</p>
			<p class="text-sm text-neutral-600">${p.description}</p>
			<p class="text-xs text-green-600 font-semibold">Activa</p>
			<button data-group="${p.groupId}" class="historyBtn text-blue-600 text-xs">
				Historial
				</button>
				</div>`
	}

	function renderDraftPolicy(p) {
		const label = POLICY_CATEGORY_ORDER[p.category]

		const isActive = p.status === "active"

		return `
	<div class="p-4 ${
		isActive ? "bg-white border" : "bg-yellow-50 border border-yellow-300"
	} rounded-xl">
		<p class="font-semibold">${label}</p>
		<p class="text-sm text-neutral-600">${p.description}</p>
		<p class="text-xs font-semibold ${isActive ? "text-green-600" : "text-yellow-700"}">
			${isActive ? "Activa" : "Borrador pendiente"}
		</p>
		${
			!isActive
				? `
			<div class="flex gap-3 mt-2">
				<button data-id="${p.id}" class="activateBtn bg-blue-600 text-white px-3 py-1 rounded-lg text-xs">
					Activar
				</button>
				<button data-id="${p.id}" class="deleteBtn bg-red-600 text-white px-3 py-1 rounded-lg text-xs">
					Eliminar
				</button>
			</div>
		`
				: ""
		}
		<button data-group="${p.groupId}" class="historyBtn text-blue-600 text-xs mt-2">
			Historial
		</button>
	</div>`
	}

	/* ================= ACTIONS ================= */

	function attachActivateButtons() {
		list.querySelectorAll(".activateBtn").forEach((btn) => {
			btn.onclick = async () => {
				await fetch("/api/policies/activate", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ policyId: btn.dataset.id }),
				})
				loadPolicies()
			}
		})
	}

	function attachHistoryButtons() {
		list.querySelectorAll(".historyBtn").forEach((btn) => {
			btn.onclick = async () => {
				const res = await fetch(`/api/policies/history?groupId=${btn.dataset.group}`)
				const versions = await res.json()
				showHistoryModal(versions)
			}
		})
	}

	function attachDeleteButtons() {
		list.querySelectorAll(".deleteBtn").forEach((btn) => {
			btn.onclick = async () => {
				if (!confirm("¿Eliminar borrador?")) return

				await fetch("/api/policies/delete", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ policyId: btn.dataset.id }),
				})

				loadPolicies()
			}
		})
	}

	function showHistoryModal(versions) {
		const historyModal = document.getElementById("historyModal")
		const historyContent = document.getElementById("historyContent")

		historyContent.innerHTML = versions
			.sort((a, b) => a.version - b.version)
			.map(
				(v) => `
					<div class="p-3 border rounded-xl">
						<p class="text-xs font-semibold">
							Versión ${v.version} - ${v.status}
						</p>
						<p class="text-xs text-neutral-600">
							${v.description}
						</p>
						<button data-id="${v.id}" class="activateBtn text-blue-600 text-xs mt-2">
							Activar
						</button>
					</div>
				`
			)
			.join("")

		historyModal.showModal()

		historyContent.querySelectorAll(".activateBtn").forEach((btn) => {
			btn.onclick = async () => {
				await fetch("/api/policies/activate", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ policyId: btn.dataset.id }),
				})
				historyModal.close()
				loadPolicies()
			}
		})
	}

	loadPolicies()
</script>
