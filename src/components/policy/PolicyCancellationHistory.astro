<div
	data-modal="history"
	id="history-modal"
	class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm"
>
	<div class="w-full max-w-2xl rounded-3xl bg-white p-8 shadow-2xl">
		<div class="mb-6 flex items-center justify-between">
			<h2 class="text-lg font-semibold text-neutral-800">Historial de Versiones</h2>

			<button data-close-modal class="text-sm text-neutral-500 hover:text-black"> Cerrar </button>
		</div>

		<div id="historyContent" class="max-h-[400px] space-y-4 overflow-y-auto pr-2"></div>
	</div>
</div>

<script type="module">
	import { openModal, registerModal } from "/src/lib/utils/modal-manager"
	const content = document.getElementById("historyContent")
	let currentVersions = []

	registerModal("history", {
		onOpen() {
			if (!content || !currentVersions.length) return

			content.innerHTML = currentVersions
				.sort((a, b) => b.version - a.version)
				.map((v) => {
					const isActive = v.status === "active"

					return `
						<div class="relative pl-6 border-l-2 ${isActive ? "border-green-500" : "border-neutral-300"}">
							<div class="absolute -left-[9px] top-2 h-4 w-4 rounded-full ${
								isActive ? "bg-green-500" : "bg-neutral-400"
							}"></div>

							<div class="rounded-2xl border bg-neutral-50 p-4 shadow-sm">
								<div class="flex items-center justify-between">
									<p class="text-sm font-semibold text-neutral-800">
										Versión ${v.version}
									</p>
									<span class="text-xs px-2 py-1 rounded-full ${
										isActive ? "bg-green-100 text-green-700" : "bg-yellow-100 text-yellow-700"
									}">
										${v.status}
									</span>
								</div>

								<p class="mt-2 text-sm text-neutral-600">
									${v.description}
								</p>

								${
									!isActive
										? `
											<button 
												data-id="${v.id}" 
												class="activateFromHistory mt-3 text-xs text-blue-600 hover:underline"
											>
												Activar esta versión
											</button>
										`
										: ""
								}
							</div>
						</div>
					`
				})
				.join("")

			attachHistoryActions()
		},
	})

	function attachHistoryActions() {
		document.querySelectorAll(".activateFromHistory").forEach((btn) => {
			btn.addEventListener("click", async () => {
				await fetch("/api/policies/activate", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ policyId: btn.dataset.id }),
				})

				window.dispatchEvent(new Event("cancellation:created"))
			})
		})
	}

	window.openHistoryModal = function (versions) {
		currentVersions = versions || []
		openModal("history")
	}
</script>
