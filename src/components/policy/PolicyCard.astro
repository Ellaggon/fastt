---
export type PolicyCardSource = "rate_plan" | "variant" | "product" | "global"
export type PolicyCardState = "override" | "inherited" | "missing"

export type Props = {
	category: string
	description: string
	version?: number
	source?: PolicyCardSource
	state?: PolicyCardState
}

const { category, description, version = 0, source = "global", state = "missing" } = Astro.props

const sourceLabel = (() => {
	if (state === "missing") return "Sin condición asignada"
	if (source === "rate_plan") return "Definida en tarifa"
	if (source === "variant") return "Heredada desde variante"
	if (source === "product") return "Heredada desde producto"
	return "Predeterminada global"
})()

const badge = (() => {
	if (state === "missing")
		return { label: "Predeterminada", className: "bg-neutral-100 text-neutral-800" }
	if (source === "rate_plan") return { label: "Definida", className: "bg-green-100 text-green-900" }
	if (source === "variant")
		return { label: "Heredada (variante)", className: "bg-yellow-100 text-yellow-900" }
	if (source === "product")
		return { label: "Heredada (producto)", className: "bg-blue-100 text-blue-900" }
	return { label: "Predeterminada", className: "bg-neutral-100 text-neutral-800" }
})()

const lines = String(description ?? "")
	.split("\n")
	.map((s) => s.trim())
	.filter(Boolean)
---

<article class="space-y-2 rounded border p-3">
	<header class="flex items-start justify-between gap-3">
		<div class="space-y-1">
			<h3 class="font-semibold">{category}</h3>
			<p class="text-xs text-neutral-600">
				{sourceLabel} | Versión: {version ? `v${version}` : "—"}
			</p>
		</div>
		<span class={`text-xs px-2 py-1 rounded ${badge.className}`}>{badge.label}</span>
	</header>

	{
		state === "missing" ? (
			<p class="text-sm text-neutral-700">Sin condición asignada.</p>
		) : lines.length ? (
			<ul class="list-disc space-y-1 pl-5 text-sm text-neutral-700">
				{lines.map((l) => (
					<li>{l.replace(/^- /, "")}</li>
				))}
			</ul>
		) : (
			<p class="text-sm text-neutral-700">Sin detalles.</p>
		)
	}
</article>
