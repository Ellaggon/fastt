---
import Badge from "@/components/ui/Badge.astro"

export type PolicyCardSource = "rate_plan" | "variant" | "product" | "global"
export type PolicyCardState = "override" | "inherited" | "missing"

export type Props = {
	category: string
	description: string
	version?: number
	source?: PolicyCardSource
	state?: PolicyCardState
}

const { category, description, version = 0, source = "global", state = "missing" } = Astro.props

const sourceLabel = (() => {
	if (state === "missing") return "Sin condición asignada"
	if (source === "rate_plan") return "Definida en tarifa"
	if (source === "variant") return "Heredada desde variante"
	if (source === "product") return "Heredada desde producto"
	return "Predeterminada global"
})()

const badge = (() => {
	if (state === "missing") return { label: "Predeterminada", variant: "neutral" }
	if (source === "rate_plan") return { label: "Definida", variant: "success" }
	if (source === "variant") return { label: "Heredada (variante)", variant: "warning" }
	if (source === "product") return { label: "Heredada (producto)", variant: "info" }
	return { label: "Predeterminada", variant: "neutral" }
})()

const lines = String(description ?? "")
	.split("\n")
	.map((s) => s.trim())
	.filter(Boolean)
---

<article class="fastt-row-card space-y-2 p-3">
	<header class="flex items-start justify-between gap-3">
		<div class="space-y-1">
			<h3 class="font-semibold">{category}</h3>
			<p class="text-xs text-slate-500">
				{sourceLabel} | Versión: {version ? `v${version}` : "—"}
			</p>
		</div>
		<Badge variant={badge.variant} class="px-2 py-1 text-xs">{badge.label}</Badge>
	</header>

	{
		state === "missing" ? (
			<p class="text-sm text-slate-600">Sin condición asignada.</p>
		) : lines.length ? (
			<ul class="list-disc space-y-1 pl-5 text-sm text-slate-600">
				{lines.map((l) => (
					<li>{l.replace(/^- /, "")}</li>
				))}
			</ul>
		) : (
			<p class="text-sm text-slate-600">Sin detalles.</p>
		)
	}
</article>
