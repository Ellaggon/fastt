---
const { scope, scopeId } = Astro.props
---

<div
	data-modal="cancellation"
	class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/70"
>
	<div class="w-[620px] space-y-6 rounded-2xl bg-white p-8 text-neutral-800">
		<h2 class="text-lg font-semibold">Política de Cancelación</h2>

		<div id="tiersContainer" class="space-y-4"></div>

		<button id="addTier" class="text-sm text-blue-600"> + Agregar tramo </button>

		<div class="flex justify-end gap-3 pt-4">
			<button data-close-modal>Cancelar</button>
			<button id="saveCancelPolicy" class="rounded-xl bg-blue-600 px-4 py-2 text-white">
				Guardar
			</button>
		</div>
	</div>
</div>

<script type="module" define:vars={{ scope, scopeId }}>
	import { registerModal } from "/src/lib/utils/modal-manager"

	const tiersContainer = document.getElementById("tiersContainer")
	let currentEditingPolicy = null

	registerModal("cancellation", {
		onOpen(modal) {
			tiersContainer.innerHTML = ""

			if (modal.dataset.editPolicy) {
				currentEditingPolicy = JSON.parse(modal.dataset.editPolicy)
				currentEditingPolicy.cancellationTiers.forEach((t) => addTier(t))
			} else {
				currentEditingPolicy = null
				addTier()
			}
		},
		onClose(modal) {
			modal.dataset.editPolicy = ""
		},
	})

	document.getElementById("addTier").onclick = () => addTier()

	function addTier(data = {}) {
		const div = document.createElement("div")
		div.className = "border p-4 rounded-xl space-y-3 bg-neutral-50"

		div.innerHTML = `
			<div>
				<label class="text-sm font-medium">Días antes de llegada</label>
				<input type="number"
					class="days border p-2 rounded w-full mt-1"
					value="${data.daysBeforeArrival ?? 0}"
				/>
			</div>

			<div>
				<label class="text-sm font-medium">Tipo penalidad</label>
				<select class="type border p-2 rounded w-full mt-1">
					<option value="percentage" ${data.penaltyType === "percentage" ? "selected" : ""}>Porcentaje</option>
					<option value="nights" ${data.penaltyType === "nights" ? "selected" : ""}>Noches</option>
				</select>
			</div>

			<div>
				<label class="text-sm font-medium">Monto</label>
				<input type="number"
					class="amount border p-2 rounded w-full mt-1"
					value="${data.penaltyAmount ?? 100}"
				/>
			</div>

			<button class="removeTier text-red-600 text-xs">Eliminar tramo</button>
		`

		div.querySelector(".removeTier").onclick = () => div.remove()
		tiersContainer.appendChild(div)
	}

	document.getElementById("saveCancelPolicy").onclick = async () => {
		const tiers = [...tiersContainer.children].map((div) => ({
			daysBeforeArrival: Number(div.querySelector(".days").value),
			penaltyType: div.querySelector(".type").value,
			penaltyAmount: Number(div.querySelector(".amount").value),
		}))

		if (!tiers.length) {
			alert("Debe agregar al menos un tramo.")
			return
		}

		const description = buildDescription(tiers)

		const endpoint = currentEditingPolicy ? "/api/policies/create-version" : "/api/policies/create"

		const res = await fetch(endpoint, {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({
				category: "Cancellation",
				scope,
				scopeId,
				description,
				cancellationTiers: tiers,
				previousPolicyId: currentEditingPolicy?.id,
			}),
		})

		if (!res.ok) {
			alert(await res.text())
			return
		}

		window.dispatchEvent(new Event("cancellation:created"))
		document.querySelector(`[data-modal="cancellation"]`)?.click()
	}

	function buildDescription(tiers) {
		return tiers
			.sort((a, b) => b.daysBeforeArrival - a.daysBeforeArrival)
			.map((t) =>
				t.daysBeforeArrival === 0
					? `El día de llegada: ${t.penaltyAmount}${t.penaltyType === "percentage" ? "%" : " noche(s)"}`
					: `${t.daysBeforeArrival} días antes: ${t.penaltyAmount}${t.penaltyType === "percentage" ? "%" : " noche(s)"}`
			)
			.join(". ")
	}
</script>
