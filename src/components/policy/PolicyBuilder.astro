---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import { POLICY_PRESET_CATALOG } from "@/data/policy/policy-presets"
import { routes } from "@/lib/routes"

type BuilderMode = "create" | "version"

type InitialValues = {
	category?: string
	name?: string
	policyPresetKey?: string
	stayLengthType?: string
	gracePeriod?: number | string | null
	refundBasis?: string | null
	payoutBasis?: string | null
	localTimezone?: string | null
	legalOverrideFlags?: Record<string, boolean> | string | null
	rules?: Record<string, unknown>
	cancellationTiers?: Array<{
		daysBeforeArrival?: number | string | null
		penaltyAmount?: number | string | null
		penaltyType?: string | null
	}>
}

type Props = {
	mode?: BuilderMode
	error?: string | null
	fieldErrors?: Record<string, string>
	initialValues?: InitialValues
	previousPolicyId?: string
	policyGroupId?: string
}

const {
	mode = "create",
	error = null,
	fieldErrors = {},
	initialValues = {},
	previousPolicyId = "",
	policyGroupId = "",
} = Astro.props as Props

const isVersionMode = mode === "version"

const categoryLabels: Record<string, string> = {
	Cancellation: "Cancelación",
	Payment: "Pago",
	CheckIn: "Ingreso / salida",
	NoShow: "No presentación",
}
const categoryDescriptions: Record<string, string> = {
	Cancellation: "Ventanas de reembolso, penalidades y trato de impuestos/cargos.",
	Payment: "Cuándo paga el huésped y si existe prepago antes de llegar.",
	CheckIn: "Horarios operativos de llegada y salida visibles antes de reservar.",
	NoShow: "Cargo aplicable cuando el huésped no llega y no canceló.",
}
const presetLabels: Record<string, string> = {
	flexible: "Flexible",
	moderate: "Moderada",
	limited: "Limitada",
	firm: "Firme",
	strict: "Estricta",
	long_term: "Larga estadía",
	non_refundable: "No reembolsable",
	pay_at_property: "Pago en propiedad",
	prepayment_full: "Prepago total",
	deposit_50: "Depósito 50%",
	standard_check_in: "Ingreso estándar",
	late_arrival: "Llegada tardía",
	no_show_first_night: "No presentación: primera noche",
	no_show_full_stay: "No presentación: estadía completa",
	no_show_percentage_100: "No presentación: 100%",
}
const presetDescriptions: Record<string, string> = {
	flexible: "Cancelación gratis hasta 1 día antes.",
	moderate: "Cancelación gratis hasta 5 días antes.",
	limited: "Gratis hasta 7 días antes; luego penalidad parcial/completa.",
	firm: "Gratis hasta 30 días antes; luego penalidad escalonada.",
	strict: "Reembolso parcial solo con mucha anticipación.",
	long_term: "Para estadías de 28 noches o más.",
	non_refundable: "Sin reembolso por cancelación.",
	pay_at_property: "El huésped paga en la propiedad.",
	prepayment_full: "El huésped prepaga 100%.",
	deposit_50: "El huésped prepaga 50%.",
	standard_check_in: "Llegada 15:00-22:00; salida 11:00.",
	late_arrival: "Permite llegada hasta medianoche.",
	no_show_first_night: "No presentación cobra primera noche.",
	no_show_full_stay: "No presentación cobra estadía completa.",
	no_show_percentage_100: "No presentación cobra 100%.",
}

function presetCopy(preset: any) {
	return {
		...preset,
		displayName: presetLabels[preset.key] ?? preset.name,
		displayDescription: presetDescriptions[preset.key] ?? preset.description,
		categoryLabel: categoryLabels[preset.category] ?? preset.category,
	}
}

const presetsByCategory = POLICY_PRESET_CATALOG.reduce(
	(acc, preset) => {
		acc[preset.category] ??= []
		acc[preset.category].push(presetCopy(preset))
		return acc
	},
	{} as Record<string, any[]>
)

const selectedCategory = String(initialValues.category ?? "").trim()
const selectedRules = initialValues.rules ?? {}
const selectedTiers =
	Array.isArray(initialValues.cancellationTiers) && initialValues.cancellationTiers.length
		? initialValues.cancellationTiers
		: [{ daysBeforeArrival: "", penaltyAmount: "" }]

function legalOverrideText(value: InitialValues["legalOverrideFlags"]) {
	if (!value) return ""
	if (typeof value === "string") return value
	try {
		return JSON.stringify(value, null, 2)
	} catch {
		return ""
	}
}
---

{
	error && (
		<Card className="border-red-200 bg-red-50 text-red-900">
			<p class="text-sm font-semibold">
				{isVersionMode ? "No se pudo crear la nueva versión" : "No se pudo crear la condición"}
			</p>
			<p class="mt-1 text-sm">{error}</p>
		</Card>
	)
}

<Card className="bg-white text-slate-900">
	<form
		method="POST"
		id="policyBuilderForm"
		class="space-y-8"
		novalidate
		data-policy-builder-mode={mode}
	>
		<input type="hidden" name="libraryStatus" id="libraryStatus" value="draft" />
		<input
			type="hidden"
			name="policyPresetKey"
			id="policyPresetKey"
			value={initialValues.policyPresetKey ?? ""}
		/>
		{isVersionMode && <input type="hidden" name="previousPolicyId" value={previousPolicyId} />}
		{
			isVersionMode && (
				<input type="hidden" name="category" id="category" value={selectedCategory} />
			)
		}

		<div
			id="clientErrorBox"
			class="hidden rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-900"
		>
			<strong>Error:</strong>
			<span id="clientErrorText"></span>
		</div>

		<nav class="grid gap-2 text-sm md:grid-cols-4" aria-label="Pasos para crear una condición">
			<div class="rounded-md border border-blue-200 bg-blue-50 p-3 text-blue-950">
				<p class="font-semibold">1. Categoría y plantilla</p>
				<p class="text-xs">Elige la base OTA.</p>
			</div>
			<div class="rounded-md border border-slate-200 bg-slate-50 p-3">
				<p class="font-semibold">2. Campos humanos</p>
				<p class="text-xs text-slate-600">Ajusta lo visible.</p>
			</div>
			<div class="rounded-md border border-slate-200 bg-slate-50 p-3">
				<p class="font-semibold">3. Vista previa</p>
				<p class="text-xs text-slate-600">Ejemplos calculables.</p>
			</div>
			<div class="rounded-md border border-slate-200 bg-slate-50 p-3">
				<p class="font-semibold">4. Guardar</p>
				<p class="text-xs text-slate-600">Borrador o publicar.</p>
			</div>
		</nav>

		<section class="space-y-4" id="stepCategoryPreset">
			<div>
				<p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Paso 1</p>
				<h2 class="text-xl font-semibold">Categoría y plantilla</h2>
				<p class="mt-1 text-sm text-slate-600">
					La plantilla carga reglas estructuradas. Puedes editar los campos humanos en el paso
					siguiente.
				</p>
			</div>

			<div class="grid gap-3 md:grid-cols-4">
				{
					Object.entries(categoryLabels).map(([value, label]) => {
						const lockedInactive = isVersionMode && value !== selectedCategory
						const lockedActive = isVersionMode && value === selectedCategory
						return (
							<button
								type="button"
								class:list={[
									"rounded-md border p-4 text-left transition",
									lockedActive ? "border-blue-500 bg-blue-50 text-blue-950" : "border-slate-200",
									lockedInactive
										? "cursor-not-allowed bg-slate-100 opacity-50"
										: "hover:border-blue-300 hover:bg-blue-50",
								]}
								data-category-choice={value}
								disabled={lockedInactive || lockedActive}
								aria-disabled={isVersionMode ? "true" : "false"}
							>
								<span class="block font-semibold">{label}</span>
								<span class="mt-1 block text-xs leading-5 text-slate-600">
									{categoryDescriptions[value]}
								</span>
								{lockedActive && (
									<span class="mt-2 block text-xs font-semibold">Bloqueada para esta versión</span>
								)}
							</button>
						)
					})
				}
			</div>

			{
				isVersionMode ? (
					<div class="grid gap-3 md:grid-cols-2">
						<label class="block space-y-1 text-sm">
							<span class="font-medium text-slate-700">Categoría contractual</span>
							<input
								class="w-full cursor-not-allowed rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-slate-600"
								value={categoryLabels[selectedCategory] ?? selectedCategory}
								readonly
								aria-readonly="true"
							/>
							<p class="text-xs text-slate-500">
								Bloqueado: editar crea una nueva versión dentro del mismo grupo contractual.
							</p>
						</label>
						<label class="block space-y-1 text-sm">
							<span class="font-medium text-slate-700">Grupo contractual</span>
							<input
								class="w-full cursor-not-allowed rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-slate-600"
								value={policyGroupId}
								readonly
								aria-readonly="true"
							/>
							<p class="text-xs text-slate-500">
								Bloqueado: las asignaciones apuntan al grupo, no a una versión editable.
							</p>
						</label>
					</div>
				) : (
					<label class="block space-y-1 text-sm">
						<span class="font-medium text-slate-700">Categoría contractual</span>
						<select
							name="category"
							id="category"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
						>
							<option value="">Seleccionar...</option>
							{Object.entries(categoryLabels).map(([value, label]) => (
								<option value={value} selected={selectedCategory === value}>
									{label}
								</option>
							))}
						</select>
						<p class="text-sm text-red-700" id="err-category">
							{fieldErrors["category"]}
						</p>
					</label>
				)
			}

			<div class="space-y-3">
				<p class="text-sm font-semibold text-slate-700">Plantillas disponibles</p>
				<div id="presetGrid" class="grid gap-3 lg:grid-cols-2">
					{
						Object.entries(presetsByCategory).flatMap(([category, presets]) =>
							presets.map((preset) => (
								<button
									type="button"
									class="hidden rounded-md border border-slate-200 p-4 text-left transition hover:border-blue-300 hover:bg-blue-50"
									data-policy-template={JSON.stringify({ category, template: preset })}
									data-preset-category={category}
								>
									<span class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
										{preset.categoryLabel}
									</span>
									<span class="mt-1 block font-semibold text-slate-900">{preset.displayName}</span>
									<span class="mt-1 block text-sm text-slate-600">{preset.displayDescription}</span>
								</button>
							))
						)
					}
				</div>
				{
					isVersionMode && (
						<p class="text-xs text-slate-500">
							La plantilla puede cambiar la nueva versión, pero la categoría contractual permanece
							bloqueada.
						</p>
					)
				}
			</div>
		</section>

		<section class="space-y-4" id="stepHumanFields">
			<div>
				<p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Paso 2</p>
				<h2 class="text-xl font-semibold">Campos humanos por categoría</h2>
			</div>

			<label class="block space-y-1 text-sm">
				<span class="font-medium text-slate-700">Nombre humano</span>
				<input
					name="name"
					id="policyName"
					minlength="2"
					class="w-full rounded-lg border border-slate-300 px-3 py-2"
					placeholder="Flexible 24h · Web"
					value={initialValues.name ?? ""}
				/>
				<p class="text-xs text-slate-500">
					Nombre operativo para la biblioteca; no se muestra como ID al huésped.
				</p>
				<p class="text-sm text-red-700" id="err-name">
					{fieldErrors["description"] || fieldErrors["name"]}
				</p>
			</label>

			<section
				class:list={[
					"space-y-3",
					selectedCategory && selectedCategory !== "Cancellation" ? "hidden" : "",
				]}
				id="cancellationFields"
			>
				<div class="rounded-md border-l-4 border-blue-500 bg-blue-50 p-3 text-sm text-blue-950">
					Define ventanas: mientras más cerca de la llegada, mayor puede ser la penalidad.
				</div>
				<div id="tiers" class="space-y-2">
					{
						selectedTiers.map((tier) => (
							<div class="tier-row grid gap-2 md:grid-cols-[1fr_1fr_auto]">
								<label class="space-y-1 text-sm">
									<span>Días antes de llegada</span>
									<input
										name="daysBeforeArrival"
										type="number"
										min="0"
										class="w-full rounded-lg border border-slate-300 px-3 py-2"
										value={tier.daysBeforeArrival ?? ""}
									/>
								</label>
								<label class="space-y-1 text-sm">
									<span>Penalidad para el huésped (%)</span>
									<input
										name="penaltyPercent"
										type="number"
										min="0"
										max="100"
										class="w-full rounded-lg border border-slate-300 px-3 py-2"
										value={tier.penaltyAmount ?? ""}
									/>
								</label>
								<button
									type="button"
									class="self-end rounded-lg border border-slate-300 px-3 py-2 text-sm"
									data-remove-tier
								>
									Quitar
								</button>
							</div>
						))
					}
				</div>
				<button
					type="button"
					class="rounded-lg border border-slate-300 px-3 py-2 text-sm"
					id="addTier"
				>
					Agregar tramo
				</button>
				<p class="text-sm text-red-700" id="err-cancellationTiers">
					{fieldErrors["cancellationTiers"]}
				</p>
			</section>

			<section
				class:list={["space-y-3", selectedCategory === "Payment" ? "" : "hidden"]}
				id="paymentFields"
			>
				<label class="space-y-1 text-sm">
					<span>¿Cómo paga el huésped?</span>
					<select
						name="paymentType"
						id="paymentType"
						class="w-full rounded-lg border border-slate-300 px-3 py-2"
					>
						<option value="">Seleccionar...</option>
						<option
							value="pay_at_property"
							selected={String(selectedRules.paymentType ?? "") === "pay_at_property"}
							>Paga en la propiedad</option
						>
						<option
							value="prepayment"
							selected={String(selectedRules.paymentType ?? "") === "prepayment"}
							>Prepaga antes de llegar</option
						>
					</select>
					<p class="text-sm text-red-700" id="err-paymentType">{fieldErrors["paymentType"]}</p>
				</label>
				<div class="grid gap-2 md:grid-cols-2" id="prepaymentFields">
					<label class="space-y-1 text-sm">
						<span>Porcentaje de prepago</span>
						<input
							name="prepaymentPercentage"
							type="number"
							min="1"
							max="100"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							value={String(selectedRules.prepaymentPercentage ?? "")}
						/>
						<p class="text-sm text-red-700" id="err-prepaymentPercentage">
							{fieldErrors["prepaymentPercentage"]}
						</p>
					</label>
					<label class="space-y-1 text-sm">
						<span>Días antes de llegada</span>
						<input
							name="prepaymentDaysBeforeArrival"
							type="number"
							min="0"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							value={String(selectedRules.prepaymentDaysBeforeArrival ?? "")}
						/>
					</label>
				</div>
			</section>

			<section
				class:list={["space-y-3", selectedCategory === "CheckIn" ? "" : "hidden"]}
				id="checkinFields"
			>
				<div class="grid gap-2 md:grid-cols-3">
					<label class="space-y-1 text-sm">
						<span>Ingreso desde</span>
						<input
							name="checkInFrom"
							type="time"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							value={String(selectedRules.checkInFrom ?? "")}
						/>
						<p class="text-sm text-red-700" id="err-checkInFrom">{fieldErrors["checkInFrom"]}</p>
					</label>
					<label class="space-y-1 text-sm">
						<span>Ingreso hasta</span>
						<input
							name="checkInUntil"
							type="time"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							value={String(selectedRules.checkInUntil ?? "")}
						/>
						<p class="text-sm text-red-700" id="err-checkInUntil">{fieldErrors["checkInUntil"]}</p>
					</label>
					<label class="space-y-1 text-sm">
						<span>Salida hasta</span>
						<input
							name="checkOutUntil"
							type="time"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							value={String(selectedRules.checkOutUntil ?? "")}
						/>
						<p class="text-sm text-red-700" id="err-checkOutUntil">
							{fieldErrors["checkOutUntil"]}
						</p>
					</label>
				</div>
			</section>

			<section
				class:list={["space-y-3", selectedCategory === "NoShow" ? "" : "hidden"]}
				id="noshowFields"
			>
				<label class="space-y-1 text-sm">
					<span>¿Qué se cobra si el huésped no llega?</span>
					<select
						name="noShowPenaltyType"
						id="noShowPenaltyType"
						class="w-full rounded-lg border border-slate-300 px-3 py-2"
					>
						<option value="">Seleccionar...</option>
						<option
							value="first_night"
							selected={String(selectedRules.penaltyType ?? "") === "first_night"}
							>Primera noche</option
						>
						<option value="full" selected={String(selectedRules.penaltyType ?? "") === "full"}
							>Estadía completa</option
						>
						<option
							value="percentage"
							selected={String(selectedRules.penaltyType ?? "") === "percentage"}>Porcentaje</option
						>
					</select>
					<p class="text-sm text-red-700" id="err-noShowPenaltyType">
						{fieldErrors["noShowPenaltyType"]}
					</p>
				</label>
				<label class="space-y-1 text-sm" id="noshowAmountRow">
					<span>Porcentaje a cobrar</span>
					<input
						name="noShowPenaltyAmount"
						type="number"
						min="0"
						max="100"
						class="w-full rounded-lg border border-slate-300 px-3 py-2"
						value={String(selectedRules.penaltyAmount ?? "")}
					/>
					<p class="text-sm text-red-700" id="err-noShowPenaltyAmount">
						{fieldErrors["noShowPenaltyAmount"]}
					</p>
				</label>
			</section>

			<details class="rounded-md border border-slate-200 p-4">
				<summary class="cursor-pointer text-sm font-semibold text-slate-700">Avanzado</summary>
				<div class="mt-4 grid gap-3 md:grid-cols-3">
					<label class="space-y-1 text-sm">
						<span>Duración de estadía</span>
						<select
							name="stayLengthType"
							id="stayLengthType"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
						>
							<option value="any" selected={String(initialValues.stayLengthType ?? "any") === "any"}
								>Cualquier estadía</option
							>
							<option
								value="short_stay"
								selected={String(initialValues.stayLengthType ?? "") === "short_stay"}
								>Estadía corta</option
							>
							<option
								value="long_stay"
								selected={String(initialValues.stayLengthType ?? "") === "long_stay"}
								>Estadía larga</option
							>
							<option
								value="monthly"
								selected={String(initialValues.stayLengthType ?? "") === "monthly"}>Mensual</option
							>
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span>Periodo de gracia (horas)</span>
						<input
							name="gracePeriod"
							id="gracePeriod"
							type="number"
							min="0"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							value={initialValues.gracePeriod ?? ""}
						/>
					</label>
					<label class="space-y-1 text-sm">
						<span>Zona horaria local</span>
						<input
							name="localTimezone"
							id="localTimezone"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							placeholder="property_local"
							value={initialValues.localTimezone ?? ""}
						/>
					</label>
					<label class="space-y-1 text-sm">
						<span>Base de reembolso</span>
						<select
							name="refundBasis"
							id="refundBasis"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
						>
							<option value="">Seleccionar...</option>
							<option value="total_booking" selected={initialValues.refundBasis === "total_booking"}
								>Reserva total</option
							>
							<option value="room_rate" selected={initialValues.refundBasis === "room_rate"}
								>Tarifa de habitación</option
							>
							<option value="first_night" selected={initialValues.refundBasis === "first_night"}
								>Primera noche</option
							>
							<option value="deposit" selected={initialValues.refundBasis === "deposit"}
								>Depósito</option
							>
							<option
								value="provider_policy"
								selected={initialValues.refundBasis === "provider_policy"}
								>Condición del proveedor</option
							>
							<option value="none" selected={initialValues.refundBasis === "none"}>Ninguna</option>
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span>Base de pago al proveedor</span>
						<select
							name="payoutBasis"
							id="payoutBasis"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
						>
							<option value="">Seleccionar...</option>
							<option value="gross" selected={initialValues.payoutBasis === "gross"}>Bruto</option>
							<option value="net" selected={initialValues.payoutBasis === "net"}>Neto</option>
							<option value="collected" selected={initialValues.payoutBasis === "collected"}
								>Cobrado</option
							>
							<option
								value="provider_policy"
								selected={initialValues.payoutBasis === "provider_policy"}
								>Condición del proveedor</option
							>
						</select>
					</label>
					<label class="space-y-1 text-sm md:col-span-3">
						<span>Excepciones legales JSON</span>
						<textarea
							name="legalOverrideFlags"
							id="legalOverrideFlags"
							rows="3"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							placeholder='{"requiresManualReview":true}'
							>{legalOverrideText(initialValues.legalOverrideFlags)}</textarea
						>
					</label>
				</div>
			</details>
		</section>

		<section class="space-y-4" id="stepPreview">
			<div>
				<p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Paso 3</p>
				<h2 class="text-xl font-semibold">Vista previa con ejemplos calculables</h2>
				<p class="mt-1 text-sm text-slate-600">
					Estos ejemplos son una vista previa del contrato. El cálculo final ocurre en backend con
					snapshot, fechas y monto real.
				</p>
			</div>
			<div class="grid gap-3 md:grid-cols-2" id="previewExamples">
				<div class="rounded-md border border-slate-200 p-4">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Cancelación hoy
					</p>
					<p class="mt-2 text-sm" id="previewCancelToday">Selecciona categoría y plantilla.</p>
				</div>
				<div class="rounded-md border border-slate-200 p-4">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Cancelación 7 días antes
					</p>
					<p class="mt-2 text-sm" id="previewCancelWeek">Completa los campos humanos.</p>
				</div>
				<div class="rounded-md border border-slate-200 p-4">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">28+ noches</p>
					<p class="mt-2 text-sm" id="previewLongStay">Resumen pendiente.</p>
				</div>
				<div class="rounded-md border border-slate-200 p-4">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Impuestos/cargos
					</p>
					<p class="mt-2 text-sm" id="previewTaxesFees">Impacto pendiente.</p>
				</div>
				<div class="rounded-md border border-slate-200 p-4">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Cobro del proveedor
					</p>
					<p class="mt-2 text-sm" id="previewProviderPayout">Pendiente.</p>
				</div>
				<div class="rounded-md border border-slate-200 p-4">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						No presentación
					</p>
					<p class="mt-2 text-sm" id="previewNoShow">Pendiente.</p>
				</div>
				<div class="rounded-md border border-slate-200 p-4 md:col-span-2">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Pago pendiente</p>
					<p class="mt-2 text-sm" id="previewPaymentDue">Pendiente.</p>
				</div>
			</div>
		</section>

		<section class="space-y-4" id="stepSave">
			<div>
				<p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Paso 4</p>
				<h2 class="text-xl font-semibold">
					{isVersionMode ? "Guardar nueva versión o publicar" : "Guardar borrador o publicar"}
				</h2>
				<p class="mt-1 text-sm text-slate-600">
					{
						isVersionMode
							? "Editar no cambia la versión anterior: crea una nueva versión contractual en el mismo grupo."
							: "Guardar como borrador permite seguir editando. Publicar crea una condición activa lista para asignación."
					}
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				<button
					type="submit"
					class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-500 hover:text-slate-950"
					data-submit-status="draft"
				>
					{isVersionMode ? "Guardar nueva versión como borrador" : "Guardar borrador"}
				</button>
				<button
					type="submit"
					class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700"
					data-submit-status="active"
				>
					{isVersionMode ? "Crear versión y publicar" : "Publicar"}
				</button>
				<Button href={routes.providerPolicies()} variant="secondary">Cancelar</Button>
			</div>
		</section>
	</form>
</Card>

<script is:inline define:vars={{ presetsByCategory, mode }}>
	const form = document.getElementById("policyBuilderForm")
	const categorySel = document.getElementById("category")
	const paymentTypeSel = document.getElementById("paymentType")
	const noShowPenaltyTypeSel = document.getElementById("noShowPenaltyType")
	const clientErrorBox = document.getElementById("clientErrorBox")
	const clientErrorText = document.getElementById("clientErrorText")
	const libraryStatusInput = document.getElementById("libraryStatus")
	const isVersionMode = mode === "version"
	const sections = {
		Cancellation: document.getElementById("cancellationFields"),
		Payment: document.getElementById("paymentFields"),
		CheckIn: document.getElementById("checkinFields"),
		NoShow: document.getElementById("noshowFields"),
	}

	function setClientError(message) {
		if (!clientErrorBox || !clientErrorText) return
		clientErrorText.textContent = message || ""
		clientErrorBox.classList.toggle("hidden", !message)
	}

	function inputByName(name) {
		return form?.querySelector(`[name="${name}"]`)
	}

	function inputValue(name) {
		return String(inputByName(name)?.value || "").trim()
	}

	function setInput(name, value) {
		const input = inputByName(name)
		if (input) input.value = value == null ? "" : String(value)
	}

	function selectedCategory() {
		return String(categorySel?.value || "")
	}

	function updatePresetVisibility() {
		const category = selectedCategory()
		document.querySelectorAll("[data-policy-template]").forEach((button) => {
			button.classList.toggle("hidden", button.getAttribute("data-preset-category") !== category)
		})
		document.querySelectorAll("[data-category-choice]").forEach((button) => {
			const active = button.getAttribute("data-category-choice") === category
			button.classList.toggle("border-blue-500", active)
			button.classList.toggle("bg-blue-50", active)
		})
	}

	function updateCategoryUI() {
		const category = selectedCategory()
		for (const [key, section] of Object.entries(sections)) {
			section?.classList.toggle("hidden", key !== category)
		}
		updatePresetVisibility()
		updatePaymentUI()
		updateNoShowUI()
		updatePreview()
	}

	function updatePaymentUI() {
		const pre = document.getElementById("prepaymentFields")
		pre?.classList.toggle("hidden", paymentTypeSel?.value !== "prepayment")
	}

	function updateNoShowUI() {
		const row = document.getElementById("noshowAmountRow")
		row?.classList.toggle("hidden", noShowPenaltyTypeSel?.value !== "percentage")
	}

	function escapeHtml(value) {
		return String(value ?? "")
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
	}

	function resetTiers(tiers) {
		const container = document.getElementById("tiers")
		if (!container) return
		container.innerHTML = ""
		for (const tier of tiers || []) {
			const row = document.createElement("div")
			row.className = "tier-row grid gap-2 md:grid-cols-[1fr_1fr_auto]"
			row.innerHTML = `
				<label class="space-y-1 text-sm">
					<span>Días antes de llegada</span>
					<input name="daysBeforeArrival" type="number" min="0" class="w-full rounded-lg border border-slate-300 px-3 py-2" value="${escapeHtml(tier.daysBeforeArrival ?? "")}" />
				</label>
				<label class="space-y-1 text-sm">
					<span>Penalidad para el huésped (%)</span>
					<input name="penaltyPercent" type="number" min="0" max="100" class="w-full rounded-lg border border-slate-300 px-3 py-2" value="${escapeHtml(tier.penaltyAmount ?? "")}" />
				</label>
				<button type="button" class="self-end rounded-lg border border-slate-300 px-3 py-2 text-sm" data-remove-tier>Quitar</button>`
			container.appendChild(row)
		}
	}

	function cancellationTiers() {
		const rows = Array.from(document.querySelectorAll("#tiers .tier-row"))
		return rows
			.map((row) => ({
				days: Number(row.querySelector('[name="daysBeforeArrival"]')?.value || NaN),
				penalty: Number(row.querySelector('[name="penaltyPercent"]')?.value || NaN),
			}))
			.filter((tier) => Number.isFinite(tier.days) && Number.isFinite(tier.penalty))
			.sort((a, b) => b.days - a.days)
	}

	function setPreview(values) {
		const defaults = {
			cancelToday: "Se resolverá con la condición de Cancelación asignada.",
			cancelWeek: "Se resolverá con la condición de Cancelación asignada.",
			longStay: "No cambia estadías largas desde esta categoría.",
			taxesFees: "Se calculan según la condición de Cancelación y bases fiscales asignadas.",
			providerPayout: "Se calcula según la base contractual asignada.",
			noShow: "Se resolverá con la condición No presentación asignada.",
			paymentDue: "Se resolverá con la condición Pago asignada.",
			...values,
		}
		document.getElementById("previewCancelToday").textContent = defaults.cancelToday
		document.getElementById("previewCancelWeek").textContent = defaults.cancelWeek
		document.getElementById("previewLongStay").textContent = defaults.longStay
		document.getElementById("previewTaxesFees").textContent = defaults.taxesFees
		document.getElementById("previewProviderPayout").textContent = defaults.providerPayout
		document.getElementById("previewNoShow").textContent = defaults.noShow
		document.getElementById("previewPaymentDue").textContent = defaults.paymentDue
	}

	function penaltyAtDays(tiers, daysBeforeArrival) {
		const sorted = [...tiers].sort((a, b) => Number(b.days) - Number(a.days))
		const match = sorted.find((tier) => Number(daysBeforeArrival) >= Number(tier.days))
		return match ? Number(match.penalty) : null
	}

	function refundFromPenalty(penalty) {
		if (!Number.isFinite(penalty)) return "sin tramo definido; revisa antes de vender."
		return `${Math.max(0, 100 - Number(penalty))}% de reembolso / ${Number(penalty)}% de penalidad.`
	}

	function basisCopy(value) {
		const map = {
			total_booking: "reserva completa",
			room_rate: "tarifa base",
			first_night: "primera noche",
			deposit: "depósito",
			provider_policy: "condición del proveedor",
			none: "sin reembolso",
			gross: "monto bruto",
			net: "monto neto",
			collected: "monto cobrado",
		}
		return map[String(value || "")] || String(value || "sin definir")
	}

	function updatePreview() {
		const category = selectedCategory()
		if (!category) {
			setPreview({
				cancelToday: "Selecciona categoría y plantilla.",
				cancelWeek: "Completa los campos humanos.",
				longStay: "Resumen pendiente.",
				taxesFees: "Impacto pendiente.",
				providerPayout: "Pendiente.",
				noShow: "Pendiente.",
				paymentDue: "Pendiente.",
			})
			return
		}
		if (category === "Cancellation") {
			const tiers = cancellationTiers()
			const todayPenalty = penaltyAtDays(tiers, 0)
			const weekPenalty = penaltyAtDays(tiers, 7)
			const longStay = inputValue("stayLengthType") === "long_stay"
			const refundBasis = inputValue("refundBasis")
			const payoutBasis = inputValue("payoutBasis")
			setPreview({
				cancelToday: refundFromPenalty(todayPenalty),
				cancelWeek: refundFromPenalty(weekPenalty),
				longStay: longStay
					? "Usa contrato de larga estadía desde 28 noches."
					: "Mantiene contrato de estadía corta; asigna una plantilla de larga estadía si aplica.",
				taxesFees:
					refundBasis === "none"
						? "No se reembolsan automáticamente."
						: "Se prorratean según el reembolso de la reserva.",
				providerPayout: `Cobro del proveedor calculado sobre ${basisCopy(payoutBasis)}.`,
			})
			return
		}
		if (category === "Payment") {
			const paymentType = inputValue("paymentType")
			const pct = inputValue("prepaymentPercentage")
			const days = inputValue("prepaymentDaysBeforeArrival") || "0"
			setPreview({
				providerPayout:
					paymentType === "prepayment"
						? `Proveedor queda sujeto a cobro anticipado de ${pct || "100"}%.`
						: "Proveedor cobra en propiedad según su operación.",
				paymentDue:
					paymentType === "prepayment"
						? `${pct || "100"}% pendiente ${days === "0" ? "al reservar" : `${days} día(s) antes de la llegada`}.`
						: "Sin pago pendiente en plataforma; el huésped paga en propiedad.",
			})
			return
		}
		if (category === "CheckIn") {
			const from = inputValue("checkInFrom") || "15:00"
			const until = inputValue("checkInUntil") || "22:00"
			const out = inputValue("checkOutUntil") || "11:00"
			setPreview({
				providerPayout: "Sin cargo directo; afecta operación y mensajes previos a la llegada.",
				paymentDue: `Llegada entre ${from} y ${until}; salida hasta ${out}.`,
			})
			return
		}
		const noShowType = inputValue("noShowPenaltyType")
		const amount = inputValue("noShowPenaltyAmount")
		setPreview({
			providerPayout:
				noShowType === "full"
					? "Proveedor conserva la estadía completa si el huésped no llega."
					: noShowType === "first_night"
						? "Proveedor conserva la primera noche si el huésped no llega."
						: `Proveedor conserva ${amount || "100"}% si el huésped no llega.`,
			noShow:
				noShowType === "first_night"
					? "Si no llega: se cobra la primera noche."
					: noShowType === "full"
						? "Si no llega: se cobra la estadía completa."
						: `Si no llega: se cobra ${amount || "100"}%.`,
		})
	}

	document.querySelectorAll("[data-category-choice]").forEach((button) => {
		button.addEventListener("click", () => {
			if (isVersionMode) return
			setInput("category", button.getAttribute("data-category-choice") || "")
			updateCategoryUI()
		})
	})

	document.querySelectorAll("[data-policy-template]").forEach((button) => {
		button.addEventListener("click", () => {
			const data = JSON.parse(button.getAttribute("data-policy-template") || "{}")
			const category = String(data.category || "")
			if (isVersionMode && category !== selectedCategory()) {
				setClientError("La categoría está bloqueada para esta nueva versión.")
				return
			}
			const template = data.template || {}
			setInput("category", category)
			setInput("name", template.displayName || template.name || "")
			setInput("policyPresetKey", template.key || "")
			setInput("stayLengthType", template.stayLengthType || "any")
			setInput("gracePeriod", template.gracePeriod ?? "")
			setInput("refundBasis", template.refundBasis || "")
			setInput("payoutBasis", template.payoutBasis || "")
			setInput("localTimezone", template.localTimezone || "property_local")
			setInput("legalOverrideFlags", JSON.stringify(template.legalOverrideFlags || {}, null, 2))
			if (category === "Cancellation") resetTiers(template.cancellationTiers || [])
			if (category === "Payment") {
				setInput("paymentType", template.rules?.paymentType || "")
				setInput("prepaymentPercentage", template.rules?.prepaymentPercentage || "")
				setInput("prepaymentDaysBeforeArrival", template.rules?.prepaymentDaysBeforeArrival ?? "")
			}
			if (category === "CheckIn") {
				setInput("checkInFrom", template.rules?.checkInFrom || "")
				setInput("checkInUntil", template.rules?.checkInUntil || "")
				setInput("checkOutUntil", template.rules?.checkOutUntil || "")
			}
			if (category === "NoShow") {
				setInput("noShowPenaltyType", template.rules?.penaltyType || "")
				setInput("noShowPenaltyAmount", template.rules?.penaltyAmount || "")
			}
			updateCategoryUI()
		})
	})

	document.getElementById("addTier")?.addEventListener("click", () => {
		const container = document.getElementById("tiers")
		const first = container?.querySelector(".tier-row")
		if (!container || !first) return
		const clone = first.cloneNode(true)
		clone.querySelectorAll("input").forEach((input) => {
			input.value = ""
		})
		container.appendChild(clone)
	})

	document.addEventListener("click", (event) => {
		const target = event.target
		if (!(target instanceof Element)) return
		if (!target.matches("[data-remove-tier]")) return
		const rows = document.querySelectorAll("#tiers .tier-row")
		if (rows.length <= 1) return
		target.closest(".tier-row")?.remove()
		updatePreview()
	})

	function validate() {
		const category = selectedCategory()
		const name = inputValue("name")
		if (name.length < 2) return "Escribe un nombre humano para la condición."
		if (!category) return "Selecciona una categoría contractual."
		if (category === "Cancellation" && cancellationTiers().length === 0) {
			return "Agrega al menos un tramo de cancelación."
		}
		if (category === "Payment" && !inputValue("paymentType"))
			return "Selecciona cómo paga el huésped."
		if (category === "Payment" && inputValue("paymentType") === "prepayment") {
			const pct = Number(inputValue("prepaymentPercentage"))
			if (!Number.isFinite(pct) || pct <= 0 || pct > 100)
				return "El prepago debe estar entre 1 y 100%."
		}
		if (category === "CheckIn") {
			for (const key of ["checkInFrom", "checkInUntil", "checkOutUntil"]) {
				if (!inputValue(key)) return "Completa las horas de ingreso y salida."
			}
		}
		if (category === "NoShow" && !inputValue("noShowPenaltyType")) {
			return "Selecciona el cargo de no presentación."
		}
		if (category === "NoShow" && inputValue("noShowPenaltyType") === "percentage") {
			const pct = Number(inputValue("noShowPenaltyAmount"))
			if (!Number.isFinite(pct) || pct < 0 || pct > 100)
				return "El porcentaje debe estar entre 0 y 100%."
		}
		return ""
	}

	function parseOptionalNumber(value) {
		const raw = String(value ?? "").trim()
		if (!raw) return undefined
		const parsed = Number(raw)
		return Number.isFinite(parsed) ? parsed : undefined
	}

	function parseLegalOverrideFlags(value) {
		const raw = String(value ?? "").trim()
		if (!raw) return undefined
		try {
			const parsed = JSON.parse(raw)
			return parsed && typeof parsed === "object" && !Array.isArray(parsed) ? parsed : undefined
		} catch {
			return undefined
		}
	}

	function versionPayload(nextStatus) {
		const fd = new FormData(form)
		const category = selectedCategory()
		let rules = undefined
		let cancellationTiers = undefined
		if (category === "Cancellation") {
			const days = fd.getAll("daysBeforeArrival").map((v) => String(v).trim())
			const penalties = fd.getAll("penaltyPercent").map((v) => String(v).trim())
			cancellationTiers = days
				.map((d, i) => ({
					daysBeforeArrival: Number(d),
					penaltyType: "percentage",
					penaltyAmount: Number(penalties[i]),
				}))
				.filter(
					(tier) => Number.isFinite(tier.daysBeforeArrival) && Number.isFinite(tier.penaltyAmount)
				)
		} else if (category === "Payment") {
			const paymentType = String(fd.get("paymentType") || "").trim()
			rules = { paymentType }
			const prepaymentPercentage = parseOptionalNumber(fd.get("prepaymentPercentage"))
			const prepaymentDaysBeforeArrival = parseOptionalNumber(fd.get("prepaymentDaysBeforeArrival"))
			if (prepaymentPercentage !== undefined) rules.prepaymentPercentage = prepaymentPercentage
			if (prepaymentDaysBeforeArrival !== undefined)
				rules.prepaymentDaysBeforeArrival = prepaymentDaysBeforeArrival
		} else if (category === "CheckIn") {
			rules = {
				checkInFrom: String(fd.get("checkInFrom") || "").trim(),
				checkInUntil: String(fd.get("checkInUntil") || "").trim(),
				checkOutUntil: String(fd.get("checkOutUntil") || "").trim(),
			}
		} else if (category === "NoShow") {
			const penaltyType = String(fd.get("noShowPenaltyType") || "").trim()
			rules = { penaltyType }
			const penaltyAmount = parseOptionalNumber(fd.get("noShowPenaltyAmount"))
			if (penaltyAmount !== undefined) rules.penaltyAmount = penaltyAmount
		}
		return {
			previousPolicyId: String(fd.get("previousPolicyId") || "").trim(),
			description: String(fd.get("name") || "").trim(),
			status: nextStatus,
			policyPresetKey: String(fd.get("policyPresetKey") || "").trim() || undefined,
			stayLengthType: String(fd.get("stayLengthType") || "").trim() || "any",
			gracePeriod: parseOptionalNumber(fd.get("gracePeriod")),
			refundBasis: String(fd.get("refundBasis") || "").trim() || undefined,
			payoutBasis: String(fd.get("payoutBasis") || "").trim() || undefined,
			localTimezone: String(fd.get("localTimezone") || "").trim() || undefined,
			legalOverrideFlags: parseLegalOverrideFlags(fd.get("legalOverrideFlags")),
			rules,
			cancellationTiers,
		}
	}

	function applyApiErrors(payload) {
		const map = {
			description: "err-name",
			paymentType: "err-paymentType",
			prepaymentPercentage: "err-prepaymentPercentage",
			checkInFrom: "err-checkInFrom",
			checkInUntil: "err-checkInUntil",
			checkOutUntil: "err-checkOutUntil",
			penaltyType: "err-noShowPenaltyType",
			penaltyAmount: "err-noShowPenaltyAmount",
			cancellationTiers: "err-cancellationTiers",
		}
		const details = Array.isArray(payload?.details) ? payload.details : []
		for (const issue of details) {
			const path = Array.isArray(issue?.path) ? issue.path : []
			const field = String(path[path.length - 1] || "")
			const id = map[field]
			if (!id) continue
			const el = document.getElementById(id)
			if (el) el.textContent = String(issue?.message || issue?.code || "Inválido")
		}
	}

	document.addEventListener("input", (event) => {
		if (
			event.target instanceof HTMLInputElement ||
			event.target instanceof HTMLSelectElement ||
			event.target instanceof HTMLTextAreaElement
		) {
			updatePreview()
		}
	})
	categorySel?.addEventListener("change", updateCategoryUI)
	paymentTypeSel?.addEventListener("change", () => {
		updatePaymentUI()
		updatePreview()
	})
	noShowPenaltyTypeSel?.addEventListener("change", () => {
		updateNoShowUI()
		updatePreview()
	})

	form?.addEventListener("submit", async (event) => {
		const submitter = event.submitter
		const nextStatus = submitter?.getAttribute("data-submit-status") || "draft"
		const validationError = validate()
		if (validationError) {
			event.preventDefault()
			setClientError(validationError)
			return
		}
		if (libraryStatusInput) libraryStatusInput.value = nextStatus
		const message =
			nextStatus === "active"
				? isVersionMode
					? "Vas a crear y publicar una nueva versión contractual. ¿Continuar?"
					: "Vas a publicar esta condición. Quedará activa para asignación. ¿Continuar?"
				: isVersionMode
					? "Vas a guardar una nueva versión como borrador. ¿Continuar?"
					: "Vas a guardar esta condición como borrador. ¿Continuar?"
		if (!window.confirm(message)) {
			event.preventDefault()
			return
		}
		setClientError("")

		if (!isVersionMode) return
		event.preventDefault()
		const res = await fetch("/api/policies/create-version", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(versionPayload(nextStatus)),
		})
		if (!res.ok) {
			let payload = null
			try {
				payload = await res.json()
			} catch (_) {}
			applyApiErrors(payload)
			setClientError(
				payload?.error === "validation_error"
					? "Corrige los campos marcados."
					: "No se pudo guardar la nueva versión"
			)
			return
		}
		window.location.href = "/provider/policies?success=updated"
	})

	updateCategoryUI()
</script>
