---
const { productId, searchState, offers } = Astro.props
---

<div id="availability-root">
	<p class="mb-4 text-sm text-neutral-500">Selecciona fechas para ver disponibilidad</p>
</div>

<script
	type="module"
	define:vars={{
		PRODUCT_ID: productId,
		CHECK_IN: searchState.checkIn,
		CHECK_OUT: searchState.checkOut,
		ADULTS: searchState.adults,
		CHILDREN: searchState.children,
	}}
>
	// load (initial SSR sync)
	async function loadAvailability() {
		if (!PRODUCT_ID) {
			console.warn("No productId yet")
			return
		}
		console.log(
			"PRODUCT_ID:",
			PRODUCT_ID,
			"CHECK_IN: ",
			CHECK_IN,
			"CHECK_OUT: ",
			CHECK_OUT,
			"ADULTS: ",
			ADULTS,
			"CHILDREN: ",
			CHILDREN
		)

		try {
			const res = await fetch("/api/search", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					productId: PRODUCT_ID,
					checkIn: CHECK_IN,
					checkOut: CHECK_OUT,
					adults: ADULTS,
					children: CHILDREN,
					currency: "USD",
				}),
			})

			if (!res.ok) throw new Error("Availability fetch failed")
			console.log("res: ", res)

			const availabilityResult = await res.json()

			document.dispatchEvent(
				new CustomEvent("availability:updated", {
					detail: availabilityResult,
				})
			)
		} catch (err) {
			console.error("Availability error", err)
		}
	}

	// refresh (live)
	async function refreshAvailability() {
		const res = await fetch("/api/availability/live-availability", {
			method: "POST",
			body: JSON.stringify({
				productId: PRODUCT_ID,
				checkIn: CHECK_IN,
				checkOut: CHECK_OUT,
				adults: ADULTS,
				children: CHILDREN,
				currency: "USD",
			}),
		})

		if (!res.ok) throw new Error("Availability fetch failed")
		console.log("res: ", res)

		console.log(
			"PRODUCT_ID:",
			PRODUCT_ID,
			"CHECK_IN: ",
			CHECK_IN,
			"CHECK_OUT: ",
			CHECK_OUT,
			"ADULTS: ",
			ADULTS,
			"CHILDREN: ",
			CHILDREN
		)

		const availabilityResult = await res.json()

		document.dispatchEvent(
			new CustomEvent("availability:updated", {
				detail: availabilityResult,
			})
		)
	}

	loadAvailability()
	document.getElementById("searchBtn")?.addEventListener("click", refreshAvailability)
</script>
