---
import FinancialWorkspaceShell from "@/components/financial/FinancialWorkspaceShell.astro"
import Card from "@/components/ui/Card.astro"
import Select from "@/components/ui/Select.astro"
import { actorFilterOptions } from "@/pages/financial/_client/financial-actor-filters"
import { workTypeOptions } from "@/pages/financial/_client/financial-queues"

type FinancialViewId =
	| "inbox"
	| "collections"
	| "settlements"
	| "provider-payables"
	| "refunds"
	| "exceptions"

const routeToView: Record<string, FinancialViewId> = {
	"/financial": "inbox",
	"/financial/collections": "collections",
	"/financial/settlements": "settlements",
	"/financial/provider-payables": "provider-payables",
	"/financial/refunds": "refunds",
	"/financial/exceptions": "exceptions",
}

const normalizedPath = Astro.url.pathname.replace(/\/$/, "") || "/"
const initialView = routeToView[normalizedPath] || "inbox"
const viewClass = (view: FinancialViewId) =>
	view === initialView ? "space-y-4" : "hidden space-y-4"
---

<FinancialWorkspaceShell
	title="Finanzas"
	description="Casos que requieren revisión, seguimiento o cierre."
	note="Fastt organiza evidencia y revisiones financieras. No ejecuta cobros, pagos ni reembolsos."
>
	<section data-financial-view="inbox" class={viewClass("inbox")}>
		<Card class="overflow-hidden bg-slate-100 p-0">
			<div class="border-b border-slate-200 p-4">
				<div class="space-y-4">
					<label class="block">
						<span class="sr-only">Buscar reserva o referencia</span>
						<input
							id="financialSearchFilter"
							type="search"
							placeholder="Buscar reserva, referencia o proveedor..."
							class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm font-medium text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-500"
						/>
					</label>
					<div id="financialSummary" class="flex flex-wrap gap-2">
						{
							[
								"Requieren atención",
								"Bloqueados",
								"Esperando respuesta",
								"Listos para cerrar",
								"Cerrados recientemente",
							].map((label) => (
								<div class="rounded-full border border-slate-200 bg-white px-3 py-2">
									<span class="text-xs font-semibold text-slate-500">{label}</span>
								</div>
							))
						}
					</div>
					<div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
						<p id="financialListSummary" class="text-sm text-slate-700">
							Cargando casos que requieren atención, espera o cierre...
						</p>
						<details class="group rounded-2xl border border-slate-200 bg-white">
							<summary
								class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-semibold text-slate-800"
							>
								<span>Filtros</span>
								<span id="financialFilterSummary" class="text-xs text-slate-500 group-open:hidden"
									>Todos los tipos · Todos los equipos</span
								>
								<span class="hidden text-xs text-slate-500 group-open:inline">Ocultar filtros</span>
							</summary>
							<div class="grid gap-3 border-t border-slate-200 p-4 sm:grid-cols-2 xl:grid-cols-4">
								<label class="space-y-1 text-sm font-medium text-slate-700">
									<span class="text-xs uppercase tracking-[0.12em] text-slate-500"
										>Equipo responsable</span
									>
									<Select id="financialActorFilter" name="actor" value="all">
										{
											actorFilterOptions.map((option) => (
												<option value={option.value}>{option.label}</option>
											))
										}
									</Select>
								</label>
								<label class="space-y-1 text-sm font-medium text-slate-700">
									<span class="text-xs uppercase tracking-[0.12em] text-slate-500">Alojamiento</span
									>
									<input
										id="financialLodgingFilter"
										type="search"
										placeholder="Nombre o asignación"
										class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-500"
									/>
								</label>
								<label class="space-y-1 text-sm font-medium text-slate-700">
									<span class="text-xs uppercase tracking-[0.12em] text-slate-500">Antigüedad</span>
									<Select id="financialAgeFilter" name="age" value="all">
										<option value="all">Todas</option>
										<option value="today">Hoy</option>
										<option value="over_3">Más de 3 días</option>
										<option value="over_7">Más de 7 días</option>
										<option value="over_14">Más de 14 días</option>
									</Select>
								</label>
								<div class="space-y-2 sm:col-span-2 xl:col-span-1">
									<p class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">
										Tipo de trabajo
									</p>
									<div id="financialWorkTypeFilters" class="flex flex-wrap gap-2">
										{
											workTypeOptions.map((option) => (
												<button
													type="button"
													data-work-type={option.value}
													class={
														option.value === "all"
															? "rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
															: "rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
													}
												>
													{option.label}
												</button>
											))
										}
									</div>
								</div>
							</div>
						</details>
					</div>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead>
						<tr class="text-left text-slate-700">
							<th class="px-3 py-2">Qué ocurrió</th>
							<th class="px-3 py-2">Importe involucrado</th>
							<th class="px-3 py-2">Qué impide avanzar</th>
							<th class="px-3 py-2">Responsable</th>
							<th class="px-3 py-2">Antigüedad</th>
							<th class="px-3 py-2">Próxima acción</th>
						</tr>
					</thead>
					<tbody id="financialRows">
						<tr
							><td colspan="6" class="px-3 py-8 text-center text-sm text-slate-500"
								>Cargando casos...</td
							></tr
						>
					</tbody>
				</table>
			</div>
		</Card>
	</section>

	<section data-financial-view="collections" class={viewClass("collections")}>
		<Card class="overflow-hidden bg-white p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="collectionsSummary" class="text-sm font-semibold text-slate-950">
							Cargando cobros...
						</p><p class="mt-1 text-sm text-slate-600">
							Prioriza comprobantes faltantes, cobros sin reserva y referencias repetidas.
						</p>
					</div>
					<div
						id="collectionsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de cobros"
					>
						<button
							type="button"
							data-collections-segment="requires_proof"
							class="rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
							>Requieren comprobante</button
						>
						<button
							type="button"
							data-collections-segment="unmatched"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Sin reserva asociada</button
						>
						<button
							type="button"
							data-collections-segment="duplicate"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Referencias duplicadas</button
						>
						<button
							type="button"
							data-collections-segment="in_review"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>En revisión</button
						>
					</div>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead
						><tr class="text-left text-slate-700"
							><th class="px-3 py-2">Reserva</th><th class="px-3 py-2">Importe</th><th
								class="px-3 py-2">Referencia externa</th
							><th class="px-3 py-2">Procesador</th><th class="px-3 py-2">Comprobante</th><th
								class="px-3 py-2">Responsable</th
							><th class="px-3 py-2">Próxima acción</th></tr
						></thead
					><tbody id="collectionsRows"
						><tr
							><td colspan="7" class="px-3 py-8 text-center text-sm text-slate-500"
								>Cargando cobros...</td
							></tr
						></tbody>
				</table>
			</div>
		</Card>
	</section>

	<section data-financial-view="settlements" class={viewClass("settlements")}>
		<Card class="overflow-hidden bg-white p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="settlementsSummary" class="text-sm font-semibold text-slate-950">
							Cargando diferencias...
						</p><p class="mt-1 text-sm text-slate-600">
							Revisa primero importes distintos, cobros faltantes y liquidaciones externas
							faltantes.
						</p>
					</div><div
						id="settlementsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de liquidaciones"
					>
						<button
							type="button"
							data-settlements-segment="amount_mismatch"
							class="rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
							>Montos diferentes</button
						><button
							type="button"
							data-settlements-segment="missing_payment"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Falta cobro</button
						><button
							type="button"
							data-settlements-segment="missing_settlement"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Falta liquidación</button
						><button
							type="button"
							data-settlements-segment="duplicate_reference"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Referencia duplicada</button
						><button
							type="button"
							data-settlements-segment="no_difference"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Sin diferencia</button>
					</div>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead
						><tr class="text-left text-slate-700"
							><th class="px-3 py-2">Reserva</th><th class="px-3 py-2">Importe confirmado</th><th
								class="px-3 py-2">Cobro</th
							><th class="px-3 py-2">Liquidación</th><th class="px-3 py-2">Diferencia</th><th
								class="px-3 py-2">Estado revisión</th
							><th class="px-3 py-2">Responsable</th><th class="px-3 py-2">Próxima acción</th></tr
						></thead
					><tbody id="settlementsRows"
						><tr
							><td colspan="8" class="px-3 py-8 text-center text-sm text-slate-500"
								>Cargando liquidaciones...</td
							></tr
						></tbody>
				</table>
			</div>
		</Card>
	</section>

	<section data-financial-view="provider-payables" class={viewClass("provider-payables")}>
		<Card class="overflow-hidden bg-white p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="providerPayablesSummary" class="text-sm font-semibold text-slate-950">
							Cargando pagos pendientes...
						</p><p class="mt-1 text-sm text-slate-600">
							Prioriza bloqueos por revisión de importes, comisión faltante o datos incompletos.
						</p>
					</div><div
						id="providerPayablesSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de pagos pendientes a proveedores"
					>
						<button
							type="button"
							data-provider-payables-segment="blocked"
							class="rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
							>Bloqueados</button
						><button
							type="button"
							data-provider-payables-segment="commission_missing"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Falta comisión</button
						><button
							type="button"
							data-provider-payables-segment="review_amounts"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Revisar importes</button
						><button
							type="button"
							data-provider-payables-segment="statement_review"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Resumen pendiente</button
						><button
							type="button"
							data-provider-payables-segment="ready"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Sin bloqueo principal</button>
					</div>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead
						><tr class="text-left text-slate-700"
							><th class="px-3 py-2">Proveedor</th><th class="px-3 py-2">Reserva</th><th
								class="px-3 py-2">Bruto</th
							><th class="px-3 py-2">Comisión</th><th class="px-3 py-2">Impuestos</th><th
								class="px-3 py-2">Pendiente proveedor</th
							><th class="px-3 py-2">Bloqueo</th><th class="px-3 py-2">Responsable</th><th
								class="px-3 py-2">Próxima acción</th
							></tr
						></thead
					><tbody id="providerPayablesRows"
						><tr
							><td colspan="9" class="px-3 py-8 text-center text-sm text-slate-500"
								>Cargando pagos pendientes...</td
							></tr
						></tbody>
				</table>
			</div>
		</Card>
	</section>

	<section data-financial-view="refunds" class={viewClass("refunds")}>
		<Card class="overflow-hidden bg-white p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="refundsSummary" class="text-sm font-semibold text-slate-950">
							Cargando reembolsos...
						</p><p class="mt-1 text-sm text-slate-600">
							Prioriza casos por revisar, respuestas externas pendientes y comprobantes faltantes.
						</p>
					</div><div
						id="refundsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de reembolsos"
					>
						<button
							type="button"
							data-refunds-segment="needs_review"
							class="rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
							>Requieren revisión</button
						><button
							type="button"
							data-refunds-segment="waiting_response"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Esperando respuesta</button
						><button
							type="button"
							data-refunds-segment="missing_proof"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Comprobante faltante</button
						><button
							type="button"
							data-refunds-segment="proof_received"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Comprobante recibido</button
						><button
							type="button"
							data-refunds-segment="ready_to_close"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Listos para cerrar</button>
					</div>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead
						><tr class="text-left text-slate-700"
							><th class="px-3 py-2">Reserva</th><th class="px-3 py-2">Motivo</th><th
								class="px-3 py-2">Importe esperado</th
							><th class="px-3 py-2">Comprobante</th><th class="px-3 py-2">Responsable</th><th
								class="px-3 py-2">Antigüedad</th
							><th class="px-3 py-2">Próxima acción</th></tr
						></thead
					><tbody id="refundsRows"
						><tr
							><td colspan="7" class="px-3 py-8 text-center text-sm text-slate-500"
								>Cargando reembolsos...</td
							></tr
						></tbody>
				</table>
			</div>
		</Card>
	</section>

	<section data-financial-view="exceptions" class={viewClass("exceptions")}>
		<Card class="overflow-hidden bg-white p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="financialExceptionsSummary" class="text-sm font-semibold text-slate-950">
							Cargando excepciones...
						</p><p class="mt-1 text-sm text-slate-600">
							Usa esta vista para datos faltantes, referencias inconsistentes y revisiones vencidas.
						</p>
					</div><div
						id="financialExceptionsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de excepciones financieras"
					>
						<button
							type="button"
							data-exceptions-segment="needs_review"
							class="rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
							>Requieren revisión</button
						><button
							type="button"
							data-exceptions-segment="missing_data"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Datos faltantes</button
						><button
							type="button"
							data-exceptions-segment="reference_issue"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Referencia inconsistente</button
						><button
							type="button"
							data-exceptions-segment="review_overdue"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Revisión vencida</button
						><button
							type="button"
							data-exceptions-segment="closed"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
							>Cerradas</button>
					</div>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead
						><tr class="text-left text-slate-700"
							><th class="px-3 py-2">Caso</th><th class="px-3 py-2">Reserva</th><th
								class="px-3 py-2">Qué ocurrió</th
							><th class="px-3 py-2">Impacto</th><th class="px-3 py-2">Responsable</th><th
								class="px-3 py-2">Antigüedad</th
							><th class="px-3 py-2">Próxima acción</th></tr
						></thead
					><tbody id="financialExceptionsRows"
						><tr
							><td colspan="7" class="px-3 py-8 text-center text-sm text-slate-500"
								>Cargando excepciones...</td
							></tr
						></tbody>
				</table>
			</div>
		</Card>
	</section>
</FinancialWorkspaceShell>

<div id="financialReviewBackdrop" class="hidden fixed inset-0 z-40 bg-slate-950/30"></div>
<aside
	id="financialReviewDrawer"
	class="fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto border-l border-slate-200 bg-white p-5 shadow-2xl transition-transform duration-200"
>
	<div class="mb-4 flex items-center justify-between gap-4 border-b border-slate-200 pb-3">
		<div>
			<p class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">Detalle del caso</p><p
				class="text-sm text-slate-600"
			>
				Qué ocurrió, cuánto dinero está involucrado, qué comprobantes existen y qué sigue.
			</p>
		</div><button
			id="financialReviewDrawerClose"
			type="button"
			class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
			>Cerrar</button>
	</div><div id="financialReviewDrawerBody"></div>
</aside>

<div id="collectionsDrawerBackdrop" class="hidden fixed inset-0 z-40 bg-slate-950/30"></div>
<aside
	id="collectionsDrawer"
	class="fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto border-l border-slate-200 bg-white p-5 text-slate-900 shadow-2xl transition-transform duration-200"
>
	<div class="mb-4 flex items-start justify-between gap-4 border-b border-slate-200 pb-3">
		<div>
			<p class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">
				Detalle del cobro
			</p><p class="text-sm text-slate-600">
				Qué ocurrió, cuánto dinero está involucrado, qué comprobante existe y qué sigue.
