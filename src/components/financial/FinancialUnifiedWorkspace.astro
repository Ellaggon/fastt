---
import FinancialWorkspaceShell from "@/components/financial/FinancialWorkspaceShell.astro"
import FinancialCompactSearch from "@/components/financial/FinancialCompactSearch.astro"
import AccommodationContextSwitcher from "@/components/product/AccommodationContextSwitcher.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Select from "@/components/ui/Select.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import { actorFilterOptions } from "@/pages/financial/_client/financial-actor-filters"
import { and, db, eq, Product, sql } from "astro:db"

type FinancialViewId =
	| "inbox"
	| "collections"
	| "settlements"
	| "provider-payables"
	| "refunds"
	| "exceptions"

const routeToView: Record<string, FinancialViewId> = {
	"/financial": "inbox",
	"/financial/collections": "collections",
	"/financial/settlements": "settlements",
	"/financial/provider-payables": "provider-payables",
	"/financial/refunds": "refunds",
	"/financial/exceptions": "exceptions",
}

const normalizedPath = Astro.url.pathname.replace(/\/$/, "") || "/"
const initialView = routeToView[normalizedPath] || "inbox"
const viewClass = (view: FinancialViewId) =>
	view === initialView ? "space-y-6 md:space-y-8" : "hidden space-y-6 md:space-y-8"

let isSimpleFinancialView = true
let providerId = ""
let selectedAccommodation: { id: string; name: string } | null = null
try {
	const user = await getUserFromRequest(Astro.request)
	providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
	if (providerId) {
		const professionalModeCookie = getProfessionalModeCookiePreference(Astro.request)
		const sidebarData = await getProviderSidebarData(providerId, {
			userId: user?.id,
			professionalToolsEnabled:
				typeof professionalModeCookie === "boolean" ? professionalModeCookie : undefined,
		})
		isSimpleFinancialView = sidebarData.disclosureMode === "small-provider"
		const accommodations = (
			await db
				.select({ id: Product.id, name: Product.name })
				.from(Product)
				.where(
					and(eq(Product.providerId, providerId), sql`lower(${Product.productType}) = 'hotel'`)
				)
				.all()
		)
			.map((product) => ({
				id: String(product.id),
				name: String(product.name || "Alojamiento"),
			}))
			.sort((left, right) => left.name.localeCompare(right.name, "es"))
		const requestedProductId = String(Astro.url.searchParams.get("productId") ?? "").trim()
		selectedAccommodation =
			accommodations.find((product) => product.id === requestedProductId) ??
			accommodations[0] ??
			null
	}
} catch {
	isSimpleFinancialView = true
}
---

<FinancialWorkspaceShell
	title="Finanzas"
	description="Casos que requieren revisión, seguimiento o cierre."
	note="Fastt organiza evidencia y revisiones financieras. No ejecuta cobros, pagos ni reembolsos."
>
	{
		selectedAccommodation ? (
			<Fragment slot="context">
				<AccommodationContextSwitcher
					providerId={providerId}
					productId={selectedAccommodation.id}
					currentName={selectedAccommodation.name}
					target="financial"
				/>
				<div
					id="financialAccommodationContext"
					class="hidden"
					data-product-id={selectedAccommodation.id}
					data-product-name={selectedAccommodation.name}
				/>
			</Fragment>
		) : null
	}
	<section data-financial-view="inbox" class={viewClass("inbox")}>
		<Card class="fastt-workspace-panel overflow-visible p-0">
			<div class="p-5 md:p-6">
				<div class="space-y-5 md:space-y-6">
					<div class="financial-controls">
						<div
							id="financialSummary"
							data-financial-summary
							class="financial-summary-list financial-summary-list--desktop flex min-w-0 max-w-full flex-wrap gap-1.5 sm:gap-2"
							aria-label="Estado de casos financieros"
						>
							{
								[
									"Requieren atención",
									"Bloqueados",
									"Esperando respuesta",
									"Listos para cerrar",
									"Cerrados recientemente",
								].map((label) => (
									<div class="rounded-full border border-slate-200 bg-white px-2.5 py-1.5 text-xs sm:px-3 sm:py-2">
										<span class="text-xs font-semibold text-slate-700">0</span>
										<span class="ml-1">{label}</span>
									</div>
								))
							}
						</div>
						<details class="financial-status-popover group" data-financial-popover>
							<summary
								class="financial-mobile-control financial-icon-trigger"
								aria-label="Estados de casos"
							>
								<svg
									aria-hidden="true"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M8 6h13"></path>
									<path d="M8 12h13"></path>
									<path d="M8 18h13"></path>
									<path d="M3 6h.01"></path>
									<path d="M3 12h.01"></path>
									<path d="M3 18h.01"></path>
								</svg>
							</summary>
							<div class="financial-status-popover__panel" data-financial-popover-panel>
								<div class="mb-2 flex items-center justify-between gap-3">
									<p class="text-sm font-semibold text-slate-950">Estados</p>
									<Button type="button" variant="ghost" size="sm" data-financial-popover-close>
										Cerrar
									</Button>
								</div>
								<div
									data-financial-summary
									class="financial-summary-list flex max-w-full flex-wrap gap-1.5"
									aria-label="Estado de casos financieros"
								>
									{
										[
											"Requieren atención",
											"Bloqueados",
											"Esperando respuesta",
											"Listos para cerrar",
											"Cerrados recientemente",
										].map((label) => (
											<div class="rounded-full border border-slate-200 bg-white px-2.5 py-1.5 text-xs">
												<span class="text-xs font-semibold text-slate-700">0</span>
												<span class="ml-1">{label}</span>
											</div>
										))
									}
								</div>
							</div>
						</details>
						<details class="financial-filter-popover group" data-financial-popover>
							<summary class="financial-mobile-control financial-filter-popover__trigger">
								<span class="inline-flex items-center gap-2">
									<svg
										aria-hidden="true"
										class="financial-filter-popover__icon"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<path d="M3 6h18"></path>
										<path d="M7 12h10"></path>
										<path d="M10 18h4"></path>
									</svg>
									<span class="financial-filter-popover__label">Filtros</span>
									<span id="financialFilterSummary" class="financial-filter-popover__summary"
										>{
											isSimpleFinancialView
												? "Cualquier antigüedad"
												: "Todos los responsables · Cualquier antigüedad"
										}</span
									>
								</span>
								<svg
									aria-hidden="true"
									class="financial-filter-popover__chevron"
									viewBox="0 0 20 20"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
								>
									<path d="m6 8 4 4 4-4"></path>
								</svg>
							</summary>
							<div class="financial-filter-popover__panel" data-financial-popover-panel>
								<div class="flex flex-wrap items-start justify-between gap-3">
									<div>
										<p class="text-sm font-semibold text-slate-950">Filtrar casos visibles</p>
										<p class="mt-1 text-xs leading-5 text-slate-500">
											Elige qué casos mostrar sin salir de esta bandeja.
										</p>
									</div>
									<Button type="button" id="financialClearFilters" variant="secondary" size="sm">
										Limpiar filtros
									</Button>
									<Button
										type="button"
										variant="ghost"
										size="sm"
										className="sm:hidden"
										data-financial-popover-close
									>
										Cerrar
									</Button>
								</div>
								<div class={`mt-4 grid gap-3 ${isSimpleFinancialView ? "" : "sm:grid-cols-2"}`}>
									{
										isSimpleFinancialView ? null : (
											<label class="space-y-1.5 text-sm font-medium text-slate-700">
												<span class="text-xs font-semibold text-slate-500">
													Responsable del seguimiento
												</span>
												<Select id="financialActorFilter" name="actor" value="all">
													{actorFilterOptions.map((option) => (
														<option value={option.value}>{option.label}</option>
													))}
												</Select>
											</label>
										)
									}
									<label class="space-y-1.5 text-sm font-medium text-slate-700">
										<span class="text-xs font-semibold text-slate-500">Antigüedad</span>
										<Select id="financialAgeFilter" name="age" value="all">
											<option value="all">Todas</option>
											<option value="today">Hoy</option>
											<option value="over_3">Más de 3 días</option>
											<option value="over_7">Más de 7 días</option>
											<option value="over_14">Más de 14 días</option>
										</Select>
									</label>
								</div>
							</div>
						</details>
						<FinancialCompactSearch
							id="financialSearchFilter"
							placeholder="Buscar reserva, alojamiento, proveedor o referencia..."
						/>
					</div>
					<div class="border-t border-slate-200 pt-5 md:pt-6">
						<p id="financialListSummary" class="text-sm leading-6 text-slate-700">
							Cargando casos que requieren atención, espera o cierre...
						</p>
						<p id="financialListHint" class="mt-1 text-xs leading-5 text-slate-500">
							Los casos visibles respetan el equipo y la antigüedad seleccionados.
						</p>
					</div>
				</div>
			</div>
			<div
				id="financialRows"
				class="space-y-2 overflow-hidden border-t border-slate-200 bg-slate-50/80 p-2 sm:space-y-2.5"
			>
				<div class="px-3 py-6 text-center text-sm text-slate-500 sm:px-4 sm:py-8">
					Cargando casos...
				</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="collections" class={viewClass("collections")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="space-y-4">
					<div
						id="collectionsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de cobros"
					>
						<Button type="button" data-collections-segment="requires_proof" size="sm"
							>Requieren comprobante</Button
						>
						<Button type="button" data-collections-segment="unmatched" variant="secondary" size="sm"
							>Sin reserva asociada</Button
						>
						<Button type="button" data-collections-segment="duplicate" variant="secondary" size="sm"
							>Referencias duplicadas</Button
						>
						<Button type="button" data-collections-segment="in_review" variant="secondary" size="sm"
							>En revisión</Button
						>
					</div>
					<div>
						<p id="collectionsSummary" class="text-sm leading-6 text-slate-700">
							Cargando cobros...
						</p><p id="collectionsSummaryHint" class="mt-1 text-xs leading-5 text-slate-500">
							Selecciona un segmento para revisar los cobros relacionados.
						</p>
					</div>
				</div>
			</div>
			<div id="collectionsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando cobros...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="settlements" class={viewClass("settlements")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="space-y-4">
					<div
						id="settlementsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de liquidaciones"
					>
						<Button type="button" data-settlements-segment="amount_mismatch" size="sm"
							>Montos diferentes</Button
						><Button
							type="button"
							data-settlements-segment="missing_payment"
							variant="secondary"
							size="sm">Falta cobro</Button
						><Button
							type="button"
							data-settlements-segment="missing_settlement"
							variant="secondary"
							size="sm">Falta liquidación</Button
						><Button
							type="button"
							data-settlements-segment="duplicate_reference"
							variant="secondary"
							size="sm">Referencia duplicada</Button
						><Button
							type="button"
							data-settlements-segment="no_difference"
							variant="secondary"
							size="sm">Sin diferencia</Button
						>
					</div>
					<div>
						<p id="settlementsSummary" class="text-sm leading-6 text-slate-700">
							Cargando diferencias...
						</p><p id="settlementsSummaryHint" class="mt-1 text-xs leading-5 text-slate-500">
							Selecciona un segmento para comparar los importes relacionados.
						</p>
					</div>
				</div>
			</div>
			<div id="settlementsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando liquidaciones...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="provider-payables" class={viewClass("provider-payables")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="space-y-4">
					<div
						id="providerPayablesSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de pagos pendientes a proveedores"
					>
						<Button type="button" data-provider-payables-segment="blocked" size="sm"
							>Bloqueados</Button
						><Button
							type="button"
							data-provider-payables-segment="commission_missing"
							variant="secondary"
							size="sm">Falta comisión acordada</Button
						><Button
							type="button"
							data-provider-payables-segment="review_amounts"
							variant="secondary"
							size="sm">Revisar importes</Button
						><Button
							type="button"
							data-provider-payables-segment="statement_review"
							variant="secondary"
							size="sm">Resumen del proveedor pendiente</Button
						><Button
							type="button"
							data-provider-payables-segment="ready"
							variant="secondary"
							size="sm">Sin acción urgente</Button
						>
					</div>
					<div>
						<p id="providerPayablesSummary" class="text-sm leading-6 text-slate-700">
							Cargando pagos pendientes...
						</p><p id="providerPayablesSummaryHint" class="mt-1 text-xs leading-5 text-slate-500">
							Selecciona un segmento para revisar los pagos pendientes relacionados.
						</p>
					</div>
				</div>
			</div>
			<div id="providerPayablesRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando pagos pendientes...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="refunds" class={viewClass("refunds")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="space-y-4">
					<div
						id="refundsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de reembolsos"
					>
						<Button type="button" data-refunds-segment="needs_review" size="sm"
							>Requieren revisión</Button
						><Button
							type="button"
							data-refunds-segment="waiting_response"
							variant="secondary"
							size="sm">Esperando respuesta</Button
						><Button
							type="button"
							data-refunds-segment="missing_proof"
							variant="secondary"
							size="sm">Comprobante faltante</Button
						><Button
							type="button"
							data-refunds-segment="proof_received"
							variant="secondary"
							size="sm">Comprobante recibido</Button
						><Button
							type="button"
							data-refunds-segment="ready_to_close"
							variant="secondary"
							size="sm">Listos para cerrar</Button
						>
					</div>
					<div>
						<p id="refundsSummary" class="text-sm leading-6 text-slate-700">
							Cargando reembolsos...
						</p><p id="refundsSummaryHint" class="mt-1 text-xs leading-5 text-slate-500">
							Selecciona un segmento para revisar los reembolsos relacionados.
						</p>
					</div>
				</div>
			</div>
			<div id="refundsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando reembolsos...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="exceptions" class={viewClass("exceptions")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="space-y-4">
					<div
						id="financialExceptionsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de excepciones financieras"
					>
						<Button type="button" data-exceptions-segment="needs_review" size="sm"
							>Requieren revisión</Button
						><Button
							type="button"
							data-exceptions-segment="missing_data"
							variant="secondary"
							size="sm">Datos faltantes</Button
						><Button
							type="button"
							data-exceptions-segment="reference_issue"
							variant="secondary"
							size="sm">Referencia inconsistente</Button
						><Button
							type="button"
							data-exceptions-segment="review_overdue"
							variant="secondary"
							size="sm">Revisión vencida</Button
						><Button type="button" data-exceptions-segment="closed" variant="secondary" size="sm"
							>Cerradas</Button
						>
					</div>
					<div>
						<p id="financialExceptionsSummary" class="text-sm leading-6 text-slate-700">
							Cargando excepciones...
						</p><p
							id="financialExceptionsSummaryHint"
							class="mt-1 text-xs leading-5 text-slate-500"
						>
							Selecciona un segmento para revisar las excepciones relacionadas.
						</p>
					</div>
				</div>
			</div>
			<div id="financialExceptionsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando excepciones...</div>
			</div>
		</Card>
	</section>
</FinancialWorkspaceShell>

<style>
	.financial-controls {
		position: relative;
		z-index: 20;
		display: grid;
		grid-template-areas:
			"summary search"
			"filter filter";
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: start;
		gap: 0.75rem;
	}

	.financial-summary-list--desktop {
		grid-area: summary;
	}

	.financial-status-popover {
		display: none;
		grid-area: status;
		position: relative;
	}

	.financial-filter-popover {
		grid-area: filter;
	}

	.financial-filter-popover {
		position: relative;
		flex: 0 1 auto;
		min-width: 0;
	}

	.financial-controls > :global(.financial-search-compact) {
		grid-area: search;
	}

	.financial-icon-trigger {
		display: inline-flex;
		width: 100%;
		min-height: 2.25rem;
		align-items: center;
		justify-content: center;
		list-style: none;
		cursor: pointer;
		border: 1px solid rgb(226 232 240 / 72%);
		border-radius: var(--fastt-radius-pill);
		background: rgb(248 250 252 / 72%);
		color: rgb(71 85 105);
		transition:
			border-color var(--fastt-motion-standard) ease,
			background-color var(--fastt-motion-standard) ease,
			box-shadow var(--fastt-motion-standard) ease;
	}

	.financial-icon-trigger::-webkit-details-marker {
		display: none;
	}

	.financial-icon-trigger svg {
		width: 1rem;
		height: 1rem;
	}

	.financial-status-popover[open] > .financial-icon-trigger,
	.financial-icon-trigger:hover {
		border-color: rgb(148 163 184 / 70%);
		background: rgb(255 255 255 / 92%);
		box-shadow: 0 8px 20px rgb(15 23 42 / 5%);
	}

	.financial-filter-popover__trigger {
		display: inline-flex;
		max-width: min(32rem, calc(100vw - 7rem));
		min-height: 2.25rem;
		align-items: center;
		justify-content: space-between;
		gap: 0.6rem;
		padding: 0.42rem 0.65rem 0.42rem 0.75rem;
		list-style: none;
		cursor: pointer;
		border: 1px solid rgb(226 232 240 / 72%);
		border-radius: var(--fastt-radius-pill);
		background: rgb(248 250 252 / 72%);
		color: rgb(71 85 105);
		font-size: 0.8125rem;
		font-weight: 600;
		box-shadow: none;
		transition:
			border-color var(--fastt-motion-standard) ease,
			background-color var(--fastt-motion-standard) ease,
			box-shadow var(--fastt-motion-standard) ease;
	}

	.financial-filter-popover__trigger::-webkit-details-marker {
		display: none;
	}

	.financial-filter-popover__trigger:hover,
	.financial-filter-popover[open] > .financial-filter-popover__trigger {
		border-color: rgb(148 163 184 / 70%);
		background: rgb(255 255 255 / 92%);
		box-shadow: 0 8px 20px rgb(15 23 42 / 5%);
	}

	.financial-filter-popover__summary {
		overflow: hidden;
		max-width: 18rem;
		padding: 0.16rem 0.48rem;
		border-radius: var(--fastt-radius-pill);
		background: rgb(226 232 240 / 62%);
		color: rgb(100 116 139);
		font-size: 0.6875rem;
		font-weight: 550;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.financial-filter-popover__icon {
		width: 1rem;
		height: 1rem;
		flex: none;
	}

	.financial-filter-popover__chevron {
		width: 1rem;
		height: 1rem;
		flex: none;
