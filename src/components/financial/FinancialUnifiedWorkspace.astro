<script>
	function financialPopovers() {
		return Array.from(document.querySelectorAll("[data-financial-popover]"))
	}

	function closeFinancialPopovers(except: Element | null = null) {
		for (const popover of financialPopovers()) {
			if (popover !== except) popover.removeAttribute("open")
		}
	}

	document.addEventListener(
		"click",
		(event) => {
			const target = event.target
			if (!(target instanceof Element)) return

			const closeButton = target.closest("[data-financial-popover-close]")
			if (closeButton) {
				const popover = closeButton.closest("[data-financial-popover]")
				popover?.removeAttribute("open")
				event.preventDefault()
				event.stopPropagation()
				return
			}

			const clickedPopover = target.closest("[data-financial-popover]")
			if (clickedPopover) {
				closeFinancialPopovers(clickedPopover)
				return
			}

			const hasOpenPopover = financialPopovers().some((popover) => popover.hasAttribute("open"))
			if (!hasOpenPopover) return

			closeFinancialPopovers()
			event.preventDefault()
			event.stopPropagation()
		},
		true
	)

	document.addEventListener("keydown", (event) => {
		if (event.key !== "Escape") return
		closeFinancialPopovers()
	})
</script>

