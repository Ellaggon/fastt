---
import FinancialWorkspaceShell from "@/components/financial/FinancialWorkspaceShell.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import { actorFilterOptions } from "@/pages/financial/_client/financial-actor-filters"
import { workTypeOptions } from "@/pages/financial/_client/financial-queues"

type FinancialViewId =
	| "inbox"
	| "collections"
	| "settlements"
	| "provider-payables"
	| "refunds"
	| "exceptions"

const routeToView: Record<string, FinancialViewId> = {
	"/financial": "inbox",
	"/financial/collections": "collections",
	"/financial/settlements": "settlements",
	"/financial/provider-payables": "provider-payables",
	"/financial/refunds": "refunds",
	"/financial/exceptions": "exceptions",
}

const normalizedPath = Astro.url.pathname.replace(/\/$/, "") || "/"
const initialView = routeToView[normalizedPath] || "inbox"
const viewClass = (view: FinancialViewId) =>
	view === initialView ? "space-y-4" : "hidden space-y-4"
---

<FinancialWorkspaceShell
	title="Finanzas"
	description="Casos que requieren revisión, seguimiento o cierre."
	note="Fastt organiza evidencia y revisiones financieras. No ejecuta cobros, pagos ni reembolsos."
>
	<section data-financial-view="inbox" class={viewClass("inbox")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0">
			<div class="border-b border-slate-200 p-4">
				<div class="space-y-4">
					<label class="block">
						<span class="sr-only">Buscar reserva o referencia</span>
						<Input
							id="financialSearchFilter"
							type="search"
							placeholder="Buscar reserva, referencia o proveedor..."
							class="w-full"
						/>
					</label>
					<div id="financialSummary" class="flex flex-wrap gap-2">
						{
							[
								"Requieren atención",
								"Bloqueados",
								"Esperando respuesta",
								"Listos para cerrar",
								"Cerrados recientemente",
							].map((label) => (
								<div class="rounded-full border border-slate-200 bg-white px-3 py-2">
									<span class="text-xs font-semibold text-slate-500">{label}</span>
								</div>
							))
						}
					</div>
					<div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
						<p id="financialListSummary" class="text-sm text-slate-700">
							Cargando casos que requieren atención, espera o cierre...
						</p>
						<details class="group rounded-2xl border border-slate-200 bg-white">
							<summary
								class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-semibold text-slate-800"
							>
								<span>Filtros</span>
								<span id="financialFilterSummary" class="text-xs text-slate-500 group-open:hidden"
									>Todos los tipos · Todos los equipos</span
								>
								<span class="hidden text-xs text-slate-500 group-open:inline">Ocultar filtros</span>
							</summary>
							<div class="grid gap-3 border-t border-slate-200 p-4 sm:grid-cols-2 xl:grid-cols-4">
								<label class="space-y-1 text-sm font-medium text-slate-700">
									<span class="text-xs uppercase tracking-[0.12em] text-slate-500"
										>Equipo responsable</span
									>
									<Select id="financialActorFilter" name="actor" value="all">
										{
											actorFilterOptions.map((option) => (
												<option value={option.value}>{option.label}</option>
											))
										}
									</Select>
								</label>
								<label class="space-y-1 text-sm font-medium text-slate-700">
									<span class="text-xs uppercase tracking-[0.12em] text-slate-500">Alojamiento</span
									>
									<Input
										id="financialLodgingFilter"
										type="search"
										placeholder="Nombre o asignación"
										class="w-full"
									/>
								</label>
								<label class="space-y-1 text-sm font-medium text-slate-700">
									<span class="text-xs uppercase tracking-[0.12em] text-slate-500">Antigüedad</span>
									<Select id="financialAgeFilter" name="age" value="all">
										<option value="all">Todas</option>
										<option value="today">Hoy</option>
										<option value="over_3">Más de 3 días</option>
										<option value="over_7">Más de 7 días</option>
										<option value="over_14">Más de 14 días</option>
									</Select>
								</label>
								<div class="space-y-2 sm:col-span-2 xl:col-span-1">
									<p class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">
										Tipo de trabajo
									</p>
									<div id="financialWorkTypeFilters" class="flex flex-wrap gap-2">
										{
											workTypeOptions.map((option) => (
												<Button
													type="button"
													data-work-type={option.value}
													variant={option.value === "all" ? "primary" : "secondary"}
													size="sm"
												>
													{option.label}
												</Button>
											))
										}
									</div>
								</div>
							</div>
						</details>
					</div>
				</div>
			</div>
			<div id="financialRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando casos...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="collections" class={viewClass("collections")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="collectionsSummary" class="text-sm font-semibold text-slate-950">
							Cargando cobros...
						</p><p class="mt-1 text-sm text-slate-600">
							Prioriza comprobantes faltantes, cobros sin reserva y referencias repetidas.
						</p>
					</div>
					<div
						id="collectionsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de cobros"
					>
						<Button type="button" data-collections-segment="requires_proof" size="sm"
							>Requieren comprobante</Button
						>
						<Button type="button" data-collections-segment="unmatched" variant="secondary" size="sm"
							>Sin reserva asociada</Button
						>
						<Button type="button" data-collections-segment="duplicate" variant="secondary" size="sm"
							>Referencias duplicadas</Button
						>
						<Button type="button" data-collections-segment="in_review" variant="secondary" size="sm"
							>En revisión</Button
						>
					</div>
				</div>
			</div>
			<div id="collectionsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando cobros...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="settlements" class={viewClass("settlements")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="settlementsSummary" class="text-sm font-semibold text-slate-950">
							Cargando diferencias...
						</p><p class="mt-1 text-sm text-slate-600">
							Revisa primero importes distintos, cobros faltantes y liquidaciones externas
							faltantes.
						</p>
					</div><div
						id="settlementsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de liquidaciones"
					>
						<Button type="button" data-settlements-segment="amount_mismatch" size="sm"
							>Montos diferentes</Button
						><Button
							type="button"
							data-settlements-segment="missing_payment"
							variant="secondary"
							size="sm">Falta cobro</Button
						><Button
							type="button"
							data-settlements-segment="missing_settlement"
							variant="secondary"
							size="sm">Falta liquidación</Button
						><Button
							type="button"
							data-settlements-segment="duplicate_reference"
							variant="secondary"
							size="sm">Referencia duplicada</Button
						><Button
							type="button"
							data-settlements-segment="no_difference"
							variant="secondary"
							size="sm">Sin diferencia</Button
						>
					</div>
				</div>
			</div>
			<div id="settlementsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando liquidaciones...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="provider-payables" class={viewClass("provider-payables")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="providerPayablesSummary" class="text-sm font-semibold text-slate-950">
							Cargando pagos pendientes...
						</p><p class="mt-1 text-sm text-slate-600">
							Prioriza bloqueos por revisión de importes, comisión faltante o datos incompletos.
						</p>
					</div><div
						id="providerPayablesSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de pagos pendientes a proveedores"
					>
						<Button type="button" data-provider-payables-segment="blocked" size="sm"
							>Bloqueados</Button
						><Button
							type="button"
							data-provider-payables-segment="commission_missing"
							variant="secondary"
							size="sm">Falta comisión acordada</Button
						><Button
							type="button"
							data-provider-payables-segment="review_amounts"
							variant="secondary"
							size="sm">Revisar importes</Button
						><Button
							type="button"
							data-provider-payables-segment="statement_review"
							variant="secondary"
							size="sm">Resumen del proveedor pendiente</Button
						><Button
							type="button"
							data-provider-payables-segment="ready"
							variant="secondary"
							size="sm">Sin acción urgente</Button
						>
					</div>
				</div>
			</div>
			<div id="providerPayablesRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando pagos pendientes...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="refunds" class={viewClass("refunds")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="refundsSummary" class="text-sm font-semibold text-slate-950">
							Cargando reembolsos...
						</p><p class="mt-1 text-sm text-slate-600">
							Prioriza casos por revisar, respuestas externas pendientes y comprobantes faltantes.
						</p>
					</div><div
						id="refundsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de reembolsos"
					>
						<Button type="button" data-refunds-segment="needs_review" size="sm"
							>Requieren revisión</Button
						><Button
							type="button"
							data-refunds-segment="waiting_response"
							variant="secondary"
							size="sm">Esperando respuesta</Button
						><Button
							type="button"
							data-refunds-segment="missing_proof"
							variant="secondary"
							size="sm">Comprobante faltante</Button
						><Button
							type="button"
							data-refunds-segment="proof_received"
							variant="secondary"
							size="sm">Comprobante recibido</Button
						><Button
							type="button"
							data-refunds-segment="ready_to_close"
							variant="secondary"
							size="sm">Listos para cerrar</Button
						>
					</div>
				</div>
			</div>
			<div id="refundsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando reembolsos...</div>
			</div>
		</Card>
	</section>

	<section data-financial-view="exceptions" class={viewClass("exceptions")}>
		<Card class="fastt-workspace-panel overflow-hidden p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="financialExceptionsSummary" class="text-sm font-semibold text-slate-950">
							Cargando excepciones...
						</p><p class="mt-1 text-sm text-slate-600">
							Usa esta vista para datos faltantes, referencias inconsistentes y revisiones vencidas.
						</p>
					</div><div
						id="financialExceptionsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de excepciones financieras"
					>
						<Button type="button" data-exceptions-segment="needs_review" size="sm"
							>Requieren revisión</Button
						><Button
							type="button"
							data-exceptions-segment="missing_data"
							variant="secondary"
							size="sm">Datos faltantes</Button
						><Button
							type="button"
							data-exceptions-segment="reference_issue"
							variant="secondary"
							size="sm">Referencia inconsistente</Button
						><Button
							type="button"
							data-exceptions-segment="review_overdue"
							variant="secondary"
							size="sm">Revisión vencida</Button
						><Button type="button" data-exceptions-segment="closed" variant="secondary" size="sm"
							>Cerradas</Button
						>
					</div>
				</div>
			</div>
			<div id="financialExceptionsRows" class="space-y-2 bg-slate-50/80 p-2">
				<div class="px-4 py-8 text-center text-sm text-slate-500">Cargando excepciones...</div>
			</div>
		</Card>
	</section>
</FinancialWorkspaceShell>

<div
	id="financialReviewBackdrop"
	class="hidden fixed inset-0 z-40 bg-slate-950/20 backdrop-blur-[2px]"
>
</div>
<aside
	id="financialReviewDrawer"
	class="fixed right-0 top-0 z-50 h-full w-full max-w-2xl translate-x-full overflow-y-auto border-l border-slate-200/80 bg-slate-50/95 text-slate-950 shadow-[0_24px_90px_rgba(15,23,42,0.22)] backdrop-blur-2xl transition-transform duration-300"
>
	<div
		class="sticky top-0 z-10 flex items-start justify-between gap-4 border-b border-slate-200/80 bg-slate-50/90 px-6 py-5 backdrop-blur-xl"
	>
		<div>
			<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
				Detalle del caso
			</p><p class="mt-1 max-w-md text-sm leading-6 text-slate-500">
				Resumen operativo, comprobantes y siguiente paso.
			</p>
		</div><Button id="financialReviewDrawerClose" type="button" variant="secondary" size="sm"
			>Cerrar</Button
		>
	</div><div id="financialReviewDrawerBody" class="px-6 py-5"></div>
</aside>

<div
	id="collectionsDrawerBackdrop"
	class="hidden fixed inset-0 z-40 bg-slate-950/25 backdrop-blur-[2px]"
>
</div>
<aside
	id="collectionsDrawer"
	class="fastt-side-sheet fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto p-0 text-slate-900 transition-transform duration-300"
>
	<div
		class="fastt-side-sheet-header sticky top-0 z-10 flex items-start justify-between gap-4 px-6 py-5"
	>
		<div>
			<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
				Detalle del cobro
			</p><p class="mt-1 max-w-md text-sm leading-6 text-slate-500">
				Qué ocurrió, cuánto dinero está involucrado, qué comprobante existe y qué sigue.
			</p>
		</div><Button id="collectionsDrawerClose" type="button" variant="secondary" size="sm"
			>Cerrar</Button
		>
	</div><div id="collectionsDrawerBody" class="px-6 py-5"></div>
</aside>

<div
	id="settlementsDrawerBackdrop"
	class="hidden fixed inset-0 z-40 bg-slate-950/25 backdrop-blur-[2px]"
>
</div>
<aside
	id="settlementsDrawer"
	class="fastt-side-sheet fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto p-0 text-slate-900 transition-transform duration-300"
>
	<div
		class="fastt-side-sheet-header sticky top-0 z-10 flex items-start justify-between gap-4 px-6 py-5"
	>
		<div>
			<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
				Detalle de liquidación
			</p><p class="mt-1 max-w-md text-sm leading-6 text-slate-500">
				Reserva confirmada, cobro registrado, liquidación externa y siguiente acción.
			</p>
		</div><Button id="settlementsDrawerClose" type="button" variant="secondary" size="sm"
			>Cerrar</Button
		>
	</div><div id="settlementsDrawerBody" class="px-6 py-5"></div>
</aside>

<div
	id="providerPayablesDrawerBackdrop"
	class="hidden fixed inset-0 z-40 bg-slate-950/25 backdrop-blur-[2px]"
>
</div>
<aside
	id="providerPayablesDrawer"
	class="fastt-side-sheet fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto p-0 text-slate-900 transition-transform duration-300"
>
	<div
		class="fastt-side-sheet-header sticky top-0 z-10 flex items-start justify-between gap-4 px-6 py-5"
	>
		<div>
			<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
				Detalle de pago pendiente
			</p><p class="mt-1 max-w-md text-sm leading-6 text-slate-500">
				Bloqueo, importes, comisión, impuestos, reservas relacionadas y próxima acción.
			</p>
		</div><Button id="providerPayablesDrawerClose" type="button" variant="secondary" size="sm"
			>Cerrar</Button
		>
	</div><div id="providerPayablesDrawerBody" class="px-6 py-5"></div>
</aside>

<div
	id="refundsDrawerBackdrop"
	class="hidden fixed inset-0 z-40 bg-slate-950/25 backdrop-blur-[2px]"
>
</div>
<aside
	id="refundsDrawer"
	class="fastt-side-sheet fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto p-0 text-slate-900 transition-transform duration-300"
>
	<div
		class="fastt-side-sheet-header sticky top-0 z-10 flex items-start justify-between gap-4 px-6 py-5"
	>
		<div>
			<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
				Detalle de reembolso
			</p><p class="mt-1 max-w-md text-sm leading-6 text-slate-500">
				Qué ocurrió, reserva, política, importe, comprobante, historial y acciones.
			</p>
		</div><Button id="refundsDrawerClose" type="button" variant="secondary" size="sm">Cerrar</Button
		>
	</div><div id="refundsDrawerBody" class="px-6 py-5"></div>
</aside>

<div
	id="financialExceptionsDrawerBackdrop"
	class="hidden fixed inset-0 z-40 bg-slate-950/25 backdrop-blur-[2px]"
>
</div>
<aside
	id="financialExceptionsDrawer"
	class="fastt-side-sheet fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto p-0 text-slate-900 transition-transform duration-300"
>
	<div
		class="fastt-side-sheet-header sticky top-0 z-10 flex items-start justify-between gap-4 px-6 py-5"
	>
		<div>
			<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
				Detalle de excepción
			</p><p class="mt-1 max-w-md text-sm leading-6 text-slate-500">
				Resumen, impacto, comprobantes visibles y próxima acción.
			</p>
		</div><Button id="financialExceptionsDrawerClose" type="button" variant="secondary" size="sm"
			>Cerrar</Button
		>
	</div><div id="financialExceptionsDrawerBody" class="px-6 py-5"></div>
</aside>
