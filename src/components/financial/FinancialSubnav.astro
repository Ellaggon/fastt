---
import SegmentedControl from "@/components/ui/SegmentedControl.astro"
import { financialNavigationItems } from "@/lib/financial/financialNavigation"

interface Props {
	pathname?: string
}

const { pathname = Astro.url.pathname } = Astro.props
const isActive = (href: string) =>
	href === "/financial" ? pathname === href : pathname === href || pathname.startsWith(`${href}/`)
---

<SegmentedControl class="mb-4 inline-flex max-w-full flex-wrap" aria-label="Navegación financiera">
	{
		financialNavigationItems.map((item) => {
			const active = isActive(item.href)
			return (
				<a
					href={item.href}
					data-workspace-nav
					data-financial-nav
					data-astro-prefetch="viewport"
					data-active={active ? "true" : "false"}
					aria-current={active ? "page" : undefined}
					class={`fastt-segmented-item inline-flex h-9 items-center overflow-hidden rounded-full px-3 text-sm font-medium whitespace-nowrap ${
						active ? "" : "text-slate-500 hover:bg-white/70 hover:text-slate-900"
					}`}
				>
					{item.label}
				</a>
			)
		})
	}
</SegmentedControl>
