---
import TabsInsidePanel from "@/components/ui/TabsInsidePanel.astro"
import { financialNavigationItems } from "@/lib/financial/financialNavigation"

interface Props {
	pathname?: string
}

const { pathname = Astro.url.pathname } = Astro.props
const isActive = (href: string) =>
	href === "/financial" ? pathname === href : pathname === href || pathname.startsWith(`${href}/`)
const selectedProductId = String(Astro.url.searchParams.get("productId") ?? "").trim()
const scopedHref = (href: string) => {
	if (!selectedProductId) return href
	const params = new URLSearchParams()
	params.set("productId", selectedProductId)
	return `${href}?${params.toString()}`
}
const compactLabelByLabel: Record<string, string> = {
	"Bandeja financiera": "Bandeja",
	"Pagos a proveedores": "Proveedores",
}
---

<TabsInsidePanel
	class="financial-subnav max-w-full flex-nowrap bg-black"
	aria-label="Navegación financiera"
>
	{
		financialNavigationItems.map((item) => {
			const active = isActive(item.href)
			return (
				<a
					href={scopedHref(item.href)}
					data-workspace-nav
					data-financial-nav
					data-astro-prefetch="viewport"
					data-active={active ? "true" : "false"}
					aria-current={active ? "page" : undefined}
					aria-label={item.label}
					title={item.label}
					class={`fastt-tabs-inside-panel__item inline-flex min-w-max shrink-0 items-center px-4 py-2 text-sm font-semibold whitespace-nowrap ${
						active ? "" : "bg-black text-slate-300 hover:bg-slate-800 hover:text-white"
					}`}
				>
					{compactLabelByLabel[item.label] ?? item.label}
				</a>
			)
		})
	}
</TabsInsidePanel>

<style>
	.financial-subnav {
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
	}

	.financial-subnav::-webkit-scrollbar {
		display: none;
	}

	.financial-subnav {
		background: #000;
	}

	.financial-subnav .fastt-tabs-inside-panel__item[data-active="false"] {
		background: #000;
	}
</style>
