---
import FinancialSubnav from "@/components/financial/FinancialSubnav.astro"

interface Props {
	title: string
	description: string
	note?: string
}

const { title, description, note = "" } = Astro.props
---

<section class="space-y-4">
	<header class="flex flex-col gap-2">
		<h1 class="text-3xl font-bold tracking-tight text-white">{title}</h1>
		<p class="max-w-3xl text-sm leading-6 text-slate-300">{description}</p>
		{
			note ? (
				<details class="max-w-3xl text-xs text-slate-400">
					<summary class="cursor-pointer font-semibold text-slate-400 hover:text-slate-200">
						Límites operativos
					</summary>
					<p class="mt-2 rounded-xl border border-white/10 bg-slate-950/60 px-3 py-2 leading-5">
						{note}
					</p>
				</details>
			) : null
		}
	</header>

	<FinancialSubnav />

	<slot />
</section>
