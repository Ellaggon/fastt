---
const { offers, searchState, productId, amenities, hotelRoom, productFallbackImage } = Astro.props
import { Bath, BedDouble, User } from "@lucide/astro"
import DatesModal from "./DatesModal.astro"

const variants = (offers ?? []).map((room: any) => ({
	id: String(room?.variant?.id ?? ""),
	name: String(room?.variant?.name ?? "Habitación"),
	capacity: Number(room?.variant?.maxOccupancy ?? 0),
}))
---

<header
	class="flex flex-wrap items-end justify-between gap-6 rounded-2xl bg-neutral-900 p-4 md:p-6"
>
	<div>
		<span class="block text-xs font-medium uppercase tracking-wide text-neutral-400">
			Revisa disponibilidad de
		</span>
		<h2 class="mt-1 text-2xl font-semibold text-white">Habitaciones</h2>
	</div>

	<span id="guestsLabel" class="hidden"></span>

	<div class="flex w-full flex-wrap items-end gap-3 md:w-auto">
		<div class="grid w-full grid-cols-2 gap-2 md:flex md:w-auto">
			<div class="flex flex-col gap-1">
				<label class="text-xs text-neutral-400">Adultos</label>
				<input
					id="adultsInput"
					type="number"
					min="1"
					value={String(searchState.adults ?? 2)}
					class="h-[44px] rounded-lg border border-neutral-700 bg-neutral-800 px-3 text-sm text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500 md:w-[110px]"
				/>
			</div>

			<div class="flex flex-col gap-1">
				<label class="text-xs text-neutral-400">Niños</label>
				<input
					id="childrenInput"
					type="number"
					min="0"
					value={String(searchState.children ?? 0)}
					class="h-[44px] rounded-lg border border-neutral-700 bg-neutral-800 px-3 text-sm text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500 md:w-[110px]"
				/>
			</div>
		</div>

		<div
			class="flex w-full overflow-hidden rounded-xl border border-neutral-700 bg-neutral-800 md:w-auto"
			data-open-modal="dates"
		>
			<div class="relative flex w-1/2 items-center md:w-[160px]">
				<svg
					class="absolute left-3 h-4 w-4 text-neutral-400"
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<rect x="3" y="4" width="18" height="18" rx="2"></rect>
					<line x1="16" y1="2" x2="16" y2="6"></line>
					<line x1="8" y1="2" x2="8" y2="6"></line>
					<line x1="3" y1="10" x2="21" y2="10"></line>
				</svg>

				<button
					id="checkinBtn"
					value={searchState.checkIn}
					class="h-[44px] w-full bg-transparent pl-9 pr-3 text-sm text-white outline-none focus:bg-neutral-700"
				>
					<span id="checkinText">Check-in</span>
				</button>
			</div>

			<div class="w-px bg-neutral-700"></div>

			<div class="relative flex w-1/2 items-center md:w-[160px]">
				<svg
					class="absolute left-3 h-4 w-4 text-neutral-400"
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<rect x="3" y="4" width="18" height="18" rx="2"></rect>
					<line x1="16" y1="2" x2="16" y2="6"></line>
					<line x1="8" y1="2" x2="8" y2="6"></line>
					<line x1="3" y1="10" x2="21" y2="10"></line>
				</svg>

				<button
					id="checkoutBtn"
					value={searchState.checkOut}
					class="h-[44px] w-full bg-transparent pl-9 pr-3 text-sm text-white outline-none focus:bg-neutral-700"
				>
					<span id="checkoutText">Check-out</span>
				</button>
			</div>
		</div>

		<button
			id="searchBtn"
			class="h-[44px] w-full rounded-lg bg-blue-600 px-6 text-sm font-semibold text-white shadow-lg transition hover:bg-blue-500 active:scale-[0.97] md:w-auto"
		>
			Consultar disponibilidad
		</button>
	</div>
</header>

<article class="rounded-2xl border border-neutral-200 bg-white p-4 md:p-6">
	<div class="space-y-2">
		<h3 class="text-lg font-semibold text-neutral-900">Resumen de disponibilidad</h3>
		<p id="availabilitySummaryText" class="text-sm text-neutral-600">
			Selecciona fechas para ver precio total y estado de venta.
		</p>
	</div>
	<div class="mt-4 flex flex-wrap items-center gap-2">
		<button
			type="button"
			id="reserveBtn"
			class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700"
		>
			Reservar
		</button>
		<button
			type="button"
			id="confirmBookingBtn"
			disabled
			class="rounded-lg bg-neutral-900 px-4 py-2 text-sm font-semibold text-white hover:bg-neutral-800 disabled:cursor-not-allowed disabled:opacity-50"
		>
			Confirmar reserva
		</button>
		<span id="holdStatusText" class="text-sm text-neutral-500"></span>
	</div>
</article>
<DatesModal />

<div class="-mx-4 overflow-x-auto overscroll-x-contain px-4 py-3">
	<div class="flex snap-x snap-mandatory gap-3">
		{
			(offers ?? []).map((room: any) => {
				const variant = room.variant
				const entity = hotelRoom?.find((r: any) => r.id === variant.entityId) ?? {}
				const ratePlans = room.ratePlans ?? []
				const variantImages = Array.isArray(room?.variantImages) ? room.variantImages : []
				const primaryVariantImage =
					variantImages.find((img: any) => Boolean(img?.isPrimary))?.url ?? variantImages[0]?.url
				const img =
					primaryVariantImage ??
					productFallbackImage ??
					"https://placehold.co/800x600?text=Sin+imagen"

				const prices = ratePlans
					.map((rp: any) => rp.basePrice ?? rp.finalPrice ?? rp.price)
					.filter((p: any) => typeof p === "number")

				const fromPrice = prices.length ? Math.min(...prices) : variant.basePrice
				const showBasePrice =
					typeof variant.basePrice === "number" &&
					prices.length > 0 &&
					variant.basePrice > fromPrice

				return (
					<article
						data-room-id={variant.id}
						data-capacity={variant.maxOccupancy ?? 0}
						class="w-[360px] flex-shrink-0 snap-start rounded-3xl bg-neutral-100 shadow-[0_20px_50px_rgba(0,0,0,0.08)] backdrop-blur-xl transition hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(0,0,0,0.12)]"
					>
						<img
							src={img}
							alt={variant.name}
							data-open-modal={`room-${variant.id}`}
							class="h-48 w-full cursor-pointer rounded-t-2xl object-cover"
						/>

						<div class="p-5">
							<h3 class="font-semibold text-neutral-800" data-open-modal={`room-${variant.id}`}>
								{variant.name}
							</h3>

							<p class="mt-1 text-sm text-neutral-500">
								{entity.sizeM2 && `${entity.sizeM2} m²`}
								{entity.hasView && ` • Con vista ${entity.hasView}`}
							</p>

							<div class="mt-4 grid grid-cols-2 gap-2 text-sm text-neutral-600">
								<label class="flex items-center gap-1">
									<BedDouble class={`h-4 w-4 ${entity.bedType ? "block" : "hidden"}`} />
									<span>
										{entity.bedType?.map((b: any) => `${b.count} ${b.id}`).join(", ") ?? "-"}
									</span>
								</label>

								<label class="flex items-center gap-1">
									<Bath class={`h-4 w-4 ${entity.bathroom ? "block" : "hidden"}`} />
									{entity.bathroom != null && (
										<span>
											{entity.bathroom} {entity.bathroom > 1 ? "baños" : "baño"}
										</span>
									)}
								</label>

								<label class={`${entity.hasBalcony ? "block" : "hidden"} flex items-center gap-1`}>
									<svg
										class="h-4 w-4"
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<path d="M4 10V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v6" />
										<path d="M2 10v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V10" />
										<path d="M2 14h20" />
										<path d="M6 14v7" />
										<path d="M12 14v7" />
										<path d="M18 14v7" />
									</svg>
									<span>Con balcón</span>
								</label>

								<label class="flex items-center gap-1">
									<User class={`h-4 w-4 ${entity.maxOccupancy ? "block" : "hidden"}`} />
									{entity.maxOccupancy > 0 && (
										<span>
											{entity.maxOccupancy} {entity.maxOccupancy > 1 ? "Personas" : "Persona"}
										</span>
									)}
								</label>
							</div>

							<div class="mt-5 grid grid-cols-2 items-end gap-x-3 text-right">
								{showBasePrice && (
									<>
										<span class="text-xs text-neutral-500">Precio normal:</span>
										<span class="text-sm text-neutral-500 line-through opacity-60">
											${variant.basePrice}
										</span>
									</>
								)}

								<span class="text-xs text-neutral-500">Desde:</span>
								<span class="price-value text-xl font-semibold text-neutral-900">${fromPrice}</span>
							</div>

							<div class="mt-4 space-y-3">
								{ratePlans.map((rp: any) => {
									const finalPrice = rp.finalPrice ?? rp.price ?? 0

									return (
										<div
											class="flex items-center justify-between rounded-lg border bg-white px-3 py-2"
											data-rateplan-id={rp.id}
										>
											<div>
												<p class="text-sm font-medium text-neutral-800">{rp.name ?? "Tarifa"}</p>
												<p class="text-xs text-neutral-500">
													{rp.paymentType}
													{rp.refundable === false ? " • No reembolsable" : ""}
												</p>
											</div>

											<div class="text-right">
												<p class="text-sm font-semibold text-neutral-900">${finalPrice}</p>

												<button
													type="button"
													data-select-variant-id={variant.id}
													class="mt-1 inline-block rounded-md bg-blue-600 px-3 py-1 text-xs font-semibold text-white hover:bg-blue-700"
												>
													Reservar
												</button>
											</div>
										</div>
									)
								})}
							</div>

							<div class="mt-6 flex gap-3">
								<button
									type="button"
									data-open-modal={`room-${variant.id}`}
									class="flex-1 rounded-lg border border-neutral-200 px-4 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-50"
								>
									Ver habitación
								</button>

								<button
									type="button"
									data-select-variant-id={variant.id}
									class="flex-1 rounded-lg bg-blue-600 px-4 py-2 text-center text-sm font-semibold text-white transition hover:bg-blue-700 active:scale-[0.98]"
								>
									Reservar
								</button>
							</div>
						</div>
					</article>
				)
			})
		}
	</div>
</div>

<script
	is:inline
	define:vars={{
		productId,
		selectedVariantIdFromQuery: String(searchState?.selectedVariantId ?? ""),
		defaultVariantId: String(variants[0]?.id ?? ""),
	}}
>
	if (!productId) {
		console.warn("productId missing in RoomSection")
	}

	const guestsLabel = document.getElementById("guestsLabel")
	const adultsInput = document.getElementById("adultsInput")
	const childrenInput = document.getElementById("childrenInput")
	const checkinBtn = document.getElementById("checkinBtn")
	const checkoutBtn = document.getElementById("checkoutBtn")
	const summaryText = document.getElementById("availabilitySummaryText")
	const holdStatusText = document.getElementById("holdStatusText")
	const reserveBtn = document.getElementById("reserveBtn")
	const confirmBookingBtn = document.getElementById("confirmBookingBtn")

	let selectedVariantId = String(selectedVariantIdFromQuery || defaultVariantId || "").trim()
	let latestHoldId = ""

	function parseIsoDate(iso) {
		const parsed = new Date(`${iso}T00:00:00`)
		return Number.isNaN(parsed.getTime()) ? null : parsed
	}

	function formatDateEs(iso) {
		const parsed = parseIsoDate(iso)
		if (!parsed) return iso
		return parsed.toLocaleDateString("es-CL")
	}

	function getSelectedVariantId() {
		return String(selectedVariantId ?? "").trim()
	}

	function getDateRange() {
		return {
			from: String(checkinBtn?.value ?? "").trim(),
			to: String(checkoutBtn?.value ?? "").trim(),
		}
	}

	function updateGuestsLabel() {
		const adults = Number(adultsInput?.value ?? 1)
		const children = Number(childrenInput?.value ?? 0)
		const total = adults + children

		if (guestsLabel) {
			guestsLabel.textContent =
				children > 0
					? `${adults} adultos, ${children} niño${children > 1 ? "s" : ""}`
					: `${adults} adulto${adults > 1 ? "s" : ""}`
		}

		return total
	}

	if (adultsInput) adultsInput.oninput = updateGuestsLabel
	if (childrenInput) childrenInput.oninput = updateGuestsLabel
	updateGuestsLabel()

	async function fetchCanonicalOffers() {
		const dateRange = getDateRange()
		const adults = Math.max(1, Number(adultsInput?.value ?? 1) || 1)
		const children = Math.max(0, Number(childrenInput?.value ?? 0) || 0)
		if (!dateRange.from || !dateRange.to) return { offers: [] }

		const response = await fetch(`/api/products/${encodeURIComponent(String(productId))}/offers`, {
			method: "POST",
			headers: {
				"accept": "application/json",
				"Content-Type": "application/json",
			},
			body: JSON.stringify({
				checkIn: dateRange.from,
				checkOut: dateRange.to,
				adults,
				children,
				rooms: 1,
			}),
		})
		if (!response.ok) throw new Error(`offers_${response.status}`)
		const payload = await response.json().catch(() => ({}))
		return {
			offers: Array.isArray(payload?.offers) ? payload.offers : [],
		}
	}

	document.getElementById("searchBtn")?.addEventListener("click", async () => {
		const dateRange = getDateRange()
		if (!dateRange.from || !dateRange.to) {
			if (summaryText)
				summaryText.textContent = "Selecciona check-in y check-out antes de consultar."
			return
		}

		try {
			if (summaryText) summaryText.textContent = "Consultando disponibilidad..."
			const offersPayload = await fetchCanonicalOffers()
			const selectedVariantId = getSelectedVariantId()
			const selectedOffer =
				offersPayload.offers.find(
					(offer) => String(offer?.variantId ?? offer?.variant?.id ?? "") === selectedVariantId
				) ?? offersPayload.offers[0]
			const availabilitySummary = selectedOffer?.availabilitySummary ?? null
			const total = availabilitySummary?.totalPrice
			const sellable = Boolean(availabilitySummary?.sellable)
			if (summaryText) {
				summaryText.textContent = `Estado del rango: ${sellable ? "VENDIBLE" : "NO VENDIBLE"} · Noches: ${Number(availabilitySummary?.nights ?? 0)} · Total: ${total == null ? "—" : `USD ${Number(total).toFixed(2)}`}`
			}
		} catch {
			if (summaryText)
				summaryText.textContent = "No se pudo obtener disponibilidad para el rango seleccionado."
		}

		const nextParams = new URLSearchParams({
			checkin: dateRange.from,
			checkout: dateRange.to,
			adults: String(Math.max(1, Number(adultsInput?.value ?? 1) || 1)),
			children: String(Math.max(0, Number(childrenInput?.value ?? 0) || 0)),
		})
		const variantId = getSelectedVariantId()
		if (variantId) nextParams.set("variantId", variantId)
		window.location.href = `/hotels/${encodeURIComponent(String(productId))}?${nextParams.toString()}`
	})

	if (checkinBtn?.value) {
		const label = document.getElementById("checkinText")
		if (label) label.textContent = formatDateEs(checkinBtn.value)
	}
	if (checkoutBtn?.value) {
		const label = document.getElementById("checkoutText")
		if (label) label.textContent = formatDateEs(checkoutBtn.value)
	}

	for (const trigger of document.querySelectorAll("[data-select-variant-id]")) {
		trigger.addEventListener("click", async (event) => {
			const target = event.currentTarget
			const variantId = String(target?.dataset?.selectVariantId ?? "").trim()
			if (!variantId) return
			selectedVariantId = variantId
			await handleReserve()
		})
	}

	async function handleReserve() {
		const variantId = getSelectedVariantId()
		const occupancy = updateGuestsLabel()
		const dateRange = getDateRange()
		if (!variantId || !dateRange.from || !dateRange.to) return

		console.debug("ui_hold_triggered", { variantId })
		if (holdStatusText) holdStatusText.textContent = "Creando hold..."
		if (reserveBtn) reserveBtn.disabled = true
		try {
			const response = await fetch("/api/inventory/hold", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					variantId,
					dateRange,
					occupancy: Math.max(1, occupancy),
				}),
			})
			const payload = await response.json().catch(() => ({}))
			if (!response.ok) {
				if (holdStatusText) {
					holdStatusText.textContent =
						payload?.error === "not_available"
							? "No hay disponibilidad suficiente para ese rango."
							: "No se pudo crear el hold."
				}
				return
			}
			latestHoldId = String(payload?.holdId ?? "")
			if (holdStatusText) {
				holdStatusText.textContent = latestHoldId ? "Hold creado correctamente." : "Hold creado."
			}
			if (confirmBookingBtn) confirmBookingBtn.disabled = !latestHoldId
		} catch {
			if (holdStatusText) holdStatusText.textContent = "Error de red al crear hold."
		} finally {
			if (reserveBtn) reserveBtn.disabled = false
		}
	}

	async function handleConfirmBooking() {
		if (!latestHoldId) return
		if (confirmBookingBtn) confirmBookingBtn.disabled = true
		if (holdStatusText) holdStatusText.textContent = "Confirmando reserva..."
		try {
			const response = await fetch("/api/booking/confirm", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ holdId: latestHoldId }),
			})
			const payload = await response.json().catch(() => ({}))
			if (!response.ok || !payload?.bookingId) {
				if (holdStatusText) holdStatusText.textContent = "No se pudo confirmar la reserva."
				if (confirmBookingBtn) confirmBookingBtn.disabled = false
				return
			}
			console.debug("ui_booking_confirmed", { bookingId: payload.bookingId })
			window.location.href = `/booking/${encodeURIComponent(String(payload.bookingId))}`
		} catch {
			if (holdStatusText) holdStatusText.textContent = "Error de red al confirmar la reserva."
			if (confirmBookingBtn) confirmBookingBtn.disabled = false
		}
	}

	reserveBtn?.addEventListener("click", handleReserve)
	confirmBookingBtn?.addEventListener("click", handleConfirmBooking)
</script>
