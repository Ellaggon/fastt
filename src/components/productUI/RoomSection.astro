---
const {
	offers,
	searchState,
	productId,
	amenities,
	hotelRoom,
	productFallbackImage,
	policiesByRatePlanId = {},
} = Astro.props
import GuestRoomPreviewCards from "@/components/productUI/GuestRoomPreviewCards.astro"
import Button from "@/components/ui/Button.astro"
import Input from "@/components/ui/Input.astro"
import { buildGuestRoomPreviews } from "@/components/productUI/room-section.viewmodel"
import { resolveVariantRef } from "@/shared/domain/variant-ref"
import { Bath, BedDouble, User } from "@lucide/astro"
import DatesModal from "./DatesModal.astro"

const variants = (offers ?? []).map((room: any) => ({
	id: String(room?.variant?.id ?? ""),
	name: String(room?.variant?.name ?? "Habitación"),
	capacity: Number(room?.variant?.maxOccupancy ?? 0),
}))

const guestRoomPreviews = buildGuestRoomPreviews({
	offers: offers ?? [],
	hotelRoom: hotelRoom ?? [],
	amenities: amenities ?? [],
	productFallbackImage,
})

function bedsLabel(room: any): string {
	const beds = Array.isArray(room?.beds)
		? room.beds
		: Array.isArray(room?.bedType)
			? room.bedType
			: []
	if (!beds.length) return "-"
	return beds
		.map((bed: any) => {
			const count = Number(bed?.count ?? 1)
			const label = String(bed?.id ?? bed?.bedType ?? bed?.type ?? "cama").trim()
			return `${Number.isFinite(count) && count > 0 ? count : 1} ${label}`
		})
		.join(", ")
}

function roomView(room: any): string | null {
	const value = String(room?.viewType ?? room?.hasView ?? "").trim()
	return value || null
}

function bathroomCount(room: any): number | null {
	const value = Number(room?.bathroomCount ?? room?.bathroom)
	return Number.isFinite(value) ? value : null
}

function occupancyCount(room: any): number | null {
	const value = Number(room?.maxOccupancy)
	return Number.isFinite(value) ? value : null
}

function ratePlanIdOf(ratePlan: any): string {
	return String(ratePlan?.ratePlanId ?? ratePlan?.id ?? "").trim()
}

function policyStatusLabel(status: string): string {
	if (status === "complete") return "Condiciones completas"
	if (status === "partial") return "Condiciones incompletas"
	return "Condiciones pendientes"
}

function policyStatusClass(status: string): string {
	if (status === "complete") return "border-emerald-200 bg-emerald-50 text-emerald-900"
	if (status === "partial") return "border-amber-200 bg-amber-50 text-amber-900"
	return "border-rose-200 bg-rose-50 text-rose-900"
}
---

<header class="fastt-workspace-panel flex flex-wrap items-end justify-between gap-6 p-4 md:p-6">
	<div>
		<span class="block text-xs font-semibold uppercase tracking-wide text-slate-500">
			Revisa disponibilidad de
		</span>
		<h2 class="mt-1 text-2xl font-semibold text-slate-950">Habitaciones</h2>
	</div>

	<span id="guestsLabel" class="hidden"></span>

	<div class="flex w-full flex-wrap items-end gap-3 md:w-auto">
		<div class="grid w-full grid-cols-2 gap-2 md:flex md:w-auto">
			<div class="flex flex-col gap-1">
				<label class="text-xs text-slate-500">Adultos</label>
				<Input
					id="adultsInput"
					type="number"
					min="1"
					value={String(searchState.adults ?? 2)}
					class="md:w-[110px]"
				/>
			</div>

			<div class="flex flex-col gap-1">
				<label class="text-xs text-slate-500">Niños</label>
				<Input
					id="childrenInput"
					type="number"
					min="0"
					value={String(searchState.children ?? 0)}
					class="md:w-[110px]"
				/>
			</div>
		</div>

		<div
			class="fastt-soft-box flex w-full overflow-hidden border border-slate-200 bg-white md:w-auto"
			data-open-modal="dates"
		>
			<div class="relative flex w-1/2 items-center md:w-[160px]">
				<svg
					class="absolute left-3 h-4 w-4 text-slate-500"
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<rect x="3" y="4" width="18" height="18" rx="2"></rect>
					<line x1="16" y1="2" x2="16" y2="6"></line>
					<line x1="8" y1="2" x2="8" y2="6"></line>
					<line x1="3" y1="10" x2="21" y2="10"></line>
				</svg>

				<button
					id="checkinBtn"
					value={searchState.checkIn}
					class="h-[44px] w-full bg-transparent pl-9 pr-3 text-sm text-slate-700 outline-none focus:bg-slate-50"
				>
					<span id="checkinText">Ingreso</span>
				</button>
			</div>

			<div class="w-px bg-slate-200"></div>

			<div class="relative flex w-1/2 items-center md:w-[160px]">
				<svg
					class="absolute left-3 h-4 w-4 text-slate-500"
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<rect x="3" y="4" width="18" height="18" rx="2"></rect>
					<line x1="16" y1="2" x2="16" y2="6"></line>
					<line x1="8" y1="2" x2="8" y2="6"></line>
					<line x1="3" y1="10" x2="21" y2="10"></line>
				</svg>

				<button
					id="checkoutBtn"
					value={searchState.checkOut}
					class="h-[44px] w-full bg-transparent pl-9 pr-3 text-sm text-slate-700 outline-none focus:bg-slate-50"
				>
					<span id="checkoutText">Salida</span>
				</button>
			</div>
		</div>

		<Button id="searchBtn" class="w-full md:w-auto"> Consultar disponibilidad </Button>
	</div>
</header>

<article class="fastt-card border bg-white p-4 md:p-6">
	<div class="space-y-2">
		<h3 class="text-lg font-semibold text-slate-950">Resumen de disponibilidad</h3>
		<p id="availabilitySummaryText" class="text-sm text-slate-600">
			Selecciona fechas para ver precio total y estado de venta.
		</p>
	</div>
	<div class="mt-4 flex flex-wrap items-center gap-2">
		<Button type="button" id="reserveBtn"> Reservar </Button>
		<Button type="button" id="confirmBookingBtn" disabled> Confirmar reserva </Button>
		<span id="holdStatusText" class="text-sm text-slate-500"></span>
	</div>
</article>
<DatesModal />

{
	guestRoomPreviews.length ? (
		<section class="fastt-card border bg-white p-4 md:p-6">
			<div class="flex flex-wrap items-start justify-between gap-3">
				<div>
					<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
						Experiencia de descanso
					</p>
					<h3 class="mt-1 text-xl font-semibold text-slate-950">Dónde dormirás</h3>
					<p class="mt-1 max-w-2xl text-sm leading-6 text-slate-600">
						Estas son las habitaciones y detalles que verá el huésped antes de reservar.
					</p>
				</div>
			</div>

			<GuestRoomPreviewCards
				previews={guestRoomPreviews}
				cardClass="fastt-row-card bg-white text-slate-800"
				enableModal={true}
			/>
		</section>
	) : null
}

<div class="-mx-4 overflow-x-auto overscroll-x-contain px-4 py-3">
	<div class="flex snap-x snap-mandatory gap-3">
		{
			(offers ?? []).map((room: any) => {
				const variant = room.variant
				const variantRef = resolveVariantRef(variant)
				const entity = hotelRoom?.find((r: any) => r.id === variantRef) ?? {}
				const ratePlans = room.ratePlans ?? []
				const variantImages = Array.isArray(room?.variantImages) ? room.variantImages : []
				const primaryVariantImage =
					variantImages.find((img: any) => Boolean(img?.isPrimary))?.url ?? variantImages[0]?.url
				const img =
					primaryVariantImage ??
					productFallbackImage ??
					"https://placehold.co/800x600?text=Sin+imagen"

				const prices = ratePlans
					.map((rp: any) => rp.basePrice ?? rp.finalPrice ?? rp.price)
					.filter((p: any) => typeof p === "number")

				const fromPrice = prices.length ? Math.min(...prices) : variant.basePrice
				const showBasePrice =
					typeof variant.basePrice === "number" &&
					prices.length > 0 &&
					variant.basePrice > fromPrice

				return (
					<article
						data-room-id={variant.id}
						data-capacity={variant.maxOccupancy ?? 0}
						class="fastt-row-card w-[360px] flex-shrink-0 snap-start overflow-hidden"
					>
						<img
							src={img}
							alt={variant.name}
							data-open-modal={`room-${variant.id}`}
							class="h-48 w-full cursor-pointer object-cover"
						/>

						<div class="p-5">
							<h3 class="font-semibold text-slate-950" data-open-modal={`room-${variant.id}`}>
								{variant.name}
							</h3>

							<p class="mt-1 text-sm text-slate-500">
								{entity.sizeM2 && `${entity.sizeM2} m²`}
								{roomView(entity) && ` • Con vista ${roomView(entity)}`}
							</p>

							<div class="mt-4 grid grid-cols-2 gap-2 text-sm text-slate-600">
								<label class="flex items-center gap-1">
									<BedDouble class={`h-4 w-4 ${bedsLabel(entity) !== "-" ? "block" : "hidden"}`} />
									<span>{bedsLabel(entity)}</span>
								</label>

								<label class="flex items-center gap-1">
									<Bath class={`h-4 w-4 ${bathroomCount(entity) ? "block" : "hidden"}`} />
									{bathroomCount(entity) != null && (
										<span>
											{bathroomCount(entity)} {Number(bathroomCount(entity)) > 1 ? "baños" : "baño"}
										</span>
									)}
								</label>

								<label class={`${entity.hasBalcony ? "block" : "hidden"} flex items-center gap-1`}>
									<svg
										class="h-4 w-4"
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<path d="M4 10V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v6" />
										<path d="M2 10v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V10" />
										<path d="M2 14h20" />
										<path d="M6 14v7" />
										<path d="M12 14v7" />
										<path d="M18 14v7" />
									</svg>
									<span>Con balcón</span>
								</label>

								<label class="flex items-center gap-1">
									<User class={`h-4 w-4 ${occupancyCount(entity) ? "block" : "hidden"}`} />
									{Number(occupancyCount(entity) ?? 0) > 0 && (
										<span>
											{occupancyCount(entity)}{" "}
											{Number(occupancyCount(entity)) > 1 ? "Personas" : "Persona"}
										</span>
									)}
								</label>
							</div>

							<div class="mt-5 grid grid-cols-2 items-end gap-x-3 text-right">
								{showBasePrice && (
									<>
										<span class="text-xs text-slate-500">Precio normal:</span>
										<span class="text-sm text-slate-500 line-through opacity-60">
											${variant.basePrice}
										</span>
									</>
								)}

								<span class="text-xs text-slate-500">Desde:</span>
								<span class="price-value text-xl font-semibold text-slate-950">${fromPrice}</span>
							</div>

							<div class="mt-4 space-y-3">
								{ratePlans.map((rp: any) => {
									const finalPrice = rp.finalPrice ?? rp.price ?? 0
									const ratePlanId = ratePlanIdOf(rp)
									const contract = policiesByRatePlanId[ratePlanId] ?? null
									const visibleCards = (contract?.cards ?? []).slice(0, 4)

									return (
										<div
											class="fastt-soft-box space-y-3 border border-slate-200 bg-white px-3 py-3"
											data-rateplan-id={ratePlanId}
										>
											<div class="flex items-start justify-between gap-3">
												<div>
													<p class="text-sm font-medium text-slate-800">{rp.name ?? "Tarifa"}</p>
													<p class="mt-1 text-xs text-slate-500">
														Verdad contractual de esta tarifa
													</p>
												</div>

												<div class="text-right">
													<p class="text-sm font-semibold text-slate-950">${finalPrice}</p>

													<Button
														type="button"
														data-select-variant-id={variant.id}
														data-select-rateplan-id={ratePlanId}
														size="sm"
														class="mt-1"
													>
														Reservar
													</Button>
												</div>
											</div>

											<div
												class={`rounded-md border px-3 py-2 text-xs ${policyStatusClass(String(contract?.status ?? "missing"))}`}
											>
												<p class="font-semibold">
													{policyStatusLabel(String(contract?.status ?? "missing"))}
												</p>
												<p class="mt-1">
													{contract?.summary ?? "Sin condiciones para esta tarifa."}
												</p>
											</div>

											<div class="grid gap-2 text-xs text-slate-700">
												{visibleCards.map((card: any) => (
													<div class="fastt-soft-box border border-slate-200 bg-slate-50 px-3 py-2">
														<p class="font-semibold text-slate-950">{card.label}</p>
														<p class="mt-1">
															{card.state === "missing"
																? "Pendiente para esta tarifa."
																: card.description || "Condición definida sin texto visible."}
														</p>
													</div>
												))}
											</div>
										</div>
									)
								})}
							</div>

							<div class="mt-6 flex gap-3">
								<Button
									type="button"
									data-open-modal={`room-${variant.id}`}
									variant="secondary"
									class="flex-1"
								>
									Ver habitación
								</Button>

								<Button
									type="button"
									data-select-variant-id={variant.id}
									data-select-rateplan-id={ratePlanIdOf(ratePlans[0])}
									class="flex-1"
								>
									Reservar
								</Button>
							</div>
						</div>
					</article>
				)
			})
		}
	</div>
</div>

<script
	is:inline
	define:vars={{
		productId,
		selectedVariantIdFromQuery: String(searchState?.selectedVariantId ?? ""),
		defaultVariantId: String(variants[0]?.id ?? ""),
		defaultRatePlanId: String((offers ?? [])[0]?.ratePlans?.[0]?.ratePlanId ?? ""),
	}}
>
	if (!productId) {
		console.warn("productId missing in RoomSection")
	}

	const guestsLabel = document.getElementById("guestsLabel")
	const adultsInput = document.getElementById("adultsInput")
	const childrenInput = document.getElementById("childrenInput")
	const checkinBtn = document.getElementById("checkinBtn")
	const checkoutBtn = document.getElementById("checkoutBtn")
	const summaryText = document.getElementById("availabilitySummaryText")
	const holdStatusText = document.getElementById("holdStatusText")
	const reserveBtn = document.getElementById("reserveBtn")
	const confirmBookingBtn = document.getElementById("confirmBookingBtn")

	let selectedVariantId = String(selectedVariantIdFromQuery || defaultVariantId || "").trim()
	let selectedRatePlanId = String(defaultRatePlanId || "").trim()
	let latestHoldId = ""

	function parseIsoDate(iso) {
		const parsed = new Date(`${iso}T00:00:00`)
		return Number.isNaN(parsed.getTime()) ? null : parsed
	}

	function formatDateEs(iso) {
		const parsed = parseIsoDate(iso)
		if (!parsed) return iso
		return parsed.toLocaleDateString("es-CL")
	}

	function getSelectedVariantId() {
		return String(selectedVariantId ?? "").trim()
	}

	function getSelectedRatePlanId() {
		return String(selectedRatePlanId ?? "").trim()
	}

	function getDateRange() {
		return {
			from: String(checkinBtn?.value ?? "").trim(),
			to: String(checkoutBtn?.value ?? "").trim(),
		}
	}

	function updateGuestsLabel() {
		const adults = Number(adultsInput?.value ?? 1)
		const children = Number(childrenInput?.value ?? 0)
		const total = adults + children

		if (guestsLabel) {
			guestsLabel.textContent =
				children > 0
					? `${adults} adultos, ${children} niño${children > 1 ? "s" : ""}`
					: `${adults} adulto${adults > 1 ? "s" : ""}`
		}

		return total
	}

	if (adultsInput) adultsInput.oninput = updateGuestsLabel
	if (childrenInput) childrenInput.oninput = updateGuestsLabel
	updateGuestsLabel()

	async function fetchCanonicalOffers() {
		const dateRange = getDateRange()
		const adults = Math.max(1, Number(adultsInput?.value ?? 1) || 1)
		const children = Math.max(0, Number(childrenInput?.value ?? 0) || 0)
		if (!dateRange.from || !dateRange.to) return { offers: [] }

		const response = await fetch(`/api/products/${encodeURIComponent(String(productId))}/offers`, {
			method: "POST",
			headers: {
				"accept": "application/json",
				"Content-Type": "application/json",
			},
			body: JSON.stringify({
				checkIn: dateRange.from,
				checkOut: dateRange.to,
				adults,
				children,
				rooms: 1,
			}),
		})
		if (!response.ok) throw new Error(`offers_${response.status}`)
		const payload = await response.json().catch(() => ({}))
		return {
			offers: Array.isArray(payload?.offers) ? payload.offers : [],
		}
	}

	document.getElementById("searchBtn")?.addEventListener("click", async () => {
		const dateRange = getDateRange()
		if (!dateRange.from || !dateRange.to) {
			if (summaryText) summaryText.textContent = "Selecciona ingreso y salida antes de consultar."
			return
		}

		try {
			if (summaryText) summaryText.textContent = "Consultando disponibilidad..."
			const offersPayload = await fetchCanonicalOffers()
			const selectedVariantId = getSelectedVariantId()
			const selectedOffer =
				offersPayload.offers.find(
					(offer) => String(offer?.variantId ?? offer?.variant?.id ?? "") === selectedVariantId
				) ?? offersPayload.offers[0]
			const availabilitySummary = selectedOffer?.availabilitySummary ?? null
			const total = availabilitySummary?.totalPrice
			const sellable = Boolean(availabilitySummary?.sellable)
			if (summaryText) {
				summaryText.textContent = `Estado del rango: ${sellable ? "VENDIBLE" : "NO VENDIBLE"} · Noches: ${Number(availabilitySummary?.nights ?? 0)} · Total: ${total == null ? "—" : `USD ${Number(total).toFixed(2)}`}`
			}
		} catch {
			if (summaryText)
				summaryText.textContent = "No se pudo obtener disponibilidad para el rango seleccionado."
		}

		const nextParams = new URLSearchParams({
			checkin: dateRange.from,
			checkout: dateRange.to,
			adults: String(Math.max(1, Number(adultsInput?.value ?? 1) || 1)),
			children: String(Math.max(0, Number(childrenInput?.value ?? 0) || 0)),
		})
		const variantId = getSelectedVariantId()
		if (variantId) nextParams.set("variantId", variantId)
		window.location.href = `/hotels/${encodeURIComponent(String(productId))}?${nextParams.toString()}`
	})

	if (checkinBtn?.value) {
		const label = document.getElementById("checkinText")
		if (label) label.textContent = formatDateEs(checkinBtn.value)
	}
	if (checkoutBtn?.value) {
		const label = document.getElementById("checkoutText")
		if (label) label.textContent = formatDateEs(checkoutBtn.value)
	}

	for (const trigger of document.querySelectorAll("[data-select-variant-id]")) {
		trigger.addEventListener("click", async (event) => {
			const target = event.currentTarget
			const variantId = String(target?.dataset?.selectVariantId ?? "").trim()
			const ratePlanId = String(target?.dataset?.selectRateplanId ?? "").trim()
			if (!variantId) return
			selectedVariantId = variantId
			if (ratePlanId) selectedRatePlanId = ratePlanId
			await handleReserve()
		})
	}

	async function handleReserve() {
		const variantId = getSelectedVariantId()
		const ratePlanId = getSelectedRatePlanId()
		updateGuestsLabel()
		const dateRange = getDateRange()
		if (!variantId || !ratePlanId || !dateRange.from || !dateRange.to) {
			if (holdStatusText)
				holdStatusText.textContent = "Selecciona una tarifa con condiciones antes de reservar."
			return
		}

		console.debug("ui_hold_triggered", { variantId, ratePlanId })
		if (holdStatusText) holdStatusText.textContent = "Creando hold..."
		if (reserveBtn) reserveBtn.disabled = true
		try {
			const response = await fetch("/api/inventory/hold", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					variantId,
					ratePlanId,
					dateRange,
					occupancyDetail: {
						adults: Math.max(1, Number(adultsInput?.value ?? 1) || 1),
						children: Math.max(0, Number(childrenInput?.value ?? 0) || 0),
						infants: 0,
					},
					rooms: 1,
				}),
			})
			const payload = await response.json().catch(() => ({}))
			if (!response.ok) {
				if (holdStatusText) {
					holdStatusText.textContent =
						payload?.error === "not_available"
							? "No hay disponibilidad suficiente para ese rango."
							: "No se pudo crear el hold."
				}
				return
			}
			latestHoldId = String(payload?.holdId ?? "")
			if (holdStatusText) {
				holdStatusText.textContent = latestHoldId ? "Hold creado correctamente." : "Hold creado."
			}
			if (confirmBookingBtn) confirmBookingBtn.disabled = !latestHoldId
		} catch {
			if (holdStatusText) holdStatusText.textContent = "Error de red al crear hold."
		} finally {
			if (reserveBtn) reserveBtn.disabled = false
		}
	}

	async function handleConfirmBooking() {
		if (!latestHoldId) return
		if (confirmBookingBtn) confirmBookingBtn.disabled = true
		if (holdStatusText) holdStatusText.textContent = "Confirmando reserva..."
		try {
			const response = await fetch("/api/booking/confirm", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ holdId: latestHoldId }),
			})
			const payload = await response.json().catch(() => ({}))
			if (!response.ok || !payload?.bookingId) {
				if (holdStatusText) holdStatusText.textContent = "No se pudo confirmar la reserva."
				if (confirmBookingBtn) confirmBookingBtn.disabled = false
				return
			}
			console.debug("ui_booking_confirmed", { bookingId: payload.bookingId })
			window.location.href = `/booking/${encodeURIComponent(String(payload.bookingId))}`
		} catch {
			if (holdStatusText) holdStatusText.textContent = "Error de red al confirmar la reserva."
			if (confirmBookingBtn) confirmBookingBtn.disabled = false
		}
	}

	reserveBtn?.addEventListener("click", handleReserve)
	confirmBookingBtn?.addEventListener("click", handleConfirmBooking)
</script>
