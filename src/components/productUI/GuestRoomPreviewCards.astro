---
import type { GuestRoomPreview } from "@/components/productUI/room-section.viewmodel"
import { Bath, BedDouble, Images, Ruler, User } from "@lucide/astro"

interface Props {
	previews?: GuestRoomPreview[]
	cardClass?: string
	gridClass?: string
	enableModal?: boolean
}

const {
	previews = [],
	cardClass = "border-neutral-200 bg-white text-neutral-800",
	gridClass = "grid gap-4 md:grid-cols-2 xl:grid-cols-3",
	enableModal = false,
} = Astro.props
---

<div class={gridClass}>
	{
		previews.map((preview) => {
			const gallery = preview.gallery ?? []
			const thumbnailGallery = gallery.slice(0, 4)
			return (
				<article class={`overflow-hidden rounded-2xl border ${cardClass}`}>
					<div class="relative bg-neutral-100">
						{enableModal ? (
							<button
								type="button"
								data-open-modal={`room-${preview.variantId}`}
								class="block w-full text-left"
							>
								<img
									src={preview.imageUrl}
									alt={preview.roomName}
									class="h-52 w-full object-cover"
								/>
							</button>
						) : (
							<img src={preview.imageUrl} alt={preview.roomName} class="h-52 w-full object-cover" />
						)}
						{gallery.length > 1 ? (
							<div class="absolute right-3 bottom-3 rounded-full bg-black/65 px-3 py-1 text-xs font-semibold text-white">
								{gallery.length} fotos
							</div>
						) : null}
					</div>

					<div class="space-y-5 p-4 md:p-5">
						<div>
							<p class="text-xs font-semibold tracking-wide text-neutral-500 uppercase">
								{preview.roomTypeName || "Habitación"}
							</p>
							<h3 class="mt-1 text-lg font-semibold text-neutral-950">{preview.roomName}</h3>
							<p class="mt-1 text-sm text-neutral-500">
								{[preview.sizeSummary, preview.viewSummary].filter(Boolean).join(" · ") ||
									"Detalle de habitación"}
							</p>
						</div>

						{thumbnailGallery.length > 1 ? (
							<div class="grid grid-cols-4 gap-2">
								{thumbnailGallery.map((image) => (
									<img
										src={image.url}
										alt={`${preview.roomName} foto`}
										class="h-16 rounded-lg object-cover"
									/>
								))}
							</div>
						) : null}

						<div class="grid gap-3 text-sm leading-6 text-neutral-700">
							<div>
								<p class="flex items-center gap-2 font-semibold text-neutral-900">
									<BedDouble class="h-4 w-4 text-neutral-500" />
									Dónde dormirás
								</p>
								{preview.sleepAreas.length ? (
									<div class="mt-2 grid gap-2">
										{preview.sleepAreas.map((area) => (
											<p class="rounded-lg bg-neutral-50 px-3 py-2 ring-1 ring-neutral-200">
												<span class="font-medium text-neutral-900">{area.label}:</span>{" "}
												{area.summary}
											</p>
										))}
									</div>
								) : (
									<p class="mt-1 rounded-lg bg-neutral-50 px-3 py-2 text-neutral-500 ring-1 ring-neutral-200">
										Camas por confirmar.
									</p>
								)}
							</div>

							<div class="grid gap-2 sm:grid-cols-2">
								<p class="flex items-center gap-2 rounded-lg bg-neutral-50 px-3 py-2 ring-1 ring-neutral-200">
									<Bath class="h-4 w-4 text-neutral-500" />
									<span>{preview.bathroomSummary}</span>
								</p>
								<p class="flex items-center gap-2 rounded-lg bg-neutral-50 px-3 py-2 ring-1 ring-neutral-200">
									<User class="h-4 w-4 text-neutral-500" />
									<span>{preview.occupancySummary}</span>
								</p>
								{preview.sizeSummary ? (
									<p class="flex items-center gap-2 rounded-lg bg-neutral-50 px-3 py-2 ring-1 ring-neutral-200">
										<Ruler class="h-4 w-4 text-neutral-500" />
										<span>{preview.sizeSummary}</span>
									</p>
								) : null}
								{gallery.length ? (
									<p class="flex items-center gap-2 rounded-lg bg-neutral-50 px-3 py-2 ring-1 ring-neutral-200">
										<Images class="h-4 w-4 text-neutral-500" />
										<span>
											{gallery.length} foto{gallery.length === 1 ? "" : "s"}
										</span>
									</p>
								) : null}
							</div>
						</div>

						{preview.amenityGroups.length ? (
							<div>
								<p class="text-sm font-semibold text-neutral-900">Comodidades de la habitación</p>
								<div class="mt-3 grid gap-3">
									{preview.amenityGroups.map((group) => (
										<div class="rounded-xl border border-neutral-200 bg-white p-3">
											<p class="text-xs font-semibold tracking-wide text-neutral-500 uppercase">
												{group.category}
											</p>
											<div class="mt-2 flex flex-wrap gap-2">
												{group.labels.map((label) => (
													<span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-700">
														{label}
													</span>
												))}
											</div>
										</div>
									))}
								</div>
							</div>
						) : null}

						{preview.guestFacingNotes ? (
							<div class="rounded-xl border border-neutral-200 bg-white p-4">
								<p class="text-sm font-semibold text-neutral-900">Notas para huéspedes</p>
								<p class="mt-2 text-sm leading-6 text-neutral-600">{preview.guestFacingNotes}</p>
							</div>
						) : null}
					</div>
				</article>
			)
		})
	}
</div>
