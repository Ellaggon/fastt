---
import Breadcrumbs from "../Breadcrumbs.astro"

const { productData, productId } = Astro.props
const productType = String(productData?.productType ?? "")
	.trim()
	.toLowerCase()
const collectionHref =
	productType === "hotel" ? "/hotels" : productType === "package" ? "/packages" : "/tours"

const breadcrumbItems = [
	{ name: "Home", href: "/" },
	{
		name: productData?.productType ?? "",
		href: collectionHref,
	},
	{
		name: productData?.name || "/",
		href: `${collectionHref}/${productId}`,
		current: true,
	},
]
---

<Breadcrumbs items={breadcrumbItems} />
