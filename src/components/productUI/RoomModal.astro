---
import { formatBedType } from "@/data/room/room-beds"
import { Bath, BedDouble, DoorClosed, Ruler, User } from "@lucide/astro"

const { offers = [], roomImages = [], hotelRoom = [] } = Astro.props
---

{
	offers.map((offer: any) => {
		const variant = offer.variant

		// 🔹 habitación estructural
		const room = hotelRoom.find((r: any) => r.id === variant.entityId)
		if (!room) return null

		// 🔹 imágenes reales desde roomImages
		const images = roomImages
			.filter((img: any) => img.entityId === room.id)
			.sort((a: any, b: any) => a.order - b.order)

		const mainImage =
			images.find((img: any) => img.isPrimary)?.url ??
			images[0]?.url ??
			"https://placehold.co/1200x800"

		return (
			<article
				data-modal={`room-${variant.id}`}
				class="modal-overlay hidden border-none bg-transparent p-0 outline-none backdrop:bg-black/40 backdrop:backdrop-blur-sm"
			>
				<button
					data-close-modal
					class="absolute right-0 top-3 z-20 m-4 flex h-10 w-10 items-center justify-center rounded-full bg-black/50"
				>
					✕
				</button>

				<div data-close class="fixed inset-0 overflow-y-auto flex items-start justify-center px-2 py-10 sm:p-12">
					<div class="pointer-events-auto relative w-full max-w-5xl rounded-3xl bg-neutral-100 shadow-2xl max-h-[90vh] overflow-y-auto">
						{/* HEADER */}
						<header class="border-b px-8 py-6">
							<h2 class="text-2xl font-semibold text-neutral-900">{variant.name}</h2>
							<p class="mt-2 text-sm text-neutral-500">
								{room.sizeM2 && `${room.sizeM2} m²`}
								{room.hasView && ` • Con vista ${room.hasView}`}
							</p>
						</header>

						<div class="grid grid-cols-1 gap-8 md:p-8 lg:grid-cols-2">
							{/* GALERÍA */}
							<section>
								<div class="relative h-[360px] overflow-hidden md:rounded-2xl" data-gallery>
									<img
										src={mainImage}
										class="h-full w-full object-cover transition-opacity duration-300"
										data-main-image
									/>

									{images.length > 1 && (
										<>
											<button
												type="button"
												class="absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white"
												data-prev
											>
												‹
											</button>

											<button
												type="button"
												class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white"
												data-next
											>
												›
											</button>
										</>
									)}
								</div>

								{images.length > 1 && (
									<div class="mt-4 flex gap-3 overflow-x-auto px-1">
										{images.map((img: any, i: number) => (
											<button type="button" data-thumb data-index={i}>
												<img
													src={img.url}
													class="h-16 w-24 rounded-lg object-cover opacity-70 hover:opacity-100"
												/>
											</button>
										))}
									</div>
								)}
							</section>

							{/* DETALLES */}
							<section class="space-y-8 mx-8">
								<div class="space-y-3 text-sm text-neutral-700">
									{room.maxOccupancyOverride > 0 && (
										<div class="flex items-center gap-2">
											<User class="h-4 w-4" />
											{room.maxOccupancyOverride} persona
											{room.maxOccupancyOverride > 1 && "s"}
										</div>
									)}

									{room.bedType && (
										<div class="flex items-center gap-2">
											<BedDouble class="h-4 w-4" />
											{formatBedType(room.bedType)}
										</div>
									)}

									<div class="flex items-center gap-2">
										<DoorClosed class="h-4 w-4" />
										{room.totalRooms} habitación
										{room.totalRooms > 1 && "es"}
									</div>

									{room.bathroom != null && (
										<div class="flex items-center gap-2">
											<Bath class="h-4 w-4" />
											{room.bathroom} baño
											{room.bathroom > 1 && "s"}
										</div>
									)}

									<div class="flex items-center gap-2">
										<Ruler class="h-4 w-4" />
										{room.sizeM2} m²
									</div>

									{room.hasBalcony && <div class="text-emerald-600">🌿 Con balcón</div>}
								</div>

								{/* TARIFAS */}
								<div>
									<h3 class="mb-3 font-semibold text-neutral-800">Tarifas disponibles</h3>

									<p class="text-right text-sm text-neutral-500">
										Precio base: ${variant.basePrice}
									</p>

									<div class="mt-3 space-y-3">
										{offer.ratePlans?.map((rp: any) => {
											const finalPrice = rp.finalPrice ?? rp.price ?? 0

											return (
												<div class="flex items-center justify-between rounded-lg border bg-white px-4 py-3">
													<div>
														<p class="text-sm font-medium text-neutral-800">{rp.name}</p>
													</div>

													<div class="text-right">
														<p class="font-semibold text-neutral-800">${finalPrice}</p>
														<a
															href={`/book/${variant.id}?ratePlan=${rp.id}`}
															class="mt-1 inline-block rounded-md bg-blue-600 px-3 py-1 text-xs font-semibold text-white"
														>
															Reservar
														</a>
													</div>
												</div>
											)
										})}
									</div>
								</div>
							</section>
						</div>
					</div>
				</div>
			</article>
		)
	})
}

<script>
	import { closeModal } from "@/lib/utils/modal-manager"

	document
		.querySelectorAll<HTMLElement>(".modal-overlay .pointer-events-auto")
		.forEach((content) => {
			content.addEventListener("click", (e) => {
				e.stopPropagation()
			})
		})

	document.addEventListener("click", (e) => {
		const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-close]")
		if (!btn) return

		const modal = btn.closest<HTMLElement>(".modal-overlay")
		if (!modal) return

		const name = modal.dataset.modal
		if (!name) return

		closeModal(name)
	})

	document.querySelectorAll<HTMLElement>(".modal-overlay").forEach((modal) => {
		const gallery = modal.querySelector<HTMLElement>("[data-gallery]")
		if (!gallery) return

		const _mainImage = gallery.querySelector<HTMLImageElement>("[data-main-image]")
		if (!_mainImage) return

		const mainImage = _mainImage

		const images = Array.from(modal.querySelectorAll<HTMLButtonElement>("[data-thumb]")).map(
			(btn) => {
				const img = btn.querySelector("img")
				return img?.getAttribute("src") ?? ""
			}
		)

		let currentIndex = 0

		function updateImage(index: number) {
			if (images.length === 0) return

			currentIndex = (index + images.length) % images.length
			mainImage.style.opacity = "0"

			setTimeout(() => {
				mainImage.src = images[currentIndex]
				mainImage.style.opacity = "1"
			}, 150)
		}

		gallery.querySelector("[data-prev]")?.addEventListener("click", () => {
			updateImage(currentIndex - 1)
		})

		gallery.querySelector("[data-next]")?.addEventListener("click", () => {
			updateImage(currentIndex + 1)
		})

		modal.querySelectorAll<HTMLButtonElement>("[data-thumb]").forEach((btn) => {
			btn.addEventListener("click", () => {
				const index = Number(btn.dataset.index)
				updateImage(index)
			})
		})
	})
</script>
