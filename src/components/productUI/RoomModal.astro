---
import { buildGuestRoomPreviews } from "@/components/productUI/room-section.viewmodel"
import { resolveVariantRef } from "@/shared/domain/variant-ref"
import { Bath, BedDouble, DoorClosed, Ruler, User } from "@lucide/astro"

const {
	offers = [],
	hotelRoom = [],
	amenities = [],
	productFallbackImage = "https://placehold.co/1200x800",
	productFallbackGallery = [],
	policiesByRatePlanId = {},
} = Astro.props

const guestRoomPreviews = buildGuestRoomPreviews({
	offers,
	hotelRoom,
	amenities,
	productFallbackImage,
	productFallbackGallery,
})

function ratePlanIdOf(ratePlan: any): string {
	return String(ratePlan?.ratePlanId ?? ratePlan?.id ?? "").trim()
}

function policyStatusLabel(status: string): string {
	if (status === "complete") return "Condiciones completas"
	if (status === "partial") return "Condiciones incompletas"
	return "Condiciones pendientes"
}

function policyStatusClass(status: string): string {
	if (status === "complete") return "border-emerald-200 bg-emerald-50 text-emerald-900"
	if (status === "partial") return "border-amber-200 bg-amber-50 text-amber-900"
	return "border-rose-200 bg-rose-50 text-rose-900"
}
---

{
	offers.map((offer: any) => {
		const variant = offer.variant

		// 🔹 habitación estructural
		const variantRef = resolveVariantRef(variant)
		const room = hotelRoom.find((r: any) => r.id === variantRef)
		if (!room) return null
		const preview =
			guestRoomPreviews.find((candidate) => candidate.variantId === variantRef) ??
			guestRoomPreviews.find((candidate) => candidate.variantId === String(variant.id))
		const images = preview?.gallery ?? []
		const mainImage = preview?.imageUrl || productFallbackImage

		return (
			<article
				data-modal={`room-${variant.id}`}
				class="modal-overlay hidden border-none bg-transparent p-0 outline-none backdrop:bg-black/40 backdrop:backdrop-blur-sm"
			>
				<button
					data-close-modal
					class="absolute top-3 right-0 z-20 m-4 flex h-10 w-10 items-center justify-center rounded-full bg-black/50"
				>
					✕
				</button>

				<div
					data-close
					class="fixed inset-0 flex items-start justify-center overflow-y-auto px-2 py-10 sm:p-12"
				>
					<div class="pointer-events-auto relative max-h-[90vh] w-full max-w-5xl overflow-y-auto rounded-[var(--fastt-radius-dialog)] bg-slate-50 shadow-[var(--fastt-shadow-dialog)]">
						{/* HEADER */}
						<header class="border-b px-8 py-6">
							<h2 class="text-2xl font-semibold text-slate-950">{variant.name}</h2>
							<p class="mt-2 text-sm text-slate-500">
								{[preview?.roomTypeName, preview?.sizeSummary, preview?.viewSummary]
									.filter(Boolean)
									.join(" · ") || "Detalle de habitación"}
							</p>
						</header>

						<div class="grid grid-cols-1 gap-8 md:p-8 lg:grid-cols-2">
							{/* GALERÍA */}
							<section>
								<div
									class="relative h-[360px] overflow-hidden md:rounded-[var(--fastt-radius-panel)]"
									data-gallery
								>
									<img
										src={mainImage}
										class="h-full w-full object-cover transition-opacity duration-300"
										data-main-image
									/>

									{images.length > 1 && (
										<>
											<button
												type="button"
												class="absolute top-1/2 left-3 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white"
												data-prev
											>
												‹
											</button>

											<button
												type="button"
												class="absolute top-1/2 right-3 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white"
												data-next
											>
												›
											</button>
										</>
									)}
								</div>

								{images.length > 1 && (
									<div class="mt-4 flex gap-3 overflow-x-auto px-1">
										{images.map((img: any, i: number) => (
											<button type="button" data-thumb data-index={i}>
												<img
													src={img.url}
													class="h-16 w-24 rounded-[var(--fastt-radius-control)] object-cover opacity-70 hover:opacity-100"
												/>
											</button>
										))}
									</div>
								)}
							</section>

							{/* DETALLES */}
							<section class="mx-8 space-y-8">
								<div class="space-y-5">
									<div>
										<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
											Experiencia de descanso
										</p>
										<h3 class="mt-1 text-xl font-semibold text-slate-950">Dónde dormirás</h3>
									</div>

									<div class="grid gap-3 text-sm text-slate-700">
										<div class="flex items-start gap-2">
											<BedDouble class="mt-0.5 h-4 w-4 text-slate-500" />
											<div>
												<p class="font-medium text-slate-950">
													{preview?.sleepSummary ?? "Camas por confirmar"}
												</p>
												{preview?.sleepAreas?.length ? (
													<div class="mt-2 grid gap-2">
														{preview.sleepAreas.map((area) => (
															<p class="rounded-[var(--fastt-radius-control)] bg-white px-3 py-2 text-slate-600 ring-1 ring-slate-200">
																<span class="font-medium text-slate-950">{area.label}:</span>{" "}
																{area.summary}
															</p>
														))}
													</div>
												) : null}
											</div>
										</div>

										<div class="flex items-center gap-2">
											<Bath class="h-4 w-4 text-slate-500" />
											<span>{preview?.bathroomSummary ?? "Baño por confirmar"}</span>
										</div>

										<div class="flex items-center gap-2">
											<User class="h-4 w-4 text-slate-500" />
											<span>{preview?.occupancySummary ?? "Capacidad por confirmar"}</span>
										</div>

										{Number(room.totalRooms ?? 0) > 0 && (
											<div class="flex items-center gap-2">
												<DoorClosed class="h-4 w-4 text-slate-500" />
												{room.totalRooms} habitación
												{room.totalRooms > 1 && "es"}
											</div>
										)}

										{preview?.sizeSummary ? (
											<div class="flex items-center gap-2">
												<Ruler class="h-4 w-4 text-slate-500" />
												{preview.sizeSummary}
											</div>
										) : null}

										{preview?.hasBalcony ? (
											<div class="text-sm font-medium text-emerald-700">Con balcón</div>
										) : null}
									</div>

									{preview?.amenityGroups?.length ? (
										<div>
											<p class="text-sm font-semibold text-slate-950">
												Comodidades de la habitación
											</p>
											<div class="mt-3 grid gap-3">
												{preview.amenityGroups.map((group) => (
													<div class="rounded-[var(--fastt-radius-card)] border border-slate-200 bg-white p-3">
														<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
															{group.category}
														</p>
														<div class="mt-2 flex flex-wrap gap-2">
															{group.labels.map((label) => (
																<span class="rounded-full bg-slate-50 px-3 py-1 text-xs font-medium text-slate-700">
																	{label}
																</span>
															))}
														</div>
													</div>
												))}
											</div>
										</div>
									) : null}

									{preview?.guestFacingNotes ? (
										<div class="rounded-[var(--fastt-radius-card)] border border-slate-200 bg-white p-4">
											<p class="text-sm font-semibold text-slate-950">Notas para huéspedes</p>
											<p class="mt-2 text-sm leading-6 text-slate-600">
												{preview.guestFacingNotes}
											</p>
										</div>
									) : null}
								</div>

								{/* TARIFAS */}
								<div>
									<h3 class="mb-3 font-semibold text-slate-800">Tarifas disponibles</h3>

									<p class="text-right text-sm text-slate-500">
										Referencia comercial: ${variant.basePrice}
									</p>

									<div class="mt-3 space-y-3">
										{offer.ratePlans?.map((rp: any) => {
											const finalPrice = rp.finalPrice ?? rp.price ?? 0
											const ratePlanId = ratePlanIdOf(rp)
											const contract = policiesByRatePlanId[ratePlanId] ?? null
											const visibleCards = (contract?.cards ?? []).slice(0, 4)

											return (
												<div class="space-y-3 rounded-[var(--fastt-radius-control)] border bg-white px-4 py-3">
													<div class="flex items-start justify-between gap-3">
														<div>
															<p class="text-sm font-medium text-slate-800">
																{rp.name ?? "Tarifa"}
															</p>
															<p class="mt-1 text-xs text-slate-500">
																Verdad contractual de esta tarifa
															</p>
														</div>

														<div class="text-right">
															<p class="font-semibold text-slate-800">${finalPrice}</p>
															<button
																type="button"
																data-select-variant-id={variant.id}
																data-select-rateplan-id={ratePlanId}
																class="mt-1 inline-block rounded-md bg-slate-950 px-3 py-1 text-xs font-semibold text-white"
															>
																Reservar
															</button>
														</div>
													</div>

													<div
														class={`rounded-md border px-3 py-2 text-xs ${policyStatusClass(String(contract?.status ?? "missing"))}`}
													>
														<p class="font-semibold">
															{policyStatusLabel(String(contract?.status ?? "missing"))}
														</p>
														<p class="mt-1">
															{contract?.summary ?? "Sin condiciones para esta tarifa."}
														</p>
													</div>

													<div class="grid gap-2 text-xs text-slate-700">
														{visibleCards.map((card: any) => (
															<div class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2">
																<p class="font-semibold text-slate-950">{card.label}</p>
																<p class="mt-1">
																	{card.state === "missing"
																		? "Pendiente para esta tarifa."
																		: card.description || "Condición definida sin texto visible."}
																</p>
															</div>
														))}
													</div>
												</div>
											)
										})}
									</div>
								</div>
							</section>
						</div>
					</div>
				</div>
			</article>
		)
	})
}

<script>
	import { closeModal } from "@/lib/utils/modal-manager"

	document
		.querySelectorAll<HTMLElement>(".modal-overlay .pointer-events-auto")
		.forEach((content) => {
			content.addEventListener("click", (e) => {
				e.stopPropagation()
			})
		})

	document.addEventListener("click", (e) => {
		const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-close]")
		if (!btn) return

		const modal = btn.closest<HTMLElement>(".modal-overlay")
		if (!modal) return

		const name = modal.dataset.modal
		if (!name) return

		closeModal(name)
	})

	document.querySelectorAll<HTMLElement>(".modal-overlay").forEach((modal) => {
		const gallery = modal.querySelector<HTMLElement>("[data-gallery]")
		if (!gallery) return

		const _mainImage = gallery.querySelector<HTMLImageElement>("[data-main-image]")
		if (!_mainImage) return

		const mainImage = _mainImage

		const images = Array.from(modal.querySelectorAll<HTMLButtonElement>("[data-thumb]")).map(
			(btn) => {
				const img = btn.querySelector("img")
				return img?.getAttribute("src") ?? ""
			}
		)

		let currentIndex = 0

		function updateImage(index: number) {
			if (images.length === 0) return

			currentIndex = (index + images.length) % images.length
			mainImage.style.opacity = "0"

			setTimeout(() => {
				mainImage.src = images[currentIndex]
				mainImage.style.opacity = "1"
			}, 150)
		}

		gallery.querySelector("[data-prev]")?.addEventListener("click", () => {
			updateImage(currentIndex - 1)
		})

		gallery.querySelector("[data-next]")?.addEventListener("click", () => {
			updateImage(currentIndex + 1)
		})

		modal.querySelectorAll<HTMLButtonElement>("[data-thumb]").forEach((btn) => {
			btn.addEventListener("click", () => {
				const index = Number(btn.dataset.index)
				updateImage(index)
			})
		})
	})
</script>
