---
import Button from "@/components/ui/Button.astro"
import { SERVICE_CATALOG } from "@/data/service/service-catalog"

interface Props {
	name: string
	href: string
	image: string
	alt: string
	description: string
	stars?: number
	address?: string
	difficultyLevel?: string
	duration?: string
	priceUSD?: number
	priceBOB?: number
	services: { free?: boolean; available: boolean }[]
}

const props = Astro.props as Props

const renderStars = (count: number) => {
	let starIcons = ""
	for (let i = 0; i < count; i++) {
		starIcons += "★"
	}
	return starIcons
}

const serviceMap = new Map(SERVICE_CATALOG.map((s) => [s.id, s]))
const services = (
	Array.isArray(props.services) ? props.services : JSON.parse(props.services || "[]")
)
	.map((s: any) => serviceMap.get(s.id))
	.filter(Boolean)
---

<article class="fastt-row-card flex h-48 w-full overflow-hidden md:flex-row">
	<a href={props.href} class="relative aspect-[3/4] w-32 md:aspect-[4/3] md:w-40 xl:w-72">
		<img
			src={props.image}
			alt={props.alt}
			class="absolute inset-0 h-full w-full object-cover"
			loading="lazy"
		/>
	</a>

	<div class="flex flex-grow flex-col p-4 md:p-5">
		<div class="h-full lg:flex">
			<div class="flex-grow pr-4">
				<h3 class="mb-1 text-sm font-semibold text-slate-950 md:text-xl md:font-bold">
					<a href={props.href} class="border-slate-950 transition-colors hover:border-b-2">
						{props.name}
					</a>
				</h3>
				{
					props.stars && props.stars > 0 && (
						<div
							class="mb-2 hidden text-base text-yellow-500 lg:block"
							aria-label={`Calificación: ${props.stars} estrellas`}
						>
							{renderStars(props.stars)}
						</div>
					)
				}
				<p class="mb-2 text-xs text-slate-500 md:text-sm">{props.address}</p>

				{
					props.services?.length > 0 && (
						<ul class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-slate-500">
							{services.slice(0, 4).map((s: any) => {
								const Icon = s.icon
								return (
									<li class="flex items-center space-x-1" title={s.name}>
										{Icon ? <Icon class="h-4 w-4 text-slate-600" /> : <span>•</span>}
										<span class="hidden md:block">{s.name}</span>
									</li>
								)
							})}
							{services.length > 4 && <li class="text-slate-500">+{services.length - 4} más</li>}
						</ul>
					)
				}
			</div>

			<div
				class="mt-auto flex min-w-[8rem] flex-col items-end justify-end border-gray-200 pl-4 lg:mt-2 lg:border-l"
			>
				<div class="text-right">
					<p class="hidden text-xs font-semibold text-slate-500 lg:block">Precio por noche</p>
					{
						props.priceUSD && (
							<p class="text-base font-semibold text-slate-950 md:text-2xl md:font-bold">
								<span class="text-xs text-slate-950 md:text-base">US$</span>
								{props.priceUSD}
							</p>
						)
					}
					{
						props.priceBOB && (
							<p class="text-sm text-slate-500">
								<span class="text-xs">BOB $</span>
								{props.priceBOB}
							</p>
						)
					}
				</div>

				<Button href={props.href} size="sm" class="mt-1 md:mt-2 lg:mt-4"> Ver Hotel </Button>
			</div>
		</div>
	</div>
</article>
