---
const { latitude, longitude, address } = Astro.props
---

<div
	data-modal="map"
	class="modal-overlay fixed inset-0 z-30 flex hidden items-center justify-center bg-black bg-opacity-90 backdrop-blur-sm transition-opacity duration-300 md:p-4"
>
	<button
		id="modal-close"
		data-close-modal
		class="absolute right-0 top-0 z-20 m-4 flex h-10 w-10 items-center justify-center rounded-full border-2 bg-black/50 md:right-10 md:top-10 md:h-20 md:w-20 md:bg-transparent lg:border-0"
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			class="h-6 w-6 text-2xl font-bold text-white hover:text-gray-400 md:h-12 md:w-12 md:text-5xl"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="3"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<line x1="18" y1="6" x2="6" y2="18"></line>
			<line x1="6" y1="6" x2="18" y2="18"></line>
		</svg>
	</button>
	<div id="map-container" class="relative h-[70%] w-[96%] max-w-3xl rounded-3xl lg:static">
		<div id="modal-map" class="h-full w-full rounded-3xl bg-neutral-100"></div>

		<input
			type="text"
			class="hidden"
			id="modal-map-data"
			value={JSON.stringify({ latitude, longitude, address })}
		/>

		<div
			id="modal-map-fallback"
			class="flex hidden h-64 w-full items-center justify-center rounded-lg bg-neutral-100"
		>
			No localizada
		</div>
	</div>
	<a
		href={`https://www.google.com/maps?q=${latitude},${longitude}`}
		target="_blank"
		rel="noopener noreferrer"
		class="absolute bottom-10 md:bottom-20 right-[50%] z-20 translate-x-1/2 items-center justify-center rounded-full border border-white/20 bg-black/70 px-4 py-2 text-sm font-medium text-white backdrop-blur hover:bg-black/90"
	>
		Ver en Google Maps
	</a>
</div>
<script>
	import { registerModal } from "@/lib/utils/modal-manager"

	import * as L from "leaflet"

	let map: L.Map | null = null

	registerModal("map", {
		onOpen(modal) {
			const el = modal.querySelector<HTMLElement>("#modal-map")
			if (!el) return

			if (map) {
				setTimeout(() => {
					map?.invalidateSize()
				}, 50)
				return
			}

			const dataEl = modal.querySelector<HTMLInputElement>("#modal-map-data")
			const data = dataEl ? JSON.parse(dataEl.value || "null") : null

			if (!data?.latitude || !data?.longitude) {
				el.classList.add("hidden")
				modal.querySelector("#modal-map-fallback")?.classList.remove("hidden")
				return
			}

			map = L.map(el, { scrollWheelZoom: false }).setView([data.latitude, data.longitude], 14)

			L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
				attribution: "&copy; OpenStreetMap contributors",
			}).addTo(map)

			L.marker([data.latitude, data.longitude]).addTo(map)

			setTimeout(() => {
				map!.invalidateSize()
			}, 50)
		},
	})
</script>
