---
import Breadcrumbs from "@/components/Breadcrumbs.astro"
import { SERVICE_CATALOG } from "@/data/service/service-catalog"
import Layout from "@/layouts/Layout.astro"
import {
	asc,
	db,
	Destination,
	eq,
	Image,
	Product,
	ProductContent,
	ProductLocation,
	ProductService,
	sql,
	Tour,
} from "astro:db"

const productId = String(Astro.params.id ?? "").trim()
if (!productId) return Astro.redirect("/tours")

const row = await db
	.select({
		id: Product.id,
		name: Product.name,
		productType: Product.productType,
		destinationName: Destination.name,
		destinationDepartment: Destination.department,
		description: ProductContent.description,
		highlights: ProductContent.highlightsJson,
		address: ProductLocation.address,
		lat: ProductLocation.lat,
		lng: ProductLocation.lng,
		duration: Tour.duration,
		difficultyLevel: Tour.difficultyLevel,
		guideLanguages: Tour.guideLanguages,
		includes: Tour.includes,
		excludes: Tour.excludes,
	})
	.from(Product)
	.leftJoin(Destination, eq(Destination.id, Product.destinationId))
	.leftJoin(ProductContent, eq(ProductContent.productId, Product.id))
	.leftJoin(ProductLocation, eq(ProductLocation.productId, Product.id))
	.leftJoin(Tour, eq(Tour.productId, Product.id))
	.where(sql`${Product.id} = ${productId} AND lower(${Product.productType}) = 'tour'`)
	.get()

if (!row) return Astro.redirect("/tours")

const images = await db
	.select({
		id: Image.id,
		url: Image.url,
		isPrimary: Image.isPrimary,
		order: Image.order,
	})
	.from(Image)
	.where(eq(Image.entityId, productId))
	.orderBy(asc(Image.order))
	.all()

const servicesResult = await db
	.select({ id: ProductService.serviceId })
	.from(ProductService)
	.where(eq(ProductService.productId, productId))
	.all()

const catalogById = new Map(SERVICE_CATALOG.map((service) => [service.id, service]))
const services = servicesResult
	.map((service) => {
		const id = String(service.id ?? "").trim()
		const definition = catalogById.get(id)
		return id ? { id, name: definition?.name ?? id, iconId: definition?.id ?? null } : null
	})
	.filter(Boolean) as Array<{ id: string; name: string; iconId: string | null }>

function textList(value: unknown): string[] {
	return String(value ?? "")
		.split(/\r?\n|,/)
		.map((item) => item.trim())
		.filter(Boolean)
}

const highlights = Array.isArray(row.highlights) ? row.highlights.map(String).filter(Boolean) : []
const inclusions = textList(row.includes)
const exclusions = textList(row.excludes)
const guideLanguages = Array.isArray(row.guideLanguages)
	? row.guideLanguages.map(String).filter(Boolean)
	: textList(row.guideLanguages)
const primaryImage =
	images.find((image) => image.isPrimary)?.url ||
	images[0]?.url ||
	"https://placehold.co/1200x720?text=Tour"
const locationText =
	row.address ||
	row.destinationName ||
	row.destinationDepartment ||
	"Punto de encuentro por confirmar"
const breadcrumbItems = [
	{ name: "Home", href: "/" },
	{ name: "Tours", href: "/tours" },
	{ name: row.name, href: `/tours/${productId}`, current: true },
]
---

<Layout title={row.name || "Tour"}>
	<main class="mx-auto min-h-screen max-w-7xl space-y-10 p-4 lg:p-12">
		<Breadcrumbs items={breadcrumbItems} />

		<section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
			<div class="space-y-4">
				<img
					src={primaryImage}
					alt={row.name}
					class="h-[28rem] w-full rounded-2xl object-cover shadow-lg"
				/>
				{
					images.length > 1 ? (
						<div class="grid grid-cols-3 gap-2 md:grid-cols-6">
							{images.slice(0, 6).map((image) => (
								<img src={image.url} alt={row.name} class="h-24 rounded-lg object-cover" />
							))}
						</div>
					) : null
				}
			</div>

			<aside class="space-y-5 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
				<p class="text-sm font-semibold uppercase tracking-wide text-blue-700">Tour</p>
				<h1 class="text-4xl font-bold text-gray-950">{row.name}</h1>
				<p class="text-sm text-gray-600">{locationText}</p>
				<div class="grid gap-3 sm:grid-cols-2">
					<div class="rounded-xl bg-blue-50 p-4 text-blue-950">
						<p class="text-sm font-semibold">Duración</p>
						<p class="mt-1 text-lg font-semibold">{row.duration || "Por confirmar"}</p>
					</div>
					<div class="rounded-xl bg-slate-50 p-4 text-slate-950">
						<p class="text-sm font-semibold">Dificultad</p>
						<p class="mt-1 text-lg font-semibold">{row.difficultyLevel || "No indicada"}</p>
					</div>
				</div>
				{
					guideLanguages.length ? (
						<div>
							<p class="text-sm font-semibold text-gray-950">Idiomas del guía</p>
							<div class="mt-2 flex flex-wrap gap-2">
								{guideLanguages.map((language) => (
									<span class="rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-700">
										{language}
									</span>
								))}
							</div>
						</div>
					) : null
				}
				<a
					href="/tours/search"
					class="inline-flex w-full items-center justify-center rounded-lg bg-blue-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-800"
				>
					Ver más tours
				</a>
			</aside>
		</section>

		<section class="grid gap-6 lg:grid-cols-[1fr_0.8fr]">
			<div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
				<h2 class="text-2xl font-semibold text-gray-950">Sobre este tour</h2>
				<p class="mt-4 text-base leading-8 text-gray-700">
					{row.description || "La descripción del tour está en preparación."}
				</p>
				{
					highlights.length ? (
						<ul class="mt-6 grid gap-3 text-sm text-gray-700 md:grid-cols-2">
							{highlights.map((highlight) => (
								<li class="rounded-lg bg-gray-50 px-4 py-3">{highlight}</li>
							))}
						</ul>
					) : null
				}
			</div>

			<div class="space-y-6">
				<div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
					<h2 class="text-2xl font-semibold text-gray-950">Incluye</h2>
					{
						inclusions.length ? (
							<ul class="mt-4 grid gap-3 text-sm text-gray-700">
								{inclusions.map((item) => (
									<li class="rounded-lg bg-gray-50 px-4 py-3">{item}</li>
								))}
							</ul>
						) : (
							<p class="mt-4 text-sm text-gray-600">Inclusiones en preparación.</p>
						)
					}
				</div>
				<div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
					<h2 class="text-2xl font-semibold text-gray-950">No incluye</h2>
					{
						exclusions.length ? (
							<ul class="mt-4 grid gap-3 text-sm text-gray-700">
								{exclusions.map((item) => (
									<li class="rounded-lg bg-gray-50 px-4 py-3">{item}</li>
								))}
							</ul>
						) : (
							<p class="mt-4 text-sm text-gray-600">Exclusiones no especificadas.</p>
						)
					}
				</div>
			</div>
		</section>

		{
			services.length ? (
				<section class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
					<h2 class="text-2xl font-semibold text-gray-950">
						Servicios y condiciones de experiencia
					</h2>
					<ul class="mt-5 grid gap-3 text-sm text-gray-700 md:grid-cols-3">
						{services.map((service) => (
							<li class="rounded-lg bg-gray-50 px-4 py-3">{service.name}</li>
						))}
					</ul>
				</section>
			) : null
		}

		<section class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
			<h2 class="text-2xl font-semibold text-gray-950">Punto de encuentro</h2>
			<p class="mt-3 text-sm text-gray-700">{locationText}</p>
			<div
				class="mt-4 flex h-64 items-center justify-center rounded-xl bg-gray-100 text-sm text-gray-500"
			>
				Mapa (pendiente)
			</div>
		</section>
	</main>
</Layout>
