---
import DashboardSidebar from "@/components/dashboard/DashboardSidebar.astro"
import DashboardTabs from "@/components/dashboard/DashboardTabs.astro"
import { productRepository } from "@/container"
import Layout from "@/layouts/Layout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { db, inArray, PolicyAssignment, Variant } from "astro:db"
import { getSession } from "auth-astro/server"

const session = await getSession(Astro.request)

let userProducts: any[] = []
let hotelRoomTypes: any[] = []
let hotelPolicies: any[] = []
let roomsByHotel: Record<string, any[]> = {}
let errorMessage: string | null = null

try {
	if (!session?.user?.email) {
		return Astro.redirect("/SignInPage")
	}
	const providerId = await getProviderIdFromRequest(Astro.request)
	if (!providerId) {
		return Astro.redirect("/provider")
	}

	userProducts = await productRepository.getProductsByProvider(providerId)

	const hotelIds = userProducts.filter((el) => el.productType === "Hotel").map((el) => el.id)

	if (hotelIds.length > 0) {
		hotelRoomTypes = await db.select().from(Variant).where(inArray(Variant.productId, hotelIds))
		hotelPolicies = await db
			.select()
			.from(PolicyAssignment)
			.where(inArray(PolicyAssignment.scopeId, hotelIds))

		for (const room of hotelRoomTypes) {
			if (!roomsByHotel[room.productId]) roomsByHotel[room.productId] = []
			roomsByHotel[room.productId].push(room)
		}
	}
} catch (e) {
	console.error("Error al obtener los productos del proveedor: ", e)
	errorMessage = "Hubo un error al cargar los productos. Por favor, inténtalo de nuevo más tarde."
}
---

<Layout title="Dashboard">
	<div class="mx-auto w-[98%] pt-10 md:pt-20 xl:w-3/4">
		<navbar class="sub-content mb-8 hidden w-full grid-cols-9 md:mb-12 md:grid">
			<h2
				class="col-span-4 col-start-3 text-xl font-semibold text-neutral-100 lg:text-4xl lg:font-extrabold"
			>
				Dashboard
			</h2>
			<a
				href="/products/create"
				class="col-span-9 col-start-8 transform rounded-lg bg-white px-4 py-2 text-center text-sm font-semibold text-black shadow-md transition-transform duration-300 hover:scale-95 md:text-base"
			>
				Crea un Nuevo Producto
			</a>
		</navbar>
		<div class="grid grid-cols-1 gap-6 md:grid-cols-[200px_1fr]">
			<DashboardSidebar />
			<DashboardTabs
				products={userProducts}
				roomsByHotel={roomsByHotel}
				hotelPolicies={hotelPolicies}
			/>
		</div>
	</div>
</Layout>
<script is:inline>
	async function handleDelete(button) {
		const productId = button.dataset.productId
		if (!productId) return

		const confirmed = confirm(
			"¿Estás seguro de que quieres eliminar este producto? Esta acción no se puede deshacer."
		)
		if (!confirmed) return

		try {
			const res = await fetch(`/api/products/${productId}/delete`, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ productId }),
			})

			if (res.ok) {
				window.location.reload()
			} else {
				alert(await res.text())
			}
		} catch (err) {
			console.error(err)
			alert("Error al eliminar el producto")
		}
	}

	function handleMainTab(tab) {
		const sectionName = tab.dataset.section
		if (!sectionName) return

		document.querySelectorAll(".main-tab").forEach((t) => t.classList.remove("active"))
		document.querySelectorAll(".main-section").forEach((s) => s.classList.add("hidden"))

		tab.classList.add("active")
		document.getElementById(`section-${sectionName}`)?.classList.remove("hidden")
	}

	function handleSubTab(tab) {
		const section = tab.closest(".main-section")
		if (!section) return

		const targetId = `${section.id}-${tab.dataset.tab}`
		if (!tab.dataset.tab) return

		section
			.querySelectorAll(".sub-tab")
			.forEach((t) =>
				t.classList.remove(
					"active",
					"text-white",
					"font-semibold",
					"border-b",
					"border-white",
					"pb-1"
				)
			)

		section.querySelectorAll(".sub-content").forEach((c) => {
			c.classList.add("hidden", "opacity-0", "translate-y-2")
			c.classList.remove("opacity-100", "translate-y-0")
		})

		tab.classList.add("active", "text-white", "font-semibold", "border-b", "border-white", "pb-1")

		const target = section.querySelector(`#${targetId}`)
		if (!target) return

		target.classList.remove("hidden", "opacity-0", "translate-y-2")
		target.classList.add("opacity-100", "translate-y-0")
	}

	document.addEventListener("click", (e) => {
		const target = e.target.closest(".delete-button, .main-tab, .sub-tab")
		if (!target) return

		if (target.classList.contains("delete-button")) {
			handleDelete(target)
			return
		}

		if (target.classList.contains("main-tab")) {
			handleMainTab(target)
			return
		}

		if (target.classList.contains("sub-tab")) {
			handleSubTab(target)
			return
		}
	})
</script>
