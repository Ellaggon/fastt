---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user?.email) return Astro.redirect("/SignInPage")

const providerId = await getProviderIdFromRequest(Astro.request, user)
if (!providerId) return Astro.redirect("/provider")
---

<WorkspaceLayout title="Dashboard">
	<section class="space-y-8">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">Dashboard</h1>
			<p class="text-sm text-slate-400">
				Resumen operativo para gestionar proveedor, productos y variantes desde una sola superficie.
			</p>
		</header>

		<Section title="Estado general" description="Indicadores rápidos del workspace.">
			<div id="dashboardStatsGrid" class="grid gap-4 md:grid-cols-3" data-state="loading">
				<Card id="cardProducts" class="min-h-[112px] space-y-2 bg-slate-100">
					<p class="text-sm font-semibold text-slate-900">Productos</p>
					<p id="statProducts" class="text-2xl font-bold text-slate-900">—</p>
					<div class="h-2 w-24 animate-pulse rounded bg-slate-300" data-skeleton></div>
				</Card>
				<Card id="cardVariants" class="min-h-[112px] space-y-2 bg-slate-100">
					<p class="text-sm font-semibold text-slate-900">Variantes</p>
					<p id="statVariants" class="text-2xl font-bold text-slate-900">—</p>
					<div class="h-2 w-24 animate-pulse rounded bg-slate-300" data-skeleton></div>
				</Card>
				<Card id="cardReadiness" class="min-h-[112px] space-y-2 bg-slate-100">
					<p class="text-sm font-semibold text-slate-900">Readiness</p>
					<div class="flex items-center gap-2" id="readinessWrap">
						<Badge id="readinessBadge" variant="warning"> Cargando... </Badge>
						<p id="readinessText" class="text-sm text-slate-700">Obteniendo métricas...</p>
					</div>
				</Card>
			</div>
		</Section>

		<Section title="Productos recientes" description="Carga progresiva del listado de productos.">
			<Card class="min-h-[168px] bg-slate-100">
				<div id="dashboardProductsList" class="space-y-3" data-state="loading">
					<div class="h-10 animate-pulse rounded bg-slate-300"></div>
					<div class="h-10 animate-pulse rounded bg-slate-300"></div>
					<div class="h-10 animate-pulse rounded bg-slate-300"></div>
				</div>
			</Card>
		</Section>

		<Section title="Acciones rápidas" description="Accesos directos a los flujos principales.">
			<div class="grid gap-4 md:grid-cols-2">
				<Card class="space-y-4 bg-slate-100">
					<div class="space-y-1">
						<p class="text-lg font-semibold text-slate-900">Proveedor</p>
						<p class="text-sm text-slate-600">Completa identidad, perfil y verificación.</p>
					</div>
					<div class="flex justify-end">
						<Button href="/provider" className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]">
							Ir a proveedor
						</Button>
					</div>
				</Card>

				<Card class="space-y-4 bg-slate-100">
					<div class="space-y-1">
						<p class="text-lg font-semibold text-slate-900">Productos</p>
						<p class="text-sm text-slate-600">Crea productos y continúa su configuración.</p>
					</div>
					<div class="flex justify-end">
						<Button href="/product/create" className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]">
							Crear producto
						</Button>
					</div>
				</Card>
			</div>
		</Section>
	</section>
	<script is:inline>
		;(function () {
			const shellStart = performance.now()
			const markPaint = () => {
				console.debug("shell visible", {
					page: "dashboard-surface",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				markPaint()
			} else {
				document.addEventListener("DOMContentLoaded", markPaint, { once: true })
			}

			const statsGrid = document.getElementById("dashboardStatsGrid")
			const productsList = document.getElementById("dashboardProductsList")
			const statProducts = document.getElementById("statProducts")
			const statVariants = document.getElementById("statVariants")
			const readinessBadge = document.getElementById("readinessBadge")
			const readinessText = document.getElementById("readinessText")

			const setErrorState = (message) => {
				if (readinessBadge) {
					readinessBadge.textContent = "Error"
					readinessBadge.classList.remove(
						"bg-amber-100",
						"text-amber-800",
						"bg-emerald-100",
						"text-emerald-800"
					)
					readinessBadge.classList.add("bg-rose-100", "text-rose-700")
				}
				if (readinessText) readinessText.textContent = message
				if (productsList) {
					productsList.innerHTML = ""
					const row = document.createElement("p")
					row.className = "text-sm text-rose-700"
					row.textContent = "No se pudo cargar el resumen del dashboard."
					productsList.appendChild(row)
				}
			}

			const renderProducts = (items) => {
				if (!productsList) return
				productsList.innerHTML = ""
				if (!Array.isArray(items) || items.length === 0) {
					const empty = document.createElement("div")
					empty.className = "rounded-lg border border-slate-200 bg-white p-4 text-sm text-slate-600"
					empty.textContent = "Aún no tienes productos creados."
					productsList.appendChild(empty)
					return
				}

				for (const item of items) {
					const row = document.createElement("a")
					row.href = item.href
					row.className =
						"flex items-center justify-between rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 hover:border-slate-300"

					const name = document.createElement("span")
					name.className = "font-medium"
					name.textContent = item.name || "Producto sin nombre"

					const status = document.createElement("span")
					status.className = "text-slate-500"
					status.textContent = String(item.status || "draft")

					row.appendChild(name)
					row.appendChild(status)
					productsList.appendChild(row)
				}
			}

			const fetchStart = performance.now()
			fetch("/api/internal/dashboard-summary", { headers: { accept: "application/json" } })
				.then(async (response) => {
					if (!response.ok) throw new Error(`dashboard_summary_${response.status}`)
					return await response.json()
				})
				.then((payload) => {
					if (statProducts) statProducts.textContent = String(payload.totalProducts ?? 0)
					if (statVariants) statVariants.textContent = String(payload.totalVariants ?? 0)

					const pending = Number(payload.pendingProducts ?? 0)
					const ready = Number(payload.readyProducts ?? 0)
					if (readinessBadge) {
						readinessBadge.textContent = pending === 0 ? "✅ Al día" : "⚠️ Pendiente"
						readinessBadge.classList.remove(
							"bg-amber-100",
							"text-amber-800",
							"bg-emerald-100",
							"text-emerald-800"
						)
						if (pending === 0) {
							readinessBadge.classList.add("bg-emerald-100", "text-emerald-800")
						} else {
							readinessBadge.classList.add("bg-amber-100", "text-amber-800")
						}
					}
					if (readinessText) readinessText.textContent = `${ready} listos`

					statsGrid?.querySelectorAll("[data-skeleton]").forEach((node) => node.remove())
					renderProducts(payload.products)
					console.debug("data hydrated", {
						page: "dashboard-surface",
						durationMs: Number((performance.now() - fetchStart).toFixed(1)),
					})
				})
				.catch(() => {
					setErrorState("No fue posible cargar los indicadores en este momento.")
				})
		})()
	</script>
</WorkspaceLayout>
