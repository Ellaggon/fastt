---
import Layout from "@/layouts/Layout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (user) {
	return Astro.redirect("/dashboard")
}

const error = Astro.url.searchParams.get("error")
const message = Astro.url.searchParams.get("message")
---

<Layout title="Iniciar Sesión">
	<main class="flex min-h-screen items-center justify-center">
		<section
			class="mt-20 flex h-auto flex-col items-center justify-center rounded-xl border px-20 py-10 text-white md:w-1/2"
		>
			<h1 class="mb-20 text-3xl">Iniciar Sesión</h1>

			<article class="flex flex-col gap-4">
				{
					error && (
						<p class="rounded-md bg-red-900/40 px-3 py-2 text-sm text-red-200">Error: {error}</p>
					)
				}
				{
					message && (
						<p class="rounded-md bg-blue-900/40 px-3 py-2 text-sm text-blue-200">{message}</p>
					)
				}
				<div>
					<form
						method="post"
						action="/api/auth/signin"
						class="mt-6 flex flex-col gap-3"
						autocomplete="on"
					>
						<label class="block text-sm font-medium text-gray-400">
							Email
							<input
								type="email"
								name="email"
								required
								class="mt-1 block w-full rounded-xl border border-gray-600 bg-gray-700 px-3 py-2 text-white shadow-sm focus:border-blue-100 focus:outline-none focus:ring-blue-100 sm:text-sm"
							/>
						</label>
						<label class="block text-sm font-medium text-gray-400">
							Password
							<input
								type="password"
								name="password"
								required
								class="mt-1 block w-full rounded-xl border border-gray-600 bg-gray-700 px-3 py-2 text-white shadow-sm focus:border-blue-100 focus:outline-none focus:ring-blue-100 sm:text-sm"
							/>
						</label>
						<button
							type="submit"
							class="mt-2 w-full rounded-xl bg-blue-600 px-3 py-2 text-white shadow-sm transition hover:bg-blue-700"
						>
							Ingresar
						</button>
					</form>

					<form method="post" action="/api/auth/signup" class="mt-6 flex flex-col gap-3">
						<p class="text-xs text-gray-400">O crear cuenta:</p>
						<label class="block text-sm font-medium text-gray-400">
							Email
							<input
								type="email"
								name="email"
								required
								class="mt-1 block w-full rounded-xl border border-gray-600 bg-gray-700 px-3 py-2 text-white shadow-sm focus:border-blue-100 focus:outline-none focus:ring-blue-100 sm:text-sm"
							/>
						</label>
						<label class="block text-sm font-medium text-gray-400">
							Password
							<input
								type="password"
								name="password"
								required
								class="mt-1 block w-full rounded-xl border border-gray-600 bg-gray-700 px-3 py-2 text-white shadow-sm focus:border-blue-100 focus:outline-none focus:ring-blue-100 sm:text-sm"
							/>
						</label>
						<button
							type="submit"
							class="w-full rounded-xl border border-gray-600 bg-gray-700 px-3 py-2 text-white shadow-sm transition hover:bg-gray-600"
						>
							Crear cuenta
						</button>
					</form>
				</div>
			</article>
		</section>
	</main>
</Layout>
