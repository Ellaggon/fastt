---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const bookingId = String(Astro.params.id ?? "").trim()
if (!bookingId) return Astro.redirect("/booking")
---

<WorkspaceLayout title="Detalle de reserva">
	<section class="space-y-6">
		<header class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
			<div class="space-y-2">
				<Button href="/booking" variant="ghost" size="sm" class="w-fit">Volver a reservas</Button>
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
						Detalle de reserva
					</p>
					<h1
						id="bookingGuestTitle"
						class="mt-2 text-3xl font-semibold tracking-tight text-slate-950"
					>
						Cargando reserva...
					</h1>
					<p id="bookingSubtitle" class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">
						{bookingId}
					</p>
				</div>
			</div>
			<div class="flex flex-wrap gap-2">
				<Button id="primaryBookingAction" href="/booking" variant="primary">Ver reserva</Button>
				<Button href="/booking" variant="secondary">Cerrar</Button>
			</div>
		</header>

		<Card class="border-slate-200 bg-white p-4">
			<div id="bookingHero" class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
				{
					["Estado", "Estancia", "Pago", "Próxima acción"].map((label) => (
						<div class="fastt-soft-box rounded-[var(--fastt-radius-card)] border border-slate-200 bg-slate-50 p-4">
							<p class="text-xs font-medium text-slate-500">{label}</p>
							<div class="mt-3 h-5 w-28 animate-pulse rounded bg-slate-200" />
							<div class="mt-2 h-3 w-36 animate-pulse rounded bg-slate-100" />
						</div>
					))
				}
			</div>
		</Card>

		<Card class="border-slate-200 bg-white p-3">
			<nav class="flex gap-1 overflow-x-auto" aria-label="Detalle de reserva">
				{
					[
						["summary", "Resumen"],
						["guests", "Huéspedes"],
						["room", "Habitación"],
						["policies", "Condiciones"],
						["payments", "Pagos"],
						["history", "Historial"],
						["technical", "Detalle técnico"],
					].map(([value, label]) => (
						<button
							type="button"
							class="booking-detail-tab fastt-button inline-flex h-9 shrink-0 items-center rounded-md px-3 text-sm font-medium text-slate-600 transition hover:bg-slate-100"
							data-booking-detail-tab={value}
							aria-pressed={value === "summary" ? "true" : "false"}
						>
							{label}
						</button>
					))
				}
			</nav>
		</Card>

		<div id="bookingDetailPanel">
			<Card class="min-h-[320px] border-slate-200 bg-white p-6">
				<div class="h-5 w-44 animate-pulse rounded bg-slate-200"></div>
				<div class="mt-4 h-4 w-full max-w-xl animate-pulse rounded bg-slate-100"></div>
				<div class="mt-3 h-4 w-full max-w-lg animate-pulse rounded bg-slate-100"></div>
			</Card>
		</div>
	</section>

	<script is:inline define:vars={{ bookingId }}>
		;(function () {
			const state = { activeTab: "summary", payload: null }
			const title = document.getElementById("bookingGuestTitle")
			const subtitle = document.getElementById("bookingSubtitle")
			const hero = document.getElementById("bookingHero")
			const panel = document.getElementById("bookingDetailPanel")
			const primaryAction = document.getElementById("primaryBookingAction")

			const money = (currency, value) =>
				`${String(currency || "USD")} ${Number(value || 0).toFixed(2)}`
			const fmtDate = (value) => String(value || "—")
			const guest = (booking) => booking?.guestSnapshot || {}
			const guestName = (booking) =>
				String(guest(booking)?.name || guest(booking)?.email || "Huésped sin nombre")
			const paymentLabel = (booking) => {
				const pending = Number(booking?.payment?.pendingAmount || 0)
				return pending > 0
					? `${money(booking?.currency, booking?.totalAmount)} · falta ${money(booking?.currency, pending)}`
					: `${money(booking?.currency, booking?.totalAmount)} · pagada`
			}
			const lifecycleCopy = (booking) => {
				const lifecycle = booking?.lifecycle || {}
				const state = String(lifecycle.state || "")
				if (state === "upcoming_arrival") return ["Próxima llegada", "Confirmar llegada"]
				if (state === "in_house") return ["En estancia", "Registrar salida"]
				if (state === "departure_due") return ["Salida pendiente", "Registrar salida"]
				if (state === "checked_out") return ["Finalizada", "Ver reserva"]
				if (state === "no_show") return ["No presentación", "Ver reserva"]
				if (state === "cancelled") return ["Cancelada", "Ver reembolso"]
				return [lifecycle.label || "Pendiente", "Ver reserva"]
			}
			const escapeHtml = (value) =>
				String(value ?? "")
					.replaceAll("&", "&amp;")
					.replaceAll("<", "&lt;")
					.replaceAll(">", "&gt;")
					.replaceAll('"', "&quot;")

			const updateTabs = () => {
				document.querySelectorAll("[data-booking-detail-tab]").forEach((button) => {
					const selected = button.getAttribute("data-booking-detail-tab") === state.activeTab
					button.setAttribute("aria-pressed", selected ? "true" : "false")
					button.className = selected
						? "booking-detail-tab fastt-button inline-flex h-9 shrink-0 items-center rounded-md border border-slate-950 bg-slate-950 px-3 text-sm font-medium text-white transition"
						: "booking-detail-tab fastt-button inline-flex h-9 shrink-0 items-center rounded-md px-3 text-sm font-medium text-slate-600 transition hover:bg-slate-100"
				})
			}
			const renderHero = () => {
				const payload = state.payload || {}
				const booking = payload.booking || {}
				const allocations = Array.isArray(payload.allocations) ? payload.allocations : []
				const firstAllocation = allocations[0] || {}
				const [status, action] = lifecycleCopy(booking)
				const stay = `${fmtDate(booking.checkIn)} → ${fmtDate(booking.checkOut)}`
				if (title) title.textContent = guestName(booking)
				if (subtitle) {
					subtitle.textContent = `${stay} · ${String(firstAllocation.productName || "Alojamiento")} · ${String(firstAllocation.variantName || "Habitación")}`
				}
				if (primaryAction) primaryAction.textContent = action
				if (!hero) return
				const cards = [
					["Estado", status, String(booking.status || "Contrato")],
					["Estancia", stay, `${Number(booking.rooms || allocations.length || 0)} habitación(es)`],
					["Pago", paymentLabel(booking), String(booking.payment?.state || "pending")],
					["Próxima acción", action, "Según estado actual"],
				]
				hero.innerHTML = cards
					.map(
						([
							label,
							value,
							detail,
						]) => `<div class="fastt-soft-box rounded-[var(--fastt-radius-card)] border border-slate-200 bg-slate-50 p-4">
							<p class="text-xs font-medium text-slate-500">${escapeHtml(label)}</p>
							<p class="mt-2 text-base font-semibold text-slate-950">${escapeHtml(value)}</p>
							<p class="mt-1 text-xs text-slate-500">${escapeHtml(detail)}</p>
						</div>`
					)
					.join("")
			}
			const section = (title, body) =>
				`<section class="fastt-card rounded-[var(--fastt-radius-card)] border border-slate-200 bg-white p-5">
					<h2 class="text-base font-semibold text-slate-950">${escapeHtml(title)}</h2>
					<div class="mt-4">${body}</div>
				</section>`
			const keyValue = (label, value) =>
				`<div class="flex items-start justify-between gap-4 border-b border-slate-100 py-3 last:border-0">
					<span class="text-sm text-slate-500">${escapeHtml(label)}</span>
					<strong class="text-right text-sm font-medium text-slate-900">${escapeHtml(value)}</strong>
				</div>`
			const renderPanel = () => {
				if (!panel) return
				const payload = state.payload || {}
				const booking = payload.booking || {}
				const allocations = Array.isArray(payload.allocations) ? payload.allocations : []
				const policies = Array.isArray(payload.policies) ? payload.policies : []
				const taxes = Array.isArray(payload.taxes) ? payload.taxes : []
				const payments = Array.isArray(payload.payments) ? payload.payments : []
				const [status, action] = lifecycleCopy(booking)

				if (state.activeTab === "summary") {
					panel.innerHTML = `<div class="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
						${section(
							"Resumen operativo",
							[
								keyValue("Estado", status),
								keyValue("Estancia", `${fmtDate(booking.checkIn)} → ${fmtDate(booking.checkOut)}`),
								keyValue("Próxima acción", action),
								keyValue("Pago", paymentLabel(booking)),
							].join("")
						)}
						${section(
							"Alertas",
							`<div class="space-y-2 text-sm text-slate-700">
								<p class="fastt-soft-box rounded-[var(--fastt-radius-control)] bg-slate-50 p-3">${Number(booking.payment?.pendingAmount || 0) > 0 ? "Existe saldo pendiente por registrar." : "No hay saldo pendiente."}</p>
								<p class="fastt-soft-box rounded-[var(--fastt-radius-control)] bg-slate-50 p-3">${policies.length ? "Condiciones contratadas disponibles." : "Faltan condiciones congeladas para esta reserva."}</p>
							</div>`
						)}
					</div>`
					return
				}
				if (state.activeTab === "guests") {
					panel.innerHTML = section(
						"Huéspedes",
						[
							keyValue("Titular", guestName(booking)),
							keyValue("Email", guest(booking)?.email || "No registrado"),
							keyValue("Adultos", Number(guest(booking)?.adults || 0)),
							keyValue("Niños", Number(guest(booking)?.children || 0)),
						].join("")
					)
					return
				}
				if (state.activeTab === "room") {
					panel.innerHTML = `<div class="space-y-3">
						${allocations
							.map((item) =>
								section(
									`${String(item.productName || "Alojamiento")} · ${String(item.variantName || "Habitación")}`,
									[
										keyValue("Tarifa", item.ratePlanName || item.ratePlanId || "Tarifa contratada"),
										keyValue("Fechas", `${fmtDate(item.checkIn)} → ${fmtDate(item.checkOut)}`),
										keyValue(
											"Ocupación",
											`${Number(item.occupancyDetail?.adults || 0)} adultos · ${Number(item.occupancyDetail?.children || 0)} niños`
										),
										keyValue("Total", money(booking.currency, item.totalAmount)),
									].join("")
								)
							)
							.join("")}
					</div>`
					return
				}
				if (state.activeTab === "policies") {
					panel.innerHTML = section(
						"Condiciones contratadas",
						policies.length
							? `<div class="grid gap-3 md:grid-cols-2">${policies
									.map(
										(
											policy
										) => `<article class="fastt-row-card rounded-[var(--fastt-radius-card)] border border-slate-200 bg-slate-50 p-4">
											<p class="text-sm font-semibold text-slate-950">${escapeHtml(policy.policyType || "Condición")}</p>
											<p class="mt-2 text-sm leading-6 text-slate-600">${escapeHtml(policy.description || "Condición congelada en la reserva.")}</p>
										</article>`
									)
									.join("")}</div>`
							: '<p class="text-sm text-slate-500">No hay condiciones congeladas para esta reserva.</p>'
					)
					return
				}
				if (state.activeTab === "payments") {
					panel.innerHTML = `<div class="grid gap-4 xl:grid-cols-[0.8fr_1.2fr]">
						${section(
							"Estado de pago",
							[
								keyValue("Total", money(booking.currency, booking.totalAmount)),
								keyValue("Cobrado", money(booking.currency, booking.payment?.paidAmount)),
								keyValue("Pendiente", money(booking.currency, booking.payment?.pendingAmount)),
								keyValue(
									"Impuestos/cargos",
									money(
										booking.currency,
										taxes.reduce((sum, row) => sum + Number(row.totalAmount || 0), 0)
									)
								),
							].join("")
						)}
						${section(
							"Transacciones",
							payments.length
								? `<div class="space-y-2">${payments
										.map(
											(
												payment
											) => `<div class="fastt-row-card rounded-[var(--fastt-radius-control)] border border-slate-200 p-3 text-sm">
												<div class="flex justify-between gap-3">
													<strong class="text-slate-900">${escapeHtml(payment.type || "Pago")}</strong>
													<span>${escapeHtml(money(payment.currency || booking.currency, payment.amount))}</span>
												</div>
												<p class="mt-1 text-xs text-slate-500">${escapeHtml(payment.status || "visible")} · ${escapeHtml(payment.externalReference || "sin referencia")}</p>
											</div>`
										)
										.join("")}</div>`
								: '<p class="text-sm text-slate-500">No hay transacciones registradas.</p>'
						)}
					</div>`
					return
				}
				if (state.activeTab === "history") {
					panel.innerHTML = section(
						"Historial operativo",
						`<div class="space-y-3 text-sm text-slate-700">
							<p class="fastt-row-card rounded-[var(--fastt-radius-control)] border border-slate-200 p-3">Reserva creada: ${escapeHtml(booking.createdAt || "sin fecha")}</p>
							<p class="fastt-row-card rounded-[var(--fastt-radius-control)] border border-slate-200 p-3">Confirmación: ${escapeHtml(booking.confirmedAt || "sin registrar")}</p>
							<p class="fastt-row-card rounded-[var(--fastt-radius-control)] border border-slate-200 p-3">Estado operativo: ${escapeHtml(booking.operationalStatus || "sin registrar")}</p>
						</div>`
					)
					return
				}
				panel.innerHTML = section(
					"Detalle técnico",
					`<div class="grid gap-4 xl:grid-cols-2">
						<div>${[
							keyValue("Reserva", booking.id || bookingId),
							keyValue("Estado contractual", booking.status || "—"),
							keyValue("Estado operativo", booking.operationalStatus || "—"),
							keyValue("Versión snapshot", booking.contractSnapshotVersion || "—"),
						].join("")}</div>
						<pre class="max-h-96 overflow-auto rounded-lg bg-slate-950 p-4 text-xs text-slate-100">${escapeHtml(JSON.stringify(booking.snapshotIntegrity || {}, null, 2))}</pre>
					</div>`
				)
			}
			const render = () => {
				updateTabs()
				renderHero()
				renderPanel()
			}
			document.querySelectorAll("[data-booking-detail-tab]").forEach((button) => {
				button.addEventListener("click", () => {
					state.activeTab = button.getAttribute("data-booking-detail-tab") || "summary"
					render()
				})
			})
			fetch(`/api/internal/booking-summary?bookingId=${encodeURIComponent(bookingId)}`, {
				headers: { accept: "application/json" },
			})
				.then(async (response) => {
					if (!response.ok) throw new Error(`booking_summary_${response.status}`)
					return await response.json()
				})
				.then((payload) => {
					state.payload = payload
					render()
				})
				.catch(() => {
					if (title) title.textContent = "No se pudo cargar la reserva"
					if (panel) {
						panel.innerHTML =
							'<div class="fastt-notice rounded-[var(--fastt-radius-card)] border border-red-200 bg-red-50 p-6 text-sm text-red-700">No se pudo cargar el detalle de la reserva.</div>'
					}
				})
		})()
	</script>
</WorkspaceLayout>
