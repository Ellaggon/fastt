---
import Badge from "@/components/ui/Badge.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const bookingId = String(Astro.params.id ?? "").trim()
if (!bookingId) return Astro.redirect("/dashboard")
---

<WorkspaceLayout title="Reservation Workspace">
	<section class="space-y-8">
		<header class="grid gap-6 lg:grid-cols-[1.35fr_0.85fr] lg:items-end">
			<div class="space-y-3">
				<p class="text-xs font-bold uppercase tracking-[0.18em] text-sky-300">
					Contract snapshot audit
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Reservation operational workspace</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Vista operacional de la reserva {bookingId}. Toda la información comercial mostrada viene
					del snapshot contractual confirmado; lifecycle actual es visibilidad derivada salvo
					estados persistidos como cancelación.
				</p>
			</div>
			<Card class="border-slate-700 bg-slate-900/70 text-slate-100">
				<p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">
					Operational boundary
				</p>
				<p class="mt-2 text-sm leading-6 text-slate-300">
					Reservations coordina lifecycle, auditabilidad y handoff. Pricing, Inventory y Payments
					mantienen ownership separado.
				</p>
			</Card>
		</header>

		<Section
			title="Lifecycle visibility"
			description="Estado contractual persistido y señales derivadas del stay snapshot; no es check-in/check-out operativo."
		>
			<Card class="min-h-[180px] space-y-6 bg-slate-100">
				<div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
					<p id="bookingIdText" class="text-sm text-slate-600">Reservation: {bookingId}</p>
					<div class="flex items-center gap-3">
						<p id="bookingSummaryLatency" class="text-xs text-slate-500"></p>
						<Badge id="bookingStatusBadge" variant="neutral">Cargando...</Badge>
					</div>
				</div>
				<div id="bookingLifecycle" class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
					{
						Array.from({ length: 4 }).map(() => (
							<div class="h-28 animate-pulse rounded bg-slate-200" />
						))
					}
				</div>
			</Card>
		</Section>

		<div class="grid gap-8 xl:grid-cols-[1.1fr_0.9fr]">
			<Section
				title="Contract snapshots"
				description="Guest, stay, commercial and tax snapshots captured at confirmation."
			>
				<Card class="space-y-4 bg-slate-100">
					<div id="contractSnapshot" class="grid gap-4 md:grid-cols-2">
						<div class="h-24 animate-pulse rounded bg-slate-200"></div>
						<div class="h-24 animate-pulse rounded bg-slate-200"></div>
					</div>
				</Card>
			</Section>

			<Section
				title="Snapshot integrity"
				description="Checks de auditabilidad; no recalculan el contrato."
			>
				<Card class="bg-slate-100">
					<ul id="snapshotIntegrity" class="space-y-2 text-sm text-slate-700">
						<li class="text-slate-500">Cargando integridad...</li>
					</ul>
				</Card>
			</Section>
		</div>

		<Section
			title="Room allocation visibility"
			description="Agrupación multi-room desde BookingRoomDetail; no asigna habitaciones físicas vivas."
		>
			<Card class="bg-slate-100">
				<div id="allocationList" class="space-y-3 text-sm text-slate-700">
					<div class="h-20 animate-pulse rounded bg-slate-200"></div>
				</div>
			</Card>
		</Section>

		<div class="grid gap-8 xl:grid-cols-2">
			<Section
				title="Policies snapshot"
				description="Políticas congeladas desde hold/booking snapshot."
			>
				<Card class="min-h-[140px] bg-slate-100">
					<ul id="bookingPoliciesList" class="space-y-2 text-sm text-slate-700">
						<li class="text-slate-500">Cargando políticas...</li>
					</ul>
				</Card>
			</Section>

			<Section
				title="Taxes and fees snapshot"
				description="Detalle agregado aplicado en la confirmación; no usa reglas fiscales vivas."
			>
				<Card class="min-h-[140px] bg-slate-100">
					<ul id="bookingTaxesList" class="space-y-2 text-sm text-slate-700">
						<li class="text-slate-500">Cargando impuestos y cargos...</li>
					</ul>
				</Card>
			</Section>
		</div>
	</section>

	<script is:inline define:vars={{ bookingId }}>
		;(function () {
			const shellStart = performance.now()
			const logShellVisible = () => {
				console.debug("shell visible", {
					page: "reservation-workspace",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				logShellVisible()
			} else {
				document.addEventListener("DOMContentLoaded", logShellVisible, { once: true })
			}

			if (!bookingId) return
			const hydrationStart = performance.now()

			const currencyAmount = (currency, value) =>
				`${String(currency ?? "USD")} ${Number(value ?? 0).toFixed(2)}`
			const yesNo = (value) => (value ? "Ready" : "Missing")
			const stateTone = (value) => (value ? "text-emerald-700" : "text-amber-700")

			fetch(`/api/internal/booking-summary?bookingId=${encodeURIComponent(bookingId)}`, {
				headers: { accept: "application/json" },
			})
				.then(async (response) => {
					if (!response.ok) throw new Error(`booking_summary_${response.status}`)
					return await response.json()
				})
				.then((payload) => {
					const booking = payload?.booking ?? {}
					const badge = document.getElementById("bookingStatusBadge")
					const latencyLabel = document.getElementById("bookingSummaryLatency")
					const lifecycle = document.getElementById("bookingLifecycle")
					const snapshot = document.getElementById("contractSnapshot")
					const integrity = document.getElementById("snapshotIntegrity")
					const allocations = document.getElementById("allocationList")
					const taxesList = document.getElementById("bookingTaxesList")
					const policiesList = document.getElementById("bookingPoliciesList")

					if (badge) {
						const value = String(booking?.status ?? "").toLowerCase()
						const isConfirmed = value === "confirmed"
						badge.textContent = isConfirmed ? "Confirmed" : String(booking?.status ?? "Pending")
						badge.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
							isConfirmed
								? "bg-green-100 text-green-800 border-green-200"
								: "bg-orange-100 text-orange-800 border-orange-200"
						}`
					}

					if (lifecycle) {
						const cards = [
							{
								label: "Lifecycle",
								value: booking?.lifecycle?.label ?? "Unknown",
								detail: `Reality: ${String(booking?.lifecycle?.basis ?? "derived_visibility")}`,
							},
							{
								label: "Stay",
								value: `${String(booking?.checkIn ?? "-")} → ${String(booking?.checkOut ?? "-")}`,
								detail: `${Number(booking?.rooms ?? 0)} room allocation(s)`,
							},
							{
								label: "Refund handoff",
								value: booking?.refundHandoff?.label ?? "No handoff",
								detail: `${String(booking?.refundHandoff?.owner ?? "Payments & Finance")} · ${String(booking?.refundHandoff?.boundary ?? "visibility_only")}`,
							},
							{
								label: "Reconciliation",
								value: booking?.reconciliation?.state ?? "snapshot_ready",
								detail: `Owner: ${booking?.reconciliation?.owner ?? "Payments & Finance"}`,
							},
						]
						lifecycle.innerHTML = cards
							.map(
								(card) => `<div class="rounded-2xl border border-slate-200 bg-white p-4">
									<p class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">${card.label}</p>
									<p class="mt-2 text-base font-semibold text-slate-950">${card.value}</p>
									<p class="mt-2 text-xs leading-5 text-slate-600">${card.detail}</p>
								</div>`
							)
							.join("")
					}

					if (snapshot) {
						const guest = booking?.guestSnapshot ?? {}
						const cards = [
							{
								label: "Guest snapshot",
								lines: [
									`Name: ${String(guest?.name ?? "not captured")}`,
									`Email: ${String(guest?.email ?? "not captured")}`,
									`Occupancy: ${Number(guest?.adults ?? 0)} adults · ${Number(guest?.children ?? 0)} children`,
									`Source: ${String(guest?.source ?? "snapshot")}`,
								],
							},
							{
								label: "Commercial snapshot",
								lines: [
									`Rate plan: ${String(booking?.ratePlanId ?? "captured per allocation")}`,
									`Total: ${currencyAmount(booking?.currency, booking?.total)}`,
								],
							},
							{
								label: "Source",
								lines: [
									`Channel/source: ${String(booking?.source ?? "web")}`,
									`Confirmed: ${booking?.confirmedAt ? new Date(String(booking.confirmedAt)).toLocaleString("es-CL") : "not captured"}`,
								],
							},
							{
								label: "Modification trail",
								lines: [
									String(payload?.modifications?.label ?? "No modification workflow captured"),
									String(payload?.modifications?.description ?? "No live workflow exists."),
									"Audit stance: transitional visibility, not workflow automation.",
								],
							},
						]
						snapshot.innerHTML = cards
							.map(
								(card) => `<div class="rounded-2xl border border-slate-200 bg-white p-4">
									<p class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">${card.label}</p>
									${card.lines.map((line) => `<p class="mt-2 text-sm text-slate-700">${line}</p>`).join("")}
								</div>`
							)
							.join("")
					}

					if (integrity) {
						const checks = booking?.snapshotIntegrity ?? {}
						const rows = [
							["Rate plan captured", checks?.hasRatePlanId],
							["Pricing breakdown snapshot", checks?.hasPricingBreakdown],
							["Policy snapshot", checks?.hasPolicySnapshot],
							["Taxes/fees snapshot", checks?.hasTaxSnapshot],
							["Occupancy detail", checks?.hasOccupancyDetail],
							["Textual contract labels", checks?.hasTextualSnapshot],
							["Guest contact snapshot", checks?.hasGuestSnapshot],
						]
						integrity.innerHTML = rows
							.map(
								([label, value]) =>
									`<li class="flex items-center justify-between rounded-lg border border-slate-200 bg-white p-3"><span>${label}</span><strong class="${stateTone(value)}">${yesNo(value)}</strong></li>`
							)
							.join("")
					}

					if (allocations) {
						const items = Array.isArray(payload?.allocations) ? payload.allocations : []
						allocations.innerHTML = items.length
							? items
									.map((item) => {
										const occ = item?.occupancyDetail ?? {}
										return `<div class="rounded-2xl border border-slate-200 bg-white p-4">
										<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
											<div>
													<p class="text-sm font-semibold text-slate-950">Allocation ${Number(item?.sequence ?? 0)} · ${String(item?.variantName ?? "Physical room context")}</p>
													<p class="mt-1 text-xs text-slate-500">${String(item?.productName ?? "Property")} · ${String(item?.checkIn ?? "-")} → ${String(item?.checkOut ?? "-")}</p>
												</div>
											<p class="text-sm font-medium text-slate-700">${currencyAmount(booking?.currency, item?.totalPrice)}</p>
										</div>
										<div class="mt-3 grid gap-2 text-xs text-slate-600 md:grid-cols-3">
												<span>Rate plan snapshot: ${String(item?.ratePlanName ?? item?.ratePlanId ?? "missing")}</span>
												<span>Occupancy: ${Number(occ?.adults ?? 0)}A · ${Number(occ?.children ?? 0)}C · ${Number(occ?.infants ?? 0)}I</span>
												<span>Snapshot source: booking contract</span>
										</div>
									</div>`
									})
									.join("")
							: '<p class="text-slate-500">No room allocation snapshot was captured.</p>'
					}

					if (taxesList) {
						const taxes = Array.isArray(payload?.taxes) ? payload.taxes : []
						taxesList.innerHTML = taxes.length
							? taxes
									.map(
										(tax) =>
											`<li class="rounded-lg border border-slate-200 bg-white p-3">${String(tax?.name ?? "Taxes and fees snapshot")} · ${Number(tax?.totalAmount ?? 0).toFixed(2)}</li>`
									)
									.join("")
							: '<li class="text-slate-500">No hay líneas de impuestos adicionales.</li>'
					}

					if (policiesList) {
						const policies = Array.isArray(payload?.policies) ? payload.policies : []
						policiesList.innerHTML = policies.length
							? policies
									.map(
										(policy) =>
											`<li class="rounded-lg border border-slate-200 bg-white p-3"><strong>${String(policy?.policyType ?? "Policy")}</strong><p class="mt-1 text-slate-600">${String(policy?.description ?? "Snapshot captured")}</p></li>`
									)
									.join("")
							: '<li class="text-slate-500">No policy snapshot lines were captured.</li>'
					}

					console.debug("data hydrated", {
						page: "reservation-workspace",
						durationMs: Number((performance.now() - hydrationStart).toFixed(1)),
					})
					if (latencyLabel) {
						latencyLabel.textContent = `Endpoint latency: ${Number((performance.now() - hydrationStart).toFixed(1))}ms`
					}
				})
				.catch(() => {
					const taxesList = document.getElementById("bookingTaxesList")
					if (taxesList) {
						taxesList.innerHTML =
							'<li class="text-red-600">No se pudo cargar el workspace de la reserva.</li>'
					}
				})
		})()
	</script>
</WorkspaceLayout>
