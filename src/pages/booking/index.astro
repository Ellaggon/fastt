---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import DatesModal from "@/components/ui/DatesModal.astro"
import Input from "@/components/ui/Input.astro"
import Section from "@/components/ui/Section.astro"
import Select from "@/components/ui/Select.astro"
import TabsOutsidePanel from "@/components/ui/TabsOutsidePanel.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const initialFrom = String(Astro.url.searchParams.get("from") ?? "").trim()
const initialTo = String(Astro.url.searchParams.get("to") ?? "").trim()
const initialStatus = String(Astro.url.searchParams.get("status") ?? "all")
	.trim()
	.toLowerCase()
const initialVista = String(Astro.url.searchParams.get("vista") ?? "today")
	.trim()
	.toLowerCase()
---

<WorkspaceLayout title="Reservas">
	<section class="space-y-8" data-booking-page>
		<header
			class="flex flex-col gap-4 border-b border-slate-800 pb-5 lg:flex-row lg:items-end lg:justify-between"
		>
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
					Operación diaria
				</p>
				<h1 class="text-3xl font-semibold tracking-tight text-white">Reservas</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Gestiona llegadas, estadías, salidas, pagos y cancelaciones desde una sola cola de
					trabajo.
				</p>
			</div>
			<div class="flex flex-wrap gap-2">
				<Button href="/rates/calendar" variant="secondary">Ver calendario</Button>
				<Button href="/booking?vista=today" variant="primary">Ver hoy</Button>
			</div>
		</header>

		<div id="bookingMetrics" class="grid grid-cols-2 gap-3 xl:grid-cols-4">
			{
				[
					["Llegan hoy", "—", "Check-ins esperados"],
					["Salen hoy", "—", "Check-outs pendientes"],
					["En estancia", "—", "Huéspedes alojados"],
					["Pago pendiente", "—", "Reservas con saldo"],
				].map(([label, value, detail]) => (
					<div class="rounded-[var(--fastt-radius-card)] bg-slate-900 p-4 text-slate-100 ring-1 ring-slate-800">
						<p class="text-xs font-medium text-slate-400">{label}</p>
						<p class="mt-1 text-2xl font-semibold tracking-tight text-slate-100">{value}</p>
						<p class="mt-1 hidden text-xs text-slate-500 sm:block">{detail}</p>
					</div>
				))
			}
		</div>

		<Card class="fastt-workspace-panel border bg-white p-0 text-slate-900">
			<div
				class="flex flex-col gap-3 border-b border-slate-200 px-4 pt-4 md:flex-row md:items-center md:justify-between"
			>
				<TabsOutsidePanel class="mb-3" aria-label="Vistas de reservas">
					{
						[
							["today", "Hoy"],
							["upcoming", "Próximas"],
							["in_house", "En estancia"],
							["departures", "Salidas"],
							["cancelled", "Canceladas"],
							["all", "Todas"],
						].map(([value, label]) => (
							<button
								type="button"
								class={`booking-tab fastt-tabs-outside-panel__item px-3 py-2 text-sm font-semibold whitespace-nowrap ${
									value === initialVista
										? ""
										: "text-slate-600 hover:bg-sky-100/80 hover:text-sky-950"
								}`}
								data-booking-tab={value}
								data-active={value === initialVista ? "true" : "false"}
								aria-pressed={value === initialVista ? "true" : "false"}
							>
								{label}
								<span
									class="ml-1 hidden text-xs opacity-70 data-[has-count=false]:hidden sm:inline-block"
									data-booking-tab-count={value}
									data-has-count="false"
								>
									0
								</span>
							</button>
						))
					}
				</TabsOutsidePanel>
				<p class="pb-3 text-xs text-slate-500 md:pb-0">Cola operativa de recepción</p>
			</div>
			<form id="bookingFilters" class="space-y-3">
				<div class="grid gap-2 px-4 py-3 sm:grid-cols-[minmax(220px,1fr)_auto]">
					<label class="sr-only" for="bookingSearch">Buscar</label>
					<Input
						id="bookingSearch"
						name="search"
						type="search"
						placeholder="Buscar huésped o reserva"
						className="h-10 rounded-md"
					/>
					<Button
						id="bookingFiltersToggle"
						type="button"
						variant="secondary"
						class="h-10 rounded-md"
						aria-expanded="false"
						aria-controls="bookingAdvancedFilters"
					>
						Filtros
						<span
							id="bookingFilterCount"
							class="ml-2 hidden rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-700"></span>
					</Button>
				</div>
				<div
					id="bookingAdvancedFilters"
					class="hidden border-t border-slate-200 bg-slate-50 px-4 py-3"
				>
					<div
						class="grid gap-3 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_auto] md:items-end"
					>
						<div class="flex min-w-0 flex-col">
							<label for="from" class="mb-2 block h-5 text-sm font-medium leading-5 text-slate-800">
								Desde
							</label>
							<DatesModal
								id="from"
								name="from"
								value={initialFrom}
								class="h-10 rounded-md border-slate-200"
							/>
						</div>
						<div class="flex min-w-0 flex-col">
							<label for="to" class="mb-2 block h-5 text-sm font-medium leading-5 text-slate-800">
								Hasta
							</label>
							<DatesModal
								id="to"
								name="to"
								value={initialTo}
								class="h-10 rounded-md border-slate-200"
							/>
						</div>
						<div class="flex min-w-0 flex-col">
							<label
								for="status"
								class="mb-2 block h-5 text-sm font-medium leading-5 text-slate-800"
							>
								Estado
							</label>
							<Select
								id="status"
								name="status"
								value={initialStatus}
								class="h-10 rounded-md border-slate-200 py-0"
							>
								<option value="all">Todos</option>
								<option value="draft">Borrador</option>
								<option value="confirmed">Confirmada</option>
								<option value="cancelled">Cancelada</option>
								<option value="expired">Expirada</option>
							</Select>
						</div>
						<div class="flex min-w-[7rem] flex-col">
							<span class="mb-2 hidden h-5 md:block" aria-hidden="true"></span>
							<Button
								id="applyFiltersBtn"
								type="submit"
								variant="secondary"
								class="h-10 w-full rounded-md"
							>
								Aplicar
							</Button>
						</div>
					</div>
				</div>
			</form>
		</Card>

		<Section
			title="Cola de reservas"
			description="Prioriza la próxima acción de recepción."
			class="space-y-5"
			titleClass="text-slate-100"
		>
			<Card class="fastt-workspace-panel min-h-[320px] border bg-white p-0 text-slate-900">
				<div
					class="flex flex-col gap-2 border-b border-slate-200 px-4 py-4 sm:flex-row sm:items-center sm:justify-between"
				>
					<p id="bookingListSummary" class="text-sm text-slate-600">Cargando reservas...</p>
					<p id="bookingListLatency" class="text-xs text-slate-400"></p>
				</div>

				<div class="hidden overflow-x-auto lg:block">
					<table class="min-w-full text-left text-sm">
						<thead
							class="border-b border-slate-200 bg-slate-50/80 text-xs font-semibold uppercase tracking-[0.08em] text-slate-500"
						>
							<tr>
								<th class="px-4 py-3">Huésped</th>
								<th class="px-4 py-3">Alojamiento</th>
								<th class="px-4 py-3">Estancia</th>
								<th class="px-4 py-3">Estado</th>
								<th class="px-4 py-3">Pago</th>
								<th class="px-4 py-3 text-right">Próxima acción</th>
							</tr>
						</thead>
						<tbody id="bookingRows">
							{
								Array.from({ length: 5 }).map(() => (
									<tr class="border-b border-slate-100">
										<td class="px-4 py-4">
											<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
											<div class="mt-2 h-3 w-20 animate-pulse rounded bg-slate-100" />
										</td>
										<td class="px-4 py-4">
											<div class="h-4 w-44 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-4 py-4">
											<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-4 py-4">
											<div class="h-7 w-28 animate-pulse rounded-full bg-slate-200" />
										</td>
										<td class="px-4 py-4">
											<div class="h-4 w-28 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-4 py-4 text-right">
											<div class="ml-auto h-8 w-28 animate-pulse rounded bg-slate-200" />
										</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>

				<div id="bookingCards" class="space-y-3 bg-slate-50/80 p-3 lg:hidden">
					{
						Array.from({ length: 4 }).map(() => (
							<div class="fastt-row-card rounded-[var(--fastt-radius-card)] border border-slate-200 bg-white p-4">
								<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
								<div class="mt-3 h-3 w-52 animate-pulse rounded bg-slate-100" />
								<div class="mt-4 h-8 w-32 animate-pulse rounded bg-slate-200" />
							</div>
						))
					}
				</div>
				<div
					id="bookingLoadMoreWrap"
					class="hidden border-t border-slate-200 bg-white px-4 py-3 text-center"
				>
					<Button id="bookingLoadMore" type="button" variant="secondary" size="sm">
						Cargar más reservas
					</Button>
				</div>
			</Card>
		</Section>
	</section>

	<script
		is:inline
		data-astro-rerun
		define:vars={{ initialFrom, initialTo, initialStatus, initialVista }}
	>
		;(function () {
			const bootBookingPage = () => {
				const root = document.querySelector("[data-booking-page]")
				if (!(root instanceof HTMLElement)) return
				if (root.dataset.bookingBootReady === "true") return
				root.dataset.bookingBootReady = "true"

				const state = {
					items: [],
					activeTab: initialVista || "today",
					query: "",
					limit: 25,
					hasMore: false,
				}
				const form = document.getElementById("bookingFilters")
				const rows = document.getElementById("bookingRows")
				const cards = document.getElementById("bookingCards")
				const summary = document.getElementById("bookingListSummary")
				const latency = document.getElementById("bookingListLatency")
				const applyBtn = document.getElementById("applyFiltersBtn")
				const fromInput = document.getElementById("from")
				const toInput = document.getElementById("to")
				const statusInput = document.getElementById("status")
				const searchInput = document.getElementById("bookingSearch")
				const metrics = document.getElementById("bookingMetrics")
				const filtersToggle = document.getElementById("bookingFiltersToggle")
				const advancedFilters = document.getElementById("bookingAdvancedFilters")
				const filterCount = document.getElementById("bookingFilterCount")
				const loadMoreWrap = document.getElementById("bookingLoadMoreWrap")
				const loadMoreButton = document.getElementById("bookingLoadMore")

				const todayIso = () => new Date().toISOString().slice(0, 10)
				const money = (currency, value) =>
					`${String(currency || "USD")} ${Number(value || 0).toFixed(2)}`
				const guestName = (item) =>
					String(item?.guestName || item?.guestEmail || "Huésped por registrar")
				const parseIsoDate = (value) => {
					const raw = String(value || "").trim()
					if (!/^\d{4}-\d{2}-\d{2}$/.test(raw)) return null
					const parsed = new Date(`${raw}T00:00:00.000Z`)
					if (Number.isNaN(parsed.getTime())) return null
					return parsed
				}
				const shortDate = (value, includeYear = false) => {
					const date = parseIsoDate(value)
					if (!date) return "—"
					return date.toLocaleDateString("es-CL", {
						day: "numeric",
						month: "short",
						year: includeYear ? "numeric" : undefined,
						timeZone: "UTC",
					})
				}
				const stayLabel = (item) => {
					const checkIn = String(item?.checkIn || "")
					const checkOut = String(item?.checkOut || "")
					const inDate = parseIsoDate(checkIn)
					const outDate = parseIsoDate(checkOut)
					const includeYear =
						Boolean(inDate && outDate && inDate.getUTCFullYear() !== outDate.getUTCFullYear()) ||
						Boolean(inDate && inDate.getUTCFullYear() !== new Date().getUTCFullYear()) ||
						Boolean(outDate && outDate.getUTCFullYear() !== new Date().getUTCFullYear())
					return `${shortDate(checkIn, includeYear)} → ${shortDate(checkOut, includeYear)}`
				}
				const paymentLabel = (item) => {
					const pending = Number(item?.payment?.pendingAmount || 0)
					const total = money(item?.currency, item?.totalAmount)
					return pending > 0
						? `${total} · falta ${money(item?.currency, pending)}`
						: `${total} · pagada`
				}
				const statusCopy = (item) => {
					const state = String(item?.lifecycleState || "")
					if (state === "upcoming_arrival")
						return ["Próxima llegada", "bg-sky-50 text-sky-800 border-sky-200"]
					if (state === "in_house")
						return ["En estancia", "bg-emerald-50 text-emerald-700 border-emerald-200"]
					if (state === "departure_due")
						return ["Salida pendiente", "bg-amber-50 text-amber-700 border-amber-200"]
					if (state === "checked_out")
						return ["Finalizada", "bg-slate-100 text-slate-700 border-slate-200"]
					if (state === "no_show")
						return ["No presentación", "bg-orange-50 text-orange-700 border-orange-200"]
					if (state === "cancelled") return ["Cancelada", "bg-red-50 text-red-700 border-red-200"]
					return ["Pendiente", "bg-slate-100 text-slate-700 border-slate-200"]
				}
				const nextAction = (item) => {
					const lifecycle = String(item?.lifecycleState || "")
					const pending = Number(item?.payment?.pendingAmount || 0)
					if (lifecycle === "upcoming_arrival") return "Confirmar llegada"
					if (lifecycle === "in_house") return "Registrar salida"
					if (lifecycle === "departure_due") return "Registrar salida"
					if (lifecycle === "cancelled") return "Ver reembolso"
					if (pending > 0) return "Registrar pago"
					return "Ver reserva"
				}
				const activeFilterCount = () => {
					const from = String(fromInput?.value || "").trim()
					const to = String(toInput?.value || "").trim()
					const status = String(statusInput?.value || "all")
						.trim()
						.toLowerCase()
					return [from, to, status !== "all" ? status : ""].filter(Boolean).length
				}
				const updateFilterBadge = () => {
					if (!filterCount) return
					const count = activeFilterCount()
					filterCount.textContent = String(count)
					filterCount.classList.toggle("hidden", count === 0)
				}
				const tabMatches = (item, tab) => {
					const today = todayIso()
					const lifecycle = String(item?.lifecycleState || "")
					if (tab === "all") return true
					if (tab === "today") {
						return (
							item?.checkIn === today || item?.checkOut === today || lifecycle === "departure_due"
						)
					}
					if (tab === "upcoming") return lifecycle === "upcoming_arrival"
					if (tab === "in_house") return lifecycle === "in_house"
					if (tab === "departures") return lifecycle === "departure_due" || item?.checkOut === today
					if (tab === "cancelled") return lifecycle === "cancelled"
					return true
				}
				const filteredItems = () => {
					const query = state.query.trim().toLowerCase()
					return state.items
						.filter((item) => tabMatches(item, state.activeTab))
						.filter((item) => {
							if (!query) return true
							return [
								guestName(item),
								item?.bookingId,
								item?.guestEmail,
								item?.productName,
								item?.variantName,
							]
								.map((value) => String(value || "").toLowerCase())
								.some((value) => value.includes(query))
						})
				}
				const updateTabs = () => {
					document.querySelectorAll("[data-booking-tab]").forEach((button) => {
						const selected = button.getAttribute("data-booking-tab") === state.activeTab
						button.setAttribute("aria-pressed", selected ? "true" : "false")
						button.setAttribute("data-active", selected ? "true" : "false")
						button.className = selected
							? "booking-tab fastt-tabs-outside-panel__item px-3 py-2 text-sm font-semibold whitespace-nowrap"
							: "booking-tab fastt-tabs-outside-panel__item px-3 py-2 text-sm font-semibold whitespace-nowrap text-slate-600 hover:bg-sky-100/80 hover:text-sky-950"
					})
					const tabs = ["today", "upcoming", "in_house", "departures", "cancelled", "all"]
					for (const tab of tabs) {
						const count = state.items.filter((item) => tabMatches(item, tab)).length
						document.querySelectorAll(`[data-booking-tab-count="${tab}"]`).forEach((node) => {
							node.textContent = String(count)
							node.setAttribute("data-has-count", count > 0 ? "true" : "false")
							node.classList.toggle("hidden", count === 0)
						})
					}
				}
				const renderMetrics = () => {
					if (!metrics) return
					const today = todayIso()
					const pendingPayment = state.items.filter(
						(item) => Number(item?.payment?.pendingAmount || 0) > 0
					).length
					const values = [
						[
							"Llegan hoy",
							state.items.filter((item) => item?.checkIn === today).length,
							"Check-ins esperados",
						],
						[
							"Salen hoy",
							state.items.filter((item) => item?.checkOut === today).length,
							"Check-outs pendientes",
						],
						[
							"En estancia",
							state.items.filter((item) => item?.lifecycleState === "in_house").length,
							"Huéspedes alojados",
						],
						["Pago pendiente", pendingPayment, "Reservas con saldo"],
					]
					metrics.innerHTML = values
						.map(
							([
								label,
								value,
								detail,
							]) => `<div class="rounded-[var(--fastt-radius-card)] bg-slate-900 p-4 text-slate-100 ring-1 ring-slate-800">
							<p class="text-xs font-medium text-slate-400">${label}</p>
							<p class="mt-1 text-2xl font-semibold tracking-tight text-slate-100">${value}</p>
							<p class="mt-1 text-xs text-slate-500">${detail}</p>
						</div>`
						)
						.join("")
				}
				const renderRows = (items) => {
					if (!rows || !cards) return
					if (!items.length) {
						const empty =
							'<tr><td colspan="6" class="px-4 py-12 text-center"><p class="font-medium text-slate-700">No hay reservas para esta vista.</p><p class="mt-1 text-sm text-slate-500">Cuando exista una reserva con esta condición aparecerá aquí.</p></td></tr>'
						rows.innerHTML = empty
						cards.innerHTML =
							'<div class="fastt-empty-state rounded-[var(--fastt-radius-card)] border border-dashed border-slate-300 bg-slate-50 p-6 text-center"><p class="font-medium text-slate-700">No hay reservas para esta vista.</p><p class="mt-1 text-sm text-slate-500">Cuando exista una reserva con esta condición aparecerá aquí.</p></div>'
						return
					}
					rows.innerHTML = items
						.map((item) => {
							const [label, badge] = statusCopy(item)
							const stay = stayLabel(item)
							const accommodation = `${String(item?.productName || "Alojamiento")} · ${String(item?.variantName || "Habitación")}`
							return `<tr class="border-b border-slate-100 align-top hover:bg-slate-50">
							<td class="px-4 py-4">
								<p class="font-semibold text-slate-950">${guestName(item)}</p>
							</td>
							<td class="px-4 py-4">
								<p class="text-slate-800">${accommodation}</p>
								<p class="mt-1 text-xs text-slate-500">${String(item?.ratePlanName || "Tarifa contratada")}</p>
							</td>
							<td class="px-4 py-4">
								<p class="text-slate-900">${stay}</p>
								<p class="mt-1 text-xs text-slate-500">${Number(item?.occupancyDetail?.adults || 0)} adultos · ${Number(item?.occupancyDetail?.children || 0)} niños</p>
							</td>
							<td class="px-4 py-4">
								<span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-medium ${badge}">${label}</span>
							</td>
							<td class="px-4 py-4 text-slate-700">${paymentLabel(item)}</td>
							<td class="px-4 py-4 text-right">
								<a class="fastt-button inline-flex h-8 items-center justify-center rounded-md border border-slate-950 bg-slate-950 px-3 text-xs font-semibold text-white transition hover:bg-slate-800" href="/booking/${encodeURIComponent(String(item?.bookingId || ""))}" data-astro-prefetch>${nextAction(item)}</a>
							</td>
						</tr>`
						})
						.join("")
					cards.innerHTML = items
						.map((item) => {
							const [label, badge] = statusCopy(item)
							const stay = stayLabel(item)
							return `<article class="fastt-row-card rounded-[var(--fastt-radius-card)] border border-slate-200 bg-white p-4">
							<div class="flex items-start justify-between gap-3">
								<div>
									<p class="font-semibold text-slate-950">${guestName(item)}</p>
								</div>
								<span class="inline-flex rounded-full border px-2 py-0.5 text-xs font-medium ${badge}">${label}</span>
							</div>
							<p class="mt-3 text-sm text-slate-700">${String(item?.productName || "Alojamiento")} · ${String(item?.variantName || "Habitación")}</p>
							<p class="mt-1 text-sm text-slate-600">${stay} · ${String(item?.ratePlanName || "Tarifa")}</p>
							<p class="mt-3 text-sm font-medium text-slate-900">${paymentLabel(item)}</p>
							<a class="fastt-button mt-4 inline-flex h-9 items-center justify-center rounded-md border border-slate-950 bg-slate-950 px-3 text-sm font-semibold text-white transition hover:bg-slate-800" href="/booking/${encodeURIComponent(String(item?.bookingId || ""))}" data-astro-prefetch>${nextAction(item)}</a>
						</article>`
						})
						.join("")
				}
				const render = () => {
					const items = filteredItems()
					updateTabs()
					updateFilterBadge()
					renderMetrics()
					renderRows(items)
					if (summary) summary.textContent = `${items.length} reservas en esta vista.`
					loadMoreWrap?.classList.toggle("hidden", !state.hasMore)
				}
				const fetchBookings = async () => {
					const started = performance.now()
					if (applyBtn) {
						applyBtn.setAttribute("disabled", "true")
						applyBtn.textContent = "Cargando..."
					}
					if (summary) summary.textContent = "Cargando reservas..."
					try {
						const qs = new URLSearchParams()
						const from = String(fromInput?.value || initialFrom || "").trim()
						const to = String(toInput?.value || initialTo || "").trim()
						const status = String(statusInput?.value || initialStatus || "all")
							.trim()
							.toLowerCase()
						if (from) qs.set("from", from)
						if (to) qs.set("to", to)
						if (status && status !== "all") qs.set("status", status)
						qs.set("limit", String(state.limit))
						const response = await fetch(
							`/api/internal/provider-bookings-summary?${qs.toString()}`,
							{
								headers: { accept: "application/json" },
							}
						)
						if (!response.ok) throw new Error(`provider_bookings_${response.status}`)
						const payload = await response.json()
						state.items = Array.isArray(payload?.items) ? payload.items : []
						state.hasMore = Boolean(payload?.pagination?.hasMore)
						render()
						if (latency)
							latency.textContent = `${Number((performance.now() - started).toFixed(0))} ms`
					} catch {
						state.items = []
						render()
						if (summary) summary.textContent = "No se pudo cargar el listado de reservas."
						if (latency) latency.textContent = ""
					} finally {
						if (applyBtn) {
							applyBtn.removeAttribute("disabled")
							applyBtn.textContent = "Aplicar"
						}
					}
				}
				const setFiltersOpen = (open) => {
					advancedFilters?.classList.toggle("hidden", !open)
					filtersToggle?.setAttribute("aria-expanded", open ? "true" : "false")
				}
				if (activeFilterCount() > 0) setFiltersOpen(true)
				filtersToggle?.addEventListener("click", () => {
					setFiltersOpen(advancedFilters?.classList.contains("hidden") ?? true)
				})
				fromInput?.addEventListener("change", updateFilterBadge)
				toInput?.addEventListener("change", updateFilterBadge)
				statusInput?.addEventListener("change", updateFilterBadge)
				document.querySelectorAll("[data-booking-tab]").forEach((button) => {
					button.addEventListener("click", () => {
						state.activeTab = button.getAttribute("data-booking-tab") || "today"
						const url = new URL(window.location.href)
						url.searchParams.set("vista", state.activeTab)
						window.history.replaceState({}, "", url.toString())
						render()
					})
				})
				searchInput?.addEventListener("input", () => {
					state.query = String(searchInput.value || "")
					render()
				})
				form?.addEventListener("submit", (event) => {
					event.preventDefault()
					state.limit = 25
					void fetchBookings()
				})
				loadMoreButton?.addEventListener("click", async () => {
					loadMoreButton.setAttribute("disabled", "true")
					loadMoreButton.textContent = "Cargando..."
					state.limit += 25
					try {
						await fetchBookings()
					} finally {
						loadMoreButton.removeAttribute("disabled")
						loadMoreButton.textContent = "Cargar más reservas"
					}
				})
				void fetchBookings()
			}

			if (document.documentElement.dataset.bookingBootEventsReady !== "true") {
				document.documentElement.dataset.bookingBootEventsReady = "true"
				document.addEventListener("astro:page-load", bootBookingPage)
			}
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", bootBookingPage, { once: true })
			} else {
				bootBookingPage()
			}
		})()
	</script>
</WorkspaceLayout>
