---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import DatesModal from "@/components/ui/DatesModal.astro"
import FormField from "@/components/ui/FormField.astro"
import Section from "@/components/ui/Section.astro"
import Select from "@/components/ui/Select.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const initialFrom = String(Astro.url.searchParams.get("from") ?? "").trim()
const initialTo = String(Astro.url.searchParams.get("to") ?? "").trim()
const initialStatus = String(Astro.url.searchParams.get("status") ?? "all")
	.trim()
	.toLowerCase()
---

<WorkspaceLayout title="Reservations Lifecycle">
	<section class="space-y-8">
		<header class="grid gap-6 lg:grid-cols-[1.4fr_0.8fr] lg:items-end">
			<div class="space-y-3">
				<p class="text-xs font-bold uppercase tracking-[0.18em] text-sky-300">
					Contract-safe lifecycle visibility
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Reservations Lifecycle Hub</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Coordina llegadas, estadías, salidas, cancelaciones y handoffs financieros desde el
					contrato congelado de cada reserva. Las señales de arrival/in-house/departure son
					visibilidad derivada del snapshot, no check-in/check-out operacional persistido.
				</p>
			</div>
			<Card class="border-slate-700 bg-slate-900/70 text-slate-100">
				<p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">Ownership</p>
				<p class="mt-2 text-sm leading-6 text-slate-300">
					Reservas coordina ciclo de vida y auditabilidad contractual. Precios, inventario y pagos
					siguen siendo dominios separados.
				</p>
			</Card>
		</header>

		<Section
			title="Lifecycle visibility"
			description="Señales derivadas desde contrato; no representan una state machine PMS."
		>
			<div id="lifecycleSummary" class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
				{
					["Arrivals", "In-house", "Departures", "Refund handoff"].map((label) => (
						<Card class="bg-slate-100">
							<p class="text-xs font-bold tracking-[0.12em] text-slate-500 uppercase">{label}</p>
							<div class="mt-3 h-8 w-16 animate-pulse rounded bg-slate-200" />
							<div class="mt-2 h-3 w-32 animate-pulse rounded bg-slate-200" />
						</Card>
					))
				}
			</div>
		</Section>

		<Section
			title="Operational filters"
			description="Acota la cola lifecycle sin cambiar contratos ni recalcular importes."
		>
			<Card class="bg-slate-100">
				<form id="bookingFilters" class="grid gap-4 md:grid-cols-4">
					<FormField label="Desde" htmlFor="from">
						<DatesModal id="from" name="from" value={initialFrom} />
					</FormField>
					<FormField label="Hasta" htmlFor="to">
						<DatesModal id="to" name="to" value={initialTo} />
					</FormField>
					<FormField label="Estado contractual" htmlFor="status">
						<Select id="status" name="status" value={initialStatus}>
							<option value="all">Todos</option>
							<option value="draft">Borrador</option>
							<option value="confirmed">Confirmada</option>
							<option value="cancelled">Cancelada</option>
							<option value="expired">Expirada</option>
						</Select>
					</FormField>
					<div class="flex items-end justify-end">
						<Button
							id="applyFiltersBtn"
							type="submit"
							className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
						>
							Aplicar filtros
						</Button>
					</div>
				</form>
			</Card>
		</Section>

		<Section
			title="Reservation queue"
			description="Lifecycle visibility, contract readiness y handoff financiero sin ejecutar workflows externos."
		>
			<Card class="min-h-[280px] space-y-4 bg-slate-100">
				<div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
					<p id="bookingListSummary" class="text-sm text-slate-700">Cargando reservas...</p>
					<p id="bookingListLatency" class="text-xs text-slate-500"></p>
				</div>
				<div class="overflow-x-auto">
					<table class="min-w-full divide-y divide-slate-200 text-sm">
						<thead>
							<tr class="text-left text-slate-700">
								<th class="px-3 py-2">Reserva</th>
								<th class="px-3 py-2">Lifecycle</th>
								<th class="px-3 py-2">Stay snapshot</th>
								<th class="px-3 py-2">Allocation</th>
								<th class="px-3 py-2">Contract total</th>
								<th class="px-3 py-2">Audit / handoff</th>
								<th class="px-3 py-2 text-right">Acción</th>
							</tr>
						</thead>
						<tbody id="bookingRows">
							{
								Array.from({ length: 5 }).map(() => (
									<tr class="border-t border-slate-200">
										<td class="px-3 py-2">
											<div class="h-4 w-28 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-40 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2 text-right">
											<div class="ml-auto h-8 w-24 animate-pulse rounded bg-slate-200" />
										</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
			</Card>
		</Section>
	</section>

	<script is:inline define:vars={{ initialFrom, initialTo, initialStatus }}>
		;(function () {
			const shellStart = performance.now()
			const logShellVisible = () => {
				console.debug("shell visible", {
					page: "reservations-lifecycle-hub",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				logShellVisible()
			} else {
				document.addEventListener("DOMContentLoaded", logShellVisible, { once: true })
			}

			const form = document.getElementById("bookingFilters")
			const rows = document.getElementById("bookingRows")
			const summary = document.getElementById("bookingListSummary")
			const latency = document.getElementById("bookingListLatency")
			const applyBtn = document.getElementById("applyFiltersBtn")
			const fromInput = document.getElementById("from")
			const toInput = document.getElementById("to")
			const statusInput = document.getElementById("status")
			const lifecycleSummary = document.getElementById("lifecycleSummary")

			const statusLabel = (status) => {
				const value = String(status || "").toLowerCase()
				if (value === "confirmed") return "Confirmada"
				if (value === "cancelled") return "Cancelada"
				if (value === "expired") return "Expirada"
				if (value === "locked") return "Bloqueada"
				return "Borrador"
			}

			const renderSummary = (data) => {
				if (!lifecycleSummary) return
				const metrics = [
					{
						label: "Upcoming arrivals",
						value: data?.upcomingArrivals ?? 0,
						detail: "Llegadas futuras derivadas del stay snapshot.",
					},
					{
						label: "In-house",
						value: data?.inHouse ?? 0,
						detail: "Estadías activas por fechas snapshot.",
					},
					{
						label: "Departures due",
						value: data?.departuresDue ?? 0,
						detail: "Salidas del día por check-out snapshot.",
					},
					{
						label: "Refund handoff",
						value: data?.refundHandoffRequired ?? 0,
						detail: "Cancelaciones que requieren handoff a Finance/Payments.",
					},
				]
				lifecycleSummary.innerHTML = metrics
					.map(
						(metric) => `
							<div class="rounded-2xl border border-slate-200 bg-slate-100 p-5">
								<p class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">${metric.label}</p>
								<p class="mt-3 text-3xl font-semibold text-slate-950">${metric.value}</p>
								<p class="mt-2 text-xs leading-5 text-slate-600">${metric.detail}</p>
							</div>`
					)
					.join("")
			}

			const render = (items) => {
				if (!rows) return
				rows.innerHTML = ""
				if (!Array.isArray(items) || items.length === 0) {
					const row = document.createElement("tr")
					row.innerHTML =
						'<td colspan="7" class="px-3 py-6 text-center text-slate-500">No hay reservas para los filtros seleccionados.</td>'
					rows.appendChild(row)
					return
				}

				for (const item of items) {
					const row = document.createElement("tr")
					row.className = "border-t border-slate-200 align-top"
					const total = `${String(item?.currency ?? "USD")} ${Number(item?.totalPrice ?? 0).toFixed(2)}`
					const productVariant = `${String(item?.productName ?? "Producto sin nombre")} · ${String(item?.variantName ?? "Allocation")}`
					const checkIn = String(item?.checkIn ?? "—")
					const checkOut = String(item?.checkOut ?? "—")
					const occupancy = item?.occupancyDetail ?? {}
					const guests = `${Number(occupancy?.adults ?? 0)}A · ${Number(occupancy?.children ?? 0)}C · ${Number(occupancy?.infants ?? 0)}I`
					const handoff =
						item?.refundHandoffState === "handoff_required"
							? "Finance handoff visibility"
							: "Contract snapshot ready"
					const snapshotTone =
						item?.snapshotState === "contract_snapshot_present"
							? "text-emerald-700"
							: "text-amber-700"

					row.innerHTML = `
						<td class="px-3 py-3 text-slate-900">
							<div class="font-medium">${String(item?.bookingId ?? "—")}</div>
							<div class="mt-1 text-xs text-slate-500">${statusLabel(item?.status)}</div>
						</td>
						<td class="px-3 py-3 text-slate-700">
								<div class="font-medium text-slate-900">${String(item?.lifecycleLabel ?? "Lifecycle unknown")}</div>
								<div class="mt-1 text-xs text-slate-500">${String(item?.lifecycleBasis ?? "derived_visibility")}</div>
						</td>
						<td class="px-3 py-3 text-slate-700">
							<div>${checkIn} → ${checkOut}</div>
							<div class="mt-1 text-xs text-slate-500">${guests}</div>
						</td>
						<td class="px-3 py-3 text-slate-700">
							<div>${Number(item?.rooms ?? 1)} room(s)</div>
							<div class="mt-1 text-xs text-slate-500">${productVariant}</div>
						</td>
						<td class="px-3 py-3 text-slate-700">${total}</td>
						<td class="px-3 py-3">
							<div class="text-sm ${snapshotTone}">${handoff}</div>
							<div class="mt-1 text-xs text-slate-500">${String(item?.snapshotState ?? "snapshot")}</div>
						</td>
						<td class="px-3 py-3 text-right">
							<a href="/booking/${encodeURIComponent(String(item?.bookingId ?? ""))}" class="inline-flex h-8 items-center justify-center rounded-md bg-[#1E3A8A] px-3 text-xs font-medium text-white hover:bg-[#1e40af]" data-astro-prefetch>Ver workspace</a>
						</td>
					`
					rows.appendChild(row)
				}
			}

			const fetchBookings = async () => {
				const started = performance.now()
				const from = String(fromInput?.value ?? initialFrom ?? "").trim()
				const to = String(toInput?.value ?? initialTo ?? "").trim()
				const status = String(statusInput?.value ?? initialStatus ?? "all")
					.trim()
					.toLowerCase()
				if (applyBtn) {
					applyBtn.setAttribute("disabled", "true")
					applyBtn.textContent = "Cargando..."
				}
				if (summary) summary.textContent = "Cargando reservas..."
				try {
					const qs = new URLSearchParams()
					if (from) qs.set("from", from)
					if (to) qs.set("to", to)
					if (status && status !== "all") qs.set("status", status)
					const response = await fetch(`/api/internal/provider-bookings-summary?${qs.toString()}`, {
						headers: { accept: "application/json" },
					})
					if (!response.ok) throw new Error(`provider_bookings_${response.status}`)
					const payload = await response.json()
					const items = Array.isArray(payload?.items) ? payload.items : []
					renderSummary(payload?.summary ?? {})
					render(items)
					if (summary) {
						summary.textContent = `${items.length} reservation(s) in lifecycle visibility queue. Modification workflow: ${String(payload?.summary?.modificationWorkflow ?? "not_automated")}.`
					}
					const durationMs = Number((performance.now() - started).toFixed(1))
					if (latency) latency.textContent = `Endpoint latency: ${durationMs}ms`
					console.debug("data hydrated", { page: "reservations-lifecycle-hub", durationMs })
				} catch {
					renderSummary({})
					render([])
					if (summary) summary.textContent = "No se pudo cargar el listado de reservas."
					if (latency) latency.textContent = ""
				} finally {
					if (applyBtn) {
						applyBtn.removeAttribute("disabled")
						applyBtn.textContent = "Aplicar filtros"
					}
				}
			}

			form?.addEventListener("submit", (event) => {
				event.preventDefault()
				void fetchBookings()
			})

			void fetchBookings()
		})()
	</script>
</WorkspaceLayout>
