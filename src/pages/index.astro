---
import Button from "@/components/ui/Button.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import UILayout from "@/layouts/UILayout.astro"
---

<UILayout title="Tours en Bolivia">
	<div
		id="intro"
		class="flex flex-col items-center justify-center gap-5 bg-slate-100 p-10 text-center"
	>
		<figure class="m-0 p-0">
			<img
				src="https://picsum.photos/290/183?random=7"
				alt="Salar de Uyuni, Bolivia"
				class="h-auto w-full rounded-[var(--fastt-radius-card)] shadow-sm"
			/>
			<figcaption class="mt-2 text-sm text-gray-600">
				<a
					href="/es/uyuni/tours.htm"
					class="tooltip text-slate-700 hover:text-slate-950 hover:underline"
					data-tipo="a"
					data-id="125">Salar de Uyuni, Bolivia</a
				>
			</figcaption>
		</figure>
		<div class="w-full max-w-3xl">
			<p class="mb-5 text-2xl font-medium text-gray-800">Encuentra el tour que necesitas</p>
			<form method="post" action="/es/buscar-tours.htm">
				<div class="datos mb-5 flex flex-wrap justify-center gap-4">
					<label class="tours min-w-[250px] flex-1 text-left font-medium text-gray-800"
						>Destino / Tour
						<Input
							type="text"
							name="atractivo_tour"
							className="mt-1"
							placeholder="¿Qué tour buscas?"
						/>
					</label>
					<label class="tours tipo min-w-[250px] flex-1 text-left font-medium text-gray-800"
						>Tipo de Tour
						<Select name="tipo_tour" className="custom-select mt-1 appearance-none">
							<option value="">Cualquiera</option>
							<option value="" disabled>--------</option>
							<option value="aventura">Aventura</option>
							<option value="cultural">Cultural</option>
							<option value="naturaleza">Naturaleza</option>
							<option value="historico">Histórico</option>
						</Select>
					</label>
				</div>
				<div class="accion flex justify-center">
					<div class="botones">
						<Button type="submit" size="lg" class="px-8 text-base">Buscar</Button>
					</div>
				</div>
			</form>
		</div>
	</div>
	<main
		role="main"
		id="content"
		class="fastt-card mx-auto my-8 max-w-7xl rounded-[var(--fastt-radius-panel)] p-8 leading-relaxed"
	>
		<ol
			id="ruta"
			class="breadcrumbs m-0 mb-5 flex list-none items-center gap-2 p-0 text-sm text-gray-600"
			itemscope
			itemtype="http://schema.org/BreadcrumbList"
		>
			<li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
				<a itemprop="item" href="/es/" class="text-slate-700 hover:underline">
					<span itemprop="name">Home</span>
				</a>
				<meta itemprop="position" content="1" />
			</li>
			<li
				class="relative pl-3"
				itemprop="itemListElement"
				itemscope
				itemtype="http://schema.org/ListItem"
			>
				<span class="absolute left-0 top-1/2 -translate-y-1/2 text-gray-300">/</span>
				<a itemprop="item" href="/es/tours.htm" class="text-slate-700 hover:underline">
					<span itemprop="name">Tours</span>
				</a>
				<meta itemprop="position" content="2" />
			</li>
		</ol>

		<h1 class="mb-5 text-4xl font-bold text-gray-100">Tours en Bolivia</h1>
		<p class="mb-8 text-gray-100">Explora la increíble diversidad de Bolivia con nuestros tours.</p>

		<div class="flex flex-col gap-8 md:flex-row">
			<ul
				id="zonas-bolivia"
				class="sidebar flex-shrink-0 rounded-[var(--fastt-radius-card)] bg-gray-50 p-6 shadow-md md:w-64"
			>
				<li class="mb-4 flex items-center text-lg font-semibold text-gray-100">
					<i class="fi fi-up-dir mr-2 text-slate-700"></i> Mapa
				</li>
				<li>
					<a
						href="/es/tours-amazonas.htm"
						class="block rounded-md px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 hover:text-slate-700"
						>Amazonas</a
					>
				</li>
				<li>
					<a
						href="/es/tours-altiplano.htm"
						class="block rounded-md px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 hover:text-slate-700"
						>Altiplano</a
					>
				</li>
				<li>
					<a
						href="/es/tours-valle-de-los-condores.htm"
						class="block rounded-md px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 hover:text-slate-700"
						>Valle de los Cóndores</a
					>
				</li>
				<li>
					<a
						href="/es/tours-lagos-y-volcanes.htm"
						class="block rounded-md px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 hover:text-slate-700"
						>Lagos y Volcanes</a
					>
				</li>
			</ul>

			<section class="listado mini flex-grow">
				<ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
					<li>
						<figure class="overflow-hidden rounded-[var(--fastt-radius-card)] bg-white shadow-md">
							<img
								src="https://picsum.photos/290/183?random=8"
								alt="Salar de Uyuni"
								width="290"
								height="183"
								class="h-48 w-full object-cover"
							/>
							<figcaption class="p-4">
								<h2 class="mb-2 text-xl font-semibold text-gray-900">
									<a href="/es/uyuni/tours.htm" class="hover:text-slate-700">Salar de Uyuni</a>
								</h2>
								<p class="desc mb-4 text-sm text-gray-700">
									Descubre el desierto de sal más grande del mundo en un tour de 3 días con paisajes
									que te dejarán sin aliento.
								</p>
								<ul class="flex justify-end">
									<li class="ver_tours">
										<a
											href="/es/uyuni/tours.htm"
											class="inline-block rounded-md bg-slate-950 px-4 py-2 text-white transition-colors hover:bg-slate-800"
											>Ver Tours</a
										>
									</li>
								</ul>
							</figcaption>
						</figure>
					</li>
					<li>
						<figure class="overflow-hidden rounded-[var(--fastt-radius-card)] bg-white shadow-md">
							<img
								src="https://picsum.photos/290/183?random=9"
								alt="Parque Nacional Madidi"
								width="290"
								height="183"
								class="h-48 w-full object-cover"
							/>
							<figcaption class="p-4">
								<h2 class="mb-2 text-xl font-semibold text-gray-900">
									<a href="/es/madidi/tours.htm" class="hover:text-slate-700"
										>Parque Nacional Madidi</a
									>
								</h2>
								<p class="desc mb-4 text-sm text-gray-700">
									Sumérgete en el corazón de la Amazonía boliviana. Un paraíso de biodiversidad para
									los amantes de la naturaleza.
								</p>
								<ul class="flex justify-end">
									<li class="ver_tours">
										<a
											href="/es/madidi/tours.htm"
											class="inline-block rounded-md bg-slate-950 px-4 py-2 text-white transition-colors hover:bg-slate-800"
											>Ver Tours</a
										>
									</li>
								</ul>
							</figcaption>
						</figure>
					</li>
					<li>
						<figure class="overflow-hidden rounded-[var(--fastt-radius-card)] bg-white shadow-md">
							<img
								src="https://picsum.photos/290/183?random=10"
								alt="La Paz"
								width="290"
								height="183"
								class="h-48 w-full object-cover"
							/>
							<figcaption class="p-4">
								<h2 class="mb-2 text-xl font-semibold text-gray-900">
									<a href="/es/la-paz/tours.htm" class="hover:text-slate-700">La Paz</a>
								</h2>
								<p class="desc mb-4 text-sm text-gray-700">
									Explora la ciudad más alta del mundo. Visita el Mercado de las Brujas, el
									teleférico y el Valle de la Luna.
								</p>
								<ul class="flex justify-end">
									<li class="ver_tours">
										<a
											href="/es/la-paz/tours.htm"
											class="inline-block rounded-md bg-slate-950 px-4 py-2 text-white transition-colors hover:bg-slate-800"
											>Ver Tours</a
										>
									</li>
								</ul>
							</figcaption>
						</figure>
					</li>
					<li>
						<figure class="overflow-hidden rounded-[var(--fastt-radius-card)] bg-white shadow-md">
							<img
								src="https://picsum.photos/290/183?random=11"
								alt="Cochabamba"
								width="290"
								height="183"
								class="h-48 w-full object-cover"
							/>
							<figcaption class="p-4">
								<h2 class="mb-2 text-xl font-semibold text-gray-900">
									<a href="/es/cochabamba/tours.htm" class="hover:text-slate-700">Cochabamba</a>
								</h2>
								<p class="desc mb-4 text-sm text-gray-700">
									Recorre la "Ciudad Jardín" y sus alrededores. Descubre el Cristo de la Concordia y
									los paisajes del Parque Tunari.
								</p>
								<ul class="flex justify-end">
									<li class="ver_tours">
										<a
											href="/es/cochabamba/tours.htm"
											class="inline-block rounded-md bg-slate-950 px-4 py-2 text-white transition-colors hover:bg-slate-800"
											>Ver Tours</a
										>
									</li>
								</ul>
							</figcaption>
						</figure>
					</li>
					<li>
						<figure class="overflow-hidden rounded-[var(--fastt-radius-card)] bg-white shadow-md">
							<img
								src="https://picsum.photos/290/183?random=12"
								alt="Sucre"
								width="290"
								height="183"
								class="h-48 w-full object-cover"
							/>
							<figcaption class="p-4">
								<h2 class="mb-2 text-xl font-semibold text-gray-900">
									<a href="/es/sucre/tours.htm" class="hover:text-slate-700">Sucre</a>
								</h2>
								<p class="desc mb-4 text-sm text-gray-700">
									Visita la capital constitucional de Bolivia. Conoce su historia y la arquitectura
									colonial que la caracteriza.
								</p>
								<ul class="flex justify-end">
									<li class="ver_tours">
										<a
											href="/es/sucre/tours.htm"
											class="inline-block rounded-md bg-slate-950 px-4 py-2 text-white transition-colors hover:bg-slate-800"
											>Ver Tours</a
										>
									</li>
								</ul>
							</figcaption>
						</figure>
					</li>
					<li>
						<figure class="overflow-hidden rounded-[var(--fastt-radius-card)] bg-white shadow-md">
							<img
								src="https://picsum.photos/290/183?random=13"
								alt="Potosí"
								width="290"
								height="183"
								class="h-48 w-full object-cover"
							/>
							<figcaption class="p-4">
								<h2 class="mb-2 text-xl font-semibold text-gray-900">
									<a href="/es/potosi/tours.htm" class="hover:text-slate-700">Potosí</a>
								</h2>
								<p class="desc mb-4 text-sm text-gray-700">
									Explora las minas del Cerro Rico y aprende sobre la historia colonial de esta
									ciudad declarada Patrimonio de la Humanidad.
								</p>
								<ul class="flex justify-end">
									<li class="ver_tours">
										<a
											href="/es/potosi/tours.htm"
											class="inline-block rounded-md bg-slate-950 px-4 py-2 text-white transition-colors hover:bg-slate-800"
											>Ver Tours</a
										>
									</li>
								</ul>
							</figcaption>
						</figure>
					</li>
				</ul>
			</section>
		</div>

		<article class="links mt-12">
			<h2 class="mb-6 text-3xl font-bold text-gray-100">Tours por tipo de aventura</h2>
			<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
				<section>
					<h3 class="mb-4 text-xl font-semibold text-gray-100">Aventura</h3>
					<ul class="m-0 list-none space-y-2 p-0">
						<li>
							<a
								href="/es/tours/trekking.htm"
								title="Tours de Trekking"
								class="text-slate-700 hover:underline">Trekking</a
							>
						</li>
						<li>
							<a
								href="/es/tours/escalada.htm"
								title="Tours de Escalada"
								class="text-slate-700 hover:underline">Escalada</a
							>
						</li>
						<li>
							<a
								href="/es/tours/ciclismo-de-montana.htm"
								title="Tours de Ciclismo de Montaña"
								class="text-slate-700 hover:underline">Ciclismo de Montaña</a
							>
						</li>
					</ul>
				</section>
				<section>
					<h3 class="mb-4 text-xl font-semibold text-gray-100">Cultural</h3>
					<ul class="m-0 list-none space-y-2 p-0">
						<li>
							<a
								href="/es/tours/gastronomico.htm"
								title="Tours Gastronómicos"
								class="text-slate-700 hover:underline">Gastronómicos</a
							>
						</li>
						<li>
							<a
								href="/es/tours/ciudades-coloniales.htm"
								title="Tours por Ciudades Coloniales"
								class="text-slate-700 hover:underline">Ciudades Coloniales</a
							>
						</li>
						<li>
							<a
								href="/es/tours/mercados.htm"
								title="Tours de Mercados Locales"
								class="text-slate-700 hover:underline">Mercados Locales</a
							>
						</li>
					</ul>
				</section>
				<section>
					<h3 class="mb-4 text-xl font-semibold text-gray-100">Naturaleza</h3>
					<ul class="m-0 list-none space-y-2 p-0">
						<li>
							<a
								href="/es/tours/fauna-y-flora.htm"
								title="Tours de Fauna y Flora"
								class="text-slate-700 hover:underline">Fauna y Flora</a
							>
						</li>
						<li>
							<a
								href="/es/tours/parques-nacionales.htm"
								title="Tours por Parques Nacionales"
								class="text-slate-700 hover:underline">Parques Nacionales</a
							>
						</li>
						<li>
							<a
								href="/es/tours/observacion-de-aves.htm"
								title="Tours de Observación de Aves"
								class="text-slate-700 hover:underline">Observación de Aves</a
							>
						</li>
					</ul>
				</section>
				<section>
					<h3 class="mb-4 text-xl font-semibold text-gray-100">Histórico</h3>
					<ul class="m-0 list-none space-y-2 p-0">
						<li>
							<a
								href="/es/tours/sitios-arqueologicos.htm"
								title="Tours por Sitios Arqueológicos"
								class="text-slate-700 hover:underline">Sitios Arqueológicos</a
							>
						</li>
						<li>
							<a
								href="/es/tours/ruinas.htm"
								title="Tours por Ruinas"
								class="text-slate-700 hover:underline">Ruinas</a
							>
						</li>
					</ul>
				</section>
			</div>
		</article>
	</main>
</UILayout>
