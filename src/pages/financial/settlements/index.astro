---
import FinancialWorkspaceShell from "@/components/financial/FinancialWorkspaceShell.astro"
import Card from "@/components/ui/Card.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")
---

<WorkspaceLayout title="Finanzas · Liquidaciones">
	<FinancialWorkspaceShell
		title="Liquidaciones"
		description="Comparación operativa entre reserva confirmada, cobro registrado y liquidación externa."
		note="Solo compara importes y comprobantes visibles. No crea contabilidad ni ejecuta movimientos."
	>
		<Card class="overflow-hidden bg-white p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="settlementsSummary" class="text-sm font-semibold text-slate-950">
							Cargando diferencias...
						</p>
						<p class="mt-1 text-sm text-slate-600">
							Revisa primero importes distintos, cobros faltantes y liquidaciones externas
							faltantes.
						</p>
					</div>
					<div
						id="settlementsSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de liquidaciones"
					>
						<button
							type="button"
							data-settlements-segment="amount_mismatch"
							class="rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
						>
							Montos diferentes
						</button>
						<button
							type="button"
							data-settlements-segment="missing_payment"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Falta cobro
						</button>
						<button
							type="button"
							data-settlements-segment="missing_settlement"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Falta liquidación
						</button>
						<button
							type="button"
							data-settlements-segment="duplicate_reference"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Referencia duplicada
						</button>
						<button
							type="button"
							data-settlements-segment="no_difference"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Sin diferencia
						</button>
					</div>
				</div>
			</div>

			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead>
						<tr class="text-left text-slate-700">
							<th class="px-3 py-2">Reserva</th>
							<th class="px-3 py-2">Importe confirmado</th>
							<th class="px-3 py-2">Cobro</th>
							<th class="px-3 py-2">Liquidación</th>
							<th class="px-3 py-2">Diferencia</th>
							<th class="px-3 py-2">Estado revisión</th>
							<th class="px-3 py-2">Responsable</th>
							<th class="px-3 py-2">Próxima acción</th>
						</tr>
					</thead>
					<tbody id="settlementsRows">
						{
							Array.from({ length: 5 }).map(() => (
								<tr class="border-t border-slate-200">
									<td class="px-3 py-3">
										<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-28 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-40 animate-pulse rounded bg-slate-200" />
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</Card>
	</FinancialWorkspaceShell>

	<div id="settlementsDrawerBackdrop" class="hidden fixed inset-0 z-40 bg-slate-950/30"></div>
	<aside
		id="settlementsDrawer"
		class="fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto border-l border-slate-200 bg-white p-5 text-slate-900 shadow-2xl transition-transform duration-200"
	>
		<div class="mb-4 flex items-start justify-between gap-4 border-b border-slate-200 pb-3">
			<div>
				<p class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">
					Detalle de liquidación
				</p>
				<p class="text-sm text-slate-600">
					Reserva confirmada, cobro registrado, liquidación externa y siguiente acción.
				</p>
			</div>
			<button
				id="settlementsDrawerClose"
				type="button"
				class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
			>
				Cerrar
			</button>
		</div>
		<div id="settlementsDrawerBody"></div>
	</aside>

	<script src="./_client/settlements-workspace.ts"></script>
</WorkspaceLayout>
