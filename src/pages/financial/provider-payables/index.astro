---
import FinancialWorkspaceShell from "@/components/financial/FinancialWorkspaceShell.astro"
import Card from "@/components/ui/Card.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")
---

<WorkspaceLayout title="Finanzas · Pagos a proveedores">
	<FinancialWorkspaceShell
		title="Pagos a proveedores"
		description="Seguimiento de importes pendientes para proveedores y bloqueos operativos."
		note="Solo explica importes pendientes y requisitos de revisión. No ejecuta pagos ni mueve dinero."
	>
		<Card class="overflow-hidden bg-white p-0 text-slate-900">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p id="providerPayablesSummary" class="text-sm font-semibold text-slate-950">
							Cargando pagos pendientes...
						</p>
						<p class="mt-1 text-sm text-slate-600">
							Prioriza bloqueos por revisión de importes, comisión faltante o datos incompletos.
						</p>
					</div>
					<div
						id="providerPayablesSegments"
						class="flex flex-wrap gap-2"
						aria-label="Segmentos de pagos pendientes a proveedores"
					>
						<button
							type="button"
							data-provider-payables-segment="blocked"
							class="rounded-full bg-slate-950 px-3 py-2 text-sm font-semibold text-white"
						>
							Bloqueados
						</button>
						<button
							type="button"
							data-provider-payables-segment="commission_missing"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Falta comisión
						</button>
						<button
							type="button"
							data-provider-payables-segment="review_amounts"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Revisar importes
						</button>
						<button
							type="button"
							data-provider-payables-segment="statement_review"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Resumen pendiente
						</button>
						<button
							type="button"
							data-provider-payables-segment="ready"
							class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
						>
							Sin bloqueo principal
						</button>
					</div>
				</div>
			</div>

			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead>
						<tr class="text-left text-slate-700">
							<th class="px-3 py-2">Proveedor</th>
							<th class="px-3 py-2">Reserva</th>
							<th class="px-3 py-2">Bruto</th>
							<th class="px-3 py-2">Comisión</th>
							<th class="px-3 py-2">Impuestos</th>
							<th class="px-3 py-2">Pendiente proveedor</th>
							<th class="px-3 py-2">Bloqueo</th>
							<th class="px-3 py-2">Responsable</th>
							<th class="px-3 py-2">Próxima acción</th>
						</tr>
					</thead>
					<tbody id="providerPayablesRows">
						{
							Array.from({ length: 5 }).map(() => (
								<tr class="border-t border-slate-200">
									<td class="px-3 py-3">
										<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-28 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-28 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-3">
										<div class="h-4 w-40 animate-pulse rounded bg-slate-200" />
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</Card>
	</FinancialWorkspaceShell>

	<div id="providerPayablesDrawerBackdrop" class="hidden fixed inset-0 z-40 bg-slate-950/30"></div>
	<aside
		id="providerPayablesDrawer"
		class="fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto border-l border-slate-200 bg-white p-5 text-slate-900 shadow-2xl transition-transform duration-200"
	>
		<div class="mb-4 flex items-start justify-between gap-4 border-b border-slate-200 pb-3">
			<div>
				<p class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">
					Detalle de pago pendiente
				</p>
				<p class="text-sm text-slate-600">
					Bloqueo, importes, comisión, impuestos, reservas relacionadas y próxima acción.
				</p>
			</div>
			<button
				id="providerPayablesDrawerClose"
				type="button"
				class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
			>
				Cerrar
			</button>
		</div>
		<div id="providerPayablesDrawerBody"></div>
	</aside>
</WorkspaceLayout>
