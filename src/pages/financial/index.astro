---
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import Select from "@/components/ui/Select.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")
---

<WorkspaceLayout title="Financial Operations">
	<section class="space-y-8">
		<header class="grid gap-6 lg:grid-cols-[1.35fr_0.85fr] lg:items-end">
			<div class="space-y-3">
				<p class="text-xs font-bold uppercase tracking-[0.18em] text-sky-300">
					Snapshot-safe finance visibility
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">
					Financial Operations & Reconciliation Workspace
				</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Visibilidad financiera operacional basada en snapshots contractuales y registros shadow.
					Esta superficie no orquesta PSP, no recalcula pricing, no ejecuta payouts y no actúa como
					ledger contable.
				</p>
			</div>
			<Card class="border-slate-700 bg-slate-900/70 text-slate-100">
				<p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">Ownership</p>
				<p class="mt-2 text-sm leading-6 text-slate-300">
					Payments & Finance owns reconciliation visibility, payment lifecycle visibility and
					financial handoff context. Reservations remains the contract snapshot owner.
				</p>
			</Card>
		</header>

		<Section
			title="Financial lifecycle visibility"
			description="Estados operacionales honestos: snapshots, handoffs y registros shadow; no settlement automation."
		>
			<div id="financialSummary" class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
				{
					["Contract value", "Refund handoff", "Partial reconciliation", "Snapshot ready"].map(
						(label) => (
							<Card class="bg-slate-100">
								<p class="text-xs font-bold tracking-[0.12em] text-slate-500 uppercase">{label}</p>
								<div class="mt-3 h-8 w-20 animate-pulse rounded bg-slate-200" />
								<div class="mt-2 h-3 w-32 animate-pulse rounded bg-slate-200" />
							</Card>
						)
					)
				}
			</div>
		</Section>

		<Section
			title="Reconciliation filters"
			description="Filtra visibilidad financiera sin cambiar contratos ni ejecutar workflows financieros."
		>
			<Card class="bg-slate-100">
				<div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-end">
					<label class="space-y-2 text-sm font-medium text-slate-700">
						<span>Reconciliation state</span>
						<Select id="financialStateFilter" name="state" value="all">
							<option value="all">Todos</option>
							<option value="snapshot_ready">Snapshot ready</option>
							<option value="handoff_pending">Handoff pending</option>
							<option value="partially_reconciled">Partially reconciled</option>
							<option value="reconciled">Reconciled</option>
							<option value="reconciliation_unknown">Unknown</option>
						</Select>
					</label>
					<p class="text-xs leading-5 text-slate-500">
						Financial estados aquí son read models. PSP execution, ledger settlement e invoicing
						fiscal permanecen fuera de esta capa.
					</p>
				</div>
			</Card>
		</Section>

		<Section
			title="Financial operations queue"
			description="Bookings con snapshots financieros, handoff de refund, visibilidad de payout/commission e invoice references."
		>
			<Card class="min-h-[280px] space-y-4 bg-slate-100">
				<div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
					<p id="financialListSummary" class="text-sm text-slate-700">
						Cargando operaciones financieras...
					</p>
					<p id="financialListLatency" class="text-xs text-slate-500"></p>
				</div>
				<div class="overflow-x-auto">
					<table class="min-w-full divide-y divide-slate-200 text-sm">
						<thead>
							<tr class="text-left text-slate-700">
								<th class="px-3 py-2">Booking contract</th>
								<th class="px-3 py-2">Transaction visibility</th>
								<th class="px-3 py-2">Refund / reconciliation</th>
								<th class="px-3 py-2">Payout / commission</th>
								<th class="px-3 py-2">Taxes / invoice</th>
							</tr>
						</thead>
						<tbody id="financialRows">
							{
								Array.from({ length: 5 }).map(() => (
									<tr class="border-t border-slate-200">
										<td class="px-3 py-2">
											<div class="h-4 w-40 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
										</td>
										<td class="px-3 py-2">
											<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
										</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
			</Card>
		</Section>
	</section>

	<script is:inline>
		;(function () {
			const stateFilter = document.getElementById("financialStateFilter")
			const summary = document.getElementById("financialSummary")
			const rows = document.getElementById("financialRows")
			const listSummary = document.getElementById("financialListSummary")
			const latency = document.getElementById("financialListLatency")

			const money = (currency, value) =>
				`${String(currency || "USD")} ${Number(value || 0).toFixed(2)}`
			const stateLabel = (state) => String(state || "reconciliation_unknown").replaceAll("_", " ")

			function renderSummary(data) {
				if (!summary) return
				const metrics = [
					{
						label: "Contract value",
						value: money("USD", data?.contractValue ?? 0),
						detail: "Valor contractual visible desde booking snapshots.",
					},
					{
						label: "Refund handoff",
						value: data?.refundHandoffPending ?? 0,
						detail: "Cancelaciones que requieren handoff financiero.",
					},
					{
						label: "Partial reconciliation",
						value: data?.partiallyReconciled ?? 0,
						detail: "Shadow records presentes sin cierre contable real.",
					},
					{
						label: "Snapshot ready",
						value: data?.snapshotReady ?? 0,
						detail: "Contrato listo; sin workflow financiero activo.",
					},
				]
				summary.innerHTML = metrics
					.map(
						(metric) => `<div class="rounded-2xl border border-slate-200 bg-slate-100 p-5">
							<p class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">${metric.label}</p>
							<p class="mt-3 text-2xl font-semibold text-slate-950">${metric.value}</p>
							<p class="mt-2 text-xs leading-5 text-slate-600">${metric.detail}</p>
						</div>`
					)
					.join("")
			}

			function renderRows(items) {
				if (!rows) return
				rows.innerHTML = ""
				if (!Array.isArray(items) || !items.length) {
					rows.innerHTML =
						'<tr><td colspan="5" class="px-3 py-6 text-center text-slate-500">No financial operations for this filter.</td></tr>'
					return
				}
				for (const item of items) {
					const tr = document.createElement("tr")
					tr.className = "border-t border-slate-200 align-top"
					tr.innerHTML = `
						<td class="px-3 py-3 text-slate-700">
							<a class="font-medium text-slate-950 hover:text-blue-700" href="/booking/${encodeURIComponent(String(item.bookingId || ""))}">${String(item.bookingId || "-")}</a>
							<div class="mt-1 text-xs text-slate-500">${String(item?.contract?.productName || "Property")} · ${String(item?.contract?.variantName || "Allocation")}</div>
							<div class="mt-1 text-xs text-slate-500">${money(item.currency, item.contractTotal)} · ${String(item?.contract?.version || "snapshot")}</div>
						</td>
						<td class="px-3 py-3 text-slate-700">
							<div>${Number(item?.transactions?.paymentIntents || 0)} payment intent(s)</div>
							<div class="mt-1 text-xs text-slate-500">${Number(item?.transactions?.settlementRecords || 0)} settlement · ${Number(item?.transactions?.refundRecords || 0)} refund</div>
						</td>
						<td class="px-3 py-3 text-slate-700">
							<div class="font-medium text-slate-950">${stateLabel(item?.reconciliation?.state)}</div>
							<div class="mt-1 text-xs text-slate-500">Refund: ${String(item?.refund?.state || "not_applicable")}</div>
						</td>
						<td class="px-3 py-3 text-slate-700">
							<div>${money(item.currency, item.netPayoutEstimate)} payout visibility</div>
							<div class="mt-1 text-xs text-slate-500">Commission: ${money(item.currency, item.commissionTotal)}</div>
						</td>
						<td class="px-3 py-3 text-slate-700">
							<div>${Number(item?.taxFeeVisibility?.lines || 0)} tax/fee snapshot line(s)</div>
							<div class="mt-1 text-xs text-slate-500">Invoice: ${String(item?.invoice?.state || "reference_not_issued")}</div>
						</td>`
					rows.appendChild(tr)
				}
			}

			async function fetchOperations() {
				const started = performance.now()
				const state = String(stateFilter?.value || "all")
				try {
					const params = new URLSearchParams()
					if (state && state !== "all") params.set("state", state)
					const response = await fetch(`/api/internal/financial/operations?${params.toString()}`, {
						headers: { accept: "application/json" },
					})
					if (!response.ok) throw new Error(`financial_operations_${response.status}`)
					const payload = await response.json()
					renderSummary(payload?.summary || {})
					renderRows(Array.isArray(payload?.items) ? payload.items : [])
					if (listSummary)
						listSummary.textContent = `${payload?.summary?.totalBookings || 0} booking contract(s) in financial visibility.`
					if (latency)
						latency.textContent = `Endpoint latency: ${Number((performance.now() - started).toFixed(1))}ms`
				} catch {
					renderSummary({})
					renderRows([])
					if (listSummary) listSummary.textContent = "No se pudo cargar financial operations."
					if (latency) latency.textContent = ""
				}
			}

			stateFilter?.addEventListener("change", () => void fetchOperations())
			void fetchOperations()
		})()
	</script>
</WorkspaceLayout>
