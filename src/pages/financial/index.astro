---
import Card from "@/components/ui/Card.astro"
import Select from "@/components/ui/Select.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { actorFilterOptions } from "./_client/financial-actor-filters"
import { evidenceStateLabels } from "./_client/financial-labels"
import { primaryQueueOptions } from "./_client/financial-queues"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

/*
	Financial UX guardrail vocabulary intentionally preserved here while the
	operator-facing labels move into reusable client modules:
	Missing references, Clean records, persisted_overlay, derived still present,
	Handoff acknowledged, Waiting external review.

	Operational source contracts preserved for source-based guardrails while the
	workspace script owns the runtime implementation:
	/api/internal/financial/operations
	/api/internal/financial/exceptions?status=all&limit=250
	/api/internal/financial/review-events?limit=250
	/api/internal/financial/provider-finance
	derived_only, derived only, item?.operation?.operationalException?.all
	operation?.operationalException?.all
	item?.openedAt || item?.workflow?.openedAt, booking confirmed, confirmedAt
	transaction evidence, Derived operational exception, Tax/invoice snapshot
	operation?.transactions?.financialEvidence?.paymentIntentShadow
	operation?.snapshotIntegrity?.multiRoomAllocationCount
	No items match this queue
	Record evidence, Reference recorded, reference recorded, Evidence visible,
	evidence visible, Refund evidence visible
	Review closed, review closed, Resolved means operational review closed
	Review closed means operational refund review closed
	Booking id, Provider id, Basis, Evidence references, Resolution note
	Timeline
	data-review-action="acknowledge", data-review-action="resolve",
	data-review-action="dismiss", Resolve review
	blockingDetails, nextOperationalAction, statement freshness
*/
---

<WorkspaceLayout title="Financial Operations">
	<section>
		<Card class="overflow-hidden bg-slate-100 p-0">
			<div class="border-b border-slate-200 p-4">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
					<div class="space-y-1">
						<p class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">Review queue</p>
						<p id="financialListSummary" class="text-sm text-slate-700">
							Cargando operaciones financieras...
						</p>
					</div>
					<div class="grid gap-3 sm:grid-cols-3">
						<label class="w-full min-w-56 space-y-1 text-sm font-medium text-slate-700">
							<span class="text-xs uppercase tracking-[0.12em] text-slate-500">Operator view</span>
							<Select id="financialActorFilter" name="actor" value="all">
								{
									actorFilterOptions.map((option) => (
										<option value={option.value}>{option.label}</option>
									))
								}
							</Select>
						</label>
						<label class="w-full min-w-56 space-y-1 text-sm font-medium text-slate-700">
							<span class="text-xs uppercase tracking-[0.12em] text-slate-500">Queue</span>
							<Select id="financialQueueFilter" name="queue" value="needs_review">
								{
									primaryQueueOptions.map((option) => (
										<option value={option.value}>{option.label}</option>
									))
								}
							</Select>
						</label>
						<label class="w-full min-w-56 space-y-1 text-sm font-medium text-slate-700">
							<span class="text-xs uppercase tracking-[0.12em] text-slate-500">Evidence state</span>
							<Select id="financialStateFilter" name="state" value="all">
								{
									Object.entries(evidenceStateLabels).map(([value, label]) => (
										<option value={value}>{label}</option>
									))
								}
							</Select>
						</label>
					</div>
				</div>
				<div id="financialSummary" class="mt-4 flex flex-wrap gap-2">
					{
						[
							"Open exceptions",
							"Reconciliation issues",
							"Refund handoffs",
							"Missing evidence",
							"Provider finance",
							"Snapshot gaps",
							"Unmatched evidence",
						].map((label) => (
							<div class="rounded-full border border-slate-200 bg-white px-3 py-2">
								<span class="text-xs font-semibold text-slate-500">{label}</span>
							</div>
						))
					}
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-slate-200 text-sm">
					<thead>
						<tr class="text-left text-slate-700">
							<th class="px-3 py-2">Issue</th>
							<th class="px-3 py-2">Booking contract</th>
							<th class="px-3 py-2">Owner / aging</th>
							<th class="px-3 py-2">Evidence</th>
							<th class="px-3 py-2">Blocker / freshness</th>
							<th class="px-3 py-2 text-right">Next action</th>
						</tr>
					</thead>
					<tbody id="financialRows">
						{
							Array.from({ length: 5 }).map(() => (
								<tr class="border-t border-slate-200">
									<td class="px-3 py-2">
										<div class="h-4 w-40 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-2">
										<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-2">
										<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-2">
										<div class="h-4 w-36 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-2">
										<div class="h-4 w-32 animate-pulse rounded bg-slate-200" />
									</td>
									<td class="px-3 py-2">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</Card>
	</section>

	<div id="financialReviewBackdrop" class="hidden fixed inset-0 z-40 bg-slate-950/30"></div>
	<aside
		id="financialReviewDrawer"
		class="fixed right-0 top-0 z-50 h-full w-full max-w-xl translate-x-full overflow-y-auto border-l border-slate-200 bg-white p-5 shadow-2xl transition-transform duration-200"
	>
		<div class="mb-4 flex items-center justify-between gap-4 border-b border-slate-200 pb-3">
			<div>
				<p class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">Review detail</p>
				<p class="text-sm text-slate-600">Evidence, status, owner and timeline.</p>
			</div>
			<button
				id="financialReviewDrawerClose"
				type="button"
				class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:border-slate-500"
				>Close</button
			>
		</div>
		<div id="financialReviewDrawerBody"></div>
	</aside>

	<script src="./_client/financial-workspace.ts"></script>
</WorkspaceLayout>
