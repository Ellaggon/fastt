---
import ProviderKycSlotsCard from "@/components/provider/ProviderKycSlotsCard.astro"
import ProviderReviewWaitNotice from "@/components/provider/ProviderReviewWaitNotice.astro"
import ProviderVerificationView from "@/components/provider/ProviderVerificationView.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Input from "@/components/ui/Input.astro"
import Notice from "@/components/ui/Notice.astro"
import Select from "@/components/ui/Select.astro"
import ProviderSettingsLayout from "@/layouts/ProviderSettingsLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { listOpenComplianceAssignments } from "@/lib/provider-compliance-ops"
import {
	buildRequiredKycSlots,
	listProviderDocuments,
	providerDocumentTypes,
	requiredKycDocumentTypes,
} from "@/lib/provider-documents"
import { routes } from "@/lib/routes"
import { getProviderFullAggregate } from "@/modules/catalog/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

const aggregate =
	typeof auth === "string" ? null : await getProviderFullAggregate(auth.providerId, auth.user.id)

const summaryRes = await fetch(new URL("/api/provider/settings/summary", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const summary = summaryRes.ok ? await summaryRes.json() : null
const permissions = summary?.permissions ?? {}
const canManageDocuments = Boolean(permissions.canManageDocuments)
const documents =
	typeof auth === "string" ? [] : await listProviderDocuments(auth.providerId).catch(() => [])
const openAssignments =
	typeof auth === "string"
		? []
		: await listOpenComplianceAssignments({ providerId: auth.providerId }).catch(() => [])
const verificationAssignment =
	typeof auth === "string"
		? null
		: (openAssignments.find(
				(row) => row.domain === "verification" && row.entityId === auth.providerId
			) ?? null)
const documentAssignmentById = new Map(
	openAssignments
		.filter((row) => row.domain === "documents")
		.map((row) => [row.entityId, row] as const)
)
const result = Astro.url.searchParams.get("result")
const requestedType = String(Astro.url.searchParams.get("type") ?? "").trim()
const defaultUploadType = providerDocumentTypes.some((item) => item.value === requestedType)
	? requestedType
	: requiredKycDocumentTypes[0]

const kycSlots = buildRequiredKycSlots({
	documents,
	uploadBasePath: routes.providerSettingsVerification(),
})
const optionalDocuments = documents.filter(
	(doc) => !(requiredKycDocumentTypes as readonly string[]).includes(doc.type)
)
const pendingCount = documents.filter((doc) => doc.status === "pending").length
const verifiedCount = documents.filter((doc) => doc.status === "verified").length
const rejectedCount = documents.filter((doc) => doc.status === "rejected").length

const resultMessages: Record<
	string,
	{ title: string; body: string; variant: "success" | "warning" }
> = {
	submitted: {
		title: "Documento enviado",
		body: "Quedó en revisión. El resultado aparecerá en esta página cuando el equipo Fastt termine.",
		variant: "success",
	},
	verified: {
		title: "Documento verificado",
		body: "Este respaldo ya cuenta para el checklist de cumplimiento.",
		variant: "success",
	},
	rejected: {
		title: "Documento rechazado",
		body: "Revisa el motivo en el checklist y envía una versión corregida.",
		variant: "warning",
	},
}
---

<ProviderSettingsLayout
	title="Verificación y documentos"
	heading="Verificación"
	description="Estado de aprobación del proveedor y documentos de respaldo para operar con confianza."
>
	{
		result && resultMessages[result] ? (
			<Notice variant={resultMessages[result].variant} title={resultMessages[result].title}>
				{resultMessages[result].body}
			</Notice>
		) : null
	}

	<ProviderVerificationView
		latestVerification={aggregate?.latestVerification}
		documents={documents}
		showHeader={false}
		reviewAssignment={verificationAssignment}
	/>

	<ProviderKycSlotsCard
		slots={kycSlots}
		canManageDocuments={canManageDocuments}
		documentAssignments={Object.fromEntries(documentAssignmentById)}
	/>

	<div class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
		<Card>
			<div class="space-y-4">
				<div class="flex flex-wrap items-start justify-between gap-3">
					<div>
						<h2 class="text-xl font-semibold text-slate-950">Otros documentos</h2>
						<p class="mt-2 text-sm leading-6 text-slate-600">
							Respaldo adicional (propiedad, licencias, domicilio). El checklist mínimo está arriba.
						</p>
					</div>
					<div class="flex flex-wrap gap-2">
						<Badge variant={pendingCount ? "warning" : "neutral"}>
							{pendingCount} pendiente{pendingCount === 1 ? "" : "s"}
						</Badge>
						<Badge variant={verifiedCount ? "success" : "neutral"}>
							{verifiedCount} verificado{verifiedCount === 1 ? "" : "s"}
						</Badge>
						<Badge variant={rejectedCount ? "error" : "neutral"}>
							{rejectedCount} rechazado{rejectedCount === 1 ? "" : "s"}
						</Badge>
					</div>
				</div>

				<div class="space-y-3">
					{
						optionalDocuments.length ? (
							optionalDocuments.map((doc) => (
								<Card variant="soft" class="space-y-3">
									<div class="flex flex-wrap items-start justify-between gap-3">
										<div>
											<p class="text-sm font-semibold text-slate-950">{doc.typeLabel}</p>
											<p class="mt-1 text-sm text-slate-600">
												{doc.fileName || "Sin nombre de archivo"}
												{doc.mimeType ? ` · ${doc.mimeType}` : ""}
											</p>
											{doc.submissionNotes ? (
												<p class="mt-2 text-sm leading-6 text-slate-600">
													Nota de envío: {doc.submissionNotes}
												</p>
											) : null}
											{doc.status === "rejected" && doc.reviewNotes ? (
												<Notice variant="error" title="Motivo del rechazo" class="mt-3">
													{doc.reviewNotes}
												</Notice>
											) : doc.reviewNotes ? (
												<p class="mt-2 text-sm leading-6 text-slate-600">
													Nota de revisión: {doc.reviewNotes}
												</p>
											) : null}
										</div>
										<Badge
											variant={
												doc.tone === "success"
													? "success"
													: doc.tone === "error"
														? "error"
														: doc.tone === "warning"
															? "warning"
															: "neutral"
											}
										>
											{doc.statusLabel}
										</Badge>
									</div>

									{doc.status === "pending" ? (
										<ProviderReviewWaitNotice
											domain="document"
											assignment={documentAssignmentById.get(doc.id) ?? null}
											class="mt-3"
										/>
									) : null}
								</Card>
							))
						) : (
							<Card variant="soft" class="text-sm text-slate-600">
								No hay documentos opcionales cargados todavía.
							</Card>
						)
					}
				</div>
			</div>
		</Card>

		<Card id="kyc-upload">
			{
				canManageDocuments ? (
					<form
						class="space-y-4"
						method="post"
						action="/api/provider/settings/documents"
						enctype="multipart/form-data"
					>
						<input type="hidden" name="action" value="submit" />
						<div>
							<h2 class="text-xl font-semibold text-slate-950">Subir documento</h2>
							<p class="mt-2 text-sm leading-6 text-slate-600">
								Adjunta PDF o imagen (máx. 12&nbsp;MB). El archivo queda disponible solo para
								revisión interna.
							</p>
						</div>
						<label class="grid gap-2 text-sm font-medium text-slate-700">
							Tipo
							<Select name="type" required>
								{providerDocumentTypes.map((item) => (
									<option value={item.value} selected={item.value === defaultUploadType}>
										{item.label}
										{(requiredKycDocumentTypes as readonly string[]).includes(item.value)
											? " (mínimo)"
											: ""}
									</option>
								))}
							</Select>
						</label>
						<label class="grid gap-2 text-sm font-medium text-slate-700">
							Archivo
							<input
								type="file"
								name="file"
								accept=".pdf,image/jpeg,image/png,image/webp,image/heic,image/heif,application/pdf"
								class="fastt-field block w-full text-sm text-slate-700 file:mr-3 file:bg-slate-900 file:px-3 file:py-2 file:text-sm file:font-semibold file:text-white"
							/>
						</label>
						<label class="grid gap-2 text-sm font-medium text-slate-700">
							Notas de envío (opcional)
							<Input name="submissionNotes" placeholder="Versión vigente / dato actualizado" />
						</label>
						<Button type="submit">Enviar a revisión</Button>
					</form>
				) : (
					<div class="space-y-3">
						<h2 class="text-xl font-semibold text-slate-950">Subir documento</h2>
						<p class="text-sm leading-6 text-slate-600">
							Tu rol actual no puede cargar documentos de cumplimiento.
						</p>
					</div>
				)
			}
		</Card>
	</div>
</ProviderSettingsLayout>
