---
import ProviderPaymentAccountsCard from "@/components/provider/ProviderPaymentAccountsCard.astro"
import Button from "@/components/ui/Button.astro"
import Notice from "@/components/ui/Notice.astro"
import ProviderSettingsLayout from "@/layouts/ProviderSettingsLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { listOpenComplianceAssignments } from "@/lib/provider-compliance-ops"
import { listProviderPaymentAccounts } from "@/lib/provider-payment-accounts"
import { routes } from "@/lib/routes"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

const summaryRes = await fetch(new URL("/api/provider/settings/summary", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const summary = summaryRes.ok ? await summaryRes.json() : null
const permissions = summary?.permissions ?? {}
const accounts = await listProviderPaymentAccounts(auth.providerId).catch(() => [])
const openAssignments = await listOpenComplianceAssignments({ providerId: auth.providerId }).catch(
	() => []
)
const paymentAssignments = Object.fromEntries(
	openAssignments.filter((row) => row.domain === "payments").map((row) => [row.entityId, row])
)
const result = String(Astro.url.searchParams.get("result") ?? "").trim()
const error = String(Astro.url.searchParams.get("error") ?? "").trim()
const defaultCurrency = String(summary?.profile?.defaultCurrency ?? "USD")

const resultMessages: Record<string, { title: string; body: string; variant: "success" | "info" }> =
	{
		submitted: {
			title: "Cuenta enviada",
			body: "Paso 1 listo. Ahora espera los depósitos de prueba; el timeline en la cuenta te guía hasta que quede lista.",
			variant: "success",
		},
		micro_deposit_confirmed: {
			title: "Cuenta lista",
			body: "Confirmaste los montos. La cuenta quedó verificada para liquidaciones.",
			variant: "success",
		},
	}

const postSaveCtaByResult: Record<string, { href: string; label: string }> = {
	submitted: { href: routes.providerSettings(), label: "Ir al resumen" },
	micro_deposit_confirmed: {
		href: routes.providerSettingsIntegrations(),
		label: "Continuar a integraciones",
	},
}

const errorMessages: Record<string, { title: string; body: string; variant: "warning" | "error" }> =
	{
		micro_deposit_mismatch: {
			title: "Montos incorrectos",
			body: "Los montos no coinciden. Revisa tu extracto e inténtalo de nuevo (máximo 3 intentos).",
			variant: "warning",
		},
		micro_deposit_failed: {
			title: "Intentos agotados",
			body: "Se agotaron los intentos de confirmación. Envía una cuenta nueva o contacta a soporte Fastt.",
			variant: "error",
		},
		micro_deposit_expired: {
			title: "Depósitos vencidos",
			body: "El plazo para confirmar los montos venció. El equipo Fastt puede reiniciar la verificación.",
			variant: "warning",
		},
		micro_deposit_not_initiated: {
			title: "Aún no hay depósitos",
			body: "La verificación de titularidad todavía no está lista para confirmar. Espera el paso “Esperando depósitos”.",
			variant: "warning",
		},
		invalid_micro_deposit_amounts: {
			title: "Montos inválidos",
			body: "Ingresa dos montos enteros entre 1 y 99 centavos.",
			variant: "warning",
		},
	}
---

<ProviderSettingsLayout
	title="Pagos"
	eyebrow="Configuración del proveedor · Pagos"
	heading="Pagos y liquidaciones"
	description="Cuentas bancarias para recibir pagos. Separado de tu registro fiscal y de los impuestos que cobras al huésped."
>
	<div slot="actions" class="flex flex-wrap gap-3">
		<Button href={routes.providerSettingsTaxFees()} variant="secondary">Fiscalidad</Button>
		<Button href={routes.providerSettings()} variant="secondary">Resumen</Button>
	</div>

	{
		result && resultMessages[result] ? (
			<Notice variant={resultMessages[result].variant} title={resultMessages[result].title}>
				<p>{resultMessages[result].body}</p>
				{postSaveCtaByResult[result] ? (
					<p class="mt-3" data-post-save-cta>
						<a class="font-semibold underline" href={postSaveCtaByResult[result].href}>
							{postSaveCtaByResult[result].label}
						</a>
					</p>
				) : null}
			</Notice>
		) : null
	}
	{
		error && errorMessages[error] ? (
			<Notice variant={errorMessages[error].variant} title={errorMessages[error].title}>
				{errorMessages[error].body}
			</Notice>
		) : null
	}

	<ProviderPaymentAccountsCard
		accounts={accounts}
		canManagePayments={Boolean(permissions.canManagePayments)}
		defaultCurrency={defaultCurrency}
		paymentAssignments={paymentAssignments}
	/>
</ProviderSettingsLayout>
