---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Input from "@/components/ui/Input.astro"
import Notice from "@/components/ui/Notice.astro"
import Select from "@/components/ui/Select.astro"
import ProviderSettingsLayout from "@/layouts/ProviderSettingsLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import {
	mapProviderIntegrationError,
	mapProviderIntegrationLogMessage,
} from "@/lib/provider-integration-errors"
import {
	isRecommendedProviderConnector,
	listProviderIntegrations,
	type ProviderIntegrationCard,
} from "@/lib/provider-integrations"
import { routes } from "@/lib/routes"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

const url = new URL(Astro.request.url)
const success = url.searchParams.get("success")
const error = url.searchParams.get("error")
const uiMode = url.searchParams.get("mode") === "pro" ? "pro" : "simple"
const isSimple = uiMode === "simple"
const modeQuery = isSimple ? "simple" : "pro"

const connectors = await listProviderIntegrations({
	providerId: auth.providerId,
	currentUserId: auth.user.id,
})

const recommended = connectors.filter((connector) => isRecommendedProviderConnector(connector.key))
const others = connectors.filter((connector) => !isRecommendedProviderConnector(connector.key))
const visibleConnectors = isSimple ? recommended : connectors

const connectedCount = connectors.filter((connector) => connector.status === "connected").length
const pendingSmokeCount = connectors.filter((connector) =>
	["pending", "syncing"].includes(connector.status)
).length
const productionCount = connectors.filter((connector) => connector.mode === "production").length
const lastSync = connectors
	.map((connector) => connector.lastSyncAt)
	.filter(Boolean)
	.sort((a, b) => Number(b) - Number(a))[0]

const successMessages: Record<string, string> = {
	integration_saved: "Integración guardada. Ejecuta “Probar conexión” para activarla.",
	integration_revoked: "Acceso revocado. El conector ya no puede sincronizar.",
	sync_tested: "Prueba de conexión correcta. El conector quedó activo.",
}

function formatDate(value: Date | null) {
	if (!value) return "Sin actividad"
	return new Intl.DateTimeFormat("es", {
		dateStyle: "medium",
		timeStyle: "short",
	}).format(value)
}

function canTest(connector: ProviderIntegrationCard) {
	return connector.status !== "not_configured" && connector.status !== "revoked"
}
---

<ProviderSettingsLayout
	title="Integraciones"
	eyebrow="Configuración del proveedor · Conectividad"
	heading="Integraciones"
	description={isSimple
		? "Empieza por los conectores recomendados. Guarda la referencia y prueba la conexión antes de usarla."
		: "Catálogo completo: modos, permisos y actividad. Guarda la conexión y pruébala antes de producción."}
>
	<div slot="actions" class="flex flex-wrap gap-2">
		<Button
			href={`${routes.providerSettingsIntegrations()}?mode=simple`}
			variant={isSimple ? "primary" : "secondary"}
			size="sm"
		>
			Simple
		</Button>
		<Button
			href={`${routes.providerSettingsIntegrations()}?mode=pro`}
			variant={!isSimple ? "primary" : "secondary"}
			size="sm"
		>
			Pro
		</Button>
		<Button href={routes.providerSettingsVerification()} variant="secondary" size="sm">
			Verificación
		</Button>
	</div>

	{
		success && successMessages[success] ? (
			<Notice variant="success" title="Cambio aplicado">
				{successMessages[success]}
			</Notice>
		) : null
	}
	{
		error ? (
			<Notice variant="warning" title="No se pudo completar la acción">
				{mapProviderIntegrationError(error)}
			</Notice>
		) : null
	}

	<div class="grid gap-4 md:grid-cols-4">
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">Conectados</p>
			<p class="mt-3 text-2xl font-semibold text-slate-950">
				{connectedCount}/{connectors.length}
			</p>
		</Card>
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">
				Pendientes de prueba
			</p>
			<p class="mt-3 text-2xl font-semibold text-slate-950">{pendingSmokeCount}</p>
		</Card>
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">Producción</p>
			<p class="mt-3 text-2xl font-semibold text-slate-950">{productionCount}</p>
		</Card>
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">Última sync</p>
			<p class="mt-3 text-sm font-semibold text-slate-950">{formatDate(lastSync ?? null)}</p>
		</Card>
	</div>

	{
		isSimple ? (
			<Notice variant="info" title="Modo Simple · recomendados">
				Te mostramos pasarela de pago y channel manager primero. Guarda el enlace/referencia y pulsa{" "}
				<strong>Probar conexión</strong> — solo si responde bien queda activa. Cambia a Pro para ver
				el catálogo completo y permisos avanzados.
			</Notice>
		) : (
			<Notice variant="info" title="Cómo activar un conector">
				Primero guarda la conexión. Luego ejecuta “Probar conexión”: solo si responde bien queda
				activa. El modo producción se habilita cuando el resto de la configuración del proveedor lo
				permite.
			</Notice>
		)
	}

	{
		isSimple && others.some((row) => row.status !== "not_configured") ? (
			<Notice variant="info" title="Hay más conectores configurados">
				Tienes conectores fuera de la lista recomendada. Ábrelos en{" "}
				<a
					class="font-semibold underline"
					href={`${routes.providerSettingsIntegrations()}?mode=pro`}
				>
					modo Pro
				</a>
				.
			</Notice>
		) : null
	}

	<div class="grid gap-4 xl:grid-cols-2">
		{
			visibleConnectors.map((connector) => (
				<Card
					data-connector={connector.key}
					data-recommended={isRecommendedProviderConnector(connector.key) ? "true" : "false"}
				>
					<div class="flex flex-col gap-5">
						<div class="flex flex-wrap items-start justify-between gap-4">
							<div>
								<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">
									{connector.category}
									{isRecommendedProviderConnector(connector.key) ? " · Recomendado" : ""}
								</p>
								<h2 class="mt-2 text-xl font-semibold text-slate-950">{connector.name}</h2>
							</div>
							<div class="flex flex-wrap justify-end gap-2">
								<Badge variant={connector.tone}>{connector.statusLabel}</Badge>
								<Badge variant={connector.mode === "production" ? "success" : "info"}>
									{connector.mode === "production" ? "Producción" : "Sandbox"}
								</Badge>
							</div>
						</div>

						<p class="text-sm leading-6 text-slate-600">{connector.description}</p>

						{connector.errorMessage ? (
							<Notice variant="warning" title="Último problema">
								{mapProviderIntegrationError(connector.errorMessage)}
							</Notice>
						) : null}

						<div class={`grid gap-4 ${isSimple ? "" : "lg:grid-cols-[1fr_0.85fr]"}`}>
							<Card variant="soft" class="p-4">
								<form method="post" action={`/api/provider/integrations/${connector.key}/connect`}>
									<input type="hidden" name="uiMode" value={modeQuery} />
									<div class="grid gap-4">
										<label class="grid gap-2 text-sm font-semibold text-slate-900">
											Modo
											<Select name="mode">
												<option value="sandbox" selected={connector.mode === "sandbox"}>
													Sandbox
												</option>
												<option
													value="production"
													selected={connector.mode === "production"}
													disabled={!connector.canUseProduction}
												>
													Producción
												</option>
											</Select>
										</label>

										<label class="grid gap-2 text-sm font-semibold text-slate-900">
											{isSimple ? "Enlace o referencia de conexión" : "Referencia segura de acceso"}
											<Input
												name="credentialsRef"
												value={connector.credentialsRef}
												placeholder={
													isSimple
														? "https://tu-servicio.ejemplo.com/…"
														: "https://… o referencia segura del secreto"
												}
											/>
										</label>

										{!isSimple ? (
											<div>
												<p class="text-sm font-semibold text-slate-900">Permisos</p>
												<div class="mt-3 grid gap-2">
													{connector.availableScopes.map((scope) => (
														<label class="flex items-center gap-2 text-sm text-slate-700">
															<input
																type="checkbox"
																name="scopes"
																value={scope.key}
																checked={connector.scopes.includes(scope.key)}
																class="fastt-check-input h-4 w-4 rounded border-slate-300"
															/>
															<span>{scope.label}</span>
														</label>
													))}
												</div>
											</div>
										) : null}

										<div class="flex flex-wrap gap-2">
											<Button type="submit" size="sm" variant="secondary">
												Guardar
											</Button>
										</div>
									</div>
								</form>
							</Card>

							{!isSimple ? (
								<Card variant="plain" class="p-4">
									<p class="text-sm font-semibold text-slate-950">Requisitos</p>
									<ul class="mt-3 grid gap-2 text-sm text-slate-600">
										{connector.requirements.map((requirement) => (
											<li>{requirement}</li>
										))}
									</ul>
									<div class="mt-4 border-t border-slate-200 pt-4">
										<p class="text-sm font-semibold text-slate-950">Actividad reciente</p>
										<div class="mt-3 grid gap-2">
											{connector.logs.length ? (
												connector.logs.map((log) => (
													<Card variant="soft" class="p-3">
														<div class="flex items-center justify-between gap-3">
															<p class="text-xs font-semibold tracking-[0.1em] text-slate-500 uppercase">
																{log.eventType}
															</p>
															<Badge variant={log.status === "error" ? "error" : "neutral"}>
																{log.status === "error"
																	? "Error"
																	: log.status === "success"
																		? "Ok"
																		: log.status}
															</Badge>
														</div>
														<p class="mt-2 text-sm text-slate-700">
															{mapProviderIntegrationLogMessage(log.message)}
														</p>
														<p class="mt-1 text-xs text-slate-500">{formatDate(log.createdAt)}</p>
													</Card>
												))
											) : (
												<p class="text-sm text-slate-500">Sin eventos registrados.</p>
											)}
										</div>
									</div>
								</Card>
							) : (
								<ul class="grid gap-1 text-sm text-slate-600">
									{connector.requirements.slice(0, 2).map((requirement) => (
										<li>· {requirement}</li>
									))}
								</ul>
							)}
						</div>

						<div class="flex flex-wrap justify-end gap-2 border-t border-slate-200 pt-4">
							<form method="post" action={`/api/provider/integrations/${connector.key}/sync`}>
								<input type="hidden" name="uiMode" value={modeQuery} />
								<Button type="submit" size="sm" disabled={!canTest(connector)}>
									Probar conexión
								</Button>
							</form>
							<form method="post" action={`/api/provider/integrations/${connector.key}/revoke`}>
								<input type="hidden" name="uiMode" value={modeQuery} />
								<Button type="submit" variant="danger" size="sm" disabled={!canTest(connector)}>
									Revocar
								</Button>
							</form>
						</div>
					</div>
				</Card>
			))
		}
	</div>

	{
		isSimple ? (
			<p class="text-sm text-slate-600">
				¿Necesitas calendarios, webhooks o exportación contable?{" "}
				<a
					class="font-semibold text-slate-900 underline"
					href={`${routes.providerSettingsIntegrations()}?mode=pro`}
				>
					Abrir modo Pro
				</a>
			</p>
		) : null
	}
</ProviderSettingsLayout>
