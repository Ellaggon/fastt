---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Notice from "@/components/ui/Notice.astro"
import ProviderSettingsLayout from "@/layouts/ProviderSettingsLayout.astro"
import { getProviderSessionSurfaceFromRequest } from "@/lib/auth/providerSessionSurface"
import { logRoutePerformance } from "@/lib/observability/performanceLog"
import { createServerTimingRecorder } from "@/lib/observability/serverTiming"
import { routes } from "@/lib/routes"
import { getProviderFullAggregate } from "@/modules/catalog/public"

const startedAt = performance.now()
const timing = createServerTimingRecorder()

const providerSession = await timing.time("authProvider", () =>
	getProviderSessionSurfaceFromRequest(Astro.request)
)
if (!providerSession) return Astro.redirect("/SignInPage")
const user = { id: providerSession.userId, email: "" }
const providerId = providerSession.providerId

const aggregate = await timing.time("providerAggregate", () =>
	getProviderFullAggregate(providerId, user.id)
)
const providerBase = aggregate?.provider ?? null
const blockers: any[] = []
const risks: any[] = []
const capabilities = {
	publish: false,
	booking: false,
	payments: false,
	integrations: false,
}
const counts = {
	documents: 0,
	verifiedDocuments: 0,
	paymentAccounts: 0,
	verifiedPaymentAccounts: 0,
	integrations: 0,
	connectedIntegrations: 0,
	auditEvents: 0,
	teamMembers: 0,
}
const progressPercent = 0
const progressLabel = "Cargando estado operativo..."
const providerName = String(providerBase?.displayName || providerBase?.legalName || "Proveedor")

const professionalToolsEnabled = providerSession.professionalToolsEnabled
const professionalToolsUpdatedAt: Date | null = null

const professionalToolsParam = String(Astro.url.searchParams.get("professionalTools") ?? "").trim()
const professionalToolsSaved = professionalToolsParam === "saved"
const professionalToolsError = professionalToolsParam === "error"
function formatProfessionalToolsUpdatedLabel(value: Date | null) {
	return value
		? value.toLocaleDateString("es-BO", {
				day: "2-digit",
				month: "short",
				year: "numeric",
			})
		: "Sin cambios aún"
}
const professionalToolsUpdatedLabel = formatProfessionalToolsUpdatedLabel(
	professionalToolsUpdatedAt
)

timing.addTotal("providerSettingsPage")
timing.setHeader(Astro.response.headers)
logRoutePerformance({
	name: "provider-settings-page",
	request: Astro.request,
	url: Astro.url,
	status: 200,
	startedAt,
	timing,
	userId: user.id,
	providerId,
})
---

<ProviderSettingsLayout
	title="Configuración del proveedor"
	heading="Resumen de configuración"
	description="Centro de control para identidad, cumplimiento, fiscalidad, integraciones, equipo y permisos."
>
	<div slot="actions" class="flex flex-wrap gap-3">
		<Button href={routes.providerSettingsProfile()} data-settings-primary-cta>
			Continuar configuración
		</Button>
	</div>

	{
		professionalToolsSaved ? (
			<Notice variant="success" title="Herramientas profesionales actualizadas">
				El sidebar se ajustará según la preferencia del proveedor, escala y rol.
			</Notice>
		) : null
	}
	{
		professionalToolsError ? (
			<Notice variant="warning" title="No se pudo actualizar">
				Revisa que la migración de preferencias del proveedor esté aplicada.
			</Notice>
		) : null
	}

	<section class="grid gap-4 xl:grid-cols-[0.9fr_1.1fr]">
		<Card class="border-slate-800 bg-slate-950 text-white">
			<div class="space-y-5">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div>
						<p class="text-sm text-slate-400">Proveedor</p>
						<h2 class="mt-1 text-2xl font-semibold text-white" data-settings-provider-name>
							{providerName}
						</h2>
					</div>
					<Badge variant={blockers.length ? "warning" : "neutral"} data-settings-base-badge>
						{blockers.length ? "Con bloqueos" : "Base lista"}
					</Badge>
				</div>
				<div class="h-2 overflow-hidden rounded-full bg-slate-800">
					<div
						class="h-full bg-white"
						style={`width: ${Math.max(0, Math.min(100, progressPercent))}%`}
						data-settings-progress-bar
					>
					</div>
				</div>
				<p class="text-sm leading-6 text-slate-300" data-settings-progress-label>
					{progressLabel}
				</p>
			</div>
		</Card>

		<div class="grid gap-4 md:grid-cols-2">
			<Card>
				<p class="text-sm font-semibold text-slate-950">Bloqueos</p>
				<p class="mt-2 text-3xl font-semibold text-slate-950" data-settings-blockers-count>
					{blockers.length}
				</p>
				<p class="mt-2 text-sm leading-6 text-slate-600">
					Elementos que impiden considerar completa la configuración base.
				</p>
			</Card>
			<Card>
				<p class="text-sm font-semibold text-slate-950">Riesgos</p>
				<p class="mt-2 text-3xl font-semibold text-slate-950" data-settings-risks-count>
					{risks.length}
				</p>
				<p class="mt-2 text-sm leading-6 text-slate-600">
					Alertas que no bloquean todo, pero conviene revisar antes de escalar.
				</p>
			</Card>
		</div>
	</section>

	<section class="grid gap-4 md:grid-cols-4">
		<Card>
			<p class="text-sm font-semibold text-slate-950">Publicación</p>
			<Badge
				class="mt-3"
				variant={capabilities.publish ? "success" : "neutral"}
				data-capability="publish"
			>
				{capabilities.publish ? "Habilitada" : "Bloqueada"}
			</Badge>
		</Card>
		<Card>
			<p class="text-sm font-semibold text-slate-950">Reservas</p>
			<Badge
				class="mt-3"
				variant={capabilities.booking ? "success" : "neutral"}
				data-capability="booking"
			>
				{capabilities.booking ? "Habilitadas" : "Bloqueadas"}
			</Badge>
		</Card>
		<Card>
			<p class="text-sm font-semibold text-slate-950">Cobros</p>
			<Badge
				class="mt-3"
				variant={capabilities.payments ? "success" : "neutral"}
				data-capability="payments"
			>
				{capabilities.payments ? "Habilitados" : "Bloqueados"}
			</Badge>
		</Card>
		<Card>
			<p class="text-sm font-semibold text-slate-950">Integraciones</p>
			<Badge
				class="mt-3"
				variant={capabilities.integrations ? "success" : "neutral"}
				data-capability="integrations"
			>
				{capabilities.integrations ? "Listas" : "Sin activar"}
			</Badge>
		</Card>
	</section>

	<div data-settings-deferred-root class="space-y-4"></div>

	<section class="grid gap-4 md:grid-cols-4">
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Documentos</p>
			<p class="mt-2 text-2xl font-semibold text-slate-950" data-count="documents">
				{Number(counts.verifiedDocuments ?? 0)} / {Number(counts.documents ?? 0)}
			</p>
		</Card>
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
				Cuentas de pago
			</p>
			<p class="mt-2 text-2xl font-semibold text-slate-950" data-count="paymentAccounts">
				{Number(counts.verifiedPaymentAccounts ?? 0)} / {Number(counts.paymentAccounts ?? 0)}
			</p>
		</Card>
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Conectores</p>
			<p class="mt-2 text-2xl font-semibold text-slate-950" data-count="integrations">
				{Number(counts.connectedIntegrations ?? 0)} / {Number(counts.integrations ?? 0)}
			</p>
		</Card>
		<Card variant="soft" class="bg-white">
			<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Auditoría</p>
			<p class="mt-2 text-2xl font-semibold text-slate-950" data-count="auditEvents">
				{Number(counts.auditEvents ?? 0)}
			</p>
		</Card>
	</section>

	<section class="space-y-4">
		<header class="space-y-1">
			<h2 class="text-lg font-semibold text-slate-950">Preferencias del espacio de trabajo</h2>
			<p class="text-sm text-slate-600">
				Preferencias que cambian cómo se organiza el sidebar y las herramientas visibles.
			</p>
		</header>
		<Card>
			<form method="post" action="/api/provider/preferences/professional-tools" class="space-y-5">
				<input type="hidden" name="returnTo" value={routes.providerSettings()} />
				<div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
					<div class="max-w-2xl space-y-2">
						<div class="flex flex-wrap items-center gap-3">
							<h2 class="text-xl font-semibold text-slate-900">Herramientas profesionales</h2>
							<Badge variant={professionalToolsEnabled ? "success" : "neutral"}>
								{professionalToolsEnabled ? "Activadas" : "Desactivadas"}
							</Badge>
						</div>
						<p class="text-sm leading-6 text-slate-600">
							Activa herramientas para manejar muchas tarifas, reglas, inventario físico y
							operaciones masivas.
						</p>
						<p class="text-sm leading-6 text-slate-600">
							Recomendado si administras varios hoteles, muchas habitaciones o reglas recurrentes.
						</p>
						<p class="text-xs text-slate-500">
							Última actualización: {professionalToolsUpdatedLabel}
						</p>
					</div>
					<div
						class="fastt-tabs min-w-[220px] border border-slate-200 bg-white p-1 text-sm font-semibold text-slate-700 shadow-sm"
						role="radiogroup"
						aria-label="Modo de experiencia"
					>
						<label class="block">
							<input
								type="radio"
								name="mode"
								value="simple"
								checked={!professionalToolsEnabled}
								class="peer sr-only fastt-check-input"
							/>
							<span
								class="fastt-tab block cursor-pointer px-4 py-2 text-center text-slate-600 transition peer-checked:bg-slate-950 peer-checked:text-white"
							>
								Simple
							</span>
						</label>
						<label class="mt-1 block">
							<input
								type="radio"
								name="mode"
								value="professional"
								checked={professionalToolsEnabled}
								class="peer sr-only fastt-check-input"
							/>
							<span
								class="fastt-tab block cursor-pointer px-4 py-2 text-center text-slate-600 transition peer-checked:bg-slate-950 peer-checked:text-white"
							>
								Pro
							</span>
						</label>
					</div>
				</div>
				<Card variant="soft">
					<p class="text-sm font-semibold text-slate-900">Modo Simple</p>
					<p class="mt-1 text-sm leading-6 text-slate-600">
						Muestra la operación diaria: Tarifas y Calendario. El contrato se completa dentro de
						cada tarifa.
					</p>
					<p class="mt-3 text-sm font-semibold text-slate-900">Modo Pro</p>
					<p class="mt-1 text-sm leading-6 text-slate-600">
						El sidebar puede mostrar Reglas de venta y herramientas profesionales. Las operaciones
						de cupo y disponibilidad siguen dentro de Calendario.
					</p>
				</Card>
				<div class="flex justify-end">
					<Button type="submit">Guardar preferencia</Button>
				</div>
			</form>
		</Card>
	</section>

	<script>
		import "@/pages/provider/settings/_client/settings-summary-hydration.js"
	</script>
</ProviderSettingsLayout>
