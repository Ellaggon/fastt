---
import ProviderInviteLifecycleStepper from "@/components/provider/ProviderInviteLifecycleStepper.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Input from "@/components/ui/Input.astro"
import Notice from "@/components/ui/Notice.astro"
import Select from "@/components/ui/Select.astro"
import ProviderSettingsLayout from "@/layouts/ProviderSettingsLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import {
	buildInviteLifecycleProgress,
	formatProviderRoleLabel,
	providerInviteLifecycleSteps,
	providerRoleDescriptions,
	providerRoleLabels,
} from "@/lib/provider-permissions"
import { routes } from "@/lib/routes"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

const summaryRes = await fetch(new URL("/api/provider/settings/summary", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const summary = summaryRes.ok ? await summaryRes.json() : null
const users = Array.isArray(summary?.users) ? summary.users : []
const invitations = Array.isArray(summary?.invitations) ? summary.invitations : []
const permissions = summary?.permissions ?? {}
const rolePermissions = Array.isArray(summary?.rolePermissions) ? summary.rolePermissions : []
const result = Astro.url.searchParams.get("result")
const error = Astro.url.searchParams.get("error")
const pendingInvitations = invitations.filter((invitation: any) => invitation.status === "pending")
const permissionLabels = [
	["canEditProfile", "Perfil"],
	["canManageFiscality", "Fiscalidad"],
	["canManagePayments", "Pagos"],
	["canManageIntegrations", "Integraciones"],
	["canManageDocuments", "Documentos"],
	["canInviteTeam", "Equipo"],
]

const resultMessages: Record<string, { title: string; body: string }> = {
	invited: {
		title: "Invitación creada",
		body: "Quedó pendiente de aceptación. La persona debe unirse con ese correo antes de que expire (14 días). Mientras tanto verás el estado en Invitaciones pendientes.",
	},
	canceled: {
		title: "Invitación cancelada",
		body: "La invitación ya no se puede aceptar. Puedes crear una nueva si hace falta.",
	},
	resent: {
		title: "Invitación reenviada",
		body: "Extendimos el plazo de aceptación 14 días más desde ahora.",
	},
}

const errorMessages: Record<string, string> = {
	duplicate_pending_invitation: "Ya hay una invitación pendiente para ese correo.",
	forbidden: "Tu rol no permite gestionar invitaciones.",
	not_found: "No encontramos esa invitación.",
	not_pending: "Esa invitación ya no está pendiente.",
	validation_error: "Revisa el correo y el rol e inténtalo de nuevo.",
}

function roleLabelFor(userOrInvite: { role?: string; roleLabel?: string }) {
	return userOrInvite.roleLabel || formatProviderRoleLabel(userOrInvite.role)
}
---

<ProviderSettingsLayout
	title="Equipo y permisos"
	heading="Equipo"
	description="Invita personas, elige un rol comprensible y controla qué pueden cambiar en la configuración del proveedor."
>
	{
		result && resultMessages[result] ? (
			<Notice variant="success" title={resultMessages[result].title}>
				{resultMessages[result].body}
			</Notice>
		) : null
	}
	{
		error ? (
			<Notice variant="warning" title="No se pudo completar la acción">
				{errorMessages[error] || "Revisa los datos e inténtalo de nuevo."}
			</Notice>
		) : null
	}

	<Notice variant="info" title="Ciclo de la invitación">
		<div class="grid gap-3 sm:grid-cols-4">
			{
				providerInviteLifecycleSteps.map((step, index) => (
					<div>
						<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">
							{index + 1}. {step.label}
						</p>
						<p class="mt-1 text-sm leading-6 text-slate-700">{step.description}</p>
					</div>
				))
			}
		</div>
	</Notice>

	<div class="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
		<Card>
			<div class="space-y-4">
				<div>
					<h2 class="text-xl font-semibold text-slate-950">Miembros activos</h2>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						Personas que ya tienen acceso al proveedor.
					</p>
				</div>
				<div class="space-y-3">
					{
						users.length ? (
							users.map((user: any) => (
								<Card variant="soft" class="flex items-center justify-between gap-4">
									<div>
										<p class="text-sm font-semibold text-slate-950">{user.email}</p>
										<p class="mt-1 text-sm text-slate-600">Rol: {roleLabelFor(user)}</p>
										{user.permissions && (
											<div class="mt-3 flex flex-wrap gap-2">
												{permissionLabels.map(([key, label]) => (
													<Badge variant={user.permissions[key] ? "success" : "neutral"}>
														{label}: {user.permissions[key] ? "Sí" : "No"}
													</Badge>
												))}
											</div>
										)}
									</div>
									<Badge variant="success">Activo</Badge>
								</Card>
							))
						) : (
							<Card variant="soft" class="space-y-2 text-sm text-slate-600">
								<p class="font-semibold text-slate-950">Invita a tu equipo</p>
								<p>
									Todavía no hay miembros listados. Usa el formulario de la derecha para sumar a la
									primera persona.
								</p>
							</Card>
						)
					}
				</div>
			</div>
		</Card>

		<Card>
			{
				permissions.canInviteTeam ? (
					<form class="space-y-4" method="post" action="/api/provider/settings/invitations">
						<div>
							<h2 class="text-xl font-semibold text-slate-950">Invitar persona</h2>
							<p class="mt-2 text-sm leading-6 text-slate-600">
								Paso 1 del ciclo: crea la invitación. Caduca en 14 días si no se acepta.
							</p>
						</div>
						<label class="grid gap-2 text-sm font-medium text-slate-700">
							Correo
							<Input type="email" name="email" placeholder="persona@empresa.com" required />
						</label>
						<label class="grid gap-2 text-sm font-medium text-slate-700">
							Rol
							<Select name="role" required>
								<option value="admin">{providerRoleLabels.admin}</option>
								<option value="staff">{providerRoleLabels.staff}</option>
							</Select>
						</label>
						<p class="text-xs leading-5 text-slate-500">
							<strong>{providerRoleLabels.admin}:</strong> {providerRoleDescriptions.admin}
							<br />
							<strong>{providerRoleLabels.staff}:</strong> {providerRoleDescriptions.staff}
						</p>
						<Button type="submit">Enviar invitación</Button>
					</form>
				) : (
					<div class="space-y-4">
						<h2 class="text-xl font-semibold text-slate-950">Invitaciones</h2>
						<p class="text-sm leading-6 text-slate-600">
							Tu rol actual no permite invitar ni cancelar miembros del equipo. Pide ayuda al
							propietario.
						</p>
					</div>
				)
			}
		</Card>
	</div>

	<Card>
		<div class="space-y-4">
			<div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<h2 class="text-xl font-semibold text-slate-950">Invitaciones pendientes</h2>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						Esperando aceptación (paso 3). Si expiran, crea una nueva invitación.
					</p>
				</div>
				<Badge variant={pendingInvitations.length ? "warning" : "success"}>
					{pendingInvitations.length} pendiente{pendingInvitations.length === 1 ? "" : "s"}
				</Badge>
			</div>
			<div class="space-y-3">
				{
					pendingInvitations.length ? (
						pendingInvitations.map((invitation: any) => {
							const progress = buildInviteLifecycleProgress({
								status: invitation.status,
								expiresAt: invitation.expiresAt,
								acceptedAt: invitation.acceptedAt,
							})
							return (
								<Card variant="soft" class="space-y-4">
									<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
										<div>
											<p class="text-sm font-semibold text-slate-950">{invitation.email}</p>
											<p class="mt-1 text-sm text-slate-600">
												{invitation.statusLabel || "Pendiente de aceptación"} ·{" "}
												{progress.phaseLabel} · Rol: {roleLabelFor(invitation)} · Expira:{" "}
												{new Date(invitation.expiresAt).toLocaleDateString("es-BO")}
											</p>
										</div>
										{permissions.canInviteTeam && (
											<div class="flex flex-wrap gap-2">
												{progress.canResend && (
													<form method="post" action="/api/provider/settings/invitations">
														<input type="hidden" name="action" value="resend" />
														<input type="hidden" name="id" value={invitation.id} />
														<Button type="submit" variant="secondary" size="sm" data-invite-resend>
															Reenviar invitación
														</Button>
													</form>
												)}
												<form method="post" action="/api/provider/settings/invitations">
													<input type="hidden" name="action" value="cancel" />
													<input type="hidden" name="id" value={invitation.id} />
													<Button type="submit" variant="secondary" size="sm">
														Cancelar invitación
													</Button>
												</form>
											</div>
										)}
									</div>
									<ProviderInviteLifecycleStepper progress={progress} compact />
								</Card>
							)
						})
					) : (
						<Card variant="soft" class="space-y-2 text-sm text-slate-600">
							<p class="font-semibold text-slate-950">Sin invitaciones en curso</p>
							<p>Cuando invites a alguien, aparecerá aquí hasta que acepte o cancele / expire.</p>
						</Card>
					)
				}
			</div>
		</div>
	</Card>

	<Card>
		<div class="space-y-4">
			<h2 class="text-xl font-semibold text-slate-950">Tus permisos</h2>
			<div class="grid gap-3 text-sm text-slate-600 sm:grid-cols-2 lg:grid-cols-3">
				<p>Editar perfil: {permissions.canEditProfile ? "habilitado" : "restringido"}</p>
				<p>Fiscalidad: {permissions.canManageFiscality ? "habilitado" : "restringido"}</p>
				<p>Pagos: {permissions.canManagePayments ? "habilitado" : "restringido"}</p>
				<p>Integraciones: {permissions.canManageIntegrations ? "habilitado" : "restringido"}</p>
				<p>Documentos: {permissions.canManageDocuments ? "habilitado" : "restringido"}</p>
				<p>Invitar equipo: {permissions.canInviteTeam ? "habilitado" : "restringido"}</p>
			</div>
		</div>
	</Card>

	<Card>
		<details class="space-y-4">
			<summary class="cursor-pointer text-xl font-semibold text-slate-950">
				Qué puede cada rol
			</summary>
			<p class="text-sm leading-6 text-slate-600">
				Resumen por rol humano. No cambia la matriz técnica de permisos.
			</p>
			<div class="overflow-x-auto">
				<table class="min-w-full text-left text-sm">
					<thead
						class="border-b border-slate-200 text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase"
					>
						<tr>
							<th class="py-3 pr-4">Rol</th>
							<th class="py-3 pr-4">Perfil</th>
							<th class="py-3 pr-4">Fiscalidad</th>
							<th class="py-3 pr-4">Pagos</th>
							<th class="py-3 pr-4">Integraciones</th>
							<th class="py-3 pr-4">Documentos</th>
							<th class="py-3 pr-4">Equipo</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-slate-200">
						{
							rolePermissions.map((role: any) => (
								<tr>
									<td class="py-3 pr-4">
										<p class="font-semibold text-slate-950">{role.label}</p>
										{role.description ? (
											<p class="mt-1 text-xs leading-5 text-slate-500">{role.description}</p>
										) : null}
									</td>
									<td class="py-3 pr-4">
										<Badge variant={role.canEditProfile ? "success" : "neutral"}>
											{role.canEditProfile ? "Sí" : "No"}
										</Badge>
									</td>
									<td class="py-3 pr-4">
										<Badge variant={role.canManageFiscality ? "success" : "neutral"}>
											{role.canManageFiscality ? "Sí" : "No"}
										</Badge>
									</td>
									<td class="py-3 pr-4">
										<Badge variant={role.canManagePayments ? "success" : "neutral"}>
											{role.canManagePayments ? "Sí" : "No"}
										</Badge>
									</td>
									<td class="py-3 pr-4">
										<Badge variant={role.canManageIntegrations ? "success" : "neutral"}>
											{role.canManageIntegrations ? "Sí" : "No"}
										</Badge>
									</td>
									<td class="py-3 pr-4">
										<Badge variant={role.canManageDocuments ? "success" : "neutral"}>
											{role.canManageDocuments ? "Sí" : "No"}
										</Badge>
									</td>
									<td class="py-3 pr-4">
										<Badge variant={role.canInviteTeam ? "success" : "neutral"}>
											{role.canInviteTeam ? "Sí" : "No"}
										</Badge>
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</details>
	</Card>
</ProviderSettingsLayout>
