---
import ProviderProfileForm from "@/components/provider/ProviderProfileForm.astro"
import ProviderRegisterForm from "@/components/provider/ProviderRegisterForm.astro"
import ProviderVerificationView from "@/components/provider/ProviderVerificationView.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProviderProfessionalToolsPreference } from "@/lib/providerProfessionalToolsPreference"
import { getProviderFullAggregate } from "@/modules/catalog/public"

type ProviderStep = "register" | "profile" | "verification" | null
type ProviderAggregate = NonNullable<Awaited<ReturnType<typeof getProviderFullAggregate>>>

let providerId: string | null = null
let userId: string | null = null
let authError: Response | null = null
let loadError: string | null = null

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const stepParam = String(Astro.url.searchParams.get("step") ?? "").trim()
const currentStep: ProviderStep =
	stepParam === "register" || stepParam === "profile" || stepParam === "verification"
		? stepParam
		: null
const isStepView =
	currentStep === "register" || currentStep === "profile" || currentStep === "verification"

try {
	const auth = await requireProvider(Astro.request)
	providerId = auth.providerId
	userId = auth.user.id
} catch (error: unknown) {
	if (error instanceof Response) authError = error
	else loadError = "No pudimos cargar su sesión de proveedor."
}

if (authError?.status === 401) return Astro.redirect("/SignInPage")
if (authError?.status === 403 && currentStep !== "register")
	return Astro.redirect("/provider?step=register")
if (authError?.status && authError.status !== 401 && authError.status !== 403) {
	loadError = "No pudimos autorizar esta sesión de proveedor."
}

userId = user.id

const successParam = String(Astro.url.searchParams.get("success") ?? "").trim()
const showSuccess = successParam === "saved" || successParam === "updated"
const errorParam = String(Astro.url.searchParams.get("error") ?? "").trim()
const providerErrorMessages: Record<string, string> = {
	invalid_method: "La acción no se envió correctamente. Intenta guardar nuevamente.",
	session_expired: "Tu sesión no se pudo validar. Vuelve a iniciar sesión e intenta de nuevo.",
	provider_not_found:
		"No pudimos asociar esta sesión con tu proveedor. Intenta cerrar sesión y volver a entrar.",
	validation_error: "Revisa los campos obligatorios antes de guardar.",
	save_failed: "No pudimos guardar la identidad del proveedor en este momento.",
}
const providerErrorMessage = providerErrorMessages[errorParam] ?? null

let provider: ProviderAggregate["provider"] | null = null
let profile: ProviderAggregate["profile"] | null = null
let latestVerification: ProviderAggregate["latestVerification"] | null = null
let professionalToolsEnabled = false
let professionalToolsUpdatedAt: Date | null = null

if (isStepView && userId && providerId && !loadError) {
	try {
		const aggregate = await getProviderFullAggregate(providerId, userId)
		provider = aggregate?.provider ?? null
		profile = aggregate?.profile ?? null
		latestVerification = aggregate?.latestVerification ?? null
	} catch {
		loadError = "No pudimos cargar los datos del proveedor en este momento."
	}
}

if (!isStepView && providerId && !loadError) {
	try {
		const preferences = await getProviderProfessionalToolsPreference(providerId)
		professionalToolsEnabled = preferences.professionalToolsEnabled
		professionalToolsUpdatedAt = preferences.updatedAt
	} catch {
		professionalToolsEnabled = false
		professionalToolsUpdatedAt = null
	}
}

const professionalToolsParam = String(Astro.url.searchParams.get("professionalTools") ?? "").trim()
const professionalToolsSaved = professionalToolsParam === "saved"
const professionalToolsError = professionalToolsParam === "error"
const professionalToolsUpdatedLabel = professionalToolsUpdatedAt
	? professionalToolsUpdatedAt.toLocaleDateString("es-BO", {
			day: "2-digit",
			month: "short",
			year: "numeric",
		})
	: "Sin cambios registrados"
---

<WorkspaceLayout title="Proveedor">
	<section class="space-y-8 text-slate-200">
		{
			showSuccess && (
				<Card>
					<div class="flex items-center justify-between gap-4">
						<div class="space-y-1">
							<p class="text-lg font-semibold text-slate-900">Guardado</p>
							<p class="text-sm text-slate-600">
								La información del proveedor se actualizó correctamente.
							</p>
						</div>
						<Badge variant="success">Guardado</Badge>
					</div>
				</Card>
			)
		}
		{
			providerErrorMessage && (
				<Card>
					<div class="flex items-center justify-between gap-4">
						<div class="space-y-1">
							<p class="text-lg font-semibold text-slate-900">No se pudo guardar</p>
							<p class="text-sm text-slate-600">{providerErrorMessage}</p>
						</div>
						<Badge variant="error">Error</Badge>
					</div>
				</Card>
			)
		}
		{
			professionalToolsSaved && (
				<Card>
					<div class="flex items-center justify-between gap-4">
						<div class="space-y-1">
							<p class="text-lg font-semibold text-slate-900">
								Herramientas profesionales actualizadas
							</p>
							<p class="text-sm text-slate-600">
								El sidebar se ajustará según la preferencia del proveedor, escala y rol.
							</p>
						</div>
						<Badge variant="success">Guardado</Badge>
					</div>
				</Card>
			)
		}
		{
			professionalToolsError && (
				<Card>
					<div class="flex items-center justify-between gap-4">
						<div class="space-y-1">
							<p class="text-lg font-semibold text-slate-900">No se pudo actualizar</p>
							<p class="text-sm text-slate-600">
								Revisa que la migración de preferencias del proveedor esté aplicada.
							</p>
						</div>
						<Badge variant="error">Error</Badge>
					</div>
				</Card>
			)
		}

		{
			loadError && (
				<Card>
					<div class="space-y-4">
						<div class="flex items-center justify-between gap-4">
							<div class="space-y-1">
								<p class="text-2xl font-semibold text-slate-900">Ocurrió un error de carga</p>
								<p class="text-sm text-slate-600">{loadError}</p>
							</div>
							<Badge variant="error">Error</Badge>
						</div>
						<Button href="/provider?step=register">Abrir configuración</Button>
					</div>
				</Card>
			)
		}

		{
			currentStep === "register" && (
				<ProviderRegisterForm provider={provider} hasProvider={Boolean(provider)} />
			)
		}
		{
			currentStep === "profile" && (
				<ProviderProfileForm isProviderAvailable={Boolean(provider)} profile={profile} />
			)
		}
		{
			currentStep === "verification" && (
				<ProviderVerificationView latestVerification={latestVerification} />
			)
		}

		{
			!isStepView && !loadError && (
				<>
					<header class="space-y-6">
						<div class="flex flex-wrap items-start justify-between gap-6">
							<div class="space-y-2">
								<h1
									id="providerTitle"
									class="text-3xl font-semibold tracking-wide text-slate-100 uppercase"
								>
									Cargando proveedor...
								</h1>
								<p id="providerProgressMessage" class="text-sm text-slate-300">
									Cargando estado de configuración...
								</p>
								<p id="providerOwnerEmail" class="text-xs text-slate-400">
									Propietario: —
								</p>
							</div>
							<div class="flex items-center gap-3">
								<Badge id="providerStateBadge" variant="neutral">
									Cargando...
								</Badge>
								<Button id="providerPrimaryAction" href="/provider?step=register">
									Cargando...
								</Button>
							</div>
						</div>
					</header>

					<section class="space-y-4">
						<Card class="min-h-[130px] border-slate-800 bg-slate-950 text-white">
							<div class="space-y-4">
								<h2 class="text-xl font-semibold text-white">
									Lista de verificación de activación
								</h2>
								<div class="h-2 w-full overflow-hidden rounded-full bg-slate-700">
									<div id="providerProgressBar" class="h-full w-0 bg-white" />
								</div>
								<p id="providerProgressDescription" class="text-sm text-slate-200">
									Cargando progreso...
								</p>
							</div>
						</Card>

						<div class="space-y-4">
							<Card class="min-h-[220px]">
								<div class="space-y-6">
									<div class="flex items-start justify-between gap-4">
										<div class="space-y-1">
											<h2 class="text-xl font-semibold text-slate-900">Identidad del proveedor</h2>
											<p class="text-sm text-slate-600">Nombre comercial y razón social.</p>
										</div>
										<div class="flex items-center gap-3">
											<Badge id="providerIdentityBadge" variant="warning">
												Cargando...
											</Badge>
											<Button href="/provider?step=register">Editar</Button>
										</div>
									</div>
									<div class="grid gap-4 md:grid-cols-2">
										<div class="space-y-2">
											<p class="text-sm text-slate-500">Nombre comercial</p>
											<p id="providerDisplayName" class="text-sm text-slate-900">
												—
											</p>
										</div>
										<div class="space-y-2 md:col-span-2">
											<p class="text-sm text-slate-500">Razón social</p>
											<p id="providerLegalName" class="text-sm text-slate-900">
												—
											</p>
										</div>
									</div>
								</div>
							</Card>

							<Card class="min-h-[244px]">
								<div class="space-y-6">
									<div class="flex items-start justify-between gap-4">
										<div class="space-y-1">
											<h2 class="text-xl font-semibold text-slate-900">Perfil operativo</h2>
											<p class="text-sm text-slate-600">
												Zona horaria, moneda por defecto y contacto de soporte.
											</p>
										</div>
										<div class="flex items-center gap-3">
											<Badge id="providerProfileBadge" variant="warning">
												Cargando...
											</Badge>
											<Button href="/provider?step=profile">Editar</Button>
										</div>
									</div>
									<div class="grid gap-4 md:grid-cols-2">
										<div class="space-y-2">
											<p class="text-sm text-slate-500">Zona horaria</p>
											<p id="providerTimezone" class="text-sm text-slate-900">
												—
											</p>
										</div>
										<div class="space-y-2">
											<p class="text-sm text-slate-500">Moneda por defecto</p>
											<p id="providerCurrency" class="text-sm text-slate-900">
												—
											</p>
										</div>
										<div class="space-y-2 md:col-span-2">
											<p class="text-sm text-slate-500">Correo de soporte</p>
											<p id="providerSupportEmail" class="text-sm text-slate-900">
												—
											</p>
										</div>
									</div>
								</div>
							</Card>

							<Card class="min-h-[220px]">
								<div class="space-y-6">
									<div class="flex items-start justify-between gap-4">
										<div class="space-y-1">
											<h2 class="text-xl font-semibold text-slate-900">Estado de verificación</h2>
											<p class="text-sm text-slate-600">Estado de verificación de solo lectura.</p>
										</div>
										<div class="flex items-center gap-3">
											<Badge id="providerVerificationBadge" variant="warning">
												Cargando...
											</Badge>
											<Button href="/provider?step=verification">Ver detalles</Button>
										</div>
									</div>
									<div class="grid gap-4 md:grid-cols-2">
										<div class="space-y-2">
											<p class="text-sm text-slate-500">Estado</p>
											<p id="providerVerificationStatus" class="text-sm text-slate-900">
												—
											</p>
										</div>
										<div class="space-y-2 md:col-span-2">
											<p class="text-sm text-slate-500">Motivo</p>
											<p id="providerVerificationReason" class="text-sm text-slate-900">
												—
											</p>
										</div>
									</div>
								</div>
							</Card>
						</div>
					</section>

					<section class="space-y-4">
						<header class="space-y-1">
							<h2 class="text-lg font-semibold text-slate-100">Configuración</h2>
							<p class="text-sm text-slate-300">
								Preferencias que cambian cómo se organiza el espacio de trabajo.
							</p>
						</header>
						<Card>
							<form
								method="post"
								action="/api/provider/preferences/professional-tools"
								class="space-y-5"
							>
								<div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
									<div class="max-w-2xl space-y-2">
										<div class="flex flex-wrap items-center gap-3">
											<h2 class="text-xl font-semibold text-slate-900">
												Herramientas profesionales
											</h2>
											<Badge variant={professionalToolsEnabled ? "success" : "neutral"}>
												{professionalToolsEnabled ? "Activadas" : "Desactivadas"}
											</Badge>
										</div>
										<p class="text-sm leading-6 text-slate-600">
											Activa herramientas para manejar muchas tarifas, reglas, inventario físico y
											operaciones masivas.
										</p>
										<p class="text-sm leading-6 text-slate-600">
											Recomendado si administras varios hoteles, muchas habitaciones o reglas
											recurrentes.
										</p>
										<p class="text-xs text-slate-500">
											Última actualización: {professionalToolsUpdatedLabel}
										</p>
									</div>
									<div
										class="fastt-tabs min-w-[220px] border border-slate-200 bg-white p-1 text-sm font-semibold text-slate-700 shadow-sm"
										role="radiogroup"
										aria-label="Modo de experiencia"
									>
										<label class="block">
											<input
												type="radio"
												name="mode"
												value="simple"
												checked={!professionalToolsEnabled}
												class="peer sr-only"
											/>
											<span class="fastt-tab block cursor-pointer px-4 py-2 text-center text-slate-600 transition peer-checked:bg-slate-950 peer-checked:text-white">
												Simple
											</span>
										</label>
										<label class="mt-1 block">
											<input
												type="radio"
												name="mode"
												value="professional"
												checked={professionalToolsEnabled}
												class="peer sr-only"
											/>
											<span class="fastt-tab block cursor-pointer px-4 py-2 text-center text-slate-600 transition peer-checked:bg-slate-950 peer-checked:text-white">
												Pro
											</span>
										</label>
									</div>
								</div>
								<div class="fastt-soft-box border border-slate-200 bg-slate-50 p-4">
									<p class="text-sm font-semibold text-slate-900">Modo Simple</p>
									<p class="mt-1 text-sm leading-6 text-slate-600">
										Muestra la operación diaria: Tarifas y Calendario. El contrato se completa
										dentro de cada tarifa.
									</p>
									<p class="mt-3 text-sm font-semibold text-slate-900">Modo Pro</p>
									<p class="mt-1 text-sm leading-6 text-slate-600">
										El sidebar puede mostrar Reglas de venta y herramientas profesionales. Las
										operaciones de cupo y disponibilidad siguen dentro de Calendario.
									</p>
								</div>
								<div class="flex justify-end">
									<Button type="submit">Guardar preferencia</Button>
								</div>
							</form>
						</Card>
					</section>

					<section class="space-y-4">
						<header class="space-y-1">
							<h2 class="text-lg font-semibold text-slate-100">Equipo y acceso</h2>
							<p class="text-sm text-slate-300">Usuarios vinculados al proveedor.</p>
						</header>
						<Card class="min-h-[164px]">
							<div class="space-y-3">
								<ul id="providerUsersList" class="space-y-2 text-sm text-slate-700">
									<li class="text-slate-500">Cargando usuarios...</li>
								</ul>
							</div>
						</Card>
					</section>
				</>
			)
		}
	</section>

	<script define:vars={{ isStepView, loadError }} is:inline>
		;(function () {
			if (isStepView || loadError) return
			const shellStart = performance.now()
			const logShellVisible = () => {
				console.debug("shell visible", {
					page: "provider-surface",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				logShellVisible()
			} else {
				document.addEventListener("DOMContentLoaded", logShellVisible, { once: true })
			}

			const setBadge = (id, complete) => {
				const el = document.getElementById(id)
				if (!el) return
				el.textContent = complete ? "✅ Completo" : "⚠️ Incompleto"
				el.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold ${
					complete
						? "border-emerald-200 bg-emerald-50 text-emerald-800"
						: "border-amber-200 bg-amber-50 text-amber-900"
				}`
			}

			const hydrationStart = performance.now()
			fetch("/api/internal/provider-summary", {
				headers: { accept: "application/json" },
			})
				.then(async (response) => {
					if (!response.ok) throw new Error(`provider_summary_${response.status}`)
					return await response.json()
				})
				.then((payload) => {
					const providerTitle = document.getElementById("providerTitle")
					const progressMessage = document.getElementById("providerProgressMessage")
					const ownerEmail = document.getElementById("providerOwnerEmail")
					const stateBadge = document.getElementById("providerStateBadge")
					const primaryAction = document.getElementById("providerPrimaryAction")
					const progressBar = document.getElementById("providerProgressBar")
					const progressDescription = document.getElementById("providerProgressDescription")
					const displayName = document.getElementById("providerDisplayName")
					const legalName = document.getElementById("providerLegalName")
					const timezone = document.getElementById("providerTimezone")
					const currency = document.getElementById("providerCurrency")
					const supportEmail = document.getElementById("providerSupportEmail")
					const verificationStatus = document.getElementById("providerVerificationStatus")
					const verificationReason = document.getElementById("providerVerificationReason")
					const usersList = document.getElementById("providerUsersList")

					if (providerTitle)
						providerTitle.textContent = String(payload?.provider?.displayName ?? "Proveedor")
					if (progressMessage)
						progressMessage.textContent = String(payload?.progress?.progressMessage ?? "")
					if (ownerEmail)
						ownerEmail.textContent = `Propietario: ${String(payload?.ownerEmail ?? "Sin vincular")}`

					if (stateBadge) {
						stateBadge.textContent = String(payload?.state?.stateLabel ?? "Borrador")
						stateBadge.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold ${
							payload?.state?.badgeVariant === "success"
								? "border-emerald-200 bg-emerald-50 text-emerald-800"
								: payload?.state?.badgeVariant === "info"
									? "border-sky-200 bg-sky-50 text-sky-800"
									: payload?.state?.badgeVariant === "warning"
										? "border-amber-200 bg-amber-50 text-amber-900"
										: "border-slate-200 bg-slate-100 text-slate-700"
						}`
					}

					if (primaryAction) {
						primaryAction.textContent = String(payload?.actions?.primaryCtaLabel ?? "Continuar")
						primaryAction.setAttribute(
							"href",
							String(payload?.actions?.primaryCtaAction ?? "/provider?step=register")
						)
					}

					const percent = Number(payload?.progress?.progressPercent ?? 0)
					if (progressBar) progressBar.style.width = `${Math.max(0, Math.min(100, percent))}%`
					if (progressDescription)
						progressDescription.textContent = `${Number(payload?.progress?.completedSteps ?? 0)} de ${Number(payload?.progress?.totalSteps ?? 0)} pasos completos`

					setBadge("providerIdentityBadge", Boolean(payload?.checks?.identityComplete))
					setBadge("providerProfileBadge", Boolean(payload?.checks?.operationalComplete))
					setBadge("providerVerificationBadge", Boolean(payload?.checks?.verificationComplete))

					if (displayName)
						displayName.textContent = String(payload?.provider?.displayName || "Falta completar")
					if (legalName)
						legalName.textContent = String(payload?.provider?.legalName || "Falta completar")
					if (timezone)
						timezone.textContent = String(payload?.profile?.timezone || "Falta completar")
					if (currency)
						currency.textContent = String(payload?.profile?.defaultCurrency || "Falta completar")
					if (supportEmail)
						supportEmail.textContent = String(payload?.profile?.supportEmail || "Falta completar")

					const verification = String(payload?.verification?.status ?? "pending")
					if (verificationStatus) {
						verificationStatus.textContent =
							verification === "approved" ? "Aprobado" : verification || "Pendiente"
					}
					if (verificationReason)
						verificationReason.textContent = String(
							payload?.verification?.reason || "Sin motivo informado"
						)

					if (usersList) {
						usersList.innerHTML = ""
						const users = Array.isArray(payload?.users) ? payload.users : []
						if (users.length === 0) {
							const li = document.createElement("li")
							li.className = "text-slate-500"
							li.textContent = "No hay usuarios vinculados."
							usersList.append(li)
						} else {
							for (const entry of users) {
								const li = document.createElement("li")
								li.className = "fastt-row-card flex items-center justify-between px-3 py-2"
								const email = document.createElement("span")
								email.className = "text-slate-700"
								email.textContent = String(entry?.email ?? "sin correo")
								const role = document.createElement("span")
								role.className =
									"inline-flex items-center rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-800"
								role.textContent =
									String(entry?.role ?? "member") === "owner" ? "Propietario" : "Miembro"
								li.append(email, role)
								usersList.append(li)
							}
						}
					}

					console.debug("data hydrated", {
						page: "provider-surface",
						durationMs: Number((performance.now() - hydrationStart).toFixed(1)),
					})
				})
				.catch(() => {
					const progressDescription = document.getElementById("providerProgressDescription")
					if (progressDescription) {
						progressDescription.textContent = "No se pudo cargar el resumen del proveedor."
					}
				})
		})()
	</script>
</WorkspaceLayout>
