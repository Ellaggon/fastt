---
import { routes } from "@/lib/routes"

const step = String(Astro.url.searchParams.get("step") ?? "").trim()

if (step === "register" || step === "profile") {
	return Astro.redirect(routes.providerSettingsProfile())
}

if (step === "verification") {
	return Astro.redirect(routes.providerSettingsVerification())
}

return Astro.redirect(routes.providerSettings())
---
