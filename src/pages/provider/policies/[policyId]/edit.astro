---
import PolicyBuilder from "@/components/policy/PolicyBuilder.astro"
import Button from "@/components/ui/Button.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import { routes } from "@/lib/routes"

const policyId = String(Astro.params.policyId ?? "").trim()
if (!policyId) return Astro.redirect("/provider/policies")

let providerId = ""
let userId = ""
try {
	const auth = await requireProvider(Astro.request)
	providerId = auth.providerId
	userId = auth.user.id
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

const sidebarData = await getProviderSidebarData(providerId, { userId })
const isProfessionalPolicies = sidebarData.disclosureMode !== "small-provider"

const policyRes = await fetch(new URL(`/api/policies/${policyId}`, Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})

if (policyRes.status === 404) return new Response("Condición no encontrada", { status: 404 })
if (!policyRes.ok) return new Response("No se pudo cargar la condición", { status: 500 })

const policy = (await policyRes.json()) as any
const policyRow = policy.policy ?? policy
const category = String(policy.group?.category ?? policy.category ?? policy.policyType ?? "").trim()
const policyGroupId = String(policy.group?.id ?? policyRow.groupId ?? policy.groupId ?? "").trim()
const policyRules = Array.isArray(policy.rules)
	? policy.rules
	: Array.isArray(policy.policyRules)
		? policy.policyRules
		: []
const cancellationTiers = Array.isArray(policy.tiers)
	? policy.tiers
	: Array.isArray(policy.cancellationTiers)
		? policy.cancellationTiers
		: []

const rules: Record<string, unknown> = {}
for (const rule of policyRules as any[]) {
	if (!rule?.ruleKey) continue
	rules[String(rule.ruleKey)] = rule.ruleValue
}

const initialValues = {
	category,
	name: policyRow.description ?? policy.description ?? "",
	policyPresetKey: policyRow.policyPresetKey ?? policy.policyPresetKey ?? "",
	stayLengthType: policyRow.stayLengthType ?? policy.stayLengthType ?? "any",
	gracePeriod: policyRow.gracePeriod ?? policy.gracePeriod ?? "",
	refundBasis: policyRow.refundBasis ?? policy.refundBasis ?? "",
	payoutBasis: policyRow.payoutBasis ?? policy.payoutBasis ?? "",
	localTimezone: policyRow.localTimezone ?? policy.localTimezone ?? "",
	legalOverrideFlags: policyRow.legalOverrideFlags ?? policy.legalOverrideFlags ?? undefined,
	rules,
	cancellationTiers,
}
---

<WorkspaceLayout title="Crear nueva versión">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Habitaciones y tarifas · Versionado de condiciones
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Crear nueva versión</h1>
				<p class="max-w-4xl text-sm leading-6 text-slate-300">
					Editar una condición crea una nueva versión contractual. La categoría y el grupo se
					mantienen bloqueados para proteger asignaciones e instantáneas ya generadas.
				</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.providerPolicies()} variant="secondary">Biblioteca</Button>
				<Button
					href={`/provider/policies/groups/${encodeURIComponent(policyGroupId)}/audit`}
					variant="secondary"
				>
					Auditoría
				</Button>
				<Button href={routes.ratePlansList()} variant="primary">Tarifas</Button>
			</div>
		</header>

		<div class="rounded-lg border border-blue-200 bg-blue-50 p-3 text-sm text-blue-950">
			<p class="font-semibold">Responsabilidad contractual</p>
			<p class="mt-1">
				Las condiciones definen contrato huésped-proveedor: cancelación, pago, no presentación e
				ingreso/salida. Las promociones o descuentos pertenecen a precios; las reglas de
				comportamiento pertenecen a Reglas para huéspedes.
			</p>
		</div>

		<PolicyBuilder
			mode="version"
			initialValues={initialValues}
			previousPolicyId={policyId}
			policyGroupId={policyGroupId}
			showTechnicalAdvanced={isProfessionalPolicies}
		/>
	</div>
</WorkspaceLayout>
