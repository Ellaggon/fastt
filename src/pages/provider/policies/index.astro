---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { routes } from "@/lib/routes"

// Provider-only page. If unauthenticated or no provider, redirect to existing flows.
try {
	await requireProvider(Astro.request)
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

const res = await fetch(new URL("/api/policies/list-active", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const policies = res.ok ? ((await res.json()) as any[]) : []
const success = String(Astro.url.searchParams.get("success") ?? "").trim()

const categories = ["Cancellation", "Payment", "CheckIn", "NoShow"]
const byCategory: Record<string, any[]> = {}
for (const c of categories) byCategory[c] = []
for (const p of policies) {
	const c = String(p.category ?? "")
	if (!byCategory[c]) continue
	byCategory[c].push(p)
}

// Keep only the latest active version per group within each category (provider UX).
for (const c of categories) {
	const latestByGroup = new Map<string, any>()
	for (const p of byCategory[c]) {
		const gid = String(p.groupId ?? "")
		const prev = latestByGroup.get(gid)
		if (!prev || Number(p.version ?? 0) > Number(prev.version ?? 0)) {
			latestByGroup.set(gid, p)
		}
	}
	byCategory[c] = Array.from(latestByGroup.values()).sort((a, b) =>
		String(a.description ?? "").localeCompare(String(b.description ?? ""))
	)
}
---

<WorkspaceLayout title="Booking Policies">
	<main class="min-h-screen text-slate-200">
		<div class="mx-auto max-w-7xl space-y-8 px-6">
			<header class="flex flex-wrap items-start justify-between gap-4">
				<div class="space-y-2">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
						Rooms & Rates · Booking Contract
					</p>
					<h1 class="text-3xl font-semibold text-slate-100">Booking Policies</h1>
					<p class="max-w-4xl text-sm leading-6 text-slate-300">
						Biblioteca de condiciones contractuales para rate plans: cancelación, pago, no-show y
						check-in/out. Las promociones y descuentos viven en Pricing.
					</p>
				</div>
				<div class="flex items-center gap-2">
					<Button href={routes.ratePlansList()} variant="secondary">Rate Plans</Button>
					<Button href="/provider/policies/new" variant="primary">Crear policy</Button>
				</div>
			</header>

			<div class="grid gap-4 md:grid-cols-4">
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Categorías</p>
					<p class="mt-2 text-2xl font-semibold">4</p>
					<p class="mt-1 text-xs text-slate-400">Contrato de reserva</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Policies activas</p>
					<p class="mt-2 text-2xl font-semibold">{policies.length}</p>
					<p class="mt-1 text-xs text-slate-400">Última versión por grupo abajo</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Payment</p>
					<p class="mt-2 text-2xl font-semibold">{byCategory.Payment.length}</p>
					<p class="mt-1 text-xs text-slate-400">Términos de cobro</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Cancellation</p>
					<p class="mt-2 text-2xl font-semibold">{byCategory.Cancellation.length}</p>
					<p class="mt-1 text-xs text-slate-400">Ventanas y penalidades</p>
				</Card>
			</div>

			<Card className="border-blue-200 bg-blue-50 text-blue-950">
				<p class="text-sm font-semibold">Separación operacional</p>
				<p class="mt-1 text-sm">
					Booking Policies define obligaciones contractuales. Pricing define descuentos, promociones
					y overrides. House Rules define comportamiento del huésped y uso de la propiedad.
				</p>
			</Card>

			{
				success === "created" && (
					<div class="rounded-lg border border-green-200 bg-green-50 p-3 text-green-900">
						<strong>OK:</strong> Política creada.
						<div class="text-sm">
							<a class="underline" href="/rates/plans/manage">
								Asignar a un rate plan
							</a>
						</div>
					</div>
				)
			}
			{
				success === "updated" && (
					<div class="rounded-lg border border-green-200 bg-green-50 p-3 text-green-900">
						<strong>OK:</strong> Se creó una nueva versión de política.
					</div>
				)
			}

			{
				!res.ok ? (
					<p>No se pudieron cargar las políticas.</p>
				) : policies.length === 0 ? (
					<p>Aún no hay booking policies.</p>
				) : null
			}

			{
				res.ok &&
					categories.map((cat) => (
						<Section
							title={cat}
							description={
								cat === "Cancellation"
									? "Ventanas de cancelación y penalidades guest-facing."
									: cat === "Payment"
										? "Términos de pago, prepago y cobro operativo."
										: cat === "NoShow"
											? "Tratamiento contractual si el huésped no llega."
											: "Ventanas de llegada y salida comunicadas al huésped."
							}
						>
							{byCategory[cat].length === 0 ? (
								<Card className="bg-white text-slate-700">
									<p class="text-sm">No hay booking policies en esta categoría.</p>
								</Card>
							) : (
								<div class="space-y-3">
									{byCategory[cat].map((p) => (
										<Card className="bg-white text-slate-800">
											<div class="flex flex-wrap items-start justify-between gap-4">
												<div>
													<p class="text-base font-semibold text-slate-900">{p.description}</p>
													<p class="mt-1 text-sm text-slate-600">
														Version {p.version} · Group {p.groupId}
													</p>
													<p class="mt-1 text-xs text-slate-500">
														ID <code>{p.id}</code>
													</p>
												</div>
												<Button
													href={`/provider/policies/${p.id}/edit`}
													variant="secondary"
													size="sm"
												>
													Crear nueva versión
												</Button>
											</div>
										</Card>
									))}
								</div>
							)}
						</Section>
					))
			}
		</div>
	</main>
</WorkspaceLayout>
