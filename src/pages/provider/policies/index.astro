													<td class="px-4 py-4 text-slate-700">{group.card.usage}</td>
													<td class="px-4 py-4">
														<p class="max-w-[320px] text-sm leading-6 text-slate-600">
															{group.card.guestSummary}
														</p>
													</td>
													<td class="px-4 py-4">
														<div class="flex flex-wrap gap-2">
															{isProfessionalPolicies && (
																<button
																	type="button"
																	class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-500 hover:text-slate-950"
																	data-policy-view={jsonForHtml(group.card.technical)}
																>
																	Detalle técnico
																</button>
															)}
															{canPublish && (
																<button
																	type="button"
																	class="rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-blue-700"
																	data-policy-action="publish"
																	data-policy-id={latest.id}
																>
																	Publicar
																</button>
															)}
															{isProfessionalPolicies && (
																<button
																	type="button"
																	class="rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-blue-700"
																	class:list={[
																		"policy-assignment-open",
																		String(latest.status ?? "") !== "active" &&
																			"cursor-not-allowed opacity-60",
																	]}
																	data-assignment-policy-id={
																		String(latest.status ?? "") === "active" ? latest.id : ""
																	}
																	data-assignment-category={group.group.category}
																	disabled={String(latest.status ?? "") !== "active"}
																>
																	Usar existente
																</button>
															)}
															{canArchive && (
																<button
																	type="button"
																	class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-500 hover:text-slate-950"
																	data-policy-action="archive"
																	data-policy-id={latest.id}
																>
																	Archivar
																</button>
															)}
															{isProfessionalPolicies && (
																<>
																	<Button
																		href={`/provider/policies/${latest.id}/edit`}
																		variant="secondary"
																		size="sm"
																	>
																		Nueva versión
																	</Button>
																	<Button
																		href={`/provider/policies/groups/${encodeURIComponent(group.group.id)}/audit`}
																		variant="secondary"
																		size="sm"
																	>
																		Auditoría
																	</Button>
																</>
															)}
														</div>
													</td>
												</tr>
											)
										})}
									</tbody>
								</table>
							</div>
						</section>
					)
				}
			</div>
		</div>

		{
			isProfessionalPolicies && (
				<section
					class="mx-auto hidden max-w-7xl space-y-4 px-6"
					data-policy-tab-panel="history"
					data-policy-history-tab
				>
					<Card className="space-y-4 border-slate-200 bg-white text-slate-900">
						<div class="flex flex-wrap items-start justify-between gap-4">
							<div>
								<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
									Historial avanzado
								</p>
								<h2 class="mt-1 text-xl font-semibold text-slate-950">Cambios recientes</h2>
								<p class="mt-1 max-w-3xl text-sm leading-6 text-slate-600">
									Últimos movimientos de condiciones, tarifas, habitaciones y hoteles. Para revisar
									trazabilidad completa, abre Auditoría desde cada condición en Biblioteca.
								</p>
							</div>
							<Button href="/provider/policies?vista=library" variant="secondary" size="sm">
								Ir a biblioteca
							</Button>
						</div>
						<div class="flex flex-wrap gap-2" aria-label="Filtrar historial de condiciones">
							<button
								type="button"
								class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
								data-policy-history-filter="all"
							>
								Todo
							</button>
							<button
								type="button"
								class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
								data-policy-history-filter="condicion"
							>
								Condición
							</button>
							<button
								type="button"
								class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
								data-policy-history-filter="tarifa"
							>
								Tarifa
							</button>
							<button
								type="button"
								class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
								data-policy-history-filter="habitacion"
							>
								Habitación
							</button>
							<button
								type="button"
								class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
								data-policy-history-filter="hotel"
							>
								Hotel
							</button>
						</div>
						{policyHistory.length === 0 ? (
							<p class="text-sm text-slate-600">
								Todavía no hay cambios recientes para estas condiciones.
							</p>
						) : (
							<ol class="space-y-3">
								{policyHistory.map((item) => (
									<li
										class={`rounded-lg border p-3 ${historyToneClasses[item.tone] ?? historyToneClasses.neutral}`}
										data-policy-history-item
										data-policy-history-object={item.objectType}
									>
										<div class="flex flex-wrap items-start justify-between gap-3">
											<div class="min-w-0">
												<div class="flex flex-wrap items-center gap-2">
													<p class="font-semibold">{item.title}</p>
													<span class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-semibold tracking-wide text-slate-600 uppercase">
														{item.objectLabel}
													</span>
												</div>
												<p class="mt-1 text-sm opacity-80">{item.description}</p>
												<p class="mt-1 text-xs opacity-70">{item.meta}</p>
											</div>
											<time class="text-xs font-medium opacity-70">
												{formatHistoryDate(item.createdAt)}
											</time>
										</div>
									</li>
								))}
							</ol>
						)}
					</Card>
				</section>
			)
		}

		<aside
			id="policyTechnicalDrawer"
			class="fixed inset-y-0 right-0 z-50 hidden w-full max-w-lg border-l border-slate-800 bg-slate-950 p-6 text-slate-100 shadow-2xl"
			aria-hidden="true"
		>
			<div class="flex items-start justify-between gap-4">
				<div>
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Detalle técnico
					</p>
					<h2 class="mt-1 text-xl font-semibold">Condición</h2>
				</div>
				<button
					type="button"
					id="policyTechnicalDrawerClose"
					class="rounded-lg border border-slate-700 px-3 py-2 text-sm font-semibold text-slate-300"
				>
					Cerrar
				</button>
			</div>
			<div id="policyTechnicalDrawerBody" class="mt-6 space-y-4 text-sm text-slate-300"></div>
		</aside>
		<div id="policyTechnicalDrawerBackdrop" class="fixed inset-0 z-40 hidden bg-slate-950/60"></div>
		<PolicyAssignmentFlow isProfessionalMode={isProfessionalPolicies} />
	</main>
</WorkspaceLayout>

<script>
	const policyTabButtons = Array.from(document.querySelectorAll("[data-policy-tab]"))
	const policyTabPanels = Array.from(document.querySelectorAll("[data-policy-tab-panel]"))
	const policyOperationsShell = document.querySelector("[data-policy-tab-shell='operations']")

	function activatePolicyTab(tab: string) {
		const requestedTab = tab || "incomplete"
		const nextTab = policyTabButtons.some(
			(button) => button.getAttribute("data-policy-tab") === requestedTab
		)
			? requestedTab
			: "incomplete"
		policyTabButtons.forEach((button) => {
			const isActive = button.getAttribute("data-policy-tab") === nextTab
			button.setAttribute("aria-selected", isActive ? "true" : "false")
			button.classList.toggle("border-slate-300", isActive)
			button.classList.toggle("border-transparent", !isActive)
			button.classList.toggle("bg-white", isActive)
			button.classList.toggle("shadow-sm", isActive)
			button.classList.toggle("text-slate-950", isActive)
			button.classList.toggle("text-slate-600", !isActive)
			button.classList.toggle("hover:bg-slate-100", !isActive)
		})
		policyTabPanels.forEach((panel) => {
			panel.classList.toggle("hidden", panel.getAttribute("data-policy-tab-panel") !== nextTab)
		})
		policyOperationsShell?.classList.toggle(
			"hidden",
			!["incomplete", "ready", "detail"].includes(nextTab)
		)
	}

	policyTabButtons.forEach((button) => {
		button.addEventListener("click", () => {
			const tab = button.getAttribute("data-policy-tab") || "incomplete"
			activatePolicyTab(tab)
			const url = new URL(window.location.href)
			url.searchParams.set("vista", tab)
			window.history.replaceState({}, "", url)
		})
	})

	activatePolicyTab(new URL(window.location.href).searchParams.get("vista") || "incomplete")

	document.querySelectorAll("[data-policy-history-filter]").forEach((button) => {
		button.addEventListener("click", () => {
			const filter = button.getAttribute("data-policy-history-filter") || "all"
			document.querySelectorAll("[data-policy-history-item]").forEach((item) => {
				const objectType = item.getAttribute("data-policy-history-object") || ""
				item.classList.toggle("hidden", filter !== "all" && objectType !== filter)
			})
		})
	})

	const drawer = document.getElementById("policyTechnicalDrawer")
	const drawerBody = document.getElementById("policyTechnicalDrawerBody")
	const drawerClose = document.getElementById("policyTechnicalDrawerClose")
	const drawerBackdrop = document.getElementById("policyTechnicalDrawerBackdrop")

	function escapeHtml(value: unknown) {
		return String(value ?? "")
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
			.replaceAll("'", "&#039;")
	}

	function renderList(items: unknown[], renderItem: (item: any) => string, emptyLabel: string) {
		if (!Array.isArray(items) || items.length === 0) {
			return `<p class="rounded-lg border border-slate-800 bg-slate-900 p-3 text-slate-400">${escapeHtml(emptyLabel)}</p>`
		}
		return `<ul class="space-y-2">${items.map((item) => `<li class="rounded-lg border border-slate-800 bg-slate-900 p-3">${renderItem(item)}</li>`).join("")}</ul>`
	}

	function openTechnicalDrawer(details: any) {
		if (!drawer || !drawerBody || !drawerBackdrop) return
		drawerBody.innerHTML = `
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Identificadores</p>
				<div class="rounded-lg border border-slate-800 bg-slate-900 p-3">
					<p><span class="text-slate-500">Grupo:</span> <code>${escapeHtml(details.groupId)}</code></p>
					<p><span class="text-slate-500">Condición:</span> <code>${escapeHtml(details.latestPolicyId)}</code></p>
				</div>
			</section>
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Resumen</p>
				<div class="rounded-lg border border-slate-800 bg-slate-900 p-3">
					<p>Categoría: ${escapeHtml(details.category)}</p>
					<p>Plantilla: ${escapeHtml(details.preset)}</p>
					<p>Estado: ${escapeHtml(details.status)}</p>
					<p>Última versión: v${escapeHtml(details.latestVersion)}</p>
				</div>
			</section>
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Asignaciones</p>
				${renderList(
					details.assignments,
					(item: any) => `
						<p><span class="text-slate-500">ID:</span> <code>${escapeHtml(item.id)}</code></p>
						<p>${escapeHtml(item.scope)} · <code>${escapeHtml(item.scopeId)}</code> · ${escapeHtml(item.channel)}</p>
						<p>${item.isActive ? "Activa" : "Inactiva"}</p>
					`,
					"Sin asignaciones"
				)}
			</section>
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Versiones</p>
				${renderList(
					details.versions,
					(item: any) => `
						<p><span class="text-slate-500">ID:</span> <code>${escapeHtml(item.id)}</code></p>
						<p>v${escapeHtml(item.version)} · ${escapeHtml(item.status)}</p>
						<p>${escapeHtml(item.effectiveFrom || "sin inicio")} → ${escapeHtml(item.effectiveTo || "sin fin")}</p>
					`,
					"Sin versiones"
				)}
			</section>
		`
		drawer.classList.remove("hidden")
		drawerBackdrop.classList.remove("hidden")
		drawer.setAttribute("aria-hidden", "false")
	}

	function closeTechnicalDrawer() {
		drawer?.classList.add("hidden")
		drawerBackdrop?.classList.add("hidden")
		drawer?.setAttribute("aria-hidden", "true")
	}

	drawerClose?.addEventListener("click", closeTechnicalDrawer)
	drawerBackdrop?.addEventListener("click", closeTechnicalDrawer)
	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeTechnicalDrawer()
	})

	document.addEventListener("click", async (event) => {
		const target = event.target instanceof HTMLElement ? event.target : null
		const viewButton = target?.closest("[data-policy-view]")
		if (viewButton instanceof HTMLElement) {
			const details = JSON.parse(viewButton.dataset.policyView || "{}")
			openTechnicalDrawer(details)
			return
		}

		const button = target?.closest("[data-policy-action]")
		if (!(button instanceof HTMLElement)) return
		const action = button.dataset.policyAction
		const policyId = button.dataset.policyId
		if (!action || !policyId) return
		button.setAttribute("disabled", "true")
		const res = await fetch(`/api/policies/${encodeURIComponent(policyId)}/${action}`, {
			method: "POST",
		})
		if (res.ok) window.location.reload()
		else button.removeAttribute("disabled")
	})
</script>
