---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import PolicyAssignmentFlow from "@/components/policy/PolicyAssignmentFlow.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { POLICY_PRESET_CATALOG } from "@/data/policy/policy-presets"
import { requireProvider } from "@/lib/auth/requireProvider"
import { routes } from "@/lib/routes"

// Provider-only page. If unauthenticated or no provider, redirect to existing flows.
try {
	await requireProvider(Astro.request)
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

const res = await fetch(new URL("/api/policies/list-library", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const policyGroups = res.ok ? ((await res.json()) as any[]) : []
const assignmentOptionsRes = await fetch(new URL("/api/policies/assignment-options", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const assignmentOptions = assignmentOptionsRes.ok
	? await assignmentOptionsRes.json()
	: { scopes: { product: [], variant: [], rate_plan: [] }, policies: [] }
const success = String(Astro.url.searchParams.get("success") ?? "").trim()

const categoryLabels: Record<string, string> = {
	Cancellation: "Cancelación",
	Payment: "Pago",
	CheckIn: "Ingreso/salida",
	NoShow: "No presentación",
}
const statusLabels: Record<string, string> = {
	active: "Publicada",
	draft: "Borrador",
	template: "Plantilla",
	archived: "Archivada",
}
const statusClasses: Record<string, string> = {
	active: "border-emerald-200 bg-emerald-50 text-emerald-800",
	draft: "border-amber-200 bg-amber-50 text-amber-800",
	template: "border-blue-200 bg-blue-50 text-blue-800",
	archived: "border-slate-200 bg-slate-100 text-slate-600",
}
const presetLabels: Record<string, string> = {
	flexible: "Flexible",
	moderate: "Moderada",
	limited: "Limitada",
	firm: "Firme",
	strict: "Estricta",
	long_term: "Larga estadía",
	non_refundable: "No reembolsable",
	pay_at_property: "Pago en propiedad",
	prepayment_full: "Prepago total",
	deposit_50: "Depósito 50%",
	standard_check_in: "Ingreso estándar",
	late_arrival: "Llegada tardía",
	no_show_first_night: "No presentación: primera noche",
	no_show_full_stay: "No presentación: estadía completa",
	no_show_percentage_100: "No presentación: 100%",
}
const scopeLabels: Record<string, string> = {
	global: "Global",
	product: "Producto",
	variant: "Habitación",
	rate_plan: "Tarifa",
}
const channelLabels: Record<string, string> = {
	"": "Todos los canales",
	"web": "Web",
	"mobile": "Móvil",
	"b2b": "B2B",
	"direct": "Directo",
}
const matrixCategories = ["Cancellation", "Payment", "NoShow", "CheckIn"]
const presetByKey = new Map(POLICY_PRESET_CATALOG.map((preset) => [preset.key, preset]))

function statusLabel(value: unknown) {
	const status = String(value ?? "").trim()
	return (statusLabels[status] ?? status) || "Sin estado"
}

function statusClass(value: unknown) {
	return statusClasses[String(value ?? "").trim()] ?? "border-slate-200 bg-slate-100 text-slate-700"
}

function ruleMap(policy: any): Record<string, unknown> {
	const out: Record<string, unknown> = {}
	for (const rule of Array.isArray(policy?.rules) ? policy.rules : []) {
		const key = String(rule?.ruleKey ?? "").trim()
		if (key) out[key] = rule?.ruleValue
	}
	return out
}

function numberValue(value: unknown): number | null {
	const n = Number(value)
	return Number.isFinite(n) ? n : null
}

function formatBasis(value: unknown) {
	const key = String(value ?? "").trim()
	const labels: Record<string, string> = {
		total_booking: "reserva completa",
		room_rate: "tarifa base",
		first_night: "primera noche",
		deposit: "depósito",
		provider_policy: "condición del proveedor",
		none: "sin base monetaria",
		gross: "bruto",
		net: "neto",
		collected: "cobrado",
	}
	return (labels[key] ?? key) || "sin definir"
}

function presetLabel(policy: any) {
	const key = String(policy?.policyPresetKey ?? "").trim()
	return presetLabels[key] ?? presetByKey.get(key as any)?.name ?? "Personalizada"
}

function humanName(group: any) {
	const latest = group?.latest ?? {}
	const description = String(latest.description ?? "").trim()
	if (description) return description
	const preset = presetLabel(latest)
	const category = categoryLabels[String(group?.group?.category ?? "")] ?? "Condición"
	return preset === "Personalizada" ? `${category} sin nombre` : `${category} ${preset}`
}

function cancellationGuestSummary(policy: any) {
	const tiers: any[] = Array.isArray(policy?.tiers) ? policy.tiers : []
	const freeTier = tiers.find((tier: any) => {
		const amount = numberValue(tier?.penaltyAmount)
		return String(tier?.penaltyType ?? "") === "percentage" && amount != null && amount <= 0
	})
	if (freeTier) {
		const days = Number(freeTier.daysBeforeArrival ?? 0)
		return days > 0
			? `El huésped puede cancelar sin penalidad hasta ${days} día${days === 1 ? "" : "s"} antes de la llegada.`
			: "El huésped puede cancelar sin penalidad hasta el día de llegada."
	}
	const maxPenalty = Math.max(
		0,
		...tiers
			.filter((tier: any) => String(tier?.penaltyType ?? "") === "percentage")
			.map((tier: any) => Number(tier?.penaltyAmount ?? 0))
	)
	if (maxPenalty >= 100)
		return "El huésped asume una penalidad completa según la ventana aplicable."
	return "El huésped recibe un reembolso según las ventanas contractuales configuradas."
}

function guestSummary(group: any) {
	const policy = group?.latest ?? {}
	const category = String(group?.group?.category ?? "")
	const rules = ruleMap(policy)
	if (category === "Cancellation") return cancellationGuestSummary(policy)
	if (category === "Payment") {
		const paymentType = String(rules.paymentType ?? "").trim()
		const pct = numberValue(rules.prepaymentPercentage)
		if (paymentType === "pay_at_property") return "El huésped paga en la propiedad."
		if (paymentType === "prepayment" && pct != null)
			return `El huésped prepaga ${pct}% antes de la llegada.`
		if (paymentType === "prepayment") return "El huésped debe realizar prepago antes de la llegada."
		return "El pago se rige por la condición asignada a la tarifa."
	}
	if (category === "NoShow") {
		const penaltyType = String(rules.penaltyType ?? "").trim()
		const amount = numberValue(rules.penaltyAmount)
		if (penaltyType === "first_night") return "Si el huésped no llega, se cobra la primera noche."
		if (penaltyType === "full") return "Si el huésped no llega, se cobra la estadía completa."
		if (penaltyType === "percentage" && amount != null) {
			return `Si el huésped no llega, se cobra ${amount}% según contrato.`
		}
		return "La no presentación se cobra según la condición asignada."
	}
	if (category === "CheckIn") {
		const from = String(rules.checkInFrom ?? "").trim()
		const until = String(rules.checkInUntil ?? "").trim()
		const out = String(rules.checkOutUntil ?? "").trim()
		if (from && until && out) return `Llegada entre ${from} y ${until}; salida hasta ${out}.`
		return "El huésped ve ventanas de llegada y salida configuradas."
	}
	return "Resumen visible para huésped pendiente de definir."
}

function financialImpact(group: any) {
	const policy = group?.latest ?? {}
	const category = String(group?.group?.category ?? "")
	const rules = ruleMap(policy)
	if (category === "Cancellation") {
		const tiers: any[] = Array.isArray(policy?.tiers) ? policy.tiers : []
		const percentagePenalties = tiers
			.filter((tier: any) => String(tier?.penaltyType ?? "") === "percentage")
			.map((tier: any) => Number(tier?.penaltyAmount ?? 0))
			.filter(Number.isFinite)
		const maxPenalty = percentagePenalties.length ? Math.max(...percentagePenalties) : null
		const basis = formatBasis(policy.refundBasis)
		const payout = formatBasis(policy.payoutBasis)
		return `${tiers.length || 0} tramo${tiers.length === 1 ? "" : "s"} calculable${maxPenalty == null ? "" : ` · penalidad máxima ${maxPenalty}%`} · reembolso sobre ${basis} · pago proveedor ${payout}.`
	}
	if (category === "Payment") {
		const paymentType = String(rules.paymentType ?? "").trim()
		const pct = numberValue(rules.prepaymentPercentage)
		if (paymentType === "pay_at_property")
			return "Sin cobro anticipado; el flujo financiero ocurre en propiedad."
		if (paymentType === "prepayment")
			return `Cobro anticipado${pct == null ? "" : ` de ${pct}%`} antes de la llegada.`
		return "Impacto de cobro pendiente de completar."
	}
	if (category === "NoShow") {
		const penaltyType = String(rules.penaltyType ?? "").trim()
		const amount = numberValue(rules.penaltyAmount)
		if (penaltyType === "first_night") return "Cargo resoluble: primera noche."
		if (penaltyType === "full") return "Cargo resoluble: estadía completa."
		if (penaltyType === "percentage" && amount != null)
			return `Cargo resoluble: ${amount}% de la base contractual.`
		return "Cargo de no presentación pendiente de completar."
	}
	if (category === "CheckIn")
		return "Sin cargo directo; afecta operación y comunicación al huésped."
	return "Impacto financiero pendiente de clasificar."
}

function usageSummary(group: any) {
	const active = Array.isArray(group?.activeAssignments) ? group.activeAssignments : []
	if (!active.length) return "Sin asignaciones activas"
	const counts = new Map<string, number>()
	for (const assignment of active) {
		const scope = String(assignment?.scope ?? "")
		counts.set(scope, (counts.get(scope) ?? 0) + 1)
	}
	return Array.from(counts.entries())
		.map(([scope, count]) => `${count} ${scopeLabels[scope] ?? scope}${count === 1 ? "" : "s"}`)
		.join(" · ")
}

function latestVersionLabel(group: any) {
	const latest = group?.latest
	if (!latest) return "Sin versiones"
	return `v${Number(latest.version ?? 0)} · ${statusLabel(latest.status)}`
}

function technicalDetails(group: any) {
	return {
		groupId: group?.group?.id ?? null,
		category:
			categoryLabels[String(group?.group?.category ?? "")] ?? group?.group?.category ?? null,
		latestPolicyId: group?.latest?.id ?? null,
		latestVersion: group?.latest?.version ?? null,
		status: statusLabel(group?.latest?.status),
		preset: presetLabel(group?.latest),
		assignments: Array.isArray(group?.assignments)
			? group.assignments.map((assignment: any) => ({
					id: assignment.id,
					scope: scopeLabels[String(assignment.scope ?? "")] ?? assignment.scope,
					scopeId: assignment.scopeId,
					channel: assignment.channel ?? "default",
					isActive: Boolean(assignment.isActive),
				}))
			: [],
		versions: Array.isArray(group?.versions)
			? group.versions.map((version: any) => ({
					id: version.id,
					version: version.version,
					status: statusLabel(version.status),
					effectiveFrom: version.effectiveFrom,
					effectiveTo: version.effectiveTo,
				}))
			: [],
	}
}

function jsonForHtml(value: unknown) {
	return JSON.stringify(value).replace(/</g, "\\u003c")
}

const cards = policyGroups.map((group) => ({
	...group,
	card: {
		name: humanName(group),
		category:
			categoryLabels[String(group?.group?.category ?? "")] ?? String(group?.group?.category ?? ""),
		preset: presetLabel(group?.latest),
		status: statusLabel(group?.latest?.status),
		statusClass: statusClass(group?.latest?.status),
		usage: usageSummary(group),
		latestVersion: latestVersionLabel(group),
		guestSummary: guestSummary(group),
		financialImpact: financialImpact(group),
		technical: technicalDetails(group),
	},
}))

const activeCount = cards.filter((group) => String(group.latest?.status ?? "") === "active").length
const assignedCount = cards.filter((group) => (group.activeAssignments?.length ?? 0) > 0).length
const draftCount = cards.filter((group) => String(group.latest?.status ?? "") === "draft").length

function assignmentKey(scope: unknown, scopeId: unknown, channel: unknown, category: unknown) {
	return [
		String(scope ?? ""),
		String(scopeId ?? ""),
		String(channel ?? ""),
		String(category ?? ""),
	].join("::")
}

const activeAssignmentByTarget = new Map<string, any>()
const channelsByTarget = new Map<string, Set<string>>()
for (const group of cards) {
	const category = String(group?.group?.category ?? "")
	const assignments = Array.isArray(group?.activeAssignments) ? group.activeAssignments : []
	for (const assignment of assignments) {
		const scope = String(assignment?.scope ?? "")
		const scopeId = String(assignment?.scopeId ?? "")
		const channel = assignment?.channel == null ? "" : String(assignment.channel)
		if (!scope || !scopeId || !category) continue
		activeAssignmentByTarget.set(assignmentKey(scope, scopeId, channel, category), {
			assignment,
			group,
		})
		const targetKey = `${scope}::${scopeId}`
		if (!channelsByTarget.has(targetKey)) channelsByTarget.set(targetKey, new Set<string>())
		channelsByTarget.get(targetKey)?.add(channel)
	}
}

function channelLabel(channel: unknown) {
	const key = channel == null ? "" : String(channel)
	return channelLabels[key] ?? key
}

function targetChannels(scope: string, scopeId: string) {
	const channels = Array.from(channelsByTarget.get(`${scope}::${scopeId}`) ?? new Set<string>())
	if (!channels.length) return [""]
	return channels.sort((a, b) => channelLabel(a).localeCompare(channelLabel(b), "es"))
}

function buildMatrixRows() {
	const rows: any[] = []
	const targets = [
		...(assignmentOptions?.scopes?.rate_plan ?? []).map((item: any) => ({
			...item,
			scope: "rate_plan",
			scopeLabel: "Tarifa",
		})),
		...(assignmentOptions?.scopes?.product ?? []).map((item: any) => ({
			...item,
			scope: "product",
			scopeLabel: "Listing",
		})),
	]
	for (const target of targets) {
		const scope = String(target.scope)
		const scopeId = String(target.id ?? "")
		if (!scopeId) continue
		for (const channel of targetChannels(scope, scopeId)) {
			const cells = matrixCategories.map((category) => {
				const exact = activeAssignmentByTarget.get(assignmentKey(scope, scopeId, channel, category))
				const inherited =
					channel === ""
						? null
						: activeAssignmentByTarget.get(assignmentKey(scope, scopeId, "", category))
				const match = exact ?? inherited ?? null
				return {
					category,
					categoryLabel: categoryLabels[category] ?? category,
					isInherited: Boolean(!exact && inherited),
					assignment: match?.assignment ?? null,
					group: match?.group ?? null,
				}
			})
			const assignedCells = cells.filter((cell) => cell.group).length
			rows.push({
				id: `${scope}:${scopeId}:${channel || "default"}`,
				scope,
				scopeId,
				scopeLabel: target.scopeLabel,
				label: String(target.label ?? scopeId),
				helper: String(target.helper ?? ""),
				channel,
				channelLabel: channelLabel(channel),
				cells,
				assignedCells,
				isReady: assignedCells === matrixCategories.length,
			})
		}
	}
	return rows
}

const matrixRows = buildMatrixRows()
const readyMatrixRows = matrixRows.filter((row) => row.isReady).length
const incompleteMatrixRows = matrixRows.length - readyMatrixRows
const missingMatrixCells = matrixRows.reduce(
	(total, row) => total + (matrixCategories.length - row.assignedCells),
	0
)
---

<WorkspaceLayout title="Condiciones">
	<main class="min-h-screen text-slate-200">
		<div class="mx-auto max-w-7xl space-y-8 px-6">
			<header class="flex flex-wrap items-start justify-between gap-4">
				<div class="space-y-2">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
						Habitaciones y tarifas · Centro operativo
					</p>
					<h1 class="text-3xl font-semibold text-slate-100">Condiciones</h1>
					<p class="max-w-4xl text-sm leading-6 text-slate-300">
						Centro operativo por tarifa, listing y canal. Revisa qué condiciones están listas, qué
						falta para vender y qué impacto contractual tendrá cada asignación.
					</p>
				</div>
				<div class="flex items-center gap-2">
					<Button href={routes.ratePlansList()} variant="secondary">Tarifas</Button>
					<Button href="/provider/policies/new" variant="primary">Crear condición</Button>
				</div>
			</header>

			<div class="grid gap-4 md:grid-cols-4">
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Grupos</p>
					<p class="mt-2 text-2xl font-semibold">{cards.length}</p>
					<p class="mt-1 text-xs text-slate-400">Biblioteca contractual</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Publicadas</p>
					<p class="mt-2 text-2xl font-semibold">{activeCount}</p>
					<p class="mt-1 text-xs text-slate-400">Listas para asignar</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Asignadas</p>
					<p class="mt-2 text-2xl font-semibold">{assignedCount}</p>
					<p class="mt-1 text-xs text-slate-400">Con uso activo</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs uppercase tracking-wide text-slate-500">Borradores</p>
					<p class="mt-2 text-2xl font-semibold">{draftCount}</p>
					<p class="mt-1 text-xs text-slate-400">Pendientes de publicación</p>
				</Card>
			</div>

			{
				(success === "created" || success === "draft") && (
					<div class="rounded-lg border border-green-200 bg-green-50 p-3 text-green-900">
						<strong>OK:</strong> Condición guardada en biblioteca. Publícala antes de asignarla.
					</div>
				)
			}
			{
				success === "updated" && (
					<div class="rounded-lg border border-green-200 bg-green-50 p-3 text-green-900">
						<strong>OK:</strong> Se creó una nueva versión de la condición.
					</div>
				)
			}

			<section
				class="space-y-4 rounded-lg border border-slate-800 bg-slate-950/80 p-5"
				data-policy-operations-matrix
			>
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div>
						<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
							Tarifas/listings/canales vs condiciones
						</p>
						<h2 class="mt-1 text-xl font-semibold text-slate-100">Centro operativo</h2>
						<p class="mt-1 max-w-3xl text-sm leading-6 text-slate-400">
							La matriz muestra Cancelación, Pago, No presentación e Ingreso/salida por cada destino
							comercial. Las celdas vacías abren el flujo profesional de asignación.
						</p>
					</div>
					<div class="grid grid-cols-4 gap-2 text-center text-xs">
						<div class="rounded-lg border border-slate-800 bg-slate-900 px-3 py-2">
							<p class="text-slate-500">Filas</p>
							<p class="mt-1 text-lg font-semibold text-slate-100">{matrixRows.length}</p>
						</div>
						<div class="rounded-lg border border-emerald-900/70 bg-emerald-950/30 px-3 py-2">
							<p class="text-emerald-300">Listas</p>
							<p class="mt-1 text-lg font-semibold text-emerald-100">{readyMatrixRows}</p>
						</div>
						<div class="rounded-lg border border-amber-900/70 bg-amber-950/30 px-3 py-2">
							<p class="text-amber-300">Incompletas</p>
							<p class="mt-1 text-lg font-semibold text-amber-100">{incompleteMatrixRows}</p>
						</div>
						<div class="rounded-lg border border-amber-900/70 bg-amber-950/30 px-3 py-2">
							<p class="text-amber-300">Faltantes</p>
							<p class="mt-1 text-lg font-semibold text-amber-100">{missingMatrixCells}</p>
						</div>
					</div>
				</div>

				{
					!assignmentOptionsRes.ok ? (
						<div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-900">
							No se pudieron cargar tarifas, listings y canales para la matriz.
						</div>
					) : matrixRows.length === 0 ? (
						<div class="rounded-lg border border-slate-800 bg-slate-900 p-4 text-sm text-slate-300">
							Aún no hay tarifas o listings disponibles para mostrar en el centro operativo.
						</div>
					) : (
						<div class="overflow-x-auto rounded-lg border border-slate-800 bg-slate-900">
							<table class="w-full min-w-[980px] text-left text-sm">
								<thead class="border-b border-slate-800 bg-slate-950 text-xs tracking-wide text-slate-500 uppercase">
									<tr>
										<th class="px-4 py-3 font-semibold">Destino</th>
										<th class="px-4 py-3 font-semibold">Canal</th>
										{matrixCategories.map((category) => (
											<th class="px-4 py-3 font-semibold">{categoryLabels[category]}</th>
										))}
										<th class="px-4 py-3 font-semibold">Estado</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-slate-800">
									{matrixRows.map((row) => (
										<tr class="align-top">
											<td class="px-4 py-4">
												<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
													{row.scopeLabel}
												</p>
												<p class="mt-1 font-semibold text-slate-100">{row.label}</p>
												{row.helper && <p class="mt-1 text-xs text-slate-400">{row.helper}</p>}
											</td>
											<td class="px-4 py-4">
												<span class="rounded-full border border-slate-700 bg-slate-950 px-2.5 py-1 text-xs font-semibold text-slate-300">
													{row.channelLabel}
												</span>
											</td>
											{row.cells.map((cell: any) => (
												<td class="px-4 py-4">
													{cell.group ? (
														<button
															type="button"
															class="w-full rounded-lg border border-emerald-800 bg-emerald-950/40 p-3 text-left text-emerald-100 transition hover:border-emerald-500"
															data-policy-view={jsonForHtml(cell.group.card.technical)}
														>
															<span class="block text-xs font-semibold tracking-wide text-emerald-300 uppercase">
																{cell.group.card.status}
															</span>
															<span class="mt-1 block font-semibold">{cell.group.card.preset}</span>
															<span class="mt-1 block text-xs text-emerald-200/80">
																{cell.isInherited
																	? "Heredada de todos los canales"
																	: cell.group.card.latestVersion}
															</span>
														</button>
													) : (
														<button
															type="button"
															class="policy-assignment-open w-full rounded-lg border border-amber-800 bg-amber-950/40 p-3 text-left text-amber-100 transition hover:border-amber-500"
															data-assignment-mode="preset"
															data-assignment-scope={row.scope}
															data-assignment-scope-id={row.scopeId}
															data-assignment-category={cell.category}
															data-assignment-channel={row.channel}
														>
															<span class="block text-xs font-semibold tracking-wide text-amber-300 uppercase">
																Falta
															</span>
															<span class="mt-1 block font-semibold">Asignar</span>
															<span class="mt-1 block text-xs text-amber-200/80">
																{cell.categoryLabel}
															</span>
														</button>
													)}
												</td>
											))}
											<td class="px-4 py-4">
												<span
													class:list={[
														"rounded-full border px-2.5 py-1 text-xs font-semibold",
														row.isReady
															? "border-emerald-700 bg-emerald-950/50 text-emerald-200"
															: "border-amber-700 bg-amber-950/50 text-amber-200",
													]}
												>
													{row.isReady ? "Lista para vender" : "Incompleta"}
												</span>
												<p class="mt-2 text-xs text-slate-500">
													{row.assignedCells}/{matrixCategories.length} categorías
												</p>
											</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					)
				}
			</section>

			{
				!res.ok ? (
					<Card className="border-red-200 bg-red-50 text-red-900">
						<p>No se pudieron cargar las condiciones.</p>
					</Card>
				) : cards.length === 0 ? (
					<Card className="border-slate-800 bg-slate-950 text-slate-100">
						<div class="flex flex-wrap items-center justify-between gap-4">
							<div>
								<p class="text-lg font-semibold">Aún no hay condiciones</p>
								<p class="mt-1 text-sm text-slate-400">
									Crea el primer grupo contractual desde una plantilla y publícalo cuando esté
									listo.
								</p>
							</div>
							<Button href="/provider/policies/new" variant="primary">
								Crear condición
							</Button>
						</div>
					</Card>
				) : (
					<section class="space-y-4" data-policy-library-secondary>
						<div>
							<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
								Biblioteca secundaria
							</p>
							<h2 class="mt-1 text-xl font-semibold text-slate-100">Grupos de condiciones</h2>
							<p class="mt-1 max-w-3xl text-sm leading-6 text-slate-400">
								Usa estas cards para gestionar versiones, publicación, auditoría y detalle técnico.
								La operación diaria vive en la matriz superior.
							</p>
						</div>
						<div class="grid gap-4 lg:grid-cols-2">
							{cards.map((group) => {
								const latest = group.latest ?? {}
								const canPublish =
									String(latest.status ?? "") !== "active" &&
									String(latest.status ?? "") !== "archived"
								const canArchive = String(latest.status ?? "") !== "archived"
								return (
									<article class="rounded-lg border border-slate-200 bg-white p-5 text-slate-800 shadow-sm">
										<div class="flex flex-wrap items-start justify-between gap-3">
											<div class="min-w-0 space-y-2">
												<div class="flex flex-wrap items-center gap-2">
													<span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">
														{group.card.category}
													</span>
													<span
														class={`rounded-full border px-2.5 py-1 text-xs font-semibold ${group.card.statusClass}`}
													>
														{group.card.status}
													</span>
												</div>
												<h2 class="text-lg leading-tight font-semibold text-slate-950">
													{group.card.name}
												</h2>
											</div>
											<p class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
												{group.card.latestVersion}
											</p>
										</div>

										<dl class="mt-5 grid gap-4 border-y border-slate-200 py-4 sm:grid-cols-2">
											<div class="border-l-2 border-slate-200 pl-3">
												<dt class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
													Plantilla
												</dt>
												<dd class="mt-1 text-sm font-semibold text-slate-900">
													{group.card.preset}
												</dd>
											</div>
											<div class="border-l-2 border-slate-200 pl-3">
												<dt class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
													Uso
												</dt>
												<dd class="mt-1 text-sm font-semibold text-slate-900">
													{group.card.usage}
												</dd>
											</div>
										</dl>

										<div class="mt-4 space-y-3">
											<div>
												<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
													Resumen para huésped
												</p>
												<p class="mt-1 text-sm leading-6 text-slate-700">
													{group.card.guestSummary}
												</p>
											</div>
											<div>
												<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
													Impacto financiero
												</p>
												<p class="mt-1 text-sm leading-6 text-slate-700">
													{group.card.financialImpact}
												</p>
											</div>
										</div>

										<div class="mt-5 flex flex-wrap items-center gap-2">
											<button
												type="button"
												class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-500 hover:text-slate-950"
												data-policy-view={jsonForHtml(group.card.technical)}
											>
												Ver
											</button>
											{canPublish && (
												<button
													type="button"
													class="rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-blue-700"
													data-policy-action="publish"
													data-policy-id={latest.id}
												>
													Publicar
												</button>
											)}
											<button
												type="button"
												class="rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700"
												class:list={[
													"policy-assignment-open",
													String(latest.status ?? "") !== "active" &&
														"cursor-not-allowed opacity-60",
												]}
												data-assignment-policy-id={
													String(latest.status ?? "") === "active" ? latest.id : ""
												}
												data-assignment-category={group.group.category}
												disabled={String(latest.status ?? "") !== "active"}
											>
												Asignar
											</button>
											{canArchive && (
												<button
													type="button"
													class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-500 hover:text-slate-950"
													data-policy-action="archive"
													data-policy-id={latest.id}
												>
													Archivar
												</button>
											)}
											<Button
												href={`/provider/policies/${latest.id}/edit`}
												variant="secondary"
												size="sm"
											>
												Nueva versión
											</Button>
											<Button
												href={`/provider/policies/groups/${encodeURIComponent(group.group.id)}/audit`}
												variant="secondary"
												size="sm"
											>
												Auditoría
											</Button>
										</div>
									</article>
								)
							})}
						</div>
					</section>
				)
			}
		</div>

		<aside
			id="policyTechnicalDrawer"
			class="fixed inset-y-0 right-0 z-50 hidden w-full max-w-lg border-l border-slate-800 bg-slate-950 p-6 text-slate-100 shadow-2xl"
			aria-hidden="true"
		>
			<div class="flex items-start justify-between gap-4">
				<div>
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Detalle técnico
					</p>
					<h2 class="mt-1 text-xl font-semibold">Condición</h2>
				</div>
				<button
					type="button"
					id="policyTechnicalDrawerClose"
					class="rounded-lg border border-slate-700 px-3 py-2 text-sm font-semibold text-slate-300"
				>
					Cerrar
				</button>
			</div>
			<div id="policyTechnicalDrawerBody" class="mt-6 space-y-4 text-sm text-slate-300"></div>
		</aside>
		<div id="policyTechnicalDrawerBackdrop" class="fixed inset-0 z-40 hidden bg-slate-950/60"></div>
		<PolicyAssignmentFlow />
	</main>
</WorkspaceLayout>

<script>
	const drawer = document.getElementById("policyTechnicalDrawer")
	const drawerBody = document.getElementById("policyTechnicalDrawerBody")
	const drawerClose = document.getElementById("policyTechnicalDrawerClose")
	const drawerBackdrop = document.getElementById("policyTechnicalDrawerBackdrop")

	function escapeHtml(value: unknown) {
		return String(value ?? "")
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
			.replaceAll("'", "&#039;")
	}

	function renderList(items: unknown[], renderItem: (item: any) => string, emptyLabel: string) {
		if (!Array.isArray(items) || items.length === 0) {
			return `<p class="rounded-lg border border-slate-800 bg-slate-900 p-3 text-slate-400">${escapeHtml(emptyLabel)}</p>`
		}
		return `<ul class="space-y-2">${items.map((item) => `<li class="rounded-lg border border-slate-800 bg-slate-900 p-3">${renderItem(item)}</li>`).join("")}</ul>`
	}

	function openTechnicalDrawer(details: any) {
		if (!drawer || !drawerBody || !drawerBackdrop) return
		drawerBody.innerHTML = `
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Identificadores</p>
				<div class="rounded-lg border border-slate-800 bg-slate-900 p-3">
					<p><span class="text-slate-500">Grupo:</span> <code>${escapeHtml(details.groupId)}</code></p>
					<p><span class="text-slate-500">Condición:</span> <code>${escapeHtml(details.latestPolicyId)}</code></p>
				</div>
			</section>
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Resumen</p>
				<div class="rounded-lg border border-slate-800 bg-slate-900 p-3">
					<p>Categoría: ${escapeHtml(details.category)}</p>
					<p>Plantilla: ${escapeHtml(details.preset)}</p>
					<p>Estado: ${escapeHtml(details.status)}</p>
					<p>Última versión: v${escapeHtml(details.latestVersion)}</p>
				</div>
			</section>
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Asignaciones</p>
				${renderList(
					details.assignments,
					(item: any) => `
						<p><span class="text-slate-500">ID:</span> <code>${escapeHtml(item.id)}</code></p>
						<p>${escapeHtml(item.scope)} · <code>${escapeHtml(item.scopeId)}</code> · ${escapeHtml(item.channel)}</p>
						<p>${item.isActive ? "Activa" : "Inactiva"}</p>
					`,
					"Sin asignaciones"
				)}
			</section>
			<section class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Versiones</p>
				${renderList(
					details.versions,
					(item: any) => `
						<p><span class="text-slate-500">ID:</span> <code>${escapeHtml(item.id)}</code></p>
						<p>v${escapeHtml(item.version)} · ${escapeHtml(item.status)}</p>
						<p>${escapeHtml(item.effectiveFrom || "sin inicio")} → ${escapeHtml(item.effectiveTo || "sin fin")}</p>
					`,
					"Sin versiones"
				)}
			</section>
		`
		drawer.classList.remove("hidden")
		drawerBackdrop.classList.remove("hidden")
		drawer.setAttribute("aria-hidden", "false")
	}

	function closeTechnicalDrawer() {
		drawer?.classList.add("hidden")
		drawerBackdrop?.classList.add("hidden")
		drawer?.setAttribute("aria-hidden", "true")
	}

	drawerClose?.addEventListener("click", closeTechnicalDrawer)
	drawerBackdrop?.addEventListener("click", closeTechnicalDrawer)
	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeTechnicalDrawer()
	})

	document.addEventListener("click", async (event) => {
		const target = event.target instanceof HTMLElement ? event.target : null
		const viewButton = target?.closest("[data-policy-view]")
		if (viewButton instanceof HTMLElement) {
			const details = JSON.parse(viewButton.dataset.policyView || "{}")
			openTechnicalDrawer(details)
			return
		}

		const button = target?.closest("[data-policy-action]")
		if (!(button instanceof HTMLElement)) return
		const action = button.dataset.policyAction
		const policyId = button.dataset.policyId
		if (!action || !policyId) return
		button.setAttribute("disabled", "true")
		const res = await fetch(`/api/policies/${encodeURIComponent(policyId)}/${action}`, {
			method: "POST",
		})
		if (res.ok) window.location.reload()
		else button.removeAttribute("disabled")
	})
</script>
