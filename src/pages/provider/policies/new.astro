---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import { POLICY_PRESETS } from "@/data/policy/policy-presets"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { routes } from "@/lib/routes"
import { createPolicyCapa6, PolicyValidationError } from "@/modules/policies/public"
import { z } from "zod"

try {
	await requireProvider(Astro.request)
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

let error: string | null = null
let fieldErrors: Record<string, string> = {}

function requireField(value: unknown, field: string, message = "Required") {
	const normalized = String(value ?? "").trim()
	if (!normalized) {
		fieldErrors[field] = message
		throw new Error("ui_validation_error")
	}
	return normalized
}

function parseOptionalNumber(value: unknown): number | null {
	const raw = String(value ?? "").trim()
	if (!raw) return null
	const parsed = Number(raw)
	return Number.isFinite(parsed) ? parsed : null
}

function assertTimeOrder(start: string, end: string, field: string) {
	if (start && end && start !== "00:00" && end !== "00:00" && end < start) {
		fieldErrors[field] = "Must be later than check-in start"
		throw new Error("ui_validation_error")
	}
}

if (Astro.request.method === "POST") {
	try {
		const form = await Astro.request.formData()
		const name = requireField(form.get("name"), "description", "Policy name is required")
		const category = requireField(form.get("category"), "category", "Choose a policy category")

		if (category === "Cancellation") {
			const days = form.getAll("daysBeforeArrival").map((v) => String(v).trim())
			const penalties = form.getAll("penaltyPercent").map((v) => String(v).trim())
			const tiers = days
				.map((d, i) => ({
					daysBeforeArrival: d === "" ? NaN : Number(d),
					penaltyType: "percentage" as const,
					penaltyAmount: penalties[i] === "" ? NaN : Number(penalties[i]),
				}))
				.filter((t) => !Number.isNaN(t.daysBeforeArrival) && !Number.isNaN(t.penaltyAmount))

			if (!tiers.length) {
				fieldErrors["cancellationTiers"] = "Add at least one cancellation tier"
				throw new Error("ui_validation_error")
			}
			if (tiers.some((tier) => tier.penaltyAmount < 0 || tier.penaltyAmount > 100)) {
				fieldErrors["cancellationTiers"] = "Cancellation percentages must be between 0 and 100"
				throw new Error("ui_validation_error")
			}

			await createPolicyCapa6({
				category: "Cancellation",
				description: name,
				cancellationTiers: tiers,
			})
		} else if (category === "Payment") {
			const paymentType = requireField(form.get("paymentType"), "paymentType")
			const prepaymentPercentage = parseOptionalNumber(form.get("prepaymentPercentage"))
			const prepaymentDaysBeforeArrival = parseOptionalNumber(
				form.get("prepaymentDaysBeforeArrival")
			)

			if (!["pay_at_property", "prepayment"].includes(paymentType)) {
				fieldErrors["paymentType"] = "Choose pay at property or prepayment"
				throw new Error("ui_validation_error")
			}

			const rules: Record<string, unknown> = { paymentType }
			if (paymentType === "prepayment") {
				if (
					prepaymentPercentage == null ||
					prepaymentPercentage <= 0 ||
					prepaymentPercentage > 100
				) {
					fieldErrors["prepaymentPercentage"] = "Prepayment must be between 1 and 100"
					throw new Error("ui_validation_error")
				}
				rules.prepaymentPercentage = prepaymentPercentage
				rules.prepaymentDaysBeforeArrival = prepaymentDaysBeforeArrival
			}

			await createPolicyCapa6({ category: "Payment" as any, description: name, rules })
		} else if (category === "CheckIn") {
			const checkInFrom = requireField(form.get("checkInFrom"), "checkInFrom")
			const checkInUntil = requireField(form.get("checkInUntil"), "checkInUntil")
			const checkOutUntil = requireField(form.get("checkOutUntil"), "checkOutUntil")
			assertTimeOrder(checkInFrom, checkInUntil, "checkInUntil")

			await createPolicyCapa6({
				category: "CheckIn" as any,
				description: name,
				rules: { checkInFrom, checkInUntil, checkOutUntil },
			})
		} else if (category === "NoShow") {
			const penaltyType = requireField(form.get("noShowPenaltyType"), "noShowPenaltyType")
			const penaltyAmount = parseOptionalNumber(form.get("noShowPenaltyAmount"))
			if (!["first_night", "full", "percentage"].includes(penaltyType)) {
				fieldErrors["noShowPenaltyType"] = "Choose a no-show penalty"
				throw new Error("ui_validation_error")
			}
			const rules: Record<string, unknown> = { penaltyType }
			if (penaltyType === "percentage") {
				if (penaltyAmount == null || penaltyAmount < 0 || penaltyAmount > 100) {
					fieldErrors["noShowPenaltyAmount"] = "Percentage must be between 0 and 100"
					throw new Error("ui_validation_error")
				}
				rules.penaltyAmount = penaltyAmount
			}

			await createPolicyCapa6({ category: "NoShow" as any, description: name, rules })
		} else {
			error = `Unsupported category: ${category}`
			throw new Error("ui_validation_error")
		}

		return Astro.redirect(`${routes.providerPolicies()}?success=created`)
	} catch (e: any) {
		if (String(e?.message || e) === "ui_validation_error") {
			if (!error) error = "Please fix the highlighted fields."
		} else if (e instanceof z.ZodError) {
			error = "Validation error"
			for (const issue of e.issues) {
				const key = issue.path.join(".") || "form"
				fieldErrors[key] = issue.message
			}
		} else if (e instanceof PolicyValidationError) {
			error = "Validation error"
			for (const issue of e.issues) {
				const key = issue.path.join(".") || "form"
				fieldErrors[key] = issue.message ?? issue.code ?? "Invalid"
			}
		} else {
			error = String(e?.message || e)
		}
	}
}
---

<WorkspaceLayout title="Create Booking Policy">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Rooms & Rates · Booking Contract
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Crear Booking Policy</h1>
				<p class="max-w-4xl text-sm leading-6 text-slate-300">
					Define condiciones contractuales de reserva: cancelación, pago, no-show y check-in/out.
					Las promociones viven en Pricing; las policies explican obligaciones contractuales.
				</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.providerPolicies()} variant="secondary">Policy Library</Button>
				<Button href={routes.ratePlansList()} variant="primary">Rate Plans</Button>
			</div>
		</header>

		{
			error && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">No se pudo crear la política</p>
					<p class="mt-1 text-sm">{error}</p>
				</Card>
			)
		}

		<Section
			title="Templates de contrato"
			description="Usa una plantilla para cargar una semántica profesional. Puedes ajustar los campos antes de guardar."
		>
			<div class="grid gap-3 lg:grid-cols-2">
				{
					Object.entries(POLICY_PRESETS).map(([category, templates]) => (
						<Card className="bg-white text-slate-800">
							<p class="text-sm font-semibold tracking-wide text-slate-500 uppercase">{category}</p>
							<div class="mt-3 space-y-3">
								{templates.map((template) => (
									<button
										type="button"
										class="block w-full rounded-lg border border-slate-200 p-3 text-left hover:border-blue-300 hover:bg-blue-50"
										data-policy-template={JSON.stringify({ category, template })}
									>
										<span class="block font-semibold text-slate-900">{template.name}</span>
										<span class="mt-1 block text-sm text-slate-600">{template.description}</span>
										<span class="mt-2 block text-xs text-slate-500">
											Guest: {template.guestFacing}
										</span>
									</button>
								))}
							</div>
						</Card>
					))
				}
			</div>
		</Section>

		<Section
			title="Crear política"
			description="Guarda una policy versionada. Asignarla a un rate plan ocurre desde Rate Plans o el wizard de condiciones."
		>
			<Card className="bg-white text-slate-800">
				<form method="POST" class="space-y-6" id="policyCreateForm" novalidate>
					<div
						id="clientErrorBox"
						class="hidden rounded-lg border border-red-200 bg-red-50 p-3 text-red-900"
					>
						<strong>Error:</strong>
						<span id="clientErrorText"></span>
					</div>

					<div class="grid gap-4 lg:grid-cols-2">
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Nombre operativo</span>
							<input
								name="name"
								minlength="2"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
								placeholder="Flexible 24h · Web"
							/>
							<p class="text-xs text-slate-500">
								Visible para proveedores; el copy huésped se deriva desde la categoría y reglas.
							</p>
							<p class="text-sm text-red-700" id="err-name">{fieldErrors["description"]}</p>
						</label>

						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Categoría contractual</span>
							<select
								name="category"
								id="category"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
							>
								<option value="">Seleccionar...</option>
								<option value="Cancellation">Cancellation</option>
								<option value="Payment">Payment</option>
								<option value="CheckIn">Check-in / Check-out</option>
								<option value="NoShow">No-show</option>
							</select>
							<p class="text-xs text-slate-500">
								Policies no modifican descuentos ni precios: definen obligaciones de reserva.
							</p>
							<p class="text-sm text-red-700" id="err-category">{fieldErrors["category"]}</p>
						</label>
					</div>

					<div class="rounded-lg border border-blue-200 bg-blue-50 p-3 text-sm text-blue-950">
						<p class="font-semibold" id="categoryMeaningTitle">Selecciona una categoría</p>
						<p class="mt-1" id="categoryMeaningGuest">Guest-facing: pendiente.</p>
						<p class="mt-1" id="categoryMeaningOps">Operational meaning: pendiente.</p>
					</div>

					<section class="space-y-3" id="cancellationFields">
						<h2 class="font-semibold text-slate-900">Cancellation</h2>
						<p class="text-sm text-slate-600">
							Define penalidades por ventana antes de llegada. Esto es contrato, no promoción.
						</p>
						<div id="tiers" class="space-y-2">
							<div class="tier-row grid gap-2 md:grid-cols-[1fr_1fr_auto]">
								<label class="space-y-1 text-sm">
									<span>Días antes de llegada</span>
									<input
										name="daysBeforeArrival"
										type="number"
										min="0"
										class="w-full rounded-lg border border-slate-300 px-3 py-2"
									/>
								</label>
								<label class="space-y-1 text-sm">
									<span>Penalidad (%)</span>
									<input
										name="penaltyPercent"
										type="number"
										min="0"
										max="100"
										class="w-full rounded-lg border border-slate-300 px-3 py-2"
									/>
								</label>
								<button
									type="button"
									class="self-end rounded-lg border border-slate-300 px-3 py-2 text-sm"
									data-remove-tier
								>
									Quitar
								</button>
							</div>
						</div>
						<button
							type="button"
							class="rounded-lg border border-slate-300 px-3 py-2 text-sm"
							id="addTier"
						>
							Agregar tramo
						</button>
						<p class="text-sm text-red-700" id="err-cancellationTiers">
							{fieldErrors["cancellationTiers"]}
						</p>
					</section>

					<section class="hidden space-y-3" id="paymentFields">
						<h2 class="font-semibold text-slate-900">Payment</h2>
						<p class="text-sm text-slate-600">
							Define cuándo y cómo se espera el pago. Los depósitos dedicados llegarán en una fase
							posterior.
						</p>
						<label class="space-y-1 text-sm">
							<span>Tipo de pago</span>
							<select
								name="paymentType"
								id="paymentType"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
							>
								<option value="">Seleccionar...</option>
								<option value="pay_at_property">Pay at property</option>
								<option value="prepayment">Prepayment</option>
							</select>
							<p class="text-sm text-red-700" id="err-paymentType">{fieldErrors["paymentType"]}</p>
						</label>
						<div class="grid gap-2 md:grid-cols-2" id="prepaymentFields">
							<label class="space-y-1 text-sm">
								<span>Prepayment percentage</span>
								<input
									name="prepaymentPercentage"
									type="number"
									min="1"
									max="100"
									class="w-full rounded-lg border border-slate-300 px-3 py-2"
								/>
								<p class="text-sm text-red-700" id="err-prepaymentPercentage">
									{fieldErrors["prepaymentPercentage"]}
								</p>
							</label>
							<label class="space-y-1 text-sm">
								<span>Días antes de llegada</span>
								<input
									name="prepaymentDaysBeforeArrival"
									type="number"
									min="0"
									class="w-full rounded-lg border border-slate-300 px-3 py-2"
								/>
							</label>
						</div>
					</section>

					<section class="hidden space-y-3" id="checkinFields">
						<h2 class="font-semibold text-slate-900">Check-in / Check-out</h2>
						<p class="text-sm text-slate-600">
							Define ventanas operativas que se comunican al huésped antes de reservar.
						</p>
						<div class="grid gap-2 md:grid-cols-3">
							<label class="space-y-1 text-sm">
								<span>Check-in desde</span>
								<input
									name="checkInFrom"
									type="time"
									class="w-full rounded-lg border border-slate-300 px-3 py-2"
								/>
								<p class="text-sm text-red-700" id="err-checkInFrom">
									{fieldErrors["checkInFrom"]}
								</p>
							</label>
							<label class="space-y-1 text-sm">
								<span>Check-in hasta</span>
								<input
									name="checkInUntil"
									type="time"
									class="w-full rounded-lg border border-slate-300 px-3 py-2"
								/>
								<p class="text-sm text-red-700" id="err-checkInUntil">
									{fieldErrors["checkInUntil"]}
								</p>
							</label>
							<label class="space-y-1 text-sm">
								<span>Check-out hasta</span>
								<input
									name="checkOutUntil"
									type="time"
									class="w-full rounded-lg border border-slate-300 px-3 py-2"
								/>
								<p class="text-sm text-red-700" id="err-checkOutUntil">
									{fieldErrors["checkOutUntil"]}
								</p>
							</label>
						</div>
					</section>

					<section class="hidden space-y-3" id="noshowFields">
						<h2 class="font-semibold text-slate-900">No-show</h2>
						<p class="text-sm text-slate-600">
							Define la penalidad si el huésped no llega. No reemplaza la política de cancelación.
						</p>
						<label class="space-y-1 text-sm">
							<span>Penalty type</span>
							<select
								name="noShowPenaltyType"
								id="noShowPenaltyType"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
							>
								<option value="">Seleccionar...</option>
								<option value="first_night">First night</option>
								<option value="full">Full stay</option>
								<option value="percentage">Percentage</option>
							</select>
							<p class="text-sm text-red-700" id="err-noShowPenaltyType">
								{fieldErrors["noShowPenaltyType"]}
							</p>
						</label>
						<label class="space-y-1 text-sm" id="noshowAmountRow">
							<span>Penalty amount (%)</span>
							<input
								name="noShowPenaltyAmount"
								type="number"
								min="0"
								max="100"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
							/>
							<p class="text-sm text-red-700" id="err-noShowPenaltyAmount">
								{fieldErrors["noShowPenaltyAmount"]}
							</p>
						</label>
					</section>

					<div class="flex flex-wrap items-center gap-2">
						<Button type="submit" variant="primary">Crear policy</Button>
						<Button href={routes.providerPolicies()} variant="secondary">Cancelar</Button>
					</div>
				</form>
			</Card>
		</Section>
	</div>
</WorkspaceLayout>

<script define:vars={{ policyPresets: POLICY_PRESETS }}>
	const form = document.getElementById("policyCreateForm")
	const categorySel = document.getElementById("category")
	const paymentTypeSel = document.getElementById("paymentType")
	const noShowPenaltyTypeSel = document.getElementById("noShowPenaltyType")
	const clientErrorBox = document.getElementById("clientErrorBox")
	const clientErrorText = document.getElementById("clientErrorText")
	const sections = {
		Cancellation: document.getElementById("cancellationFields"),
		Payment: document.getElementById("paymentFields"),
		CheckIn: document.getElementById("checkinFields"),
		NoShow: document.getElementById("noshowFields"),
	}
	const meanings = {
		Cancellation: {
			title: "Cancellation contract",
			guest: "Guest-facing: explains refund windows and penalties before booking.",
			ops: "Operational meaning: determines cancellation handling and booking snapshots.",
		},
		Payment: {
			title: "Payment terms",
			guest: "Guest-facing: explains whether payment happens at the property or before arrival.",
			ops: "Operational meaning: tells finance and provider teams what collection expectation exists.",
		},
		CheckIn: {
			title: "Arrival and departure terms",
			guest: "Guest-facing: sets arrival and departure expectations.",
			ops: "Operational meaning: aligns front-desk or self-check-in readiness.",
		},
		NoShow: {
			title: "No-show handling",
			guest: "Guest-facing: explains the consequence of not arriving.",
			ops: "Operational meaning: separates no-show treatment from voluntary cancellation.",
		},
	}

	function setText(id, value) {
		const el = document.getElementById(id)
		if (el) el.textContent = value || ""
	}

	function setClientError(msg) {
		if (!clientErrorBox || !clientErrorText) return
		if (!msg) {
			clientErrorText.textContent = ""
			clientErrorBox.classList.add("hidden")
			return
		}
		clientErrorText.textContent = msg
		clientErrorBox.classList.remove("hidden")
	}

	function updateCategoryUI() {
		const category = categorySel?.value || ""
		for (const [key, section] of Object.entries(sections)) {
			section?.classList.toggle("hidden", key !== category)
		}
		const meaning = meanings[category] || {
			title: "Selecciona una categoría",
			guest: "Guest-facing: pendiente.",
			ops: "Operational meaning: pendiente.",
		}
		setText("categoryMeaningTitle", meaning.title)
		setText("categoryMeaningGuest", meaning.guest)
		setText("categoryMeaningOps", meaning.ops)
	}

	function updatePaymentUI() {
		const pre = document.getElementById("prepaymentFields")
		pre?.classList.toggle("hidden", paymentTypeSel?.value !== "prepayment")
	}

	function updateNoShowUI() {
		const row = document.getElementById("noshowAmountRow")
		row?.classList.toggle("hidden", noShowPenaltyTypeSel?.value !== "percentage")
	}

	function setInput(name, value) {
		const input = form?.querySelector(`[name="${name}"]`)
		if (input) input.value = value == null ? "" : String(value)
	}

	function resetTiers(tiers) {
		const container = document.getElementById("tiers")
		if (!container) return
		container.innerHTML = ""
		for (const tier of tiers || []) {
			const row = document.createElement("div")
			row.className = "tier-row grid gap-2 md:grid-cols-[1fr_1fr_auto]"
			row.innerHTML = `
				<label class="space-y-1 text-sm">
					<span>Días antes de llegada</span>
					<input name="daysBeforeArrival" type="number" min="0" class="w-full rounded-lg border border-slate-300 px-3 py-2" value="${tier.daysBeforeArrival ?? ""}" />
				</label>
				<label class="space-y-1 text-sm">
					<span>Penalidad (%)</span>
					<input name="penaltyPercent" type="number" min="0" max="100" class="w-full rounded-lg border border-slate-300 px-3 py-2" value="${tier.penaltyAmount ?? ""}" />
				</label>
				<button type="button" class="self-end rounded-lg border border-slate-300 px-3 py-2 text-sm" data-remove-tier>Quitar</button>`
			container.appendChild(row)
		}
	}

	document.querySelectorAll("[data-policy-template]").forEach((button) => {
		button.addEventListener("click", () => {
			const data = JSON.parse(button.getAttribute("data-policy-template") || "{}")
			const category = String(data.category || "")
			const template = data.template || {}
			setInput("name", template.name || "")
			setInput("category", category)
			if (category === "Cancellation") resetTiers(template.cancellationTiers || [])
			if (category === "Payment") {
				setInput("paymentType", template.rules?.paymentType || "")
				setInput("prepaymentPercentage", template.rules?.prepaymentPercentage || "")
				setInput("prepaymentDaysBeforeArrival", template.rules?.prepaymentDaysBeforeArrival ?? "")
			}
			if (category === "CheckIn") {
				setInput("checkInFrom", template.rules?.checkInFrom || "")
				setInput("checkInUntil", template.rules?.checkInUntil || "")
				setInput("checkOutUntil", template.rules?.checkOutUntil || "")
			}
			if (category === "NoShow") {
				setInput("noShowPenaltyType", template.rules?.penaltyType || "")
				setInput("noShowPenaltyAmount", template.rules?.penaltyAmount || "")
			}
			updateCategoryUI()
			updatePaymentUI()
			updateNoShowUI()
		})
	})

	document.getElementById("addTier")?.addEventListener("click", () => {
		const container = document.getElementById("tiers")
		const first = container?.querySelector(".tier-row")
		if (!container || !first) return
		const clone = first.cloneNode(true)
		clone.querySelectorAll("input").forEach((input) => {
			input.value = ""
		})
		container.appendChild(clone)
	})

	document.addEventListener("click", (event) => {
		const target = event.target
		if (!(target instanceof Element)) return
		if (!target.matches("[data-remove-tier]")) return
		const rows = document.querySelectorAll("#tiers .tier-row")
		if (rows.length <= 1) return
		target.closest(".tier-row")?.remove()
	})

	function validate() {
		setClientError("")
		let ok = true
		const category = categorySel?.value || ""
		const name = form?.querySelector('[name="name"]')?.value?.trim() || ""
		if (name.length < 2) ok = false
		if (!category) ok = false
		if (category === "Payment" && !paymentTypeSel?.value) ok = false
		if (category === "CheckIn") {
			for (const key of ["checkInFrom", "checkInUntil", "checkOutUntil"]) {
				if (!form?.querySelector(`[name="${key}"]`)?.value) ok = false
			}
		}
		if (category === "NoShow" && !noShowPenaltyTypeSel?.value) ok = false
		if (!ok) setClientError("Completa los campos requeridos para esta categoría.")
		return ok
	}

	categorySel?.addEventListener("change", updateCategoryUI)
	paymentTypeSel?.addEventListener("change", updatePaymentUI)
	noShowPenaltyTypeSel?.addEventListener("change", updateNoShowUI)
	form?.addEventListener("submit", (event) => {
		if (!validate()) event.preventDefault()
	})
	updateCategoryUI()
	updatePaymentUI()
	updateNoShowUI()
</script>
