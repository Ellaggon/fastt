---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import Section from "@/components/ui/Section.astro"
import Select from "@/components/ui/Select.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { resolveEffectivePolicies } from "@/modules/policies/public"
import { db, eq, inArray, PolicyAuditLog, Product, RatePlan, Variant } from "astro:db"

try {
	await requireProvider(Astro.request)
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

const { providerId } = await requireProvider(Astro.request)

const qPolicyId = String(Astro.url.searchParams.get("policyId") ?? "").trim()
const qRatePlanId = String(Astro.url.searchParams.get("ratePlanId") ?? "").trim()
const qEventType = String(Astro.url.searchParams.get("eventType") ?? "").trim()

const products = await db
	.select({ id: Product.id, name: Product.name })
	.from(Product)
	.where(eq(Product.providerId, providerId))
	.all()
const productIds = products.map((row) => String(row.id)).filter(Boolean)
const variants = productIds.length
	? await db
			.select({ id: Variant.id, productId: Variant.productId, name: Variant.name })
			.from(Variant)
			.where(inArray(Variant.productId, productIds))
			.all()
	: []
const variantIds = variants.map((row) => String(row.id)).filter(Boolean)
const ratePlans = variantIds.length
	? await db
			.select({ id: RatePlan.id, variantId: RatePlan.variantId })
			.from(RatePlan)
			.where(inArray(RatePlan.variantId, variantIds))
			.all()
	: []

const variantToProduct = new Map(variants.map((row) => [String(row.id), String(row.productId)]))
const ratePlanToVariant = new Map(ratePlans.map((row) => [String(row.id), String(row.variantId)]))
const productNameById = new Map(products.map((row) => [String(row.id), String(row.name)]))

const rawAuditRows = await db
	.select({
		id: PolicyAuditLog.id,
		eventType: PolicyAuditLog.eventType,
		actorUserId: PolicyAuditLog.actorUserId,
		policyId: PolicyAuditLog.policyId,
		policyGroupId: PolicyAuditLog.policyGroupId,
		assignmentId: PolicyAuditLog.assignmentId,
		scope: PolicyAuditLog.scope,
		scopeId: PolicyAuditLog.scopeId,
		channel: PolicyAuditLog.channel,
		beforeJson: PolicyAuditLog.beforeJson,
		afterJson: PolicyAuditLog.afterJson,
		createdAt: PolicyAuditLog.createdAt,
	})
	.from(PolicyAuditLog)
	.all()

const auditRows = rawAuditRows
	.filter((row) => {
		const scope = String(row.scope ?? "")
		const scopeId = String(row.scopeId ?? "")
		if (scope === "product") return productIds.includes(scopeId)
		if (scope === "variant") return variantIds.includes(scopeId)
		if (scope === "rate_plan") return ratePlans.some((rp) => String(rp.id) === scopeId)
		if (!scope) return true
		return false
	})
	.filter((row) => (!qPolicyId ? true : String(row.policyId ?? "") === qPolicyId))
	.filter((row) => (!qEventType ? true : String(row.eventType ?? "") === qEventType))
	.filter((row) => {
		if (!qRatePlanId) return true
		return String(row.scope ?? "") === "rate_plan" && String(row.scopeId ?? "") === qRatePlanId
	})
	.sort((a, b) => String(b.createdAt ?? "").localeCompare(String(a.createdAt ?? "")))
	.slice(0, 200)

function summarizeJson(input: unknown): string {
	if (!input || typeof input !== "object") return "—"
	const obj = input as Record<string, unknown>
	const parts: string[] = []
	if (obj.assignmentId) parts.push(`asignación: ${String(obj.assignmentId)}`)
	if (obj.policyGroupId) parts.push(`grupo: ${String(obj.policyGroupId)}`)
	if (obj.scope) parts.push(`nivel: ${String(obj.scope)}:${String(obj.scopeId ?? "")}`)
	if (obj.channel) parts.push(`canal: ${String(obj.channel)}`)
	if (obj.version) parts.push(`versión: v${String(obj.version)}`)
	if (obj.effectiveFrom || obj.effectiveTo) {
		parts.push(`vigencia: ${String(obj.effectiveFrom ?? "—")} → ${String(obj.effectiveTo ?? "∞")}`)
	}
	if (!parts.length) {
		const keys = Object.keys(obj).slice(0, 4)
		if (!keys.length) return "—"
		return keys.map((key) => `${key}: ${String((obj as any)[key])}`).join(" · ")
	}
	return parts.join(" · ")
}

function scopeLabel(scope: string | null, scopeId: string | null): string {
	const normalizedScope = String(scope ?? "")
	const id = String(scopeId ?? "")
	if (!normalizedScope) return "n/a"
	if (normalizedScope === "product") {
		return `${productNameById.get(id) ?? id}`
	}
	if (normalizedScope === "variant") {
		const productId = variantToProduct.get(id)
		return `${productNameById.get(String(productId ?? "")) ?? "Producto"} / ${id}`
	}
	if (normalizedScope === "rate_plan") {
		const variantId = ratePlanToVariant.get(id)
		const productId = variantId ? variantToProduct.get(variantId) : null
		return `${productNameById.get(String(productId ?? "")) ?? "Producto"} / ${String(variantId ?? "?")} / ${id}`
	}
	return `${normalizedScope}:${id}`
}

function scopeName(scope: string | null | undefined): string {
	if (scope === "rate_plan") return "Tarifa"
	if (scope === "variant") return "Variante"
	if (scope === "product") return "Producto"
	if (!scope) return "Sin ámbito"
	return String(scope)
}

function categoryLabel(category: string | null | undefined): string {
	if (category === "Cancellation") return "Cancelación"
	if (category === "Payment") return "Pago"
	if (category === "CheckIn") return "Ingreso"
	if (category === "NoShow") return "No presentación"
	return String(category ?? "—")
}

const traceProductId = String(Astro.url.searchParams.get("traceProductId") ?? "").trim()
const traceVariantId = String(Astro.url.searchParams.get("traceVariantId") ?? "").trim()
const traceRatePlanId = String(Astro.url.searchParams.get("traceRatePlanId") ?? "").trim()
const traceChannel = String(Astro.url.searchParams.get("traceChannel") ?? "").trim()
const traceCheckIn = String(Astro.url.searchParams.get("traceCheckIn") ?? "").trim()
const traceCheckOut = String(Astro.url.searchParams.get("traceCheckOut") ?? "").trim()

let traceError: string | null = null
let traceResult: (Awaited<ReturnType<typeof resolveEffectivePolicies>> & { trace?: any }) | null =
	null

if (traceProductId) {
	try {
		traceResult = await resolveEffectivePolicies({
			productId: traceProductId,
			variantId: traceVariantId || undefined,
			ratePlanId: traceRatePlanId || undefined,
			checkIn: traceCheckIn || undefined,
			checkOut: traceCheckOut || undefined,
			channel: traceChannel || undefined,
			requiredCategories: ["Cancellation", "Payment", "CheckIn", "NoShow"],
			onMissingCategory: "return_null",
			includeTrace: true,
		})
	} catch (error: any) {
		traceError = String(error?.message ?? error)
	}
}

const eventTypes = Array.from(
	new Set(rawAuditRows.map((row) => String(row.eventType ?? "")).filter(Boolean))
).sort()
---

<WorkspaceLayout title="Auditoría de políticas (avanzado)">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<h1 class="text-3xl font-semibold text-slate-100">Auditoría de políticas (avanzado)</h1>
				<p class="text-sm text-slate-300">Observabilidad y trazabilidad de cambios en políticas.</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href="/provider/policies" variant="secondary">Biblioteca de políticas</Button>
				<Button href="/product" variant="primary">Volver a operación de tarifas</Button>
			</div>
		</header>

		<div class="rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm text-blue-900">
			Esta sección es de control y trazabilidad, no de operación diaria.
		</div>

		<Section
			title="Registro de auditoría"
			description="Eventos de creación de versiones y reemplazo de asignaciones."
		>
			<Card className="space-y-6 bg-white">
				<form method="GET" class="grid gap-4 md:grid-cols-4">
					<FormField label="ID de política (avanzado)" htmlFor="policyId">
						<Input id="policyId" name="policyId" value={qPolicyId} placeholder="UUID de política" />
					</FormField>
					<FormField label="ID de tarifa (avanzado)" htmlFor="ratePlanId">
						<Input
							id="ratePlanId"
							name="ratePlanId"
							value={qRatePlanId}
							placeholder="UUID de tarifa"
						/>
					</FormField>
					<FormField label="Tipo de evento" htmlFor="eventType">
						<Select id="eventType" name="eventType">
							<option value="">Todos</option>
							{
								eventTypes.map((eventType) => (
									<option value={eventType} selected={qEventType === eventType}>
										{eventType}
									</option>
								))
							}
						</Select>
					</FormField>
					<div class="flex items-end">
						<Button type="submit" variant="primary">Aplicar filtros</Button>
					</div>
				</form>

				<div class="overflow-x-auto">
					<table class="min-w-full text-sm">
						<thead>
							<tr class="border-b border-slate-200 text-left text-slate-500">
								<th class="py-2 pr-4">Fecha y hora</th>
								<th class="py-2 pr-4">Actor</th>
								<th class="py-2 pr-4">Evento</th>
								<th class="py-2 pr-4">Ámbito</th>
								<th class="py-2 pr-4">Antes</th>
								<th class="py-2 pr-4">Después</th>
							</tr>
						</thead>
						<tbody>
							{
								auditRows.map((row) => (
									<tr class="border-b border-slate-100 text-slate-700">
										<td class="py-2 pr-4">{String(row.createdAt ?? "—")}</td>
										<td class="py-2 pr-4">{String(row.actorUserId ?? "system")}</td>
										<td class="py-2 pr-4">
											<Badge variant="info">{String(row.eventType ?? "—")}</Badge>
										</td>
										<td class="py-2 pr-4">{scopeLabel(row.scope as any, row.scopeId as any)}</td>
										<td class="py-2 pr-4">{summarizeJson(row.beforeJson)}</td>
										<td class="py-2 pr-4">{summarizeJson(row.afterJson)}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
				{
					auditRows.length === 0 && (
						<p class="text-sm text-slate-600">No hay eventos para los filtros seleccionados.</p>
					)
				}
			</Card>
		</Section>

		<Section
			title="Traza de resolución"
			description="Candidatos, filtros, prioridad y resultado final de resolución."
		>
			<Card className="space-y-6 bg-white">
				<form method="GET" class="grid gap-4 md:grid-cols-4">
					<FormField label="Producto" htmlFor="traceProductId" required>
						<Select id="traceProductId" name="traceProductId" required>
							<option value="">Selecciona producto</option>
							{
								products.map((product) => (
									<option
										value={String(product.id)}
										selected={traceProductId === String(product.id)}
									>
										{String(product.name)}
									</option>
								))
							}
						</Select>
					</FormField>
					<FormField label="Variante (opcional)" htmlFor="traceVariantId">
						<Input
							id="traceVariantId"
							name="traceVariantId"
							value={traceVariantId}
							placeholder="ID de variante"
						/>
					</FormField>
					<FormField label="Tarifa (opcional)" htmlFor="traceRatePlanId">
						<Input
							id="traceRatePlanId"
							name="traceRatePlanId"
							value={traceRatePlanId}
							placeholder="ID de tarifa"
						/>
					</FormField>
					<FormField label="Canal" htmlFor="traceChannel">
						<Input id="traceChannel" name="traceChannel" value={traceChannel} placeholder="web" />
					</FormField>

					<FormField label="Check-in" htmlFor="traceCheckIn">
						<Input id="traceCheckIn" name="traceCheckIn" type="date" value={traceCheckIn} />
					</FormField>
					<FormField label="Check-out" htmlFor="traceCheckOut">
						<Input id="traceCheckOut" name="traceCheckOut" type="date" value={traceCheckOut} />
					</FormField>
					<input type="hidden" name="policyId" value={qPolicyId} />
					<input type="hidden" name="ratePlanId" value={qRatePlanId} />
					<input type="hidden" name="eventType" value={qEventType} />
					<div class="flex items-end">
						<Button type="submit" variant="primary">Ejecutar traza</Button>
					</div>
				</form>

				{traceError && <Badge variant="error">{traceError}</Badge>}
				{
					traceResult?.trace && (
						<div class="space-y-4">
							<div class="grid gap-3 md:grid-cols-4">
								<Badge variant="info">Fecha de referencia: {traceResult.trace.asOfDate}</Badge>
								<Badge variant="neutral">Asignaciones: {traceResult.trace.assignmentsCount}</Badge>
								<Badge variant={traceResult.missingCategories.length ? "warning" : "success"}>
									Categorías faltantes: {traceResult.missingCategories.length}
								</Badge>
								<Badge variant={traceResult.trace.conflicts.length ? "warning" : "success"}>
									Conflictos: {traceResult.trace.conflicts.length}
								</Badge>
							</div>

							{traceResult.trace.conflicts.length > 0 && (
								<div class="rounded-lg border border-amber-200 bg-amber-50 p-3 text-sm text-amber-800">
									<p class="font-medium">Conflictos detectados</p>
									<ul class="mt-1 list-disc space-y-1 pl-5">
										{traceResult.trace.conflicts.map((conflict: any) => (
											<li>
												{conflict.key} ({conflict.count})
											</li>
										))}
									</ul>
								</div>
							)}

							{traceResult.trace.categories.map((categoryTrace: any) => (
								<div class="rounded-lg border border-slate-200 p-4">
									<div class="mb-3 flex items-center justify-between">
										<h3 class="text-sm font-semibold text-slate-900">
											{categoryLabel(categoryTrace.category)}
										</h3>
										{categoryTrace.winner ? (
											<Badge variant="success">
												Ganadora: {scopeName(categoryTrace.winner.scope)} · v
												{categoryTrace.winner.version}
											</Badge>
										) : (
											<Badge variant="warning">Sin resultado</Badge>
										)}
									</div>
									<div class="overflow-x-auto">
										<table class="min-w-full text-xs">
											<thead>
												<tr class="border-b border-slate-200 text-left text-slate-500">
													<th class="py-2 pr-3">Ámbito</th>
													<th class="py-2 pr-3">ID de ámbito</th>
													<th class="py-2 pr-3">Candidatas</th>
													<th class="py-2 pr-3">Canal</th>
													<th class="py-2 pr-3">Políticas activas</th>
													<th class="py-2 pr-3">Resultado</th>
												</tr>
											</thead>
											<tbody>
												{categoryTrace.steps.map((step: any) => (
													<tr class="border-b border-slate-100 text-slate-700">
														<td class="py-2 pr-3">{scopeName(step.scope)}</td>
														<td class="py-2 pr-3">{step.scopeId}</td>
														<td class="py-2 pr-3">{step.candidates}</td>
														<td class="py-2 pr-3">{step.channelCandidates}</td>
														<td class="py-2 pr-3">{step.withActivePolicy}</td>
														<td class="py-2 pr-3">{step.reason}</td>
													</tr>
												))}
											</tbody>
										</table>
									</div>
								</div>
							))}
						</div>
					)
				}
			</Card>
		</Section>
	</div>
</WorkspaceLayout>
