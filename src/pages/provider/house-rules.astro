			label: "Extra beds",
			intent: "Operational guidance for cribs, extra beds and sleeping arrangements.",
			guestFacing: "Can guests request extra beds or cribs?",
		},
		Access: {
			label: "Access",
			intent: "Self check-in, keys, locks and access method guidance.",
			guestFacing: "How do guests enter and use access devices?",
		},
		Other: {
			label: "Additional rule",
			intent:
				"Any property-use rule that does not belong to pricing, restrictions or contract terms.",
			guestFacing: "What else should guests know before staying?",
		},
	}

async function loadProviderProducts(providerId: string): Promise<ProductOption[]> {
	const rows = await db
		.select({
			id: Product.id,
			name: Product.name,
			productType: Product.productType,
		})
		.from(Product)
		.where(eq(Product.providerId, providerId))
		.all()
	return rows.map((row) => ({
		id: String(row.id),
		name: String(row.name),
		productType: String(row.productType ?? "Property"),
	}))
}

async function loadRulesByProduct(products: ProductOption[]) {
	const pairs = await Promise.all(
		products.map(async (product) => ({
			productId: product.id,
			rules: (await listHouseRulesByProduct(product.id)) as HouseRule[],
		}))
	)
	return new Map(pairs.map((pair) => [pair.productId, pair.rules]))
}

function boolFromForm(form: FormData, key: string): boolean | undefined {
	const raw = String(form.get(key) ?? "").trim()
	if (raw === "true") return true
	if (raw === "false") return false
	return undefined
}

function listFromForm(form: FormData, key: string): string[] {
	return form
		.getAll(key)
		.map((item) => String(item ?? "").trim())
		.filter(Boolean)
}

function payloadFromForm(type: HouseRuleType, form: FormData): HouseRulePayload {
	const note = String(form.get("note") ?? "").trim()
	const base: HouseRulePayload = { kind: type }
	if (note) base.note = note

	switch (type) {
		case "Pets":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				feeNote: String(form.get("feeNote") ?? "").trim() || undefined,
			}
		case "Children":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				conditions: String(form.get("conditions") ?? "").trim() || undefined,
			}
		case "Smoking":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				area: (String(form.get("smokingArea") ?? "").trim() || undefined) as any,
			}
		case "Parties":
			return { ...base, allowed: boolFromForm(form, "allowed") }
		case "QuietHours":
			return {
				...base,
				start: String(form.get("quietStart") ?? "").trim() || undefined,
				end: String(form.get("quietEnd") ?? "").trim() || undefined,
			}
		case "Parking":
			return {
				...base,
				available: boolFromForm(form, "available"),
				parkingType: (String(form.get("parkingType") ?? "").trim() || undefined) as any,
			}
		case "CheckIn":
		case "Access":
			return {
				...base,
				method: (String(form.get("checkInMethod") ?? "").trim() || undefined) as any,
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
				idRequired: form.get("idRequired") === "on",
				cardRequired: form.get("cardRequired") === "on",
			}
		case "Checkout":
			return {
				...base,
				time: String(form.get("checkoutTime") ?? "").trim() || undefined,
				tasks: listFromForm(form, "checkoutTasks"),
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
			}
		default:
			return {
				...base,
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
			}
	}
}

let actionError: string | null = null
const requestedProductId = String(Astro.url.searchParams.get("productId") ?? "").trim()

const redirectToHouseRules = (success: string, productId?: string) => {
	const params = new URLSearchParams({ success })
	const contextualProductId = String(productId ?? "").trim()
	if (contextualProductId) params.set("productId", contextualProductId)
	return Astro.redirect(`${routes.providerHouseRules()}?${params.toString()}`)
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData()
	const action = String(form.get("action") ?? "").trim()
	try {
		const products = await loadProviderProducts(auth.providerId)
		const ownedProductIds = new Set(products.map((product) => product.id))
		if (action === "create-house-rule") {
			const productId = String(form.get("productId") ?? "").trim()
			const type = String(form.get("type") ?? "").trim() as HouseRuleType
			const description = String(form.get("description") ?? "").trim()
			const payload = payloadFromForm(type, form)
			if (!ownedProductIds.has(productId)) throw new Error("Property is not available")
			if (!houseRuleTypes.includes(type)) throw new Error("Unsupported house rule category")
			await createHouseRule({ productId, type, description, payload })
			return redirectToHouseRules("created", productId)
		}
		if (action === "apply-quick-setup") {
			const productId = String(form.get("productId") ?? "").trim()
			const presetKey = String(form.get("presetKey") ?? "").trim()
			const preset = quickSetupPresets.find((item) => item.key === presetKey)
			if (!ownedProductIds.has(productId)) throw new Error("Property is not available")
			if (!preset) throw new Error("Quick setup preset is not available")

			const rulesByProduct = await loadRulesByProduct(products)
			const existingTypes = new Set(
				(rulesByProduct.get(productId) ?? []).map((rule) => String(rule.type ?? "Other"))
			)
			for (const item of preset.rules) {
				if (existingTypes.has(item.type)) continue
				await createHouseRule({ productId, type: item.type, payload: item.payload })
				existingTypes.add(item.type)
			}
			return redirectToHouseRules("preset-applied", productId)
		}
		if (action === "delete-house-rule") {
			const ruleId = String(form.get("ruleId") ?? "").trim()
			const rulesByProduct = await loadRulesByProduct(products)
			const ownedRule = Array.from(rulesByProduct.values())
				.flat()
				.find((rule) => String(rule.id) === ruleId)
			if (!ownedRule) throw new Error("House rule is not available")
			await deleteHouseRule(ruleId)
			return redirectToHouseRules("deleted", ownedRule.productId)
		}
	} catch (error) {
		actionError = error instanceof Error ? error.message : "House rule action failed"
	}
}

const products = await loadProviderProducts(auth.providerId)
const rulesByProduct = await loadRulesByProduct(products)
const allRules = Array.from(rulesByProduct.values()).flat()
const success = String(Astro.url.searchParams.get("success") ?? "").trim()
const selectedProduct =
	products.find((product) => product.id === requestedProductId) ?? products[0] ?? null
const selectedProductId = selectedProduct?.id ?? ""
const hasProductContext = Boolean(requestedProductId && selectedProduct)
const visibleProducts = hasProductContext && selectedProduct ? [selectedProduct] : products
const rulesByType = new Map<HouseRuleType, number>()
for (const type of houseRuleTypes) rulesByType.set(type, 0)
for (const rule of allRules) {
	const type = String(rule.type ?? "Other") as HouseRuleType
	rulesByType.set(type, (rulesByType.get(type) ?? 0) + 1)
}
const readinessByProduct = products.map((product) => {
	const rules = rulesByProduct.get(product.id) ?? []
	const typeSet = new Set(rules.map((rule) => String(rule.type ?? "Other") as HouseRuleType))
	const completedEssentials = essentialRuleTypes.filter((type) => typeSet.has(type))
	const missingEssentials = essentialRuleTypes.filter((type) => !typeSet.has(type))
	const progress = essentialRuleTypes.length
		? Math.round((completedEssentials.length / essentialRuleTypes.length) * 100)
		: 0
	return {
		product,
		rules,
		typeSet,
		completedEssentials,
		missingEssentials,
		progress,
		ready: missingEssentials.length === 0,
	}
})
const readyProducts = readinessByProduct.filter((item) => item.ready).length
const averageReadiness = readinessByProduct.length
	? Math.round(
			readinessByProduct.reduce((sum, item) => sum + item.progress, 0) / readinessByProduct.length
		)
	: 0
const selectedPreview =
	(hasProductContext
		? readinessByProduct.find((item) => item.product.id === selectedProductId)
		: readinessByProduct.find((item) => item.rules.length)) ?? readinessByProduct[0]
const previewRules = selectedPreview?.rules ?? []
const previewRulesByGroup = houseRuleGroups.map((group) => ({
	...group,
	rules: previewRules.filter((rule) =>
		group.types.includes(String(rule.type ?? "Other") as HouseRuleType)
	),
}))
---

<WorkspaceLayout title="Reglas de la casa">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Contenido del alojamiento · Reglas para huéspedes
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">
					{
						hasProductContext && selectedProduct
							? `Reglas de ${selectedProduct.name}`
							: "Reglas de la casa"
					}
				</h1>
				<p class="max-w-4xl text-sm leading-6 text-slate-300">
					{
						hasProductContext && selectedProduct
							? "Edita las expectativas de estadía de este alojamiento. Se verán junto a su ficha y vista previa."
							: "Define cómo deben comportarse los huéspedes y cómo funciona cada alojamiento durante la estadía."
					}
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				{
					hasProductContext && selectedProduct ? (
						<Button href={routes.productDetail(selectedProduct.id)} variant="secondary">
							Volver a la ficha
						</Button>
					) : (
						<Button href={routes.productList()} variant="secondary">
							Alojamientos
						</Button>
					)
				}
				<Button href={routes.providerPolicies()} variant="secondary">Condiciones</Button>
				{
					hasProductContext && selectedProduct ? (
						<Button href={routes.productPreview(selectedProduct.id)} variant="secondary">
							Vista previa
						</Button>
					) : null
				}
			</div>
		</header>

		{
			actionError && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">Could not update house rules</p>
					<p class="mt-1 text-sm">{actionError}</p>
				</Card>
			)
		}
		{
			success === "created" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">House rule created.</p>
					<p class="mt-1 text-sm">
						The rule is now part of property content and guest expectations.
					</p>
				</Card>
			)
		}
		{
			success === "preset-applied" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">Quick setup applied.</p>
					<p class="mt-1 text-sm">
						Missing stay expectations were added without duplicating existing house rules.
					</p>
				</Card>
			)
		}
		{
			success === "deleted" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">House rule removed.</p>
				</Card>
			)
		}

		{
			hasProductContext && selectedPreview ? (
				<Card className="border-blue-100 bg-blue-50 text-blue-950">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<div class="space-y-1">
							<p class="text-sm font-semibold">Parte de la ficha del alojamiento</p>
							<p class="max-w-3xl text-sm leading-6 text-blue-900">
								Estas reglas pertenecen a {selectedPreview.product.name}. Completa mascotas, fumar,
								fiestas, silencio, llegada y salida para que el huésped entienda la estadía.
							</p>
						</div>
						<Badge variant={selectedPreview.ready ? "success" : "warning"}>
							{selectedPreview.ready
								? "Listo para huéspedes"
								: `${selectedPreview.missingEssentials.length} pendientes`}
						</Badge>
					</div>
				</Card>
			) : (
				<section class="grid gap-4 md:grid-cols-4">
					<Card className="border-slate-800 bg-slate-950 text-slate-100">
						<p class="text-xs tracking-wide text-slate-500 uppercase">Alojamientos</p>
						<p class="mt-2 text-2xl font-semibold">{products.length}</p>
						<p class="mt-1 text-xs text-slate-400">Con reglas configurables</p>
					</Card>
					<Card className="border-slate-800 bg-slate-950 text-slate-100">
						<p class="text-xs tracking-wide text-slate-500 uppercase">Reglas</p>
						<p class="mt-2 text-2xl font-semibold">{allRules.length}</p>
						<p class="mt-1 text-xs text-slate-400">Expectativas visibles para huéspedes</p>
					</Card>
					<Card className="border-slate-800 bg-slate-950 text-slate-100">
						<p class="text-xs tracking-wide text-slate-500 uppercase">Preparación</p>
						<p class="mt-2 text-2xl font-semibold">{averageReadiness}%</p>
						<p class="mt-1 text-xs text-slate-400">Promedio de reglas esenciales</p>
					</Card>
					<Card className="border-slate-800 bg-slate-950 text-slate-100">
						<p class="text-xs tracking-wide text-slate-500 uppercase">Listos</p>
						<p class="mt-2 text-2xl font-semibold">{readyProducts}</p>
						<p class="mt-1 text-xs text-slate-400">Con reglas esenciales completas</p>
					</Card>
				</section>
			)
		}

		<section class="grid gap-4 xl:grid-cols-[1.15fr_0.85fr]">
			<Card className="space-y-5 border-blue-200 bg-blue-50 text-blue-950">
				<div class="flex flex-wrap items-start justify-between gap-3">
					<div>
						<p class="text-sm font-semibold">Stay expectations readiness</p>
						<p class="mt-1 max-w-2xl text-sm text-blue-900">
							Core house rules help guests self-select before booking and reduce avoidable arrival
							friction. They stay operational: not pricing, not restrictions, not booking-contract
							penalties.
						</p>
					</div>
					<Badge variant={averageReadiness >= 80 ? "success" : "warning"}>
						{averageReadiness}% coverage
					</Badge>
				</div>
				<div class="grid gap-3 md:grid-cols-3">
					<div class="rounded-lg border border-blue-100 bg-white/70 p-3">
						<p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Guests decide</p>
						<p class="mt-1 text-sm text-blue-950">Pets, smoking, parties and quiet hours.</p>
					</div>
					<div class="rounded-lg border border-blue-100 bg-white/70 p-3">
						<p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Guests arrive</p>
						<p class="mt-1 text-sm text-blue-950">Check-in, access, ID and parking guidance.</p>
					</div>
					<div class="rounded-lg border border-blue-100 bg-white/70 p-3">
						<p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Guests leave</p>
						<p class="mt-1 text-sm text-blue-950">Checkout time and lightweight departure tasks.</p>
					</div>
				</div>
			</Card>

			<Card className="space-y-4 bg-white text-slate-800">
				<div class="flex flex-wrap items-center justify-between gap-3">
					<div>
						<p class="text-sm font-semibold text-slate-900">Configuración rápida</p>
						<p class="mt-1 text-sm text-slate-600">
							Agrega reglas habituales al alojamiento seleccionado sin duplicar categorías
							existentes.
						</p>
					</div>
				</div>
				{
					products.length ? (
						<div class="grid gap-3">
							{quickSetupPresets.map((preset) => (
								<form method="POST" class="rounded-lg border border-slate-200 bg-slate-50 p-3">
									<input type="hidden" name="action" value="apply-quick-setup" />
									<input type="hidden" name="presetKey" value={preset.key} />
									<label class="block space-y-1 text-sm">
										<span class="font-medium text-slate-700">{preset.title}</span>
										<select
											name="productId"
											class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2"
										>
											{visibleProducts.map((product) => (
												<option value={product.id} selected={product.id === selectedProductId}>
													{product.name}
												</option>
											))}
										</select>
									</label>
									<p class="mt-2 text-sm text-slate-600">{preset.description}</p>
									<div class="mt-3 flex justify-end">
										<Button type="submit" variant="secondary" size="sm">
											Completar reglas faltantes
										</Button>
									</div>
								</form>
							))}
						</div>
					) : (
						<p class="text-sm text-slate-600">
							Crea un alojamiento antes de usar la configuración rápida.
						</p>
					)
				}
			</Card>
		</section>

		<Section
			title={hasProductContext ? "Preparación de este alojamiento" : "Preparación por alojamiento"}
