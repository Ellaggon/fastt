---
import { db, eq, Product } from "astro:db"

import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { syncHotelArrivalPolicy } from "@/lib/policies/syncHotelArrivalPolicy"
import { routes } from "@/lib/routes"
import {
	essentialHouseRuleTypes,
	houseRuleCopy,
	houseRuleEditorTypes,
	houseRuleGroups,
	houseRuleQuickSetups,
	houseRuleTypes,
} from "@/modules/house-rules/presentation/houseRulePresentation"
import {
	buildHouseRuleGuestSummary,
	createHouseRule,
	deleteHouseRule,
	listHouseRulesByProduct,
	type HouseRule,
	type HouseRulePayload,
	type HouseRuleType,
} from "@/modules/house-rules/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

type ProductOption = {
	id: string
	name: string
	productType: string
}

async function loadProviderProducts(providerId: string): Promise<ProductOption[]> {
	const rows = await db
		.select({
			id: Product.id,
			name: Product.name,
			productType: Product.productType,
		})
		.from(Product)
		.where(eq(Product.providerId, providerId))
		.all()
	return rows.map((row) => ({
		id: String(row.id),
		name: String(row.name),
		productType: String(row.productType ?? "Alojamiento"),
	}))
}

async function loadRulesByProduct(products: ProductOption[]) {
	const pairs = await Promise.all(
		products.map(async (product) => ({
			productId: product.id,
			rules: (await listHouseRulesByProduct(product.id)) as HouseRule[],
		}))
	)
	return new Map(pairs.map((pair) => [pair.productId, pair.rules]))
}

function boolFromForm(form: FormData, key: string): boolean | undefined {
	const raw = String(form.get(key) ?? "").trim()
	if (raw === "true") return true
	if (raw === "false") return false
	return undefined
}

function listFromForm(form: FormData, key: string): string[] {
	return form
		.getAll(key)
		.map((item) => String(item ?? "").trim())
		.filter(Boolean)
}

function payloadFromForm(type: HouseRuleType, form: FormData): HouseRulePayload {
	const note = String(form.get("note") ?? "").trim()
	const base: HouseRulePayload = { kind: type }
	if (note) base.note = note

	switch (type) {
		case "Pets":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				feeNote: String(form.get("feeNote") ?? "").trim() || undefined,
			}
		case "Children":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				conditions: String(form.get("conditions") ?? "").trim() || undefined,
			}
		case "Smoking":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				area: (String(form.get("smokingArea") ?? "").trim() || undefined) as any,
			}
		case "Parties":
			return { ...base, allowed: boolFromForm(form, "allowed") }
		case "QuietHours":
			return {
				...base,
				start: String(form.get("quietStart") ?? "").trim() || undefined,
				end: String(form.get("quietEnd") ?? "").trim() || undefined,
			}
		case "Parking":
			return {
				...base,
				available: boolFromForm(form, "available"),
				parkingType: (String(form.get("parkingType") ?? "").trim() || undefined) as any,
			}
		case "CheckIn":
		case "Access":
			return {
				...base,
				method: (String(form.get("checkInMethod") ?? "").trim() || undefined) as any,
				checkInFrom: String(form.get("checkInFrom") ?? "").trim() || undefined,
				checkInUntil: String(form.get("checkInUntil") ?? "").trim() || undefined,
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
				idRequired: form.get("idRequired") === "on",
				cardRequired: form.get("cardRequired") === "on",
			}
		case "Checkout":
			return {
				...base,
				time: String(form.get("checkoutTime") ?? "").trim() || undefined,
				tasks: listFromForm(form, "checkoutTasks"),
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
			}
		default:
			return {
				...base,
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
			}
	}
}

let actionError: string | null = null
const requestedProductId = String(Astro.url.searchParams.get("productId") ?? "").trim()

function redirectToHouseRules(success: string, productId?: string) {
	const params = new URLSearchParams({ success })
	const contextualProductId = String(productId ?? "").trim()
	if (contextualProductId) params.set("productId", contextualProductId)
	return Astro.redirect(`${routes.providerHouseRules()}?${params.toString()}`)
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData()
	const action = String(form.get("action") ?? "").trim()
	try {
		const products = await loadProviderProducts(auth.providerId)
		const ownedProductIds = new Set(products.map((product) => product.id))
		if (action === "create-house-rule") {
			const productId = String(form.get("productId") ?? "").trim()
			const type = String(form.get("type") ?? "").trim() as HouseRuleType
			const payload = payloadFromForm(type, form)
			if (!ownedProductIds.has(productId)) throw new Error("El alojamiento no está disponible")
			if (!houseRuleTypes.includes(type)) throw new Error("Tipo de regla no compatible")
			await createHouseRule({ productId, type, payload })
			if (type === "CheckIn" || type === "Checkout") {
				await syncHotelArrivalPolicy({
					providerId: auth.providerId,
					productId,
					actorUserId: auth.user.id,
					rules: (await listHouseRulesByProduct(productId)) as HouseRule[],
				})
			}
			return redirectToHouseRules("created", productId)
		}
		if (action === "apply-quick-setup") {
			const productId = String(form.get("productId") ?? "").trim()
			const presetKey = String(form.get("presetKey") ?? "").trim()
			const preset = houseRuleQuickSetups.find((item) => item.key === presetKey)
			if (!ownedProductIds.has(productId)) throw new Error("El alojamiento no está disponible")
			if (!preset) throw new Error("La configuración rápida no está disponible")

			const rulesByProduct = await loadRulesByProduct(products)
			const existingTypes = new Set(
				(rulesByProduct.get(productId) ?? []).map((rule) => String(rule.type ?? "Other"))
			)
			for (const item of preset.rules) {
				if (existingTypes.has(item.type)) continue
				await createHouseRule({ productId, type: item.type, payload: item.payload })
				existingTypes.add(item.type)
			}
			await syncHotelArrivalPolicy({
				providerId: auth.providerId,
				productId,
				actorUserId: auth.user.id,
				rules: (await listHouseRulesByProduct(productId)) as HouseRule[],
			})
			return redirectToHouseRules("preset-applied", productId)
		}
		if (action === "delete-house-rule") {
			const ruleId = String(form.get("ruleId") ?? "").trim()
			const rulesByProduct = await loadRulesByProduct(products)
			const ownedRule = Array.from(rulesByProduct.values())
				.flat()
				.find((rule) => String(rule.id) === ruleId)
			if (!ownedRule) throw new Error("La regla no está disponible")
			await deleteHouseRule(ruleId)
			if (ownedRule.type === "CheckIn" || ownedRule.type === "Checkout") {
				await syncHotelArrivalPolicy({
					providerId: auth.providerId,
					productId: ownedRule.productId,
					actorUserId: auth.user.id,
					rules: (await listHouseRulesByProduct(ownedRule.productId)) as HouseRule[],
				})
			}
			return redirectToHouseRules("deleted", ownedRule.productId)
		}
	} catch (error) {
		actionError = error instanceof Error ? error.message : "No se pudo actualizar la regla"
	}
}

const products = await loadProviderProducts(auth.providerId)
const rulesByProduct = await loadRulesByProduct(products)
const allRules = Array.from(rulesByProduct.values()).flat()
const success = String(Astro.url.searchParams.get("success") ?? "").trim()
const focus = String(Astro.url.searchParams.get("focus") ?? "").trim()
const selectedProduct =
	products.find((product) => product.id === requestedProductId) ?? products[0] ?? null
const selectedProductId = selectedProduct?.id ?? ""
const hasProductContext = Boolean(requestedProductId && selectedProduct)
const visibleProducts = hasProductContext && selectedProduct ? [selectedProduct] : products
const stateByProduct = products.map((product) => {
	const rules = rulesByProduct.get(product.id) ?? []
	const typeSet = new Set(rules.map((rule) => String(rule.type ?? "Other") as HouseRuleType))
	const missingEssentials = essentialHouseRuleTypes.filter((type) => !typeSet.has(type))
	return {
		product,
		rules,
		typeSet,
		missingEssentials,
		ready: missingEssentials.length === 0,
	}
})
const selectedState =
	(hasProductContext
		? stateByProduct.find((item) => item.product.id === selectedProductId)
		: stateByProduct.find((item) => item.rules.length)) ?? stateByProduct[0]
const previewRules = selectedState?.rules ?? []
const previewRulesByGroup = houseRuleGroups.map((group) => ({
	...group,
	rules: previewRules.filter((rule) =>
		group.types.includes(String(rule.type ?? "Other") as HouseRuleType)
	),
}))
const missingCount = selectedState?.missingEssentials.length ?? essentialHouseRuleTypes.length
const selectedReady = Boolean(selectedState?.ready)
const selectedRulesByType = new Map<HouseRuleType, HouseRule[]>()
for (const rule of previewRules) {
	const type = String(rule.type ?? "Other") as HouseRuleType
	const rules = selectedRulesByType.get(type) ?? []
	rules.push(rule)
	selectedRulesByType.set(type, rules)
}
const internalRuleCount = allRules.length
---

<WorkspaceLayout title="Reglas para huéspedes">
	<div class="space-y-5">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Alojamientos · Reglas para huéspedes
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">
					{
						hasProductContext && selectedProduct
							? `Reglas de ${selectedProduct.name}`
							: "Reglas para huéspedes"
					}
				</h1>
				<p class="max-w-2xl text-sm leading-6 text-slate-300">
					Edita por bloques lo que verá el huésped antes de reservar.
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				{
					hasProductContext && selectedProduct ? (
						<Button href={routes.productDetail(selectedProduct.id)} variant="secondary">
							Volver a la ficha
						</Button>
					) : (
						<Button href={routes.productList()} variant="secondary">
							Alojamientos
						</Button>
					)
				}
				{
					selectedProduct ? (
						<Button href={routes.productPreview(selectedProduct.id)} variant="secondary">
							Vista previa
						</Button>
					) : null
				}
			</div>
		</header>

		{
			actionError && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">No se pudo actualizar la regla</p>
					<p class="mt-1 text-sm">{actionError}</p>
				</Card>
			)
		}
		{
			success === "created" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">Regla agregada</p>
					<p class="mt-1 text-sm">Ya forma parte de lo que verá el huésped.</p>
				</Card>
			)
		}
		{
			success === "preset-applied" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">Reglas rápidas agregadas</p>
					<p class="mt-1 text-sm">Solo se agregaron categorías que aún faltaban.</p>
				</Card>
			)
		}
		{
			success === "deleted" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">Regla eliminada</p>
				</Card>
			)
		}

		{
			!products.length ? (
				<Card className="bg-white text-slate-800">
					<p class="text-sm text-slate-600">Crea un alojamiento antes de agregar reglas.</p>
					<div class="mt-3">
						<Button href="/product/create" variant="primary">
							Crear alojamiento
						</Button>
					</div>
				</Card>
			) : (
				<div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_360px]">
					<section class="space-y-3">
						<Card className="bg-white text-slate-800">
							<div class="flex flex-wrap items-start justify-between gap-3">
								<div>
									<p class="text-lg font-semibold text-slate-950">
										{selectedProduct?.name ?? "Alojamiento"}
									</p>
									<p class="mt-1 text-sm text-slate-600">
										{selectedReady
											? "Las reglas principales ya están visibles para huéspedes."
											: "Completa las reglas clave para que la ficha sea clara antes de reservar."}
									</p>
								</div>
								<Badge variant={selectedReady ? "success" : "warning"}>
									{selectedReady ? "Listo" : `Faltan ${missingCount} reglas`}
								</Badge>
							</div>
							{missingCount > 0 ? (
								<div class="mt-4 flex flex-wrap gap-2">
									{selectedState?.missingEssentials.map((type) => (
										<Badge variant="neutral">{houseRuleCopy[type].label}</Badge>
									))}
								</div>
							) : null}
							{focus === "arrival" ? (
								<p class="mt-4 rounded-lg border border-blue-200 bg-blue-50 px-3 py-2 text-sm text-blue-900">
									Estos horarios se aplican al hotel y se heredan automáticamente en sus tarifas.
								</p>
							) : null}
						</Card>

						<div class="grid gap-3">
							{houseRuleEditorTypes.map((type) => {
								const copy = houseRuleCopy[type]
								const rules = selectedRulesByType.get(type) ?? []
								const isEssential = essentialHouseRuleTypes.includes(type)
								const isComplete = rules.length > 0
								return (
									<Card className="bg-white text-slate-800" data-house-rule-type={type}>
										<details
											class="group"
											open={
												(!isComplete && isEssential) ||
												(focus === "arrival" && (type === "CheckIn" || type === "Checkout"))
											}
										>
											<summary class="flex cursor-pointer list-none flex-wrap items-start justify-between gap-3">
												<div class="min-w-0">
													<div class="flex flex-wrap items-center gap-2">
														<p class="text-base font-semibold text-slate-950">{copy.label}</p>
														<Badge
															variant={isComplete ? "success" : isEssential ? "warning" : "neutral"}
														>
															{isComplete ? "Visible" : isEssential ? "Falta" : "Opcional"}
														</Badge>
													</div>
													<p class="mt-1 text-sm text-slate-600">{copy.intent}</p>
												</div>
												<span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-500 group-open:bg-slate-100">
													{isComplete ? "Editar" : "Agregar"}
												</span>
											</summary>

											<div class="mt-4 space-y-4 border-t border-slate-100 pt-4">
												{rules.length ? (
													<div class="grid gap-2">
														{rules.map((rule) => {
															const summary = buildHouseRuleGuestSummary(type, rule.payloadJson)
															return (
																<div class="flex flex-wrap items-start justify-between gap-3 rounded-xl border border-slate-200 bg-slate-50 p-3">
																	<p class="max-w-2xl text-sm leading-6 text-slate-700">
																		{summary}
																	</p>
																	<form method="POST">
																		<input type="hidden" name="action" value="delete-house-rule" />
																		<input type="hidden" name="ruleId" value={rule.id} />
																		<Button type="submit" variant="secondary" size="sm">
																			Eliminar
																		</Button>
																	</form>
																</div>
															)
														})}
													</div>
												) : null}

												<form method="POST" class="grid gap-3 sm:grid-cols-2">
													<input type="hidden" name="action" value="create-house-rule" />
													<input type="hidden" name="type" value={type} />
													{hasProductContext && selectedProduct ? (
														<input type="hidden" name="productId" value={selectedProduct.id} />
													) : (
														<label class="space-y-1 text-sm sm:col-span-2">
															<span class="font-medium text-slate-700">Alojamiento</span>
															<select
																name="productId"
																class="w-full rounded-lg border border-slate-300 px-3 py-2"
															>
																{visibleProducts.map((product) => (
																	<option
																		value={product.id}
																		selected={product.id === selectedProductId}
																	>
																		{product.name}
																	</option>
																))}
															</select>
														</label>
													)}

													{type === "Pets" ? (
														<>
															<fieldset class="space-y-2 rounded-xl border border-slate-200 p-3 text-sm">
																<legend class="px-1 font-medium text-slate-700">Mascotas</legend>
																<label class="mr-4">
																	<input type="radio" name="allowed" value="true" /> Sí
																</label>
																<label>
																	<input type="radio" name="allowed" value="false" checked /> No
																</label>
															</fieldset>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Nota breve</span>
																<input
																	name="feeNote"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																	placeholder="Ej. una mascota pequeña con aprobación previa"
																/>
															</label>
														</>
													) : null}

													{type === "Children" ? (
														<>
															<fieldset class="space-y-2 rounded-xl border border-slate-200 p-3 text-sm">
																<legend class="px-1 font-medium text-slate-700">Niños</legend>
																<label class="mr-4">
																	<input type="radio" name="allowed" value="true" checked /> Sí
																</label>
																<label>
																	<input type="radio" name="allowed" value="false" /> No
																</label>
															</fieldset>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Cuidado importante</span>
																<input
																	name="conditions"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																	placeholder="Ej. supervisión en piscina"
																/>
															</label>
														</>
													) : null}

													{type === "Smoking" ? (
														<>
															<fieldset class="space-y-2 rounded-xl border border-slate-200 p-3 text-sm">
																<legend class="px-1 font-medium text-slate-700">Fumar</legend>
																<label class="mr-4">
																	<input type="radio" name="allowed" value="true" /> Permitido con
																	límites
																</label>
																<label>
																	<input type="radio" name="allowed" value="false" checked /> No
																	permitido
																</label>
															</fieldset>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Dónde aplica</span>
																<select
																	name="smokingArea"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																>
																	<option value="not_allowed">No permitido</option>
																	<option value="designated_areas">Áreas designadas</option>
																	<option value="outdoors">Solo al aire libre</option>
																	<option value="rooms">Habitaciones designadas</option>
																	<option value="other">Otra indicación</option>
																</select>
															</label>
														</>
													) : null}

													{type === "Parties" ? (
														<fieldset class="space-y-2 rounded-xl border border-slate-200 p-3 text-sm sm:col-span-2">
															<legend class="px-1 font-medium text-slate-700">
																Fiestas y eventos
															</legend>
															<label class="mr-4">
																<input type="radio" name="allowed" value="true" /> Permitidos con
																guía
															</label>
															<label>
																<input type="radio" name="allowed" value="false" checked /> No
																permitidos
															</label>
														</fieldset>
													) : null}

													{type === "QuietHours" ? (
														<>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Silencio desde</span>
																<input
																	type="time"
																	name="quietStart"
																	value="22:00"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																/>
															</label>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Silencio hasta</span>
																<input
																	type="time"
																	name="quietEnd"
																	value="08:00"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																/>
															</label>
														</>
													) : null}

													{type === "Parking" ? (
														<>
															<fieldset class="space-y-2 rounded-xl border border-slate-200 p-3 text-sm">
																<legend class="px-1 font-medium text-slate-700">
																	Estacionamiento
																</legend>
																<label class="mr-4">
																	<input type="radio" name="available" value="true" checked />{" "}
																	Disponible
																</label>
																<label>
																	<input type="radio" name="available" value="false" /> No
																	disponible
																</label>
															</fieldset>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Tipo</span>
																<select
																	name="parkingType"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																>
																	<option value="free">Gratuito</option>
																	<option value="paid">Pagado</option>
																	<option value="street">En la calle</option>
																	<option value="assigned">Espacio asignado</option>
																	<option value="nearby">Cercano</option>
																	<option value="none">Sin estacionamiento</option>
																</select>
															</label>
														</>
													) : null}

													{type === "CheckIn" || type === "Access" ? (
														<>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Llegada desde</span>
																<input
																	type="time"
																	name="checkInFrom"
																	value="15:00"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																	required={type === "CheckIn"}
																/>
															</label>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Llegada hasta</span>
																<input
																	type="time"
																	name="checkInUntil"
																	value="22:00"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																	required={type === "CheckIn"}
																/>
															</label>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">
																	Cómo entra el huésped
																</span>
																<select
																	name="checkInMethod"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																>
																	<option value="self">Llegada autónoma</option>
																	<option value="host">Con anfitrión o personal</option>
																	<option value="front_desk">Recepción</option>
																	<option value="lockbox">Caja de seguridad</option>
																	<option value="smart_lock">Cerradura o código</option>
																	<option value="manual">Entrega manual</option>
																</select>
															</label>
															<div class="space-y-2 rounded-xl border border-slate-200 p-3 text-sm">
																<p class="font-medium text-slate-700">Al llegar</p>
																<label class="block">
																	<input type="checkbox" name="idRequired" /> Puede pedirse
																	documento
																</label>
																<label class="block">
																	<input type="checkbox" name="cardRequired" /> Puede pedirse
																	tarjeta
																</label>
															</div>
														</>
													) : null}

													{type === "Checkout" ? (
														<>
															<label class="space-y-1 text-sm">
																<span class="font-medium text-slate-700">Hora de salida</span>
																<input
																	type="time"
																	name="checkoutTime"
																	value="11:00"
																	class="w-full rounded-lg border border-slate-300 px-3 py-2"
																/>
															</label>
															<div class="space-y-2 rounded-xl border border-slate-200 p-3 text-sm">
																<p class="font-medium text-slate-700">Antes de salir</p>
																<label class="block">
																	<input
																		type="checkbox"
																		name="checkoutTasks"
																		value="devolver llaves o dispositivos de acceso"
																	/>{" "}
																	Devolver llaves o acceso
																</label>
																<label class="block">
																	<input
																		type="checkbox"
																		name="checkoutTasks"
																		value="cerrar puertas y ventanas"
																	/>{" "}
																	Cerrar puertas y ventanas
																</label>
																<label class="block">
																	<input
																		type="checkbox"
																		name="checkoutTasks"
																		value="dejar la basura en el lugar indicado"
																	/>{" "}
																	Dejar basura donde corresponde
																</label>
																<label class="block">
																	<input
																		type="checkbox"
																		name="checkoutTasks"
																		value="apagar luces y electrodomésticos"
																	/>{" "}
																	Apagar luces y electrodomésticos
																</label>
															</div>
														</>
													) : null}

													{type === "Safety" || type === "ExtraBeds" || type === "Other" ? (
														<label class="space-y-1 text-sm sm:col-span-2">
															<span class="font-medium text-slate-700">
																Indicación para huéspedes
															</span>
															<textarea
																name="instructions"
																rows="3"
																class="w-full rounded-lg border border-slate-300 px-3 py-2"
																placeholder="Ej. no ingresar a zonas de personal."
															/>
														</label>
													) : null}

													<div class="sm:col-span-2">
														<Button type="submit" variant="primary" size="sm">
															Guardar regla
														</Button>
													</div>
												</form>
											</div>
										</details>
									</Card>
								)
							})}
						</div>
					</section>

					<aside class="order-first space-y-4 xl:order-none">
						<Card className="bg-white text-slate-800 xl:sticky xl:top-6">
							<div class="flex flex-wrap items-start justify-between gap-3">
								<div>
									<p class="text-base font-semibold text-slate-950">Así lo verá el huésped</p>
									<p class="mt-1 text-sm text-slate-600">
										{selectedProduct?.name ?? "Alojamiento"}
									</p>
								</div>
								<Badge variant={selectedReady ? "success" : "warning"}>
									{selectedReady ? "Listo" : `Faltan ${missingCount}`}
								</Badge>
							</div>

							{selectedProduct ? (
								<div class="mt-4">
									<Button
										href={routes.productPreview(selectedProduct.id)}
										variant="secondary"
										size="sm"
									>
										Ver ficha completa
									</Button>
								</div>
							) : null}

							{previewRules.length ? (
								<div class="mt-5 space-y-4">
									{previewRulesByGroup.map((group) => {
										if (!group.rules.length) return null
										return (
											<div>
												<p class="text-sm font-semibold text-slate-950">{group.label}</p>
												<ul class="mt-2 space-y-2 text-sm leading-6 text-slate-700">
													{group.rules.map((rule) => {
														const type = String(rule.type ?? "Other") as HouseRuleType
														const summary = buildHouseRuleGuestSummary(type, rule.payloadJson)
														return (
															<li class="rounded-xl border border-slate-200 bg-slate-50 p-3">
																<span class="font-medium text-slate-900">
																	{houseRuleCopy[type]?.label ?? "Otra regla"}:
																</span>{" "}
																{summary}
															</li>
														)
													})}
												</ul>
											</div>
										)
									})}
								</div>
							) : (
								<div class="mt-5 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-4">
									<p class="text-sm font-semibold text-slate-900">Aún no hay reglas visibles.</p>
									<p class="mt-1 text-sm text-slate-600">
										Agrega las reglas principales para que la ficha sea clara.
									</p>
								</div>
							)}
						</Card>
					</aside>
				</div>
			)
		}

		<details class="rounded-2xl border border-slate-700/60 bg-slate-900/70 p-4 text-slate-200">
			<summary class="cursor-pointer text-sm font-semibold">Detalle interno</summary>
			<div class="mt-4 grid gap-4 lg:grid-cols-2">
				<div class="rounded-xl border border-slate-700 bg-slate-950/50 p-4">
					<p class="text-sm font-semibold text-slate-100">Base rápida</p>
					<p class="mt-1 text-sm text-slate-400">
						Agrega reglas comunes sin volver a editar categorías que ya existen.
					</p>
					<div class="mt-4 grid gap-3">
						{
							houseRuleQuickSetups.map((preset) => (
								<form method="POST" class="rounded-xl border border-slate-700 bg-slate-900 p-3">
									<input type="hidden" name="action" value="apply-quick-setup" />
									<input type="hidden" name="presetKey" value={preset.key} />
									<p class="text-sm font-semibold text-slate-100">{preset.title}</p>
									<p class="mt-1 text-sm text-slate-400">{preset.description}</p>
									<label class="mt-3 block text-sm">
										<span class="font-medium text-slate-300">Alojamiento</span>
										<select
											name="productId"
											class="mt-1 w-full rounded-lg border border-slate-600 bg-slate-950 px-3 py-2 text-slate-100"
										>
											{visibleProducts.map((product) => (
												<option value={product.id} selected={product.id === selectedProductId}>
													{product.name}
												</option>
											))}
										</select>
									</label>
									<div class="mt-3">
										<Button type="submit" variant="secondary" size="sm">
											Agregar base
										</Button>
									</div>
								</form>
							))
						}
					</div>
				</div>
				<p
					class="rounded-xl border border-slate-700 bg-slate-950/50 p-4 text-sm leading-6 text-slate-400"
				>
					{internalRuleCount} reglas visibles. No cambian precios, restricciones de venta ni condiciones
					comerciales.
				</p>
			</div>
		</details>
	</div>
</WorkspaceLayout>
