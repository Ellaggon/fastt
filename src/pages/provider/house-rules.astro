	{
		key: "arrival",
		label: "Arrival & access",
		description: "Instructions that reduce check-in friction and operational surprises.",
		types: ["CheckIn", "Access", "Parking"],
	},
	{
		key: "during-stay",
		label: "During the stay",
		description: "Property-use expectations, safety notes and shared-space guidance.",
