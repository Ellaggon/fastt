---
import { db, eq, Product } from "astro:db"

import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { routes } from "@/lib/routes"
import {
	buildHouseRuleGuestSummary,
	createHouseRule,
	deleteHouseRule,
	listHouseRulesByProduct,
	type HouseRule,
	type HouseRulePayload,
	type HouseRuleType,
} from "@/modules/house-rules/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

type ProductOption = {
	id: string
	name: string
	productType: string
}

type HouseRuleGroup = {
	key: string
	label: string
	description: string
	types: HouseRuleType[]
}

const houseRuleTypes: HouseRuleType[] = [
	"Pets",
	"Children",
	"Smoking",
	"Parties",
	"QuietHours",
	"Parking",
	"CheckIn",
	"Checkout",
	"Safety",
	"ExtraBeds",
	"Access",
	"Other",
]

const essentialRuleTypes: HouseRuleType[] = [
	"Pets",
	"Smoking",
	"Parties",
	"QuietHours",
	"CheckIn",
	"Checkout",
]

const houseRuleGroups: HouseRuleGroup[] = [
	{
		key: "before-booking",
		label: "Before booking",
		description: "Rules guests should understand before they reserve.",
		types: ["Pets", "Children", "Smoking", "Parties", "QuietHours"],
