const categoryCopy: Record<HouseRuleType, { label: string; intent: string; guestFacing: string }> =
	{
		Children: {
			label: "Children",
			intent: "Child acceptance, child-age expectations and family stay guidance.",
			guestFacing: "Can children stay here and under what expectations?",
		},
		Pets: {
			label: "Pets",
			intent: "Pet permission, service-animal clarity and pet behavior expectations.",
			guestFacing: "Can guests bring pets, and what should they know?",
		},
		Smoking: {
			label: "Smoking",
			intent: "Smoking, vaping and designated-area behavior.",
			guestFacing: "Where, if anywhere, can guests smoke or vape?",
		},
		Parties: {
			label: "Parties & events",
			intent: "Parties, events, gatherings and property-use expectations.",
			guestFacing: "Are parties, events or gatherings allowed?",
		},
		QuietHours: {
			label: "Quiet hours",
			intent: "Noise, neighbor respect and quiet-hour expectations.",
			guestFacing: "When should guests keep noise especially low?",
		},
		Parking: {
