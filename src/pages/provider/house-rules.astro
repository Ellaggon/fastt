										<p class="mt-4 text-sm text-slate-500">
											Add rules for pets, smoking, parties, quiet hours, parking or arrival
											instructions.
										</p>
									)}
								</Card>
							)
						})}
					</div>
				)
			}
		</Section>
	</div>
</WorkspaceLayout>

<script>
	const form = document.querySelector("[data-house-rule-form]") as HTMLFormElement | null
	if (form) {
		const categoryCopy: Record<string, string> = {
			Pets: "Can guests bring pets, and what should they know?",
			Children: "Can children stay here and under what expectations?",
			Smoking: "Where, if anywhere, can guests smoke or vape?",
			Parties: "Are parties, events or gatherings allowed?",
			QuietHours: "When should guests keep noise especially low?",
			Parking: "Where can guests park and what rules apply?",
			CheckIn: "What must guests do when they arrive?",
			Checkout: "What should guests do before leaving?",
			Safety: "How should guests use the property safely?",
			ExtraBeds: "Can guests request extra beds or cribs?",
			Access: "How do guests enter and use access devices?",
			Other: "What else should guests know before staying?",
		}
		const typeSelect = form.querySelector("[data-rule-type]") as HTMLSelectElement | null
		const help = form.querySelector("[data-category-help]") as HTMLElement | null
		const panels = Array.from(form.querySelectorAll("[data-rule-panel]")) as HTMLElement[]

		const syncHelp = () => {
			const type = String(typeSelect?.value ?? "Children")
			if (help) help.textContent = categoryCopy[type] ?? categoryCopy.Other
			for (const panel of panels) {
				const types = String(panel.dataset.rulePanel ?? "").split(/\s+/)
				const active = types.includes(type)
				panel.classList.toggle("hidden", !active)
				for (const input of Array.from(
					panel.querySelectorAll("input, select, textarea")
				) as HTMLInputElement[]) {
					input.disabled = !active
				}
			}
		}

		typeSelect?.addEventListener("change", () => {
			syncHelp()
		})

		typeSelect?.dispatchEvent(new Event("change"))
	}
</script>
