---
import { db, eq, Product } from "@/shared/infrastructure/db/compat"

import AccommodationContextSwitcher from "@/components/product/AccommodationContextSwitcher.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import SegmentedControl from "@/components/ui/SegmentedControl.astro"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { buildPlaybookHref } from "@/lib/playbook/launch-accommodation"
import { resolvePlaybookFromUrl } from "@/lib/playbook/resolve-playbook"
import { refreshProductPreparationSnapshotAfterMutation } from "@/lib/playbook/summarize-product-preparation"
import { syncHotelArrivalPolicy } from "@/lib/policies/syncHotelArrivalPolicy"
import { routes } from "@/lib/routes"
import {
	essentialHouseRuleTypes,
	houseRuleCopy,
	houseRuleGroups,
	houseRuleQuickSetups,
	houseRuleTypes,
} from "@/modules/house-rules/presentation/houseRulePresentation"
import {
	buildHouseRuleGuestSummary,
	createHouseRule,
	deleteHouseRule,
	listHouseRulesByProduct,
	listHouseRulesByProductIds,
	type HouseRule,
	type HouseRulePayload,
	type HouseRuleType,
} from "@/modules/house-rules/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

type ProductOption = {
	id: string
	name: string
	productType: string
}

async function loadProviderProducts(providerId: string): Promise<ProductOption[]> {
	const rows = await db
		.select({
			id: Product.id,
			name: Product.name,
			productType: Product.productType,
		})
		.from(Product)
		.where(eq(Product.providerId, providerId))

	return rows.map((row) => ({
		id: String(row.id),
		name: String(row.name),
		productType: String(row.productType ?? "Alojamiento"),
	}))
}

async function loadRulesByProduct(products: ProductOption[]) {
	return (await listHouseRulesByProductIds(products.map((product) => product.id))) as Map<
		string,
		HouseRule[]
	>
}

function boolFromForm(form: FormData, key: string): boolean | undefined {
	const raw = String(form.get(key) ?? "").trim()
	if (raw === "true") return true
	if (raw === "false") return false
	return undefined
}

function listFromForm(form: FormData, key: string): string[] {
	return form
		.getAll(key)
		.map((item) => String(item ?? "").trim())
		.filter(Boolean)
}

function payloadFromForm(type: HouseRuleType, form: FormData): HouseRulePayload {
	const note = String(form.get("note") ?? "").trim()
	const base: HouseRulePayload = { kind: type }
	if (note) base.note = note

	switch (type) {
		case "Pets":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				feeNote: String(form.get("feeNote") ?? "").trim() || undefined,
			}
		case "Children":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				conditions: String(form.get("conditions") ?? "").trim() || undefined,
			}
		case "Smoking":
			return {
				...base,
				allowed: boolFromForm(form, "allowed"),
				area: (String(form.get("smokingArea") ?? "").trim() || undefined) as any,
			}
		case "Parties":
			return { ...base, allowed: boolFromForm(form, "allowed") }
		case "QuietHours":
			return {
				...base,
				start: String(form.get("quietStart") ?? "").trim() || undefined,
				end: String(form.get("quietEnd") ?? "").trim() || undefined,
			}
		case "Parking":
			return {
				...base,
				available: boolFromForm(form, "available"),
				parkingType: (String(form.get("parkingType") ?? "").trim() || undefined) as any,
			}
		case "CheckIn":
		case "Access":
			return {
				...base,
				method: (String(form.get("checkInMethod") ?? "").trim() || undefined) as any,
				checkInFrom: String(form.get("checkInFrom") ?? "").trim() || undefined,
				checkInUntil: String(form.get("checkInUntil") ?? "").trim() || undefined,
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
				idRequired: form.get("idRequired") === "on",
				cardRequired: form.get("cardRequired") === "on",
			}
		case "Checkout":
			return {
				...base,
				time: String(form.get("checkoutTime") ?? "").trim() || undefined,
				tasks: listFromForm(form, "checkoutTasks"),
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
			}
		default:
			return {
				...base,
				instructions: String(form.get("instructions") ?? "").trim() || undefined,
			}
	}
}

let actionError: string | null = null
const requestedProductId = String(Astro.url.searchParams.get("productId") ?? "").trim()
const focus = String(Astro.url.searchParams.get("focus") ?? "").trim()
const requestedReturnTo = String(Astro.url.searchParams.get("returnTo") ?? "").trim()
const safeReturnTo =
	requestedReturnTo.startsWith("/") && !requestedReturnTo.startsWith("//") ? requestedReturnTo : ""

function redirectToHouseRules(success: string, productId?: string) {
	const params = new URLSearchParams({ success })
	const contextualProductId = String(productId ?? "").trim()
	if (contextualProductId) params.set("productId", contextualProductId)
	if (focus === "arrival") params.set("focus", "arrival")
	if (safeReturnTo) params.set("returnTo", safeReturnTo)
	const activePlaybook = resolvePlaybookFromUrl(Astro.url, { isHotel: true })
	if (activePlaybook.playbookId === "launch") {
		params.set("playbook", "launch")
		params.set("step", "house-rules")
		params.set("flow", "create")
	} else if (activePlaybook.playbookId === "complete-to-publish") {
		params.set("playbook", "complete-to-publish")
		params.set("step", "houseRules")
		params.set("flow", "complete")
	}
	return Astro.redirect(`${routes.providerHouseRules()}?${params.toString()}`)
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData()
	const action = String(form.get("action") ?? "").trim()
	try {
		const products = await loadProviderProducts(auth.providerId)
		const ownedProductIds = new Set(products.map((product) => product.id))
		if (action === "create-house-rule") {
			const productId = String(form.get("productId") ?? "").trim()
			const type = String(form.get("type") ?? "").trim() as HouseRuleType
			const payload = payloadFromForm(type, form)
			if (!ownedProductIds.has(productId)) throw new Error("El alojamiento no está disponible")
			if (!houseRuleTypes.includes(type)) throw new Error("Tipo de regla no compatible")
			await createHouseRule({ productId, type, payload })
			if (type === "CheckIn" || type === "Checkout") {
				await syncHotelArrivalPolicy({
					providerId: auth.providerId,
					productId,
					actorUserId: auth.user.id,
					rules: (await listHouseRulesByProduct(productId)) as HouseRule[],
				})
			}
			await refreshProductPreparationSnapshotAfterMutation({
				productId,
				providerId: auth.providerId,
				request: Astro.request,
				url: Astro.url,
				source: "provider.house-rules.create",
			})
			return redirectToHouseRules("created", productId)
		}
		if (action === "apply-quick-setup") {
			const productId = String(form.get("productId") ?? "").trim()
			const presetKey = String(form.get("presetKey") ?? "").trim()
			const preset = houseRuleQuickSetups.find((item) => item.key === presetKey)
			if (!ownedProductIds.has(productId)) throw new Error("El alojamiento no está disponible")
			if (!preset) throw new Error("La configuración rápida no está disponible")

			const rulesByProduct = await loadRulesByProduct(products)
			const existingTypes = new Set(
				(rulesByProduct.get(productId) ?? []).map((rule) => String(rule.type ?? "Other"))
			)
			for (const item of preset.rules) {
				if (existingTypes.has(item.type)) continue
				await createHouseRule({ productId, type: item.type, payload: item.payload })
				existingTypes.add(item.type)
			}
			await syncHotelArrivalPolicy({
				providerId: auth.providerId,
				productId,
				actorUserId: auth.user.id,
				rules: (await listHouseRulesByProduct(productId)) as HouseRule[],
			})
			await refreshProductPreparationSnapshotAfterMutation({
				productId,
				providerId: auth.providerId,
				request: Astro.request,
				url: Astro.url,
				source: "provider.house-rules.quick-setup",
			})
			return redirectToHouseRules("preset-applied", productId)
		}
		if (action === "delete-house-rule") {
			const ruleId = String(form.get("ruleId") ?? "").trim()
			const rulesByProduct = await loadRulesByProduct(products)
			const ownedRule = Array.from(rulesByProduct.values())
				.flat()
				.find((rule) => String(rule.id) === ruleId)
			if (!ownedRule) throw new Error("La regla no está disponible")
			await deleteHouseRule(ruleId)
			if (ownedRule.type === "CheckIn" || ownedRule.type === "Checkout") {
				await syncHotelArrivalPolicy({
					providerId: auth.providerId,
					productId: ownedRule.productId,
					actorUserId: auth.user.id,
					rules: (await listHouseRulesByProduct(ownedRule.productId)) as HouseRule[],
				})
			}
			await refreshProductPreparationSnapshotAfterMutation({
				productId: ownedRule.productId,
				providerId: auth.providerId,
				request: Astro.request,
				url: Astro.url,
				source: "provider.house-rules.delete",
			})
			return redirectToHouseRules("deleted", ownedRule.productId)
		}
	} catch (error) {
		actionError = error instanceof Error ? error.message : "No se pudo actualizar la regla"
	}
}

const products = await loadProviderProducts(auth.providerId)
const rulesByProduct = await loadRulesByProduct(products)
const success = String(Astro.url.searchParams.get("success") ?? "").trim()
const playbook = resolvePlaybookFromUrl(Astro.url, { isHotel: true })
const isLaunchWizard =
	playbook.playbookId === "launch" && (playbook.stepId ?? "house-rules") === "house-rules"
const isCompleteWizard =
	playbook.playbookId === "complete-to-publish" &&
	(playbook.stepId === "houseRules" || playbook.stepId === "house-rules")
const isGuidedRules = isLaunchWizard || isCompleteWizard
const houseRuleViews = ["essential", "arrival", "optional", "preview"] as const
type HouseRuleView = (typeof houseRuleViews)[number]
const requestedView = String(Astro.url.searchParams.get("vista") ?? "").trim()
const activeView: HouseRuleView =
	focus === "arrival"
		? "arrival"
		: isGuidedRules && requestedView === "preview"
			? "essential"
			: houseRuleViews.includes(requestedView as HouseRuleView)
				? (requestedView as HouseRuleView)
				: "essential"
const selectedProduct =
	products.find((product) => product.id === requestedProductId) ?? products[0] ?? null
const selectedProductId = selectedProduct?.id ?? ""
const hasProductContext = Boolean(requestedProductId && selectedProduct)
const visibleProducts = hasProductContext && selectedProduct ? [selectedProduct] : products
const stateByProduct = products.map((product) => {
	const rules = rulesByProduct.get(product.id) ?? []
	const typeSet = new Set(rules.map((rule) => String(rule.type ?? "Other") as HouseRuleType))
	const missingEssentials = essentialHouseRuleTypes.filter((type) => !typeSet.has(type))
	return {
		product,
		rules,
		typeSet,
		missingEssentials,
		ready: missingEssentials.length === 0,
	}
})
const selectedState =
	(hasProductContext
		? stateByProduct.find((item) => item.product.id === selectedProductId)
		: stateByProduct.find((item) => item.rules.length)) ?? stateByProduct[0]
const previewRules = selectedState?.rules ?? []
const previewRulesByGroup = houseRuleGroups.map((group) => ({
	...group,
	rules: previewRules.filter((rule) =>
		group.types.includes(String(rule.type ?? "Other") as HouseRuleType)
	),
}))
const missingCount = selectedState?.missingEssentials.length ?? essentialHouseRuleTypes.length
const selectedReady = Boolean(selectedState?.ready)
const essentialReadyCount = essentialHouseRuleTypes.length - missingCount
const selectedRulesByType = new Map<HouseRuleType, HouseRule[]>()
for (const rule of previewRules) {
	const type = String(rule.type ?? "Other") as HouseRuleType
	const rules = selectedRulesByType.get(type) ?? []
	rules.push(rule)
	selectedRulesByType.set(type, rules)
}
const flow = Astro.url.searchParams.get("flow") === "create" ? "create" : "edit"
if (Astro.request.method === "GET" && !requestedProductId && products.length === 1) {
	const params = new URLSearchParams(Astro.url.searchParams)
	params.set("productId", products[0].id)
	return Astro.redirect(`${routes.providerHouseRules()}?${params.toString()}`)
}
if (!playbook.active && flow === "create" && selectedProductId) {
	return Astro.redirect(
		buildPlaybookHref(
			`${routes.providerHouseRules()}?productId=${encodeURIComponent(selectedProductId)}`,
			"house-rules"
		)
	)
}
const showProductIndex = products.length > 1 && !hasProductContext && !playbook.active

const ruleTypesByView: Record<HouseRuleView, HouseRuleType[]> = {
	essential: essentialHouseRuleTypes,
	arrival: ["CheckIn", "Checkout", "Access", "Parking"],
	optional: ["Children", "Safety", "ExtraBeds", "Other"],
	preview: [],
}
const activeEditorTypes = ruleTypesByView[activeView]
const optionalReadyCount = ruleTypesByView.optional.filter(
	(type) => (selectedRulesByType.get(type) ?? []).length > 0
).length
function houseRulesViewHref(view: HouseRuleView) {
	const params = new URLSearchParams()
	if (selectedProductId) params.set("productId", selectedProductId)
	params.set("vista", view)
	if (safeReturnTo) params.set("returnTo", safeReturnTo)
	if (isLaunchWizard) {
		params.set("playbook", "launch")
		params.set("step", "house-rules")
		params.set("flow", "create")
	} else if (isCompleteWizard) {
		params.set("playbook", "complete-to-publish")
		params.set("step", "houseRules")
		params.set("flow", "complete")
	}
	return `${routes.providerHouseRules()}?${params.toString()}`
}

function productHouseRulesHref(productId: string) {
	const params = new URLSearchParams({ productId })
	return `${routes.providerHouseRules()}?${params.toString()}`
}

const ruleTabs = [
	{
		id: "essential",
		label: "Esenciales",
		meta: `${essentialReadyCount}/${essentialHouseRuleTypes.length}`,
	},
	{
		id: "arrival",
		label: "Llegada y salida",
		meta: `${["CheckIn", "Checkout"].filter((type) => selectedRulesByType.has(type as HouseRuleType)).length}/2`,
	},
	{ id: "optional", label: "Opcionales", meta: optionalReadyCount },
	...(isGuidedRules
		? []
		: [{ id: "preview" as const, label: "Vista huésped", meta: previewRules.length }]),
] satisfies Array<{ id: HouseRuleView; label: string; meta: string | number }>
const previewPlaybookHref = selectedProductId
	? buildPlaybookHref(routes.productPreview(selectedProductId), "preview")
	: null
const guidedContinueLabel = isLaunchWizard ? "Continuar a vista previa →" : "Continuar →"
const guidedContinueDisabledTitle = isLaunchWizard
	? "Completa las reglas esenciales para pasar a la vista previa."
	: "Completa las reglas esenciales para continuar la preparación."
const successMessage =
	success === "created"
		? {
				title: "Regla guardada",
				detail:
					missingCount > 0
						? `Faltan ${missingCount} regla${missingCount === 1 ? "" : "s"} esencial${missingCount === 1 ? "" : "es"}.`
						: "Las reglas esenciales están listas.",
			}
		: success === "preset-applied"
			? {
					title: "Base aplicada",
					detail:
						missingCount > 0
							? `Se completaron las categorías disponibles. Faltan ${missingCount}.`
							: "Las reglas esenciales están listas para revisar.",
				}
			: success === "deleted"
				? { title: "Regla eliminada", detail: "Puedes agregar una nueva versión cuando quieras." }
				: null
---

<PlaybookLayout
	title="Reglas para huéspedes"
	active={playbook.active}
	playbookId={playbook.playbookId}
	stepId={isCompleteWizard ? "houseRules" : (playbook.stepId ?? "house-rules")}
	productId={selectedProductId}
	isHotel={true}
	continueHref={isLaunchWizard ? previewPlaybookHref : null}
	continueLabel={guidedContinueLabel}
	continueDisabled={isGuidedRules && !selectedReady}
	continueDisabledTitle={guidedContinueDisabledTitle}
>
	<div class="space-y-5">
		<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
			<div class="space-y-1.5">
				{
					selectedProduct ? (
						<AccommodationContextSwitcher
							providerId={auth.providerId}
							productId={selectedProduct.id}
							currentName={selectedProduct.name}
							target="house-rules"
						/>
					) : null
				}
				<h1 class="text-3xl font-semibold text-slate-100">Reglas para huéspedes</h1>
				<p class="max-w-2xl text-sm leading-6 text-slate-300">
					{
						isLaunchWizard
							? "Configura las reglas básicas que el huésped debe aceptar antes de reservar. Podrás revisar cómo se ven en el siguiente paso."
							: isCompleteWizard
								? "Completa las reglas pendientes para poder publicar este alojamiento."
								: showProductIndex
									? "Configura expectativas de estadía por alojamiento. Las habitaciones describen espacios; las tarifas definen condiciones comerciales."
									: "Define comportamiento, llegada y salida para que el huésped sepa qué esperar antes de reservar."
					}
				</p>
			</div>
			{
				isGuidedRules ? null : (
					<div class="flex flex-wrap items-center gap-2">
						{showProductIndex ? null : safeReturnTo ? (
							<Button href={safeReturnTo} variant="secondary">
								Volver a condiciones
							</Button>
						) : hasProductContext && selectedProduct ? (
							<Button href={routes.productDetail(selectedProduct.id)} variant="secondary">
								Volver a la ficha
							</Button>
						) : (
							<Button href={routes.accommodations()} variant="secondary">
								Alojamientos
							</Button>
						)}
						{!showProductIndex && selectedProduct ? (
							<Button href={routes.productPreview(selectedProduct.id)} variant="secondary">
								Vista previa
							</Button>
						) : null}
					</div>
				)
			}
		</header>

		{
			actionError && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">No se pudo actualizar la regla</p>
					<p class="mt-1 text-sm">{actionError}</p>
				</Card>
			)
		}
		{
			successMessage ? (
				isGuidedRules ? (
					<div
						role="status"
						class="flex flex-wrap items-center justify-between gap-3 rounded-xl bg-white px-4 py-3 text-sm text-slate-700 ring-1 ring-slate-200"
					>
						<p>
							<span class="font-semibold text-slate-950">{successMessage.title}.</span>{" "}
							{successMessage.detail}
						</p>
						<span class="text-xs font-semibold text-[var(--fastt-color-selection)]">Guardado</span>
					</div>
				) : (
					<Card className="border-green-200 bg-green-50 text-green-900">
						<p class="text-sm font-semibold">{successMessage.title}</p>
						<p class="mt-1 text-sm">{successMessage.detail}</p>
					</Card>
				)
			) : null
		}

		{
			!products.length ? (
				<Card className="bg-white text-slate-800">
					<p class="text-sm text-slate-600">Crea un alojamiento antes de agregar reglas.</p>
					<div class="mt-3">
						<Button
							href="/product/create?playbook=launch&step=create&flow=create"
							variant="primary"
						>
							Crear alojamiento
						</Button>
					</div>
				</Card>
			) : showProductIndex ? (
				<section class="space-y-4">
					<Card className="bg-white text-slate-900">
						<div class="flex flex-wrap items-start justify-between gap-4">
							<div class="space-y-1">
								<p class="text-lg font-semibold text-slate-950">Elige un alojamiento</p>
								<p class="max-w-3xl text-sm leading-6 text-slate-600">
									Cada propiedad puede tener horarios, acceso, normas y operación distintos. Edita
									las reglas desde el alojamiento correcto para evitar contradicciones con tarifas y
									preview.
								</p>
							</div>
							<Badge variant="neutral">{products.length} alojamientos</Badge>
						</div>
					</Card>

					<div class="grid gap-3 lg:grid-cols-2">
						{stateByProduct.map((item) => {
							const readyCount = essentialHouseRuleTypes.length - item.missingEssentials.length
							const completion = (readyCount / essentialHouseRuleTypes.length) * 100
							return (
								<Card className="bg-white text-slate-900">
									<div class="flex h-full flex-col gap-4">
										<div class="flex flex-wrap items-start justify-between gap-3">
											<div class="space-y-1">
												<p class="text-base font-semibold text-slate-950">{item.product.name}</p>
												<p class="text-sm text-slate-600">
													{readyCount} de {essentialHouseRuleTypes.length} reglas esenciales listas
												</p>
											</div>
											<Badge variant={item.ready ? "success" : "warning"}>
												{item.ready ? "Listo" : `Faltan ${item.missingEssentials.length}`}
											</Badge>
										</div>

										<div class="h-1.5 overflow-hidden rounded-full bg-slate-100">
											<div
												class="h-full rounded-full"
												style={`width: ${completion}%; background-color: var(--fastt-color-selection);`}
											/>
										</div>

										{item.missingEssentials.length ? (
											<div class="flex flex-wrap gap-2">
												{item.missingEssentials.map((type) => (
													<Badge variant="neutral">{houseRuleCopy[type].label}</Badge>
												))}
											</div>
										) : (
											<p class="text-sm leading-6 text-slate-600">
												Las expectativas principales ya están listas para mostrarse al huésped.
											</p>
										)}

										<div class="mt-auto flex flex-wrap justify-end gap-2 border-t border-slate-100 pt-4">
											<Button
												href={routes.productPreview(item.product.id)}
												variant="secondary"
												size="sm"
											>
												Vista previa
											</Button>
											<Button
												href={productHouseRulesHref(item.product.id)}
												variant="primary"
												size="sm"
											>
												Editar reglas
											</Button>
										</div>
									</div>
								</Card>
							)
						})}
					</div>
				</section>
			) : (
				<div class={isGuidedRules ? "space-y-3" : "grid gap-5 xl:grid-cols-[minmax(0,1fr)_360px]"}>
					<section class={isGuidedRules ? "flex flex-col gap-3" : "space-y-3"}>
						{isGuidedRules ? null : (
							<div class="order-2">
								<Card className="bg-white text-slate-900">
									<div class="flex flex-wrap items-start justify-between gap-3">
										<div class="space-y-1">
											<p class="text-lg font-semibold text-slate-950">
												{`${essentialReadyCount} de ${essentialHouseRuleTypes.length} reglas esenciales listas`}
											</p>
