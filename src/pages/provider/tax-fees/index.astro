---
import TaxFeePage from "@/components/tax-fees/TaxFeePage"
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"

try {
	await requireProvider(Astro.request)
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

const defsRes = await fetch(new URL("/api/provider/tax-fees/definitions", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const defsBody = defsRes.ok ? await defsRes.json() : null
const initialDefinitions = Array.isArray(defsBody?.definitions) ? defsBody.definitions : []
const initialWarnings = Array.isArray(defsBody?.warnings) ? defsBody.warnings : []
const hasDefinitions = Array.isArray(initialDefinitions) && initialDefinitions.length > 0
const initialMode = Astro.url.searchParams.get("create") === "1" ? "creating" : "idle"
---

<DashboardLayout>
	<main class="min-h-screen bg-black text-slate-200">
		<div class="mx-auto max-w-7xl space-y-8 px-6">
			<header
				class="flex flex-col gap-4 rounded-[2rem] border border-neutral-200 bg-white/90 p-6 shadow-sm lg:flex-row lg:items-end lg:justify-between"
			>
				<div class="max-w-2xl">
					<p class="text-xs font-semibold uppercase tracking-[0.22em] text-amber-700">
						Configuración del proveedor
					</p>
					<h1 class="mt-2 text-3xl font-semibold tracking-tight text-neutral-950">
						Asistente de impuestos y cargos
					</h1>
					<p class="mt-3 text-sm leading-6 text-neutral-600">
						Configure cargos visibles para el huésped con presets guiados, lenguaje claro y vista
						previa real antes de asignar.
					</p>
				</div>

				<nav class="flex gap-3 text-sm">
					<a
						href="/dashboard"
						class="rounded-full border border-neutral-300 px-4 py-2 text-neutral-700 transition hover:border-neutral-500 hover:text-neutral-950"
					>
						Panel
					</a>
					<a
						href="/provider/policies"
						class="rounded-full border border-neutral-300 px-4 py-2 text-neutral-700 transition hover:border-neutral-500 hover:text-neutral-950"
					>
						Políticas
					</a>
				</nav>
			</header>

			<section
				class="rounded-[2rem] border border-dashed border-neutral-300 bg-white/70 p-5 text-sm text-neutral-600"
			>
				<strong class="text-neutral-900">Cómo funciona:</strong> elija un preset, confirme el monto,
				guarde la definición y luego ejecute una vista previa real antes de asignar.
			</section>

			<section class="rounded-[2rem] border border-neutral-200 bg-white p-5 shadow-sm">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div class="max-w-2xl">
						<h2 class="text-xl font-semibold text-neutral-950">Comience aquí</h2>
						<p class="mt-2 text-sm leading-6 text-neutral-600">
							Use este botón para abrir inmediatamente el asistente de impuestos y cargos. Esta
							acción siempre está disponible, incluso si aún no hay definiciones.
						</p>
					</div>
					<a
						href="/provider/tax-fees?create=1"
						class="inline-flex w-fit items-center justify-center rounded-full bg-[#1E3A8A] px-5 py-3 text-sm font-medium text-white transition hover:bg-[#1e40af]"
					>
						Crear impuesto o cargo
					</a>
				</div>

				{
					!hasDefinitions && (
						<div class="mt-5 rounded-3xl border border-dashed border-neutral-300 bg-neutral-50 p-5">
							<h3 class="text-lg font-semibold text-neutral-950">Aún no hay impuestos ni cargos</h3>
							<p class="mt-2 text-sm leading-6 text-neutral-600">
								Cree su primer impuesto o cargo para que los huéspedes vean precios correctos antes
								de reservar.
							</p>
							<a
								href="/provider/tax-fees?create=1"
								class="mt-4 inline-flex items-center justify-center rounded-full bg-[#1E3A8A] px-5 py-3 text-sm font-medium text-white transition hover:bg-[#1e40af]"
							>
								Crear impuesto o cargo
							</a>
						</div>
					)
				}
			</section>

			<TaxFeePage
				client:load
				initialDefinitions={initialDefinitions}
				initialWarnings={initialWarnings}
				initialMode={initialMode}
			/>
		</div>
	</main>
</DashboardLayout>
