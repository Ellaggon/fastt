---
import { routes } from "@/lib/routes"

const target = new URL(routes.pricing(), Astro.url)
const variantId = String(Astro.url.searchParams.get("variantId") ?? "").trim()
const productId = String(Astro.url.searchParams.get("productId") ?? "").trim()
const dateFrom = String(Astro.url.searchParams.get("dateFrom") ?? "").trim()
const month = dateFrom.slice(0, 7)
if (variantId) target.searchParams.set("variantId", variantId)
if (productId) target.searchParams.set("productId", productId)
if (month) target.searchParams.set("month", month)
target.searchParams.set("focus", "availability")
target.searchParams.set("source", "inventory-bulk-redirect")

return Astro.redirect(target.toString(), 303)
---
