						const targetId = String(toggle.getAttribute("data-detail-toggle") ?? "").trim()
						if (!targetId) return
						const detail = document.getElementById(targetId)
						detail?.classList.toggle("hidden")
					})
				}
			}
			if (previewFailures) {
				const failures = Array.isArray(payload?.failures) ? payload.failures : []
				if (!failures.length) {
					previewFailures.classList.add("hidden")
					previewFailures.textContent = ""
				} else {
					previewFailures.classList.remove("hidden")
					previewFailures.innerHTML = `<p class="font-medium">${copy.partialFailureTitle || "Planes que necesitan revisión"} (${failures.length})</p><p class="mt-1 text-xs">El resto de la revisión sigue disponible. Estos planes necesitan una corrección antes de aplicar.</p><div class="mt-2 grid gap-2">${failures
						.map((item) => renderFailureCard(item))
						.join("")}</div>`
				}
			}
		}

		function renderApplyResult(payload) {
			if (resultSummary) {
				resultSummary.textContent = `${copy.resultTitle || "Resultado de aplicación"} · Planes: ${payload?.summary?.total ?? 0} · Aplicados: ${payload?.summary?.success ?? 0} · Revisar: ${payload?.summary?.failed ?? 0}`
			}
			renderResultCards(payload)
			if (resultRows) {
				resultRows.innerHTML = ""
				for (const row of payload?.results ?? []) {
					const info = catalogMap.get(String(row.ratePlanId))
					const tr = document.createElement("tr")
					tr.className = "border-t border-slate-200 text-slate-700"
					tr.innerHTML = `
						<td class="px-3 py-2"><div class="font-medium text-slate-900">${info?.ratePlanName ?? row.ratePlanId}</div><div class="text-xs text-slate-500">${info?.variantName ?? ""}</div></td>
						<td class="px-3 py-2">${row?.ruleId ?? "—"}</td>
						<td class="px-3 py-2">${Number(row?.daysGenerated ?? 0)}</td>
						<td class="px-3 py-2"><span class="inline-flex rounded-full bg-emerald-100 px-2 py-1 text-xs font-medium text-emerald-800">Aplicado</span></td>
					`
					resultRows.appendChild(tr)
				}
			}
			if (resultFailures) {
				const failures = Array.isArray(payload?.failures) ? payload.failures : []
				if (!failures.length) {
					resultFailures.classList.add("hidden")
					resultFailures.textContent = ""
				} else {
					resultFailures.classList.remove("hidden")
					resultFailures.innerHTML = `<p class="font-medium">Planes no aplicados (${failures.length})</p><p class="mt-1 text-xs">Los planes aplicados quedan guardados. Revisa estos casos y vuelve a intentar solo el alcance pendiente.</p><div class="mt-2 grid gap-2">${failures
						.map((item) => renderFailureCard(item))
						.join("")}</div>`
				}
			}
		}

		const restored = Array.from(new Set([...initialRatePlanIds, ...readPersistedSelection()]))
		for (const checkbox of checkboxes) {
			const ratePlanId = String(checkbox.value ?? "").trim()
			if (!ratePlanId) continue
			if (restored.includes(ratePlanId)) {
				checkbox.checked = true
				selectedRatePlanIds.add(ratePlanId)
			}
			checkbox.addEventListener("change", () => {
				if (checkbox.checked) selectedRatePlanIds.add(ratePlanId)
				else selectedRatePlanIds.delete(ratePlanId)
				updateSelectionUI()
			})
		}

		selectAll?.addEventListener("change", () => {
			const checked = Boolean(selectAll.checked)
			for (const checkbox of checkboxes) {
				const ratePlanId = String(checkbox.value ?? "").trim()
				if (!ratePlanId) continue
				checkbox.checked = checked
				if (checked) selectedRatePlanIds.add(ratePlanId)
				else selectedRatePlanIds.delete(ratePlanId)
			}
			updateSelectionUI()
		})

		contextFrom?.addEventListener("change", syncContextRangeFields)
		contextTo?.addEventListener("change", syncContextRangeFields)

		previewBtn?.addEventListener("click", async () => {
			const operation = getBulkOperation()
			if (operation.error) {
				if (configFeedback) configFeedback.textContent = operation.error
				return
			}
			if (!(previewBtn instanceof HTMLButtonElement)) return
			previewBtn.disabled = true
			previewBtn.textContent = copy.reviewingAction || "Revisando impacto..."
			if (configFeedback)
				configFeedback.textContent = copy.reviewingAction || "Revisando impacto..."
			const body = {
				ratePlanIds: Array.from(selectedRatePlanIds),
				operation: operation.operation,
				concurrency: 4,
			}
			lastBulkOperation = body
			try {
				const response = await fetch("/api/pricing/rules/v2/bulk-preview", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(body),
				})
				const payload = await response.json().catch(() => ({}))
				if (!response.ok) {
					const error = String(payload?.error ?? response.status)
					const guidance = buildRecoveryGuidance(error, "preview")
					if (configFeedback) configFeedback.textContent = `${guidance.title}: ${guidance.action}`
					return
				}
				previewPayload = payload
				renderPreview(payload)
				if (configFeedback)
					configFeedback.textContent = "Revisión lista. Confirma cuando el impacto sea correcto."
				if (applyBtn instanceof HTMLButtonElement) applyBtn.disabled = false
			} catch (error) {
				const guidance = buildRecoveryGuidance(String(error), "network")
				if (configFeedback) configFeedback.textContent = `${guidance.title}: ${guidance.action}`
			} finally {
				previewBtn.disabled = false
				previewBtn.textContent = copy.reviewAction || "Revisar impacto"
			}
		})

		applyBtn?.addEventListener("click", async () => {
			if (!lastBulkOperation) return
			if (!(applyBtn instanceof HTMLButtonElement)) return
			applyBtn.disabled = true
			applyBtn.textContent = copy.applyingAction || "Aplicando cambio..."
			try {
				const response = await fetch("/api/pricing/rules/v2/bulk-apply", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(lastBulkOperation),
				})
				const payload = await response.json().catch(() => ({}))
				if (!response.ok) {
					const error = String(payload?.error ?? response.status)
					const guidance = buildRecoveryGuidance(error, "apply")
					if (resultSummary)
						resultSummary.textContent = `${guidance.title}. ${guidance.summary} ${guidance.action}`
					return
				}
				renderApplyResult(payload)
			} catch (error) {
				const guidance = buildRecoveryGuidance(String(error), "network")
				if (resultSummary)
					resultSummary.textContent = `${guidance.title}. ${guidance.summary} ${guidance.action}`
			} finally {
				applyBtn.disabled = false
				applyBtn.textContent = copy.bulkApplyAction || "Extender cambio a planes"
			}
		})

		previewSort?.addEventListener("change", () => {
			if (previewPayload) renderPreview(previewPayload)
		})

		if (context?.from && contextFrom instanceof HTMLInputElement)
			contextFrom.value = String(context.from)
		if (context?.to && contextTo instanceof HTMLInputElement) contextTo.value = String(context.to)
		updateSelectionUI()
		syncContextRangeFields()
	</script>
</WorkspaceLayout>
