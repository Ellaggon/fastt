---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { buildRangeContextLabel, pricingOperationCopy } from "@/lib/pricing/pricingOperationCopy"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const rows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})

const ratePlanCatalog = rows.map((row) => ({
	ratePlanId: String(row.ratePlanId),
	ratePlanName: String(row.ratePlanName),
	productName: String(row.productName),
	variantName: String(row.variantName),
}))
const isDateOnly = (value: string) => /^\d{4}-\d{2}-\d{2}$/.test(value)
const addOneDay = (value: string) => {
	const date = new Date(`${value}T00:00:00.000Z`)
	if (Number.isNaN(date.getTime())) return ""
	date.setUTCDate(date.getUTCDate() + 1)
	return date.toISOString().slice(0, 10)
}
const countDaysInclusive = (from: string, to: string) => {
	const start = new Date(`${from}T00:00:00.000Z`)
	const end = new Date(`${to}T00:00:00.000Z`)
	if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime()) || end < start) return 0
	return Math.floor((end.getTime() - start.getTime()) / 86_400_000) + 1
}
const initialRatePlanIds = String(Astro.url.searchParams.get("ratePlanIds") ?? "")
	.split(",")
	.map((id) => id.trim())
	.filter(Boolean)
const sourceContext = String(Astro.url.searchParams.get("source") ?? "").trim()
const contextFromRaw = String(Astro.url.searchParams.get("from") ?? "").trim()
const contextToRaw = String(Astro.url.searchParams.get("to") ?? "").trim()
const contextFrom = isDateOnly(contextFromRaw) ? contextFromRaw : ""
const contextTo =
	isDateOnly(contextToRaw) && (!contextFrom || contextToRaw >= contextFrom) ? contextToRaw : ""
const contextDays = contextFrom && contextTo ? countDaysInclusive(contextFrom, contextTo) : 0
const contextEffectiveTo = contextTo ? addOneDay(contextTo) : ""
const originRatePlan = ratePlanCatalog.find((item) => initialRatePlanIds.includes(item.ratePlanId))
const launchedFromPricingContext =
	sourceContext === "calendar" || initialRatePlanIds.length > 0 || contextDays > 0
const bulkContext = {
	source: sourceContext || "direct",
	from: contextFrom,
	to: contextTo,
	days: contextDays,
	effectiveTo: contextEffectiveTo,
	originRatePlanName: originRatePlan?.ratePlanName ?? "",
}
const contextLabel =
	contextDays > 0
		? buildRangeContextLabel({
				from: contextFrom,
				to: contextTo,
				nights: contextDays,
				ratePlanName: originRatePlan?.ratePlanName ?? "",
			})
		: ""
---

<WorkspaceLayout title="Pricing · Modo avanzado">
	<div class="space-y-6">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Pricing · soporte avanzado
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">
					{pricingOperationCopy.extension.advancedModeTitle}
				</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					{pricingOperationCopy.extension.advancedModeDescription}
				</p>
				{/* guardrail-copy: Operacion avanzada de pricing */}
				{/* guardrail-copy: el calendario de Pricing es la operacion diaria principal */}
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.pricing()} variant="secondary">Volver a Pricing</Button>
			</div>
		</header>

		<Section
			title="Contexto del calendario"
			description="Este modo existe como soporte y diagnóstico. Para la operación diaria, vuelve al calendario."
		>
			<Card className="space-y-4 bg-white text-slate-800">
				<div
					data-bulk-advanced-context
					class:list={[
						"rounded-lg border p-3 text-sm",
						launchedFromPricingContext
							? "border-blue-100 bg-blue-50 text-blue-950"
							: "border-slate-200 bg-slate-50 text-slate-700",
					]}
				>
					<div class="flex flex-wrap items-start justify-between gap-3">
						<div>
							<p class="font-semibold">
								{
									launchedFromPricingContext
										? pricingOperationCopy.extension.contextTitle
										: "Modo avanzado sin contexto"
								}
							</p>
							<p class="mt-1">
								{contextDays > 0 ? contextLabel : pricingOperationCopy.extension.contextFallback}
							</p>
						</div>
						<a
							href={routes.pricing()}
							class="rounded border border-blue-200 bg-white px-3 py-2 text-xs font-semibold text-blue-900 hover:bg-blue-100"
						>
							Volver al calendario
						</a>
					</div>
					<p class="mt-2 text-xs opacity-80">
						{pricingOperationCopy.extension.intentSummary}
					</p>
				</div>
			</Card>
		</Section>

		<details class="rounded-lg border border-slate-700 bg-slate-900/70 p-1">
			<summary class="cursor-pointer px-3 py-2 text-sm font-semibold text-slate-100">
				{pricingOperationCopy.extension.targetsTitle}
			</summary>
			<Card className="mt-1 space-y-4 bg-white text-slate-800">
				<div
					class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 pb-3"
				>
					<span id="bulkSelectionCount" class="text-sm text-slate-600">0 seleccionados</span>
					<details class="text-sm text-slate-600">
						<summary class="cursor-pointer font-medium text-slate-700"> Selección masiva </summary>
						<label class="mt-2 inline-flex items-center gap-2">
							<input id="bulkSelectAll" type="checkbox" class="h-4 w-4 rounded border-slate-300" />
							Seleccionar todos los planes visibles
						</label>
					</details>
				</div>
				<div class="grid gap-2 md:grid-cols-2">
					{
						rows.map((row) => (
							<label class="flex items-start gap-2 rounded border border-slate-200 p-2 hover:bg-slate-50">
								<input
									type="checkbox"
									class="mt-1 h-4 w-4 rounded border-slate-300"
									data-rateplan-checkbox
									value={String(row.ratePlanId)}
								/>
								<span>
									<span class="block font-medium text-slate-900">{row.ratePlanName}</span>
									<span class="block text-xs text-slate-600">
										{row.productName} · {row.variantName}
									</span>
								</span>
							</label>
						))
					}
				</div>
			</Card>
		</details>

		<Section
			title={pricingOperationCopy.extension.changeTitle}
			description="Manténlo simple: replica el cambio puntual; lo técnico queda bajo detalle avanzado."
		>
			<Card className="space-y-4 bg-white text-slate-800">
				<div class="grid gap-4 md:grid-cols-3">
					<label class="space-y-1 text-sm text-slate-700">
						<span class="font-medium text-slate-900">Desde</span>
						<input
							id="bulkContextFrom"
							type="date"
							value={contextFrom}
							class="w-full rounded border border-slate-300 px-3 py-2 text-sm text-slate-900"
						/>
					</label>
					<label class="space-y-1 text-sm text-slate-700">
						<span class="font-medium text-slate-900">Hasta</span>
						<input
							id="bulkContextTo"
							type="date"
							value={contextTo}
							class="w-full rounded border border-slate-300 px-3 py-2 text-sm text-slate-900"
						/>
					</label>
					<label class="space-y-1 text-sm text-slate-700">
						<span class="font-medium text-slate-900">Cómo replicar el cambio</span>
						<select
							id="bulkOperationType"
							class="w-full rounded border border-slate-300 px-3 py-2 text-sm text-slate-900"
						>
							<option value="percentage_markup">Subir %</option>
							<option value="percentage_discount">Bajar %</option>
							<option value="fixed_adjustment">Sumar/restar monto</option>
							<option value="fixed_override">Fijar precio final</option>
						</select>
					</label>
					<label class="space-y-1 text-sm text-slate-700">
						<span class="font-medium text-slate-900">Valor</span>
						<input
							id="bulkOperationValue"
							type="number"
							step="0.01"
							value="10"
							class="w-full rounded border border-slate-300 px-3 py-2 text-sm text-slate-900"
						/>
					</label>
				</div>
				<details class="rounded border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
					<summary class="cursor-pointer font-medium text-slate-800">
						{pricingOperationCopy.extension.advancedDetailTitle}
					</summary>
					<div class="mt-3 grid gap-4 md:grid-cols-2">
						<label class="space-y-1">
							<span class="font-medium text-slate-900">Prioridad avanzada</span>
							<select
								id="bulkOperationPriority"
								class="w-full rounded border border-slate-300 px-3 py-2 text-sm text-slate-900"
							>
								<option value="0">Muy alta</option>
								<option value="5">Alta</option>
								<option value="10" selected>Media</option>
								<option value="25">Baja</option>
							</select>
						</label>
						<label class="space-y-1">
							<span class="font-medium text-slate-900">Noches para revisar</span>
							<input
								id="bulkPreviewDays"
								type="number"
								min="1"
								max="120"
								value={contextDays > 0 ? contextDays : 30}
								class="w-full rounded border border-slate-300 px-3 py-2 text-sm text-slate-900"
							/>
						</label>
						<label class="space-y-1">
							<span class="font-medium text-slate-900">Noches a refrescar después de guardar</span>
							<input
								id="bulkEffectiveDays"
								type="number"
								min="1"
								max="365"
								value={contextDays > 0 ? contextDays : 60}
								class="w-full rounded border border-slate-300 px-3 py-2 text-sm text-slate-900"
							/>
						</label>
					</div>
				</details>
				<div class="flex items-center justify-between gap-2">
					<p id="bulkConfigFeedback" class="text-sm text-slate-700"></p>
					<button
						id="bulkPreviewBtn"
						type="button"
						class="rounded bg-blue-700 px-4 py-2 text-sm font-medium text-white hover:bg-blue-800 disabled:opacity-60"
						>{pricingOperationCopy.reviewAction}</button
					>
				</div>
			</Card>
		</Section>

		<Section
			title={pricingOperationCopy.extension.reviewTitle}
			description="Confirma que el cambio manual se replica correctamente antes de guardarlo en otros planes."
		>
			<Card className="space-y-4 bg-white text-slate-800">
				<div id="bulkExecutiveSummary" class="rounded-lg border border-slate-200 bg-slate-50 p-3">
					<p class="text-sm font-semibold text-slate-900">
						{pricingOperationCopy.extension.reviewTitle}
					</p>
					<div class="mt-2 grid gap-2 text-sm text-slate-700 md:grid-cols-4">
						<p>
							<span class="font-medium text-slate-900">Elegidos:</span>
							<span id="bulkExecutiveSelected">0</span>
						</p>
						<p>
							<span class="font-medium text-slate-900">Aplicables:</span>
							<span id="bulkExecutiveAffected">0</span>
						</p>
						<p>
							<span class="font-medium text-slate-900">Noches:</span>
							<span id="bulkExecutiveDays">0</span>
						</p>
						<p>
							<span class="font-medium text-slate-900">Impacto:</span>
							<span id="bulkExecutiveImpact">—</span>
						</p>
					</div>
					<p id="bulkExecutiveRange" class="mt-2 text-xs text-slate-600">
						Rango que viene del calendario: —
					</p>
					<p id="bulkExecutiveCoverage" class="mt-1 text-xs text-slate-500">Alcance listo: 0%</p>
				</div>
				<div
					id="bulkGlobalAlerts"
					class="hidden rounded-lg border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900"
				>
				</div>
				<div class="flex items-center justify-between gap-2">
					<p id="bulkPreviewSummary" class="text-sm text-slate-700">Sin revisión aún.</p>
					<div class="flex items-center gap-2">
						<label class="hidden items-center gap-2 text-xs text-slate-600 sm:inline-flex">
							<span>Ordenar por</span>
							<select
								id="bulkPreviewSort"
								class="rounded border border-slate-300 px-2 py-1 text-xs text-slate-900"
							>
								<option value="impact_desc">Mayor impacto</option>
								<option value="risk_desc">Mayor riesgo</option>
								<option value="coverage_asc">Menor alcance</option>
							</select>
						</label>
						<button
							id="bulkApplyBtn"
							type="button"
							class="rounded bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-800 disabled:opacity-60"
							disabled>{pricingOperationCopy.bulkApplyAction}</button
						>
					</div>
				</div>
				<div id="bulkPreviewCards" data-bulk-preview-result-cards class="grid gap-3 md:grid-cols-2">
				</div>
				<details class="rounded-lg border border-slate-200 bg-slate-50/70">
					<summary class="cursor-pointer px-3 py-2 text-sm font-semibold text-slate-800">
						{pricingOperationCopy.extension.technicalTableTitle}
					</summary>
					<div class="overflow-x-auto border-t border-slate-200">
						<table class="min-w-full bg-white text-sm">
							<thead class="bg-slate-50 text-left text-slate-600">
								<tr>
									<th class="px-3 py-2">Plan tarifario</th>
									<th class="px-3 py-2">Rango</th>
									<th class="px-3 py-2">Antes</th>
									<th class="px-3 py-2">Después</th>
									<th class="px-3 py-2">Cambio/noche</th>
									<th class="px-3 py-2">Impacto estimado</th>
									<th class="px-3 py-2">Alcance</th>
									<th class="px-3 py-2">Estado</th>
								</tr>
							</thead>
							<tbody id="bulkPreviewRows"></tbody>
						</table>
					</div>
				</details>
				<div
					id="bulkApplyConfirmation"
					class="hidden rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-900"
				>
				</div>
				<div
					id="bulkPreviewFailures"
					class="hidden rounded-lg border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900"
				>
				</div>
			</Card>
		</Section>

		<Section
			title={pricingOperationCopy.resultTitle}
			description="Qué se replicó y qué necesita revisión."
		>
			<Card className="space-y-4 bg-white text-slate-800">
				<p id="bulkResultSummary" class="text-sm text-slate-700">Sin aplicación aún.</p>
				<div id="bulkResultCards" data-bulk-apply-result-cards class="grid gap-3 md:grid-cols-2">
				</div>
				<details class="rounded-lg border border-slate-200 bg-slate-50/70">
					<summary class="cursor-pointer px-3 py-2 text-sm font-semibold text-slate-800">
						{pricingOperationCopy.extension.technicalTableTitle}
					</summary>
					<div class="overflow-x-auto border-t border-slate-200">
						<table class="min-w-full bg-white text-sm">
							<thead class="bg-slate-50 text-left text-slate-600">
								<tr>
									<th class="px-3 py-2">Plan tarifario</th>
									<th class="px-3 py-2">Aplicación</th>
									<th class="px-3 py-2">Noches actualizadas</th>
									<th class="px-3 py-2">Estado</th>
								</tr>
							</thead>
							<tbody id="bulkResultRows"></tbody>
						</table>
					</div>
				</details>
				<div
					id="bulkResultFailures"
					class="hidden rounded-lg border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900"
				>
				</div>
			</Card>
		</Section>
	</div>

	<script
		type="module"
		define:vars={{
			ratePlanCatalog,
			initialRatePlanIds,
			bulkContext,
			operationCopy: pricingOperationCopy,
		}}
	>
		const STORAGE_KEY = "bulkPricing.selection"
		const catalog = Array.isArray(ratePlanCatalog) ? ratePlanCatalog : []
		const catalogMap = new Map(catalog.map((item) => [String(item.ratePlanId), item]))
		const context = bulkContext && typeof bulkContext === "object" ? bulkContext : {}
		const copy = operationCopy && typeof operationCopy === "object" ? operationCopy : {}
		const selectedRatePlanIds = new Set()
		let lastBulkOperation = null
		let previewPayload = null

		const selectAll = document.getElementById("bulkSelectAll")
		const selectionCount = document.getElementById("bulkSelectionCount")
		const checkboxes = Array.from(document.querySelectorAll("[data-rateplan-checkbox]"))
		const configFeedback = document.getElementById("bulkConfigFeedback")

		const operationType = document.getElementById("bulkOperationType")
		const operationValue = document.getElementById("bulkOperationValue")
		const operationPriority = document.getElementById("bulkOperationPriority")
		const contextFrom = document.getElementById("bulkContextFrom")
		const contextTo = document.getElementById("bulkContextTo")
		const previewDays = document.getElementById("bulkPreviewDays")
		const effectiveDays = document.getElementById("bulkEffectiveDays")

		const previewBtn = document.getElementById("bulkPreviewBtn")
		const applyBtn = document.getElementById("bulkApplyBtn")
		const previewSummary = document.getElementById("bulkPreviewSummary")
		const previewSort = document.getElementById("bulkPreviewSort")
		const previewCards = document.getElementById("bulkPreviewCards")
		const previewRows = document.getElementById("bulkPreviewRows")
		const previewFailures = document.getElementById("bulkPreviewFailures")
		const globalAlerts = document.getElementById("bulkGlobalAlerts")
		const executiveSelected = document.getElementById("bulkExecutiveSelected")
		const executiveAffected = document.getElementById("bulkExecutiveAffected")
		const executiveDays = document.getElementById("bulkExecutiveDays")
		const executiveImpact = document.getElementById("bulkExecutiveImpact")
		const executiveCoverage = document.getElementById("bulkExecutiveCoverage")
		const executiveRange = document.getElementById("bulkExecutiveRange")
		const applyConfirmation = document.getElementById("bulkApplyConfirmation")
		const resultSummary = document.getElementById("bulkResultSummary")
		const resultCards = document.getElementById("bulkResultCards")
		const resultRows = document.getElementById("bulkResultRows")
		const resultFailures = document.getElementById("bulkResultFailures")

		const RISK_THRESHOLDS = {
			coveragePct: 70,
			changePct: 25,
			negativeImpact: -100,
		}

		function readPersistedSelection() {
			try {
				const raw = localStorage.getItem(STORAGE_KEY)
				if (!raw) return []
				const parsed = JSON.parse(raw)
				return Array.isArray(parsed) ? parsed.map((id) => String(id)) : []
			} catch {
				return []
			}
		}

		function persistSelection() {
			localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(selectedRatePlanIds)))
		}

		function updateSelectionUI() {
			const count = selectedRatePlanIds.size
			if (selectionCount) selectionCount.textContent = `${count} seleccionados`
			if (applyBtn instanceof HTMLButtonElement && !previewPayload) applyBtn.disabled = true
			if (selectAll instanceof HTMLInputElement) {
				const total = checkboxes.length
				selectAll.checked = total > 0 && count === total
				selectAll.indeterminate = count > 0 && count < total
			}
			persistSelection()
		}

		function isDateOnly(value) {
			return /^\d{4}-\d{2}-\d{2}$/.test(String(value ?? ""))
		}

		function addOneDay(value) {
			const date = new Date(`${value}T00:00:00.000Z`)
			if (Number.isNaN(date.getTime())) return ""
			date.setUTCDate(date.getUTCDate() + 1)
			return date.toISOString().slice(0, 10)
		}

		function countContextDays(from, to) {
			if (!isDateOnly(from) || !isDateOnly(to) || to < from) return 0
			const start = new Date(`${from}T00:00:00.000Z`)
			const end = new Date(`${to}T00:00:00.000Z`)
			return Math.floor((end.getTime() - start.getTime()) / 86400000) + 1
		}

		function getContextRange() {
			const from = String(contextFrom?.value ?? "").trim()
			const to = String(contextTo?.value ?? "").trim()
			const days = countContextDays(from, to)
			return days > 0 ? { from, to, days, effectiveTo: addOneDay(to) } : null
		}

		function syncContextRangeFields() {
			const range = getContextRange()
			if (!range) {
				if (configFeedback) {
					configFeedback.textContent =
						"Puedes revisar por horizonte o definir un rango para mantener continuidad con el calendario."
				}
				return
			}
			if (previewDays instanceof HTMLInputElement) previewDays.value = String(range.days)
			if (effectiveDays instanceof HTMLInputElement) effectiveDays.value = String(range.days)
			if (executiveRange) {
				executiveRange.textContent = `Rango que viene del calendario: ${range.from} → ${range.to}`
			}
			if (configFeedback) {
				configFeedback.textContent = `Rango contextual listo: ${range.days} ${range.days === 1 ? "noche" : "noches"}.`
			}
		}

		function getBulkOperation() {
			const type = String(operationType?.value ?? "").trim()
			const value = Number(operationValue?.value)
			const priority = Number(operationPriority?.value)
			const previewDaysValue = Number(previewDays?.value)
			const effectiveDaysValue = Number(effectiveDays?.value)
			const range = getContextRange()
			if (!selectedRatePlanIds.size) return { error: "Debes seleccionar al menos un rate plan." }
			if (!type) return { error: "Debes seleccionar cómo replicar el cambio." }
			if (!Number.isFinite(value)) return { error: "Debes definir un valor numérico válido." }
			return {
				operation: {
					type,
					value,
					conditions: {
						priority: Number.isFinite(priority) ? priority : 10,
						...(range
							? {
									dateFrom: range.from,
									dateTo: range.to,
									previewFrom: range.from,
									effectiveFrom: range.from,
									effectiveTo: range.effectiveTo,
								}
							: {}),
						previewDays: Number.isFinite(previewDaysValue) ? previewDaysValue : 30,
						effectiveDays: Number.isFinite(effectiveDaysValue) ? effectiveDaysValue : 60,
					},
				},
			}
		}

		function formatMoney(value, currency) {
			const numeric = Number(value ?? 0)
			const safeCurrency = String(currency ?? "").trim() || "USD"
			return new Intl.NumberFormat("es-CL", {
				style: "currency",
				currency: safeCurrency,
				maximumFractionDigits: 2,
			}).format(Number.isFinite(numeric) ? numeric : 0)
		}

		function escapeHtml(value) {
			return String(value ?? "")
				.replaceAll("&", "&amp;")
				.replaceAll("<", "&lt;")
				.replaceAll(">", "&gt;")
				.replaceAll('"', "&quot;")
				.replaceAll("'", "&#39;")
		}

		function buildRecoveryGuidance(error, stage = "") {
			const recovery = copy.recovery || {}
			const text = `${stage} ${error}`.toLowerCase()
			if (text.includes("valid") || text.includes("required") || text.includes("missing")) {
				return recovery.validation || recovery.unknown
			}
			if (text.includes("coverage") || text.includes("material") || text.includes("recompute")) {
				return recovery.coverage || recovery.unknown
			}
			if (text.includes("network") || text.includes("timeout") || text.includes("fetch")) {
				return recovery.network || recovery.unknown
			}
			if (text.includes("apply") || text.includes("rule") || text.includes("insert")) {
				return recovery.apply || recovery.unknown
			}
			return (
				recovery.unknown || {
					title: "Necesita revisión",
					summary: "Este plan no pudo completarse automáticamente.",
					action: "Abre el detalle técnico y vuelve a intentar.",
				}
			)
		}

		function renderFailureCard(item) {
			const ratePlanId = String(item?.ratePlanId ?? "")
			const info = catalogMap.get(ratePlanId)
			const error = String(item?.error ?? "Error no especificado")
			const stage = String(item?.stage ?? "desconocida")
			const guidance = buildRecoveryGuidance(error, stage)
			return `
				<div class="rounded-lg border border-amber-200 bg-white/75 p-3">
					<div class="flex items-start justify-between gap-3">
						<div>
							<p class="font-semibold">${escapeHtml(info?.ratePlanName ?? (ratePlanId || "Plan por revisar"))}</p>
							<p class="text-xs opacity-75">${escapeHtml(info?.variantName ?? "")}</p>
						</div>
						<span class="rounded-full bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-900">Revisar</span>
					</div>
					<p class="mt-2 font-medium">${escapeHtml(guidance.title)}</p>
					<p class="mt-1 text-xs">${escapeHtml(guidance.summary)}</p>
					<p class="mt-2 text-xs"><span class="font-semibold">${escapeHtml(copy.nextStepLabel || "Qué hacer ahora")}:</span> ${escapeHtml(guidance.action)}</p>
					<details class="mt-2 rounded border border-amber-100 bg-amber-50/70 p-2 text-xs">
						<summary class="cursor-pointer font-semibold">${escapeHtml(copy.technicalDetail || "Detalle técnico")}</summary>
						<p class="mt-1">${escapeHtml(error)}</p>
						<p class="mt-1 opacity-75">Etapa: ${escapeHtml(stage)}</p>
					</details>
				</div>
			`
		}

		function formatNights(count) {
			const safeCount = Number.isFinite(Number(count)) ? Number(count) : 0
			return `${safeCount} ${safeCount === 1 ? "noche" : "noches"}`
		}

		function formatDateWithDay(value, fallbackDayLabel = "") {
			const dateText = String(value ?? "")
			if (!dateText) return "—"
			return fallbackDayLabel ? `${fallbackDayLabel} ${dateText}` : dateText
		}

		function calculateRiskSignals(row) {
			const beforeAvg = Number(row?.preview?.priceSummary?.before?.avg ?? 0)
			const afterAvg = Number(row?.preview?.priceSummary?.after?.avg ?? 0)
			const totalDays = Number(row?.preview?.dateRange?.totalDays ?? 0)
			const changedDays = Number(row?.diff?.changedDays ?? 0)
			const estimatedImpact = Number(
				row?.businessMetrics?.estimatedRevenueImpact ?? row?.diff?.totalDelta ?? 0
			)
			const coveragePct = totalDays > 0 ? (changedDays / totalDays) * 100 : 0
			const changePct = beforeAvg > 0 ? Math.abs(((afterAvg - beforeAvg) / beforeAvg) * 100) : 0
			const alerts = []
			if (changePct > RISK_THRESHOLDS.changePct) {
				alerts.push(`Cambio alto (${changePct.toFixed(1)}%)`)
			}
			if (coveragePct < RISK_THRESHOLDS.coveragePct) {
				alerts.push(`Alcance parcial (${coveragePct.toFixed(1)}%)`)
			}
			if (estimatedImpact < RISK_THRESHOLDS.negativeImpact) {
				alerts.push(`Impacto negativo (${estimatedImpact.toFixed(2)})`)
			}
			return { coveragePct, changePct, estimatedImpact, alerts }
		}

		function getSortedPreviewRows(results, mode) {
			const input = Array.isArray(results) ? [...results] : []
			if (mode === "risk_desc") {
				return input.sort(
					(a, b) => calculateRiskSignals(b).alerts.length - calculateRiskSignals(a).alerts.length
				)
			}
			if (mode === "coverage_asc") {
				return input.sort(
					(a, b) => calculateRiskSignals(a).coveragePct - calculateRiskSignals(b).coveragePct
				)
			}
			return input.sort(
				(a, b) =>
					Math.abs(Number(b?.businessMetrics?.estimatedRevenueImpact ?? b?.diff?.totalDelta ?? 0)) -
					Math.abs(Number(a?.businessMetrics?.estimatedRevenueImpact ?? a?.diff?.totalDelta ?? 0))
			)
		}

		function renderExecutiveSummary(payload) {
			const results = Array.isArray(payload?.results) ? payload.results : []
			const totalSelected = selectedRatePlanIds.size
			const affected = results.filter((row) => Number(row?.diff?.changedDays ?? 0) > 0)
			const totalDays = results.reduce(
				(acc, row) => acc + Number(row?.preview?.dateRange?.totalDays ?? 0),
				0
			)
			const changedDays = results.reduce((acc, row) => acc + Number(row?.diff?.changedDays ?? 0), 0)
			const totalImpact = Number(
				results
					.reduce(
						(acc, row) =>
							acc +
							Number(row?.businessMetrics?.estimatedRevenueImpact ?? row?.diff?.totalDelta ?? 0),
						0
					)
					.toFixed(2)
			)
			const coveragePct = totalDays > 0 ? Number(((changedDays / totalDays) * 100).toFixed(1)) : 0
			if (executiveSelected) executiveSelected.textContent = String(totalSelected)
			if (executiveAffected) executiveAffected.textContent = String(affected.length)
			if (executiveDays) executiveDays.textContent = String(changedDays)
			if (executiveImpact)
				executiveImpact.textContent = formatMoney(
					totalImpact,
					results[0]?.preview?.currency ?? "USD"
				)
			if (executiveCoverage) executiveCoverage.textContent = `Alcance listo: ${coveragePct}%`
			const from = results
				.map((row) => String(row?.preview?.dateRange?.from ?? ""))
				.filter(Boolean)
				.sort()[0]
			const to = results
				.map((row) => String(row?.preview?.dateRange?.to ?? ""))
				.filter(Boolean)
				.sort()
				.slice(-1)[0]
			if (executiveRange) {
				executiveRange.textContent =
					from && to
						? `Rango que viene del calendario: ${from} → ${to}`
						: "Rango que viene del calendario: —"
			}
			if (applyConfirmation) {
				applyConfirmation.classList.remove("hidden")
				applyConfirmation.textContent = `Vas a extender este cambio manual a ${affected.length} planes, ${formatNights(changedDays)} con cambio, impacto estimado total ${formatMoney(totalImpact, results[0]?.preview?.currency ?? "USD")}.`
			}
			return { coveragePct, totalImpact, affected: affected.length, changedDays }
		}

		function renderGlobalAlerts(payload, executive) {
			if (!globalAlerts) return
			const results = Array.isArray(payload?.results) ? payload.results : []
			const riskyRows = results.filter((row) => calculateRiskSignals(row).alerts.length > 0)
			const messages = []
			if (executive.coveragePct < RISK_THRESHOLDS.coveragePct) {
				messages.push(
					`El alcance aplicable es parcial (${executive.coveragePct.toFixed(1)}%). Revisa si el rango tiene noches pendientes antes de aplicar.`
				)
			}
			if (executive.totalImpact < RISK_THRESHOLDS.negativeImpact) {
				messages.push(
					`Impacto negativo relevante (${executive.totalImpact.toFixed(2)}). Confirma que esta reducción es intencional.`
				)
			}
			if (riskyRows.length > 0) {
				messages.push(
					`${riskyRows.length} planes necesitan revisión. Puedes aplicar si el impacto es esperado o abrir el detalle avanzado.`
				)
			}
			if (!messages.length) {
				globalAlerts.classList.add("hidden")
				globalAlerts.textContent = ""
				return
			}
			globalAlerts.classList.remove("hidden")
			globalAlerts.innerHTML = `<p class="font-medium">Revisar antes de aplicar</p><ul class="mt-2 list-disc pl-5">${messages
				.map((msg) => `<li>${msg}</li>`)
				.join("")}</ul>`
		}

		function renderPreviewCards(rows) {
			if (!previewCards) return
			previewCards.innerHTML = ""
			for (const row of rows) {
				const info = catalogMap.get(String(row.ratePlanId))
				const currency = String(row?.preview?.currency ?? "USD")
				const before = row?.preview?.priceSummary?.before ?? {}
				const after = row?.preview?.priceSummary?.after ?? {}
