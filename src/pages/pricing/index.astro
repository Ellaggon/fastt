---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import MaterializationFreshnessStrip from "@/components/rates/MaterializationFreshnessStrip.astro"
import MobileCalendarSheetStyles from "@/components/rates/MobileCalendarSheetStyles.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import {
	loadPricingAutomationSurface,
	type PricingAutomationTemplate,
} from "@/lib/pricing/pricingAutomationSurface"
import { buildPricingCalendarSurface } from "@/lib/rates/calendarSurfaces"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { resolvePolicyDateRange } from "@/modules/policies/public"
import { POST as createPricingRulePost } from "@/pages/api/pricing/rules/v2/create"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

let actionError: string | null = null

const mapTemplatePayload = (template: PricingAutomationTemplate, rawValue: number) => {
	const value =
		template.kind === "fixed_discount" ? -Math.abs(rawValue) : Math.max(0, Number(rawValue))
	return {
		type: template.internalType,
		value,
		contextKey: template.contextKey,
	}
}

const eligibilityForForm = (kind: string, form: FormData): Record<string, number> => {
	if (kind === "early_bird") {
		const minLeadDays = Number(form.get("minLeadDays") ?? 30)
		if (!Number.isFinite(minLeadDays) || minLeadDays < 1) {
			throw new Error("Reserva anticipada necesita al menos 1 día de anticipación")
		}
		return { minLeadDays: Math.trunc(minLeadDays) }
	}
	if (kind === "last_minute") {
		const maxLeadDays = Number(form.get("maxLeadDays") ?? 3)
		if (!Number.isFinite(maxLeadDays) || maxLeadDays < 1) {
			throw new Error("Último minuto necesita una ventana de llegada de al menos 1 día")
		}
		return { maxLeadDays: Math.trunc(maxLeadDays) }
	}
	if (kind === "los_discount") {
		const minNights = Number(form.get("minNights") ?? 5)
		if (!Number.isFinite(minNights) || minNights < 1) {
			throw new Error("El descuento por estadía necesita al menos 1 noche")
		}
		return { minNights: Math.trunc(minNights) }
	}
	return {}
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData()
	const action = String(form.get("action") ?? "").trim()
	if (action === "create-pricing-automation") {
		try {
			const automation = await loadPricingAutomationSurface(auth.providerId)
			const ratePlanId = String(form.get("ratePlanId") ?? "").trim()
			const kind = String(form.get("kind") ?? "").trim()
			const template = automation.templates.find((item) => item.kind === kind)
			if (!template) throw new Error("Tipo de automatización no soportado")
			if (!automation.ratePlanOptions.some((item) => item.id === ratePlanId)) {
				throw new Error("El plan tarifario no está disponible para este proveedor")
			}
			const value = Number(form.get("value") ?? Number.NaN)
			if (!Number.isFinite(value) || value < 0)
				throw new Error("El valor de automatización debe ser cero o mayor")
			const priority = Number(form.get("priority") ?? 20)
			if (!Number.isFinite(priority) || priority < 0 || priority > 1000) {
				throw new Error("La prioridad debe estar entre 0 y 1000")
			}
			const dateFrom = String(form.get("dateFrom") ?? "").trim()
			const dateTo = String(form.get("dateTo") ?? "").trim()
			const mapped = mapTemplatePayload(template, value)
			const body: Record<string, unknown> = {
				ratePlanId,
				type: mapped.type,
				value: mapped.value,
				priority,
				contextKey: mapped.contextKey,
			}
			if (dateFrom) body.dateFrom = dateFrom
			if (dateTo) body.dateTo = dateTo
			Object.assign(body, eligibilityForForm(kind, form))

			const headers = new Headers({ "Content-Type": "application/json" })
			const cookie = Astro.request.headers.get("cookie")
			if (cookie) headers.set("cookie", cookie)
			const response = await createPricingRulePost({
				request: new Request(new URL("/api/pricing/rules/v2/create", Astro.url), {
					method: "POST",
					headers,
					body: JSON.stringify(body),
				}),
				url: new URL("/api/pricing/rules/v2/create", Astro.url),
			} as any)
			if (!response.ok) {
				const payload = await response.json().catch(() => null)
				throw new Error(String(payload?.error ?? "No se pudo crear la automatización"))
			}
			return Astro.redirect(`${routes.pricing()}?success=automation-created#pricing-automation`)
		} catch (error) {
			actionError = error instanceof Error ? error.message : "Falló la automatización de precios"
		}
	}
}

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const rows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})
const surface = await buildPricingCalendarSurface({
	rows,
	ratePlanId: Astro.url.searchParams.get("ratePlanId"),
	month: Astro.url.searchParams.get("month"),
})
const selected = surface.selectedRatePlan
const vocabulary = surface.vocabulary

function money(amount: number | null, currency: string): string {
	if (amount == null) return "Sin precio"
	return `${currency} ${Number(amount).toFixed(0)}`
}

const pricedDays = surface.days.filter((day) => day.status === "priced").length
const adjustedDays = surface.days.filter((day) => Number(day.ruleAdjustment ?? 0) !== 0).length
const basePriceDays = surface.days.filter((day) => day.priceSignal === "baseline").length
const restrictionSignalDays = surface.days.filter((day) => day.restrictionSignals.count > 0).length
const restrictionBlockerDays = surface.days.filter(
	(day) => day.restrictionSignals.hasCommercialBlocker
).length
const pricingRangeDays = surface.days.map((day) => ({
	date: day.date,
	status: day.status,
	ruleAdjustment: day.ruleAdjustment,
	restrictionCount: day.restrictionSignals.count,
	restrictionBlocker: day.restrictionSignals.hasCommercialBlocker,
}))
const selectedRatePlanId = String(selected?.ratePlanId ?? "")
const selectedRatePlanName = String(selected?.ratePlanName ?? "")
const pricingBulkHref = `${routes.pricingBulk()}?ratePlanIds=${encodeURIComponent(selectedRatePlanId)}`
const automationSurface = await loadPricingAutomationSurface(auth.providerId)
const automationDefaultRatePlanId = automationSurface.ratePlanOptions[0]?.id ?? ""
const automationDefaultTemplate = automationSurface.templates[1]
const success = String(Astro.url.searchParams.get("success") ?? "").trim()
const statusVariant = {
	active: "success",
	inactive: "neutral",
} as const
const shouldOpenAutomation = Boolean(actionError || success === "automation-created")
---

<WorkspaceLayout title="Pricing">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Rooms & Rates · Pricing
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Pricing</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Opera precios diarios por {vocabulary.ratePlan}. Pricing responde cuanto cuesta;
					Restrictions responde cuando se puede vender.
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				<Button href="#pricing-automation" variant="secondary">Automatización avanzada</Button>
				<Button href={routes.ratePlansList()} variant="secondary">Rate Plans</Button>
			</div>
		</header>

		{
			actionError && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">No se pudo crear la automatización de pricing</p>
					<p class="mt-1 text-sm">{actionError}</p>
				</Card>
			)
		}
		{
			success === "automation-created" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">Automatización de pricing creada.</p>
					<p class="mt-1 text-sm">
						La regla quedó dentro de Pricing y puede impactar precio efectivo según elegibilidad.
					</p>
				</Card>
			)
		}

		<section
			data-mobile-calendar-summary
			class="-mx-1 flex gap-2 overflow-x-auto px-1 pb-1 text-xs sm:hidden"
		>
			<span
				class="shrink-0 rounded-full border border-slate-700 bg-slate-900 px-3 py-2 font-semibold text-slate-100"
			>
				{surface.summary.coveragePercent}% cobertura
			</span>
			<span
				class="shrink-0 rounded-full border border-slate-700 bg-slate-900 px-3 py-2 text-slate-300"
			>
				{pricedDays} con precio
			</span>
			<span
				class="shrink-0 rounded-full border border-slate-700 bg-slate-900 px-3 py-2 text-slate-300"
			>
				{adjustedDays} ajustes
			</span>
			<span
				class="shrink-0 rounded-full border border-slate-700 bg-slate-900 px-3 py-2 text-slate-300"
			>
				{surface.summary.missingDays} sin precio
			</span>
		</section>

		<section class="hidden gap-4 sm:grid md:grid-cols-4">
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Cobertura</p>
				<p class="mt-2 text-2xl font-semibold">{surface.summary.coveragePercent}%</p>
				<p class="mt-1 text-xs text-slate-400">Dias futuros con precio efectivo</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Dias con precio</p>
				<p class="mt-2 text-2xl font-semibold">{pricedDays}</p>
				<p class="mt-1 text-xs text-slate-400">{surface.summary.missingDays} faltantes futuros</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Base de precio</p>
				<p class="mt-2 text-2xl font-semibold">
					{money(surface.baseline.basePrice, surface.baseline.currency)}
				</p>
				<p class="mt-1 text-xs text-slate-400">Precio heredado del {vocabulary.ratePlan}</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Ajustes</p>
				<p class="mt-2 text-2xl font-semibold">{adjustedDays}</p>
				<p class="mt-1 text-xs text-slate-400">Dias con ajuste manual visible</p>
			</Card>
		</section>

		<Section
			title="Calendario de precios"
			description={`Operación diaria: selecciona ${vocabulary.ratePlan}, toca fechas, corrige gaps y ajusta precios visibles sin salir del calendario.`}
		>
			<Card className="space-y-5 bg-white text-slate-800">
				<form method="get" class="grid gap-3 lg:grid-cols-[1.6fr_0.8fr_auto] lg:items-end">
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">{vocabulary.scopeRatePlan}</span>
						<select name="ratePlanId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							{
								rows.map((row) => (
									<option
										value={String(row.ratePlanId)}
										selected={selected?.ratePlanId === row.ratePlanId}
									>
										{row.productName} · {row.variantName} · {row.ratePlanName}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Mes</span>
						<input
							type="month"
							name="month"
							value={surface.month}
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
						/>
					</label>
					<Button type="submit" variant="primary">Aplicar</Button>
				</form>

				<div
					class="flex flex-wrap items-center justify-between gap-3 border-y border-slate-200 py-3"
				>
					<div class="flex flex-wrap items-center gap-2">
						<Button
							href={`/pricing?ratePlanId=${encodeURIComponent(String(selected?.ratePlanId ?? ""))}&month=${surface.previousMonth}`}
							variant="secondary"
							size="sm"
						>
							Mes anterior
						</Button>
						<Button
							href={`/pricing?ratePlanId=${encodeURIComponent(String(selected?.ratePlanId ?? ""))}&month=${surface.nextMonth}`}
							variant="secondary"
							size="sm"
						>
							Mes siguiente
						</Button>
						<Badge variant={surface.summary.missingDays > 0 ? "warning" : "success"}>
							{
								surface.summary.missingDays > 0
									? `${surface.summary.missingDays} dias sin precio`
									: "Cobertura lista"
							}
						</Badge>
					</div>
					<div class="flex flex-wrap items-center gap-2">
						<Button
							id="generatePricingCoverageBtn"
							type="button"
							variant="secondary"
							size="sm"
							data-rate-plan-id={String(selected?.ratePlanId ?? "")}
							data-from={surface.startDate}
							data-to={surface.endDate}
						>
							Regenerar mes
						</Button>
					</div>
				</div>
				<p class="text-xs text-slate-500 sm:hidden">
					Toca una fecha para editarla; toca otra fecha para crear un rango.
				</p>

				<details
					data-mobile-operational-summary
					class="rounded-lg border border-slate-200 bg-slate-50 p-2.5 text-xs text-slate-600 sm:hidden"
				>
					<summary
						class="flex cursor-pointer list-none items-center justify-between gap-2 font-semibold text-slate-900"
					>
						<span>Estado operativo</span>
						<span class="text-[11px] font-medium text-slate-500">
							{surface.summary.missingDays} sin precio · {adjustedDays} ajustes
						</span>
					</summary>
					<div class="mt-3 grid gap-2">
						<div class="flex flex-wrap gap-1">
							<span class="rounded-full bg-white px-2 py-1">{basePriceDays} heredados</span>
							<span class="rounded-full bg-white px-2 py-1">
								{restrictionSignalDays} restricciones
							</span>
							<span class="rounded-full bg-white px-2 py-1">
								{surface.freshness.overall.label}: {surface.freshness.overall.state}
							</span>
						</div>
					</div>
				</details>

				<div
					data-pricing-intelligence-strip
					class="hidden gap-2 rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-600 sm:grid md:grid-cols-4"
				>
					<div>
						<p class="font-semibold text-slate-900">{surface.summary.missingDays} sin precio</p>
						<p>Fechas futuras sin precio efectivo.</p>
					</div>
					<div>
						<p class="font-semibold text-slate-900">{adjustedDays} ajustes</p>
						<p>Cambios manuales sobre la base heredada.</p>
					</div>
					<div>
						<p class="font-semibold text-slate-900">{basePriceDays} heredados</p>
						<p>Noches heredadas del {vocabulary.ratePlan}.</p>
					</div>
					<div>
						<p class="font-semibold text-slate-900">{restrictionSignalDays} con restricciones</p>
						<p>
							{
								restrictionBlockerDays > 0
									? `${restrictionBlockerDays} pueden bloquear venta.`
									: "Señales de vendibilidad viven en Restrictions."
							}
						</p>
					</div>
				</div>

				<div class="hidden sm:block">
					<MaterializationFreshnessStrip
						title="Actualizacion operacional"
						description="Lectura ligera de materializaciones visibles para este calendario."
						items={[
							surface.freshness.pricing,
							surface.freshness.restrictions,
							surface.freshness.search,
						]}
					/>
				</div>

				{
					!selected ? (
						<div class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
							No hay {vocabulary.ratePlanPlural} para operar pricing todavia.
						</div>
					) : (
						<>
							<div
								id="pricingSheetBackdrop"
								class="mobile-calendar-sheet-backdrop hidden"
								aria-hidden="true"
							/>
							<div
								id="pricingRangePanel"
								data-mobile-calendar-action-sheet
								data-sheet-state="compact"
								class="mobile-calendar-action-sheet sticky top-3 z-20 hidden rounded-lg border border-blue-200 bg-blue-50/95 p-4 text-sm text-blue-950 shadow-sm backdrop-blur"
							>
								<div
									data-mobile-sheet-handle
									class="mobile-sheet-handle mx-auto mb-3 hidden h-1 w-12 rounded-full bg-blue-200"
								/>
								<div class="grid gap-3 md:grid-cols-[minmax(16rem,1fr)_auto] md:items-start">
									<div class="min-w-0 space-y-1.5">
										<div class="flex items-start justify-between gap-2">
											<p class="text-sm leading-5 font-semibold sm:text-base">
												Aplicar precio al rango
											</p>
											<div class="flex items-center gap-1 md:hidden">
												<button
													id="pricingSheetExpandBtn"
													type="button"
													class="rounded border border-blue-200 bg-white px-2 py-1 text-[11px] font-semibold text-blue-900"
												>
													Expandir
												</button>
												<button
													id="pricingSheetCloseBtn"
													type="button"
													class="rounded border border-blue-200 bg-white px-2 py-1 text-[11px] font-semibold text-blue-900"
												>
													Cerrar
												</button>
											</div>
										</div>
										<p id="pricingRangeSummary" class="text-xs text-blue-900 sm:text-sm">
											Toca una fecha para editarla o toca otra para completar el rango.
										</p>
										<p id="pricingRangePreview" class="hidden text-xs text-blue-800 sm:block" />
									</div>
									<div class="flex w-full flex-wrap items-center gap-2 md:w-auto md:justify-end">
										<div class="hidden w-full gap-1 overflow-x-auto pb-1 sm:flex sm:flex-wrap sm:overflow-visible sm:pb-0">
											<button
												type="button"
												data-pricing-range-preset="visible_week"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Semana visible
											</button>
											<button
												type="button"
												data-pricing-range-preset="visible_weekend"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Fin de semana
											</button>
											<button
												type="button"
												data-pricing-range-preset="visible_month"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Mes visible
											</button>
											<button
												type="button"
												data-pricing-range-preset="next_7"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Prox. 7 dias
											</button>
											<button
												type="button"
												data-pricing-range-preset="next_30"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Prox. 30 dias
											</button>
										</div>
										<div class="grid w-full grid-cols-[1fr_auto_auto] gap-2 sm:w-auto sm:grid-cols-[10rem_auto_auto_auto_auto] sm:items-end">
											<label class="space-y-1">
												<span class="text-xs font-medium text-blue-950">Precio final</span>
												<input
													id="pricingRangeValue"
													type="number"
													min="0"
													step="1"
													placeholder="Precio"
													class="w-full rounded border border-blue-200 px-3 py-2 text-slate-900"
												/>
											</label>
											<button
												id="pricingRangePreviewBtn"
												type="button"
												class="hidden rounded border border-blue-300 px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100 sm:block"
											>
												Previsualizar
											</button>
											<button
												id="pricingRangeApplyBtn"
												type="button"
												class="rounded bg-blue-700 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-800 disabled:opacity-60"
											>
												Aplicar
											</button>
											<button
												id="pricingRangeGenerateBtn"
												type="button"
												class="hidden rounded border border-blue-300 px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100 sm:block"
											>
												Regenerar
											</button>
											<button
												id="pricingRangeClearBtn"
												type="button"
												class="rounded border border-blue-300 px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100"
											>
												Limpiar
											</button>
										</div>
										<a
											href={pricingBulkHref}
											class="w-full text-right text-xs font-medium text-blue-800 underline-offset-2 hover:underline sm:w-auto"
										>
											Aplicar a otros planes
										</a>
									</div>
								</div>
								<div
									id="pricingDayEditor"
									class="mt-3 rounded-md border border-blue-200 bg-white/80 p-2.5 sm:mt-4 sm:p-3"
								>
									<div class="grid grid-cols-[1fr_auto] items-end gap-2 sm:flex sm:flex-wrap">
										<label class="min-w-0 flex-1 space-y-1 sm:max-w-xs">
											<span class="text-xs font-medium text-blue-950">
												Editar fecha seleccionada
											</span>
											<input
												id="pricingDayValue"
												type="number"
												min="0"
												step="1"
												placeholder="Precio diario"
												class="w-full rounded border border-blue-200 px-3 py-2 text-slate-900"
											/>
										</label>
										<div class="flex gap-1 sm:contents">
											<button
												type="button"
												data-pricing-quick-delta="-10"
												class="rounded border border-blue-300 px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100"
											>
												-10
											</button>
											<button
												type="button"
												data-pricing-quick-delta="10"
												class="rounded border border-blue-300 px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100"
											>
												+10
											</button>
										</div>
										<button
											id="pricingDaySaveBtn"
											type="button"
											class="col-span-2 rounded bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-700 sm:col-span-1"
										>
											Guardar fecha
										</button>
									</div>
									<p id="pricingDayHint" class="mt-2 hidden text-xs text-blue-800 sm:block">
										Usa este editor para una noche; usa el rango para varias.
									</p>
								</div>
							</div>
							<div class="mobile-calendar-grid grid grid-cols-7 gap-1 md:gap-2">
								{surface.days.map((day) => (
									<div
										data-pricing-day-card
										data-date={day.date}
										data-current-price={day.finalPrice == null ? "" : String(day.finalPrice)}
										role={day.isPast ? undefined : "button"}
										tabindex={day.isPast ? undefined : "0"}
										aria-label={`Seleccionar ${day.date} para editar precio o rango`}
										class:list={[
											"mobile-calendar-cell min-h-[4.75rem] rounded-lg border p-1.5 transition hover:-translate-y-0.5 hover:shadow-sm md:min-h-32 md:p-3",
											!day.isPast &&
												"cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500",
											day.status === "priced" && "border-emerald-200 bg-emerald-50",
											day.status === "missing" && "border-amber-200 bg-amber-50",
											day.status === "past" && "border-slate-200 bg-slate-50 text-slate-500",
										]}
									>
										<div class="flex items-start justify-between gap-1">
											<div>
												<p class="text-[10px] text-slate-500 md:text-xs">{day.weekday}</p>
												<p class="text-sm font-semibold text-slate-950 md:text-lg">{day.day}</p>
											</div>
											<span
												aria-hidden="true"
												class:list={[
													"mt-1 h-2 w-2 rounded-full md:hidden",
													day.status === "priced" && "bg-emerald-500",
													day.status === "missing" && "bg-amber-500",
													day.status === "past" && "bg-slate-300",
												]}
											/>
											<span class="hidden md:inline-flex">
												<Badge
													variant={
														day.status === "priced"
															? "success"
															: day.status === "missing"
																? "warning"
																: "neutral"
													}
												>
													{day.priceSignalLabel}
												</Badge>
											</span>
										</div>
										<p class="mobile-priority-signal mt-1 truncate text-[11px] font-semibold text-slate-950 md:mt-3 md:text-base">
											<span data-pricing-output>{money(day.finalPrice, day.currency)}</span>
										</p>
										<p class="mt-1 hidden text-xs text-slate-600 sm:block">
											Base{" "}
											{day.baseComponent == null
												? "sin materializar"
												: money(day.baseComponent, day.currency)}
										</p>
										<div class="mt-1 flex flex-wrap gap-1 md:mt-2">
											{day.status === "missing" ? (
												<span class="rounded-full bg-amber-100 px-1.5 py-0.5 text-[10px] font-medium text-amber-800 md:px-2 md:text-[11px]">
													Sin precio
												</span>
											) : null}
											{day.baseComponent != null ? (
												<span class="hidden rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-700 sm:inline-flex">
													Base heredada
												</span>
											) : null}
											{day.hasPrice ? (
												<span class="hidden rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-medium text-emerald-800 sm:inline-flex">
													Efectivo
												</span>
											) : null}
											{Number(day.ruleAdjustment ?? 0) !== 0 ? (
												<span class="rounded-full bg-blue-100 px-1.5 py-0.5 text-[10px] font-medium text-blue-800 md:px-2 md:text-[11px]">
													<span class="md:hidden">Manual</span>
													<span class="hidden md:inline">Ajuste manual</span>
												</span>
											) : null}
											{day.restrictionSignals.count > 0 ? (
												<a
													href={routes.rateRestrictions()}
													class:list={[
														"rounded-full px-1.5 py-0.5 text-[10px] font-medium underline-offset-2 hover:underline md:px-2 md:text-[11px]",
														day.restrictionSignals.hasCommercialBlocker
															? "bg-red-100 text-red-800"
															: "bg-blue-100 text-blue-800",
													]}
												>
													<span class="md:hidden">Restr.</span>
													<span class="hidden md:inline">
														{day.restrictionSignals.summary ?? "Restrictions"}
													</span>
												</a>
											) : null}
										</div>
										{day.restrictionSignals.count > 0 ? (
											<p class="mt-1 hidden text-xs text-slate-600 sm:block">
												Vendibilidad: {day.restrictionSignals.summary}. No cambia el precio.
											</p>
										) : null}
										{Number(day.ruleAdjustment ?? 0) !== 0 ? (
											<p class="mt-1 hidden text-xs text-blue-700 sm:block">
												Ajuste {money(day.ruleAdjustment, day.currency)}
											</p>
										) : null}
									</div>
								))}
							</div>
						</>
					)
				}
				<details
					data-pricing-advanced-panel
					class="rounded-lg border border-dashed border-slate-300 bg-slate-50/80 p-3 text-sm text-slate-700"
				>
					<summary class="cursor-pointer font-semibold text-slate-900">
						Flujo avanzado multi-plan
					</summary>
					<div class="mt-2 flex flex-wrap items-center justify-between gap-3">
						<p class="max-w-2xl leading-6">
							El calendario es el lugar natural para operar precios. Abre este flujo solo si
							necesitas aplicar un mismo cambio sobre varios {vocabulary.ratePlanPlural} y revisar fallos
							parciales antes de confirmar.
						</p>
						<Button href={pricingBulkHref} variant="secondary" size="sm"> Abrir multi-plan </Button>
					</div>
				</details>
				<p id="pricingCalendarFeedback" class="text-sm text-slate-600"></p>
			</Card>
		</Section>

		<Section
			title="Capas avanzadas de pricing"
			description="Automatización y multi-plan quedan como soporte progresivo. El calendario sigue siendo la operación diaria."
		>
			<Card id="pricing-automation" className="space-y-4 bg-white text-slate-800">
				<details
					open={shouldOpenAutomation}
					class="rounded-lg border border-slate-200 bg-slate-50 p-3"
					data-pricing-automation-panel
				>
					<summary class="cursor-pointer list-none">
						<div class="flex flex-wrap items-start justify-between gap-3">
							<div class="space-y-1">
								<p class="text-sm font-semibold text-slate-950">Automatización de precios</p>
								<p class="max-w-3xl text-sm leading-6 text-slate-600">
									Usa esta capa para descuentos, precios fijos o elegibilidad recurrente. Para
									cambiar una fecha o rango visible, usa primero el calendario.
								</p>
							</div>
							<div class="flex flex-wrap gap-1 text-xs">
								<span class="rounded-full bg-white px-2 py-1 text-slate-700">
									{automationSurface.stats.totalRules} reglas
								</span>
								<span class="rounded-full bg-white px-2 py-1 text-slate-700">
									{automationSurface.stats.activeRules} activas
								</span>
								<span class="rounded-full bg-white px-2 py-1 text-slate-700">
									{automationSurface.stats.ratePlansWithRules} planes
								</span>
							</div>
						</div>
					</summary>

					<div class="mt-4 space-y-5">
						<div class="rounded-lg border border-blue-100 bg-blue-50 p-3 text-sm text-blue-950">
							<p class="font-semibold">Ownership claro</p>
							<p class="mt-1">
								Automatización cambia dinero. Restrictions gobierna vendibilidad. Booking Policies
								gobierna el contrato de reserva. House Rules gobierna comportamiento del huésped.
							</p>
						</div>

						{
							!automationSurface.ratePlanOptions.length ? (
								<p class="text-sm text-slate-600">
									No hay planes tarifarios activos disponibles para automatización de precios.
								</p>
							) : (
								<form
									method="POST"
									class="grid gap-4 rounded-lg border border-slate-200 p-4 lg:grid-cols-6"
									data-pricing-automation-form
								>
									<input type="hidden" name="action" value="create-pricing-automation" />
									<label class="space-y-1 text-sm lg:col-span-3">
										<span class="font-medium text-slate-700">Plan tarifario</span>
										<select
											name="ratePlanId"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										>
											{automationSurface.ratePlanOptions.map((option) => (
												<option
													value={option.id}
													selected={option.id === automationDefaultRatePlanId}
												>
													{option.label}
												</option>
											))}
										</select>
									</label>
									<label class="space-y-1 text-sm lg:col-span-3">
										<span class="font-medium text-slate-700">Tipo de automatización</span>
										<select
											name="kind"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
											data-pricing-automation-kind
										>
											{automationSurface.templates.map((template) => (
												<option
													value={template.kind}
													selected={template.kind === automationDefaultTemplate?.kind}
													data-default-value={String(template.defaultValue)}
													data-value-suffix={template.valueSuffix}
												>
													{template.label}
												</option>
											))}
										</select>
									</label>
									<label class="space-y-1 text-sm lg:col-span-2">
										<span class="font-medium text-slate-700">Valor</span>
										<input
											name="value"
											type="number"
											min="0"
											step="0.01"
											value={String(automationDefaultTemplate?.defaultValue ?? 10)}
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
											data-pricing-automation-value
										/>
										<p class="text-xs text-slate-500" data-pricing-automation-value-help>
											{automationDefaultTemplate?.valueSuffix ?? "% de descuento"}
										</p>
									</label>
									<label class="space-y-1 text-sm lg:col-span-2">
										<span class="font-medium text-slate-700">Válida desde</span>
										<input
											name="dateFrom"
											type="date"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<label class="space-y-1 text-sm lg:col-span-2">
										<span class="font-medium text-slate-700">Válida hasta</span>
										<input
											name="dateTo"
											type="date"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<label class="space-y-1 text-sm lg:col-span-2">
										<span class="font-medium text-slate-700">Prioridad</span>
										<input
											name="priority"
											type="number"
											min="0"
											max="1000"
											value="20"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<label class="space-y-1 text-sm" data-pricing-eligibility="early_bird">
										<span class="font-medium text-slate-700">Anticipación mínima</span>
										<input
											name="minLeadDays"
											type="number"
											min="1"
											value="30"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<label class="space-y-1 text-sm" data-pricing-eligibility="last_minute">
										<span class="font-medium text-slate-700">Anticipación máxima</span>
										<input
											name="maxLeadDays"
											type="number"
											min="1"
											value="3"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<label class="space-y-1 text-sm" data-pricing-eligibility="los_discount">
										<span class="font-medium text-slate-700">Noches mínimas</span>
										<input
											name="minNights"
											type="number"
											min="1"
											value="5"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<div class="flex items-end lg:col-span-6">
										<Button type="submit" variant="primary">
											Crear automatización
										</Button>
									</div>
								</form>
							)
						}

						<div class="space-y-3">
							<div class="flex flex-wrap items-center justify-between gap-3">
								<p class="text-sm font-semibold text-slate-900">Automatizaciones existentes</p>
								<Button href={routes.pricingBulk()} variant="secondary" size="sm">
									Multi-plan avanzado
								</Button>
							</div>
							{
								automationSurface.rules.length ? (
									<div class="grid gap-3">
										{automationSurface.rules.slice(0, 12).map((rule) => (
											<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
												<div class="flex flex-wrap items-start justify-between gap-3">
													<div>
														<div class="flex flex-wrap items-center gap-2">
															<Badge variant="info">{rule.kindLabel}</Badge>
															<Badge variant={statusVariant[rule.status]}>{rule.statusLabel}</Badge>
															<Badge variant="neutral">Prioridad {rule.priority}</Badge>
														</div>
														<p class="mt-2 text-sm font-semibold text-slate-900">
															{rule.productName} · {rule.variantName} · {rule.ratePlanName}
														</p>
														<p class="mt-1 text-sm text-slate-700">{rule.summary}</p>
														<p class="mt-1 text-xs text-slate-500">
															Vigencia: {rule.validityLabel} · Elegibilidad: {rule.eligibilityLabel}
														</p>
													</div>
													<div class="flex flex-wrap gap-2">
														<Button href={rule.quickLinks.ratePlan} variant="secondary" size="sm">
															Plan tarifario
														</Button>
														<Button
															href={rule.quickLinks.advancedPricing}
															variant="secondary"
															size="sm"
														>
															Multi-plan
														</Button>
													</div>
												</div>
											</div>
										))}
									</div>
								) : (
									<div class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">
										Todavía no hay automatizaciones. Crea descuentos, precios fijos o reglas por
										estadía solo cuando necesites lógica monetaria recurrente.
									</div>
								)
							}
						</div>
					</div>
				</details>
			</Card>
		</Section>
	</div>

	<div
		hidden
		id="pricingRangeData"
		data-range={JSON.stringify({
			days: pricingRangeDays,
			ratePlanId: selectedRatePlanId,
			ratePlanName: selectedRatePlanName,
		})}
	>
	</div>

	<script>
		// @ts-nocheck
		import {
			addDays,
			countInclusiveDays,
			formatRangeLabel,
			normalizeCalendarRange,
			selectCalendarRangePreset,
			summarizeRangeDays,
			updateCalendarRangeHighlight,
		} from "@/lib/rates/calendarRangeOperations"
		import {
			createMobileActionSheet,
			findNextSelectableDate,
			flashAppliedRange,
		} from "@/lib/rates/mobileCalendarInteraction"

		const feedback = document.getElementById("pricingCalendarFeedback")
		const generateBtn = document.getElementById("generatePricingCoverageBtn")
		const rangePanel = document.getElementById("pricingRangePanel")
		const rangeSummary = document.getElementById("pricingRangeSummary")
		const rangePreview = document.getElementById("pricingRangePreview")
		const rangeValue = document.getElementById("pricingRangeValue")
		const sheetBackdrop = document.getElementById("pricingSheetBackdrop")
		const sheetCloseBtn = document.getElementById("pricingSheetCloseBtn")
		const sheetExpandBtn = document.getElementById("pricingSheetExpandBtn")
		const sheetHandle = document.querySelector("[data-mobile-sheet-handle]")
		const dayEditor = document.getElementById("pricingDayEditor")
		const dayValue = document.getElementById("pricingDayValue")
		const daySaveBtn = document.getElementById("pricingDaySaveBtn")
		const dayHint = document.getElementById("pricingDayHint")
		const quickDeltaButtons = Array.from(document.querySelectorAll("[data-pricing-quick-delta]"))
		const rangePreviewBtn = document.getElementById("pricingRangePreviewBtn")
		const rangeApplyBtn = document.getElementById("pricingRangeApplyBtn")
		const rangeGenerateBtn = document.getElementById("pricingRangeGenerateBtn")
		const rangeClearBtn = document.getElementById("pricingRangeClearBtn")
		const rangePresetButtons = Array.from(document.querySelectorAll("[data-pricing-range-preset]"))
		const rangeCards = Array.from(document.querySelectorAll("[data-pricing-day-card]"))
		const rangeConfig = JSON.parse(
			document.getElementById("pricingRangeData")?.dataset?.range || "{}"
		)
		const rangeDays = Array.isArray(rangeConfig.days) ? rangeConfig.days : []
		const selectedRatePlanId = String(rangeConfig.ratePlanId || "")
		const selectedRatePlanName = String(rangeConfig.ratePlanName || "")
		let rangeAnchor = null
		let selectedRange = null
		let rangePreviewPayload = null

		function setFeedback(message) {
			if (feedback) feedback.textContent = message
		}

		function formatMoneyLike(sample, value) {
			const rounded = Number(value).toFixed(Number(value) % 1 === 0 ? 0 : 2)
			const text = String(sample || "").trim()
			const prefix = text.match(/^[^\d-]+/)?.[0]?.trim()
			const suffix = text.match(/[^\d\s]+$/)?.[0]?.trim()
			if (prefix) return `${prefix} ${rounded}`
			if (suffix && suffix !== prefix) return `${rounded} ${suffix}`
			return rounded
		}

		function updateSelectedPricingCells(value) {
			if (!selectedRange) return
			rangeCards.forEach((card) => {
				const date = card.getAttribute("data-date")
				if (!date || date < selectedRange.from || date > selectedRange.to) return
				const output = card.querySelector("[data-pricing-output]")
				const nextText = formatMoneyLike(output?.textContent, value)
				card.setAttribute("data-current-price", String(value))
				card.classList.remove("border-amber-200", "bg-amber-50")
				card.classList.add("border-emerald-200", "bg-emerald-50")
				if (output) output.textContent = nextText
			})
			flashAppliedRange({ cards: rangeCards, range: selectedRange })
		}

		function setApplyNeedsConfirmation(ready) {
			if (!(rangeApplyBtn instanceof HTMLButtonElement)) return
			rangeApplyBtn.textContent = ready ? "Confirmar" : "Aplicar"
		}

		const mobileSheet = createMobileActionSheet({
			panel: rangePanel,
			backdrop: sheetBackdrop,
			handle: sheetHandle,
			expandButton: sheetExpandBtn,
			closeButton: sheetCloseBtn,
			onClose: clearRangeSelection,
		})

		function setSheetExpanded(isExpanded) {
			mobileSheet.setState(isExpanded ? "expanded" : "compact")
		}

		function getSelectedRangeDays() {
			if (!selectedRange) return 0
			return countInclusiveDays(selectedRange)
		}

		function nightsLabel(days) {
			return `${days} ${days === 1 ? "noche" : "noches"}`
		}

		function syncDayEditor(date) {
			if (!dayEditor || !date) return
			const days = getSelectedRangeDays()
			const card = rangeCards.find((item) => item.getAttribute("data-date") === date)
			const current = card?.getAttribute("data-current-price") || ""
			if (dayValue instanceof HTMLInputElement) dayValue.value = current
			dayEditor.classList.toggle("hidden", days !== 1)
			if (dayHint) {
				dayHint.textContent =
					days === 1
						? "Toca Guardar fecha para ajustar solo esta noche, o toca otra fecha para crear un rango."
						: "Edita el precio del rango desde la accion principal."
			}
		}

		function buildPricingRangePayload() {
			if (!selectedRange || !selectedRatePlanId) return null
			const value = Number(rangeValue?.value)
			if (!Number.isFinite(value) || value < 0) return null
			const days = countInclusiveDays(selectedRange)
			return {
				ratePlanIds: [selectedRatePlanId],
				operation: {
					type: "fixed_override",
					value,
					conditions: {
						priority: 1000,
						dateFrom: selectedRange.from,
						dateTo: selectedRange.to,
						previewFrom: selectedRange.from,
						previewDays: days,
						effectiveFrom: selectedRange.from,
						effectiveTo: addDays(selectedRange.to, 1),
						contextKey: "manual",
					},
				},
				concurrency: 1,
			}
		}

		function renderRangeSelection() {
			if (!selectedRange) return
			mobileSheet.setOpen(true)
			const days = countInclusiveDays(selectedRange)
			const summary = summarizeRangeDays(rangeDays, selectedRange)
			if (rangeSummary) {
				rangeSummary.textContent = `${formatRangeLabel(selectedRange)} · Impactara ${nightsLabel(days)} en ${selectedRatePlanName || "el plan seleccionado"}.`
			}
			if (rangePreview) {
				rangePreview.textContent = `${nightsLabel(days)} seleccionadas · ${summary.missing} dias sin precio efectivo · ${summary.adjusted} manuales · ${summary.restricted} con restricciones.`
			}
			rangePreviewPayload = null
			setApplyNeedsConfirmation(false)
			updateCalendarRangeHighlight({ cards: rangeCards, range: selectedRange })
			syncDayEditor(selectedRange.from)
		}

		function clearRangeSelection() {
			selectedRange = null
			rangeAnchor = null
			rangePreviewPayload = null
			mobileSheet.setOpen(false)
			setSheetExpanded(false)
			setApplyNeedsConfirmation(false)
			updateCalendarRangeHighlight({ cards: rangeCards, range: null })
			mobileSheet.setState("compact")
		}

		function selectPricingDate(date) {
			if (!date) return
			if (!rangeAnchor && selectedRange && selectedRange.from !== selectedRange.to) {
				selectedRange = normalizeCalendarRange(selectedRange.from, date)
			} else if (!rangeAnchor) {
				rangeAnchor = date
				selectedRange = { from: date, to: date }
			} else {
				selectedRange = normalizeCalendarRange(rangeAnchor, date)
				rangeAnchor = null
			}
			renderRangeSelection()
		}

		rangeCards.forEach((card) => {
			card.addEventListener("click", (event) => {
				if (card.getAttribute("tabindex") !== "0") return
				if (event.target?.closest?.("a,button,input,select,textarea")) return
				selectPricingDate(card.getAttribute("data-date"))
			})
			card.addEventListener("keydown", (event) => {
				if (event.key !== "Enter" && event.key !== " ") return
				event.preventDefault()
				selectPricingDate(card.getAttribute("data-date"))
			})
		})

		rangePresetButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const preset = button.getAttribute("data-pricing-range-preset")
				const nextRange = selectCalendarRangePreset(preset, rangeDays)
				if (!nextRange) {
					setFeedback("Ese preset no tiene fechas visibles en este mes.")
					return
				}
				selectedRange = nextRange
				rangeAnchor = null
				renderRangeSelection()
			})
		})

		rangeClearBtn?.addEventListener("click", clearRangeSelection)
		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && selectedRange) clearRangeSelection()
		})

		quickDeltaButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const delta = Number(button.getAttribute("data-pricing-quick-delta") ?? 0)
				const current = Number(dayValue?.value || rangeValue?.value || 0)
				const next = Math.max(0, current + delta)
				if (getSelectedRangeDays() === 1 && dayValue instanceof HTMLInputElement) {
					dayValue.value = String(next)
					dayValue.focus()
					return
				}
				if (rangeValue instanceof HTMLInputElement) {
					rangeValue.value = String(next)
					rangeValue.focus()
				}
			})
		})

		daySaveBtn?.addEventListener("click", async () => {
			if (!selectedRange || selectedRange.from !== selectedRange.to || !selectedRatePlanId) {
				setFeedback("Selecciona una sola fecha para guardar un precio diario.")
				return
			}
			const value = Number(dayValue?.value)
			if (!Number.isFinite(value) || value < 0) {
				setFeedback("Completa un precio valido.")
				return
			}
			setFeedback(`Guardando precio para ${selectedRange.from}...`)
			if (daySaveBtn instanceof HTMLButtonElement) daySaveBtn.disabled = true
			const response = await fetch("/api/pricing/rules/v2/create", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					ratePlanId: selectedRatePlanId,
					type: "fixed_override",
					value,
					priority: 1000,
					dateFrom: selectedRange.from,
					dateTo: selectedRange.from,
					contextKey: "manual",
				}),
			})
			if (!response.ok) {
				const body = await response.json().catch(() => ({}))
				setFeedback(`No se pudo guardar: ${String(body?.error ?? response.status)}`)
				if (daySaveBtn instanceof HTMLButtonElement) daySaveBtn.disabled = false
				return
			}
			updateSelectedPricingCells(value)
			const nextDate = findNextSelectableDate(rangeCards, selectedRange.from)
			if (nextDate) {
				rangeAnchor = nextDate
				selectedRange = { from: nextDate, to: nextDate }
				renderRangeSelection()
				mobileSheet.setState("expanded")
				if (dayValue instanceof HTMLInputElement) {
					dayValue.focus()
					dayValue.select()
				}
				setFeedback(`Precio guardado. Seguimos con ${nextDate}.`)
			} else {
				setFeedback("Precio guardado. Puedes tocar otra fecha para seguir.")
			}
			if (daySaveBtn instanceof HTMLButtonElement) daySaveBtn.disabled = false
		})

		rangePreviewBtn?.addEventListener("click", async () => {
			const payload = buildPricingRangePayload()
			if (!payload) {
				setFeedback("Selecciona rango y precio valido.")
				return
			}
			setFeedback("Simulando precio del rango...")
			const response = await fetch("/api/pricing/rules/v2/bulk-preview", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(payload),
			})
			const body = await response.json().catch(() => ({}))
			if (!response.ok) {
				setFeedback(`No se pudo simular: ${String(body?.error ?? response.status)}`)
				return
			}
			const first = Array.isArray(body?.results) ? body.results[0] : null
			const previewDays = Array.isArray(first?.preview?.days) ? first.preview.days : []
			const changedFromDays = previewDays.filter((day) => Number(day?.delta ?? 0) !== 0).length
			const changed = Number(
				changedFromDays > 0 ? changedFromDays : (first?.diff?.changedDays ?? 0)
			)
			const avg = Number(first?.preview?.priceSummary?.after?.avg ?? payload.operation.value)
			if (rangePreview) {
				rangePreview.textContent = `Previsualizacion lista: ${changed} noches cambiaran · precio promedio final ${avg.toFixed(0)}.`
			}
			rangePreviewPayload = payload
			setApplyNeedsConfirmation(true)
			setFeedback("Previsualizacion lista. Confirma para aplicar al rango.")
		})

		rangeApplyBtn?.addEventListener("click", async () => {
			const payload = rangePreviewPayload ?? buildPricingRangePayload()
			if (!payload) {
				setFeedback("Selecciona rango y precio valido.")
				return
			}
			if (!rangePreviewPayload) {
				setFeedback("Primero generando previsualizacion del rango...")
				const previewResponse = await fetch("/api/pricing/rules/v2/bulk-preview", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				})
				const previewBody = await previewResponse.json().catch(() => ({}))
				if (!previewResponse.ok) {
					setFeedback(`No se pudo simular: ${String(previewBody?.error ?? previewResponse.status)}`)
					return
				}
				const first = Array.isArray(previewBody?.results) ? previewBody.results[0] : null
				const previewDays = Array.isArray(first?.preview?.days) ? first.preview.days : []
				const changedFromDays = previewDays.filter((day) => Number(day?.delta ?? 0) !== 0).length
				const changed = Number(
					changedFromDays > 0 ? changedFromDays : (first?.diff?.changedDays ?? 0)
				)
				if (rangePreview) {
					rangePreview.textContent = `Previsualizacion lista: ${changed} noches cambiaran · confirma nuevamente para aplicar.`
				}
				rangePreviewPayload = payload
				setApplyNeedsConfirmation(true)
				setFeedback(
					"Previsualizacion lista. Revisa el impacto y vuelve a tocar Aplicar para confirmar."
				)
				return
			}
			setFeedback("Aplicando precio al rango...")
			if (rangeApplyBtn instanceof HTMLButtonElement) rangeApplyBtn.disabled = true
			const response = await fetch("/api/pricing/rules/v2/bulk-apply", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(rangePreviewPayload),
			})
			const body = await response.json().catch(() => ({}))
			if (!response.ok) {
				setFeedback(`No se pudo aplicar: ${String(body?.error ?? response.status)}`)
				if (rangeApplyBtn instanceof HTMLButtonElement) rangeApplyBtn.disabled = false
				return
			}
			setFeedback(
				`Precio aplicado. Reglas creadas: ${Number(body?.summary?.success ?? 0)}. Puedes seguir operando.`
			)
			updateSelectedPricingCells(rangePreviewPayload.operation.value)
			if (rangeApplyBtn instanceof HTMLButtonElement) rangeApplyBtn.disabled = false
			rangePreviewPayload = null
			setApplyNeedsConfirmation(false)
		})

		rangeGenerateBtn?.addEventListener("click", async () => {
			if (!selectedRange || !selectedRatePlanId) {
				setFeedback("Selecciona un rango para regenerar cobertura.")
				return
			}
			setFeedback("Regenerando cobertura del rango...")
			const response = await fetch("/api/pricing/rules/v2/generate-effective", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					ratePlanId: selectedRatePlanId,
					from: selectedRange.from,
					to: addDays(selectedRange.to, 1),
				}),
			})
			const body = await response.json().catch(() => ({}))
			if (!response.ok) {
				setFeedback(`No se pudo regenerar: ${String(body?.error ?? response.status)}`)
				return
			}
			setFeedback("Cobertura regenerada. Actualizando calendario...")
			window.location.reload()
		})

		generateBtn?.addEventListener("click", async () => {
			const ratePlanId = generateBtn.getAttribute("data-rate-plan-id")
			if (!ratePlanId) return
			setFeedback("Regenerando cobertura del mes...")
			const response = await fetch("/api/pricing/rules/v2/generate-effective", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					ratePlanId,
					from: generateBtn.getAttribute("data-from"),
					to: generateBtn.getAttribute("data-to"),
				}),
			})
			if (!response.ok) {
				const body = await response.json().catch(() => ({}))
				setFeedback(`No se pudo regenerar: ${String(body?.error ?? response.status)}`)
				return
			}
			setFeedback("Cobertura regenerada. Actualizando calendario...")
			window.location.reload()
		})
	</script>
	<MobileCalendarSheetStyles />
</WorkspaceLayout>
