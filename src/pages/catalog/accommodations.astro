---
import { ArrowRight, BedDouble, Building2, Check, Hotel, Plus } from "@lucide/astro"

import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import SegmentedControl from "@/components/ui/SegmentedControl.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProviderCatalogSummary } from "@/lib/catalog/providerCatalogSummary"
import { buildAddRoomHref } from "@/lib/playbook/add-room"
import { PRODUCT_VERTICALS } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const vertical = PRODUCT_VERTICALS.hotel
const catalog = await getProviderCatalogSummary(providerId, vertical.storageType)
const createHref = "/product/create?playbook=launch&step=create&flow=create"
const view = Astro.url.searchParams.get("vista") ?? "all"
const filteredProducts = catalog.products.filter((product) => {
	if (view === "published") return product.status.state === "published"
	if (view === "attention") return product.status.state !== "published"
	return true
})
const singleAccommodation = catalog.summary.total === 1
const tabs = [
	{ id: "all", label: "Todos", count: catalog.summary.total },
	{
		id: "attention",
		label: "Requieren atención",
		count: catalog.summary.ready + catalog.summary.draft,
	},
	{ id: "published", label: "Publicados", count: catalog.summary.published },
]

function accommodationViewHref(id: string) {
	const params = new URLSearchParams()
	if (id !== "all") params.set("vista", id)
	const query = params.toString()
	return query ? `${routes.catalogAccommodations()}?${query}` : routes.catalogAccommodations()
}

function plural(value: number, singular: string, pluralLabel = `${singular}s`) {
	return `${value} ${value === 1 ? singular : pluralLabel}`
}

function nextAction(product: (typeof catalog.products)[number]) {
	if (product.roomCount === 0) {
		return {
			label: "Crear primera habitación",
			description: "Aún falta definir los espacios físicos que podrá reservar el huésped.",
			href: buildAddRoomHref(routes.productRoomNew(product.id), "create-room"),
		}
	}
	if (product.status.state !== "published") {
		return {
			label: "Continuar preparación",
			description: "Revisa la ficha pública antes de dejar este alojamiento listo para vender.",
			href: routes.productDetail(product.id),
		}
	}
	return {
		label: "Abrir alojamiento",
		description: "Gestiona contenido, fotos, habitaciones y reglas desde su ficha principal.",
		href: routes.productDetail(product.id),
	}
}
---

<WorkspaceLayout title="Alojamientos">
	<section class="space-y-7">
		<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
			<div class="space-y-1.5">
				<p
					class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400"
				>
					<Hotel class="h-4 w-4" aria-hidden="true" />
					{singleAccommodation ? "Alojamiento" : "Alojamientos"}
				</p>
				<h1 class="text-3xl font-semibold tracking-tight text-slate-100">Alojamientos</h1>
				<p class="max-w-2xl text-sm leading-6 text-slate-300">
					Administra cada propiedad de hospedaje por separado: ficha pública, habitaciones, reglas y
					publicación. Agrega otro alojamiento solo si operas otra propiedad, sucursal o negocio
					independiente.
				</p>
			</div>
		</header>

		{
			catalog.products.length === 0 ? (
				<Card class="overflow-hidden bg-white p-0">
					<div class="grid gap-0 lg:grid-cols-[minmax(0,1fr)_320px]">
						<div class="space-y-5 p-6 md:p-8">
							<div class="inline-flex h-11 w-11 items-center justify-center rounded-[var(--fastt-radius-card)] bg-slate-950 text-white">
								<Hotel class="h-5 w-5" aria-hidden="true" />
							</div>
							<div class="space-y-2">
								<h2 class="text-2xl font-semibold text-slate-950">Prepara tu primer alojamiento</h2>
								<p class="max-w-2xl text-sm leading-6 text-slate-500">
									Crea la ficha de tu propiedad principal. El recorrido guiado te llevará por
									contenido, ubicación, fotos, habitaciones, tarifa y disponibilidad.
								</p>
							</div>
							<Button href={createHref}>
								Empezar preparación
								<ArrowRight class="h-4 w-4" aria-hidden="true" />
							</Button>
						</div>
						<aside class="border-t border-slate-100 bg-slate-50 p-6 lg:border-t-0 lg:border-l">
							<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">
								Cuándo crear otro
							</p>
							<ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
								<li class="flex gap-2">
									<Check
										class="mt-0.5 h-4 w-4 text-[var(--fastt-color-selection)]"
										aria-hidden="true"
									/>
									Otra propiedad física.
								</li>
								<li class="flex gap-2">
									<Check
										class="mt-0.5 h-4 w-4 text-[var(--fastt-color-selection)]"
										aria-hidden="true"
									/>
									Otra marca, sucursal o negocio.
								</li>
								<li class="flex gap-2">
									<Check
										class="mt-0.5 h-4 w-4 text-[var(--fastt-color-selection)]"
										aria-hidden="true"
									/>
									Otra ubicación con reglas propias.
								</li>
							</ul>
						</aside>
					</div>
				</Card>
			) : (
				<>
					<section class="flex flex-wrap items-center justify-between gap-3">
						<SegmentedControl
							class="inline-flex max-w-full flex-wrap"
							aria-label="Filtro de alojamientos"
						>
							{tabs.map((tab) => {
								const active = view === tab.id || (view === "all" && tab.id === "all")
								return (
									<a
										href={accommodationViewHref(tab.id)}
										data-workspace-nav
										data-active={active ? "true" : "false"}
										aria-current={active ? "page" : undefined}
										class={`fastt-segmented-item inline-flex h-9 items-center overflow-hidden rounded-full px-3 text-sm font-medium whitespace-nowrap ${
											active ? "" : "text-slate-500 hover:bg-white/70 hover:text-slate-900"
										}`}
									>
										{tab.label}
										<span class="ml-1 font-semibold">{tab.count}</span>
									</a>
								)
							})}
						</SegmentedControl>
					</section>

					<section class="grid gap-4" aria-label="Fichas de alojamiento">
						{filteredProducts.map((product) => {
							const action = nextAction(product)
							const roomText =
								product.roomCount > 0
									? `${plural(product.roomCount, "habitación", "habitaciones")} · ${plural(product.activeRoomCount, "activa", "activas")}`
									: "Sin habitaciones creadas"
							return (
								<Card class="overflow-hidden bg-white p-0 shadow-sm">
									<div class="grid gap-0 lg:grid-cols-[minmax(0,1fr)_300px]">
										<div class="space-y-5 p-5 md:p-6">
											<div class="flex flex-wrap items-start justify-between gap-3">
												<div class="min-w-0 space-y-1">
													<div class="flex flex-wrap items-center gap-2">
														<h2 class="truncate text-xl font-semibold text-slate-950">
															{product.name}
														</h2>
														<Badge variant={product.status.variant}>{product.status.label}</Badge>
													</div>
													<p class="text-sm leading-6 text-slate-500">
														Propiedad de hospedaje · ficha pública, habitaciones y reglas.
													</p>
												</div>
												<Button href={action.href} size="sm">
													{action.label}
													<ArrowRight class="h-4 w-4" aria-hidden="true" />
												</Button>
											</div>

											<div class="grid gap-3 sm:grid-cols-3">
												<div class="rounded-[var(--fastt-radius-card)] bg-slate-50 p-4">
													<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">
														Ficha
													</p>
													<p class="mt-2 text-sm font-semibold text-slate-950">
														{product.status.state === "published"
															? "Publicada"
															: product.status.state === "ready"
																? "Lista para revisar"
																: "En preparación"}
													</p>
												</div>
												<div class="rounded-[var(--fastt-radius-card)] bg-slate-50 p-4">
													<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">
														Habitaciones
													</p>
													<p class="mt-2 text-sm font-semibold text-slate-950">{roomText}</p>
												</div>
												<div class="rounded-[var(--fastt-radius-card)] bg-slate-50 p-4">
													<p class="text-xs font-semibold tracking-[0.12em] text-slate-500 uppercase">
														Siguiente acción
													</p>
													<p class="mt-2 text-sm font-semibold text-slate-950">{action.label}</p>
												</div>
											</div>

											<p class="text-sm leading-6 text-slate-500">{action.description}</p>
										</div>

										<aside class="flex flex-col justify-between gap-4 border-t border-slate-100 bg-slate-50 p-5 md:p-6 lg:border-t-0 lg:border-l">
											<div class="space-y-3">
												<div class="inline-flex h-10 w-10 items-center justify-center rounded-[var(--fastt-radius-card)] bg-white text-slate-700 ring-1 ring-slate-900/[0.06]">
													<BedDouble class="h-5 w-5" aria-hidden="true" />
												</div>
												<div>
													<p class="text-sm font-semibold text-slate-950">
														Operación del alojamiento
													</p>
													<p class="mt-1 text-sm leading-6 text-slate-500">
														Tarifas y calendario se gestionan desde Venta cuando sus habitaciones
														estén preparadas.
													</p>
												</div>
											</div>
											<div class="flex flex-wrap gap-2">
												<Button
													href={routes.productRoomsForProduct(product.id)}
													variant="secondary"
													size="sm"
												>
													<Building2 class="h-4 w-4" aria-hidden="true" />
													Habitaciones
												</Button>
												<Button
													href={routes.productPreview(product.id)}
													variant="secondary"
													size="sm"
												>
													Vista previa
												</Button>
											</div>
										</aside>
									</div>
								</Card>
							)
						})}
					</section>
				</>
			)
		}

		{
			catalog.products.length > 0 && (
				<section class="border-t border-slate-200 pt-5">
					<div class="flex flex-wrap items-center justify-between gap-4 rounded-[var(--fastt-radius-panel)] bg-white px-5 py-4 shadow-sm ring-1 ring-slate-900/[0.06]">
						<div class="max-w-2xl">
							<h2 class="text-base font-semibold text-slate-950">¿Administras otra propiedad?</h2>
							<p class="mt-1 text-sm leading-6 text-slate-500">
								Agrega otro alojamiento solo si corresponde a otro hotel, hostal, departamento,
								casa, sucursal o negocio independiente. Si quieres sumar espacios dentro del mismo
								hotel, crea habitaciones.
							</p>
						</div>
						<Button href={createHref} variant="secondary">
							<Plus class="h-4 w-4" aria-hidden="true" />
							Agregar otro alojamiento
						</Button>
					</div>
				</section>
			)
		}
	</section>
</WorkspaceLayout>
