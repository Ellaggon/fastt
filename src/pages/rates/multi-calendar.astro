				<div class="flex items-start justify-between gap-3">
					<div class="min-w-0">
						<div class="flex flex-wrap items-center gap-1.5">
							<span class="rounded-md border px-2 py-0.5 text-[11px] font-semibold ${statusClass}">${rule.isActive ? "Activa" : "Pausada"}</span>
							<span class="text-xs font-medium text-slate-500">${escapeHtml(rule.categoryLabel)}</span>
						</div>
						<h4 class="mt-2 text-sm font-semibold text-slate-950">${escapeHtml(rule.typeLabel)}</h4>
						<p class="mt-0.5 text-xs text-slate-500">${escapeHtml(rule.targetName)}${rule.contextName ? ` · ${escapeHtml(rule.contextName)}` : ""}</p>
					</div>
					<span class="shrink-0 text-xs font-semibold text-slate-700">${escapeHtml(rule.valueLabel)}</span>
				</div>
				<div class="mt-3 grid gap-1 text-xs text-slate-600">
					<p><span class="font-medium text-slate-700">Vigencia:</span> ${escapeHtml(ruleDateLabel(rule))}</p>
					<p>${escapeHtml(rule.impactLabel)}</p>
				</div>
				<div class="mt-3 flex flex-wrap gap-1.5 border-t border-slate-100 pt-3">
					<button type="button" data-rule-governance-action="edit" data-rule-id="${escapeHtml(rule.id)}" class="rule-governance-button">Editar</button>
					<button type="button" data-rule-governance-action="toggle" data-rule-id="${escapeHtml(rule.id)}" class="rule-governance-button">${rule.isActive ? "Pausar" : "Activar"}</button>
					<details class="rule-overflow-menu relative ml-auto">
						<summary class="rule-governance-button cursor-pointer list-none" aria-label="Más acciones">•••</summary>
						<div class="absolute right-0 z-20 mt-1 min-w-40 rounded-lg border border-slate-200 bg-white p-1 shadow-lg">
							${variantAction}
							<button type="button" data-rule-governance-action="delete" data-rule-id="${escapeHtml(rule.id)}" class="rule-overflow-action is-danger">Eliminar</button>
						</div>
					</details>
				</div>
			</article>`
	}

	function conflictPairs(rules: AppliedRule[]) {
		const active = rules.filter((rule) => rule.isActive)
		const conflicts: Array<{ left: AppliedRule; right: AppliedRule; reason: string }> = []
		for (let leftIndex = 0; leftIndex < active.length; leftIndex += 1) {
			for (let rightIndex = leftIndex + 1; rightIndex < active.length; rightIndex += 1) {
				const left = active[leftIndex]
				const right = active[rightIndex]
				const sameTarget = (left.ratePlanId || left.scopeId) === (right.ratePlanId || right.scopeId)
				const datesOverlap =
					(left.startDate || "0000-01-01") <= (right.endDate || "9999-12-31") &&
					(left.endDate || "9999-12-31") >= (right.startDate || "0000-01-01")
				if (!sameTarget || !datesOverlap) continue
				const sameType = left.type === right.type
				const bothPrice = left.category === "price" && right.category === "price"
				const contradictoryStay =
					new Set([left.type, right.type]).has("min_los") &&
					new Set([left.type, right.type]).has("max_los") &&
					Number((left.type === "min_los" ? left : right).value ?? 0) >
						Number((left.type === "max_los" ? left : right).value ?? 0)
				const contradictoryLead =
					new Set([left.type, right.type]).has("min_lead_time") &&
					new Set([left.type, right.type]).has("max_lead_time") &&
					Number((left.type === "min_lead_time" ? left : right).value ?? 0) >
						Number((left.type === "max_lead_time" ? left : right).value ?? 0)
				if (!sameType && !bothPrice && !contradictoryStay && !contradictoryLead) continue
				conflicts.push({
					left,
					right,
					reason: contradictoryStay
						? "El mínimo de noches supera el máximo."
						: contradictoryLead
							? "La anticipación mínima supera la máxima."
							: sameType
								? "Dos reglas del mismo tipo coinciden en fechas."
								: "Dos ajustes de precio coinciden; la prioridad define el resultado.",
				})
			}
		}
		return conflicts
	}

	function bindRulesPanelActions() {
		rulesContent
			?.querySelectorAll<HTMLElement>("[data-rule-governance-action]")
			.forEach((button) => {
				button.addEventListener("click", () => {
					const rule = appliedRules.find((item) => item.id === button.dataset.ruleId)
					if (!rule) return
					const action = button.dataset.ruleGovernanceAction
					if (action === "edit") openRuleEditor(rule)
					if (action === "toggle") void mutateRule(rule, "toggle-rule")
					if (action === "variant" && rule.category === "price") {
						openRuleEditor(rule, "variant")
					}
					if (action === "delete" && window.confirm(`Eliminar ${rule.typeLabel}?`)) {
						void mutateRule(rule, "delete-rule")
					}
				})
			})
	}

	function renderRulesView(mode: string) {
		if (!rulesContent || !rulesPanelTitle || !rulesPanelSummary) return
		ruleEditor?.classList.add("hidden")
		rulesContent.classList.remove("hidden")
		const rules = selectedAppliedRules()
		if (mode === "rules_conflicts") {
			const conflicts = conflictPairs(rules)
			rulesPanelTitle.textContent = "Conflictos"
			rulesPanelSummary.textContent = `${conflicts.length} ${conflicts.length === 1 ? "conflicto detectado" : "conflictos detectados"} en la selección.`
			rulesContent.innerHTML = conflicts.length
				? conflicts
						.map(
							(conflict) => `<article class="rounded-lg border border-amber-200 bg-amber-50 p-3">
								<p class="text-sm font-semibold text-amber-950">${escapeHtml(conflict.reason)}</p>
								<p class="mt-1 text-xs text-amber-800">${escapeHtml(conflict.left.typeLabel)} · ${escapeHtml(conflict.right.typeLabel)}</p>
								<p class="mt-1 text-xs text-amber-700">${escapeHtml(conflict.left.targetName)} · prioridades ${conflict.left.priority} y ${conflict.right.priority}</p>
								<div class="mt-3 flex gap-2"><button type="button" data-rule-governance-action="edit" data-rule-id="${escapeHtml(conflict.left.id)}" class="rule-governance-button">Editar regla</button></div>
							</article>`
						)
						.join("")
				: '<div class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">No se detectaron conflictos en esta selección.</div>'
		} else if (mode === "rules_history") {
			rulesPanelTitle.textContent = "Historial"
			rulesPanelSummary.textContent = "Actividad disponible para las reglas de esta selección."
			rulesContent.innerHTML = rules.length
				? [...rules]
						.sort((left, right) => right.createdAt.localeCompare(left.createdAt))
						.map(
							(rule) => `<article class="border-l-2 border-slate-200 py-1 pl-3">
								<p class="text-sm font-semibold text-slate-900">Regla creada · ${escapeHtml(rule.typeLabel)}</p>
								<p class="mt-0.5 text-xs text-slate-500">${new Intl.DateTimeFormat("es-BO", { dateStyle: "medium", timeStyle: "short" }).format(new Date(rule.createdAt))}</p>
								<p class="mt-1 text-xs text-slate-600">Estado actual: ${rule.isActive ? "activa" : "pausada"} · ${escapeHtml(ruleDateLabel(rule))}</p>
								<button type="button" data-rule-governance-action="edit" data-rule-id="${escapeHtml(rule.id)}" class="rule-governance-button mt-2">Ver regla</button>
							</article>`
						)
						.join("")
				: '<div class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">No hay actividad para esta selección.</div>'
		} else {
			rulesPanelTitle.textContent = "Reglas aplicadas"
			rulesPanelSummary.textContent = `${rules.length} ${rules.length === 1 ? "regla coincide" : "reglas coinciden"} con las fechas y tarifas seleccionadas.`
			rulesContent.innerHTML = rules.length
				? rules.map(ruleCard).join("")
				: '<div class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">No hay reglas en esta selección. Créala desde Precio, Venta, Estancia o Llegada/salida.</div>'
		}
		bindRulesPanelActions()
	}

	function setEditorInput(selector: string, value: string) {
		const input = ruleEditor?.querySelector<HTMLInputElement>(selector)
		if (input) input.value = value
	}

	function openRuleEditor(rule: AppliedRule, mode: "edit" | "variant" = "edit") {
		editingRule = rule
		rulesContent?.classList.add("hidden")
		ruleEditor?.classList.remove("hidden")
		const today = todayIso()
		setEditorInput("[data-rule-editor-id]", rule.id)
		setEditorInput("[data-rule-editor-category]", rule.category)
		setEditorInput("[data-rule-editor-scope]", rule.scope)
		setEditorInput("[data-rule-editor-scope-id]", rule.scopeId)
		setEditorInput("[data-rule-editor-rate-plan-id]", rule.ratePlanId)
		setEditorInput("[data-rule-editor-type]", rule.type)
		setEditorInput("[data-rule-editor-context-key]", rule.contextKey || "")
		setEditorInput(
			"[data-rule-editor-action]",
			mode === "variant" ? "create-variant" : "update-rule"
		)
		setEditorInput("[data-rule-editor-start]", rule.startDate || today)
		setEditorInput("[data-rule-editor-end]", rule.endDate || rule.startDate || today)
		setEditorInput("[data-rule-editor-value]", rule.value == null ? "" : String(rule.value))
		setEditorInput("[data-rule-editor-priority]", String(rule.priority))
		const title = ruleEditor?.querySelector<HTMLElement>("[data-rule-editor-title]")
		const context = ruleEditor?.querySelector<HTMLElement>("[data-rule-editor-context]")
		const eyebrow = ruleEditor?.querySelector<HTMLElement>("[data-rule-editor-eyebrow]")
		const submit = ruleEditor?.querySelector<HTMLButtonElement>("[data-rule-editor-submit]")
		const valueField = ruleEditor?.querySelector<HTMLElement>("[data-rule-editor-value-field]")
		const valueLabel = ruleEditor?.querySelector<HTMLElement>("[data-rule-editor-value-label]")
		if (title) title.textContent = rule.typeLabel
		if (eyebrow) eyebrow.textContent = mode === "variant" ? "Crear variante" : "Editar regla"
		if (submit) submit.textContent = mode === "variant" ? "Guardar variante" : "Guardar cambios"
		if (context) {
			context.textContent =
				mode === "variant"
					? `Basada en ${rule.typeLabel} · cambia la vigencia o el valor`
					: `${rule.targetName} · ${rule.categoryLabel}`
		}
		if (valueLabel) valueLabel.textContent = rule.category === "price" ? "Valor" : rule.valueLabel
		valueField?.classList.toggle("hidden", rule.value == null)
		if (ruleEditorFeedback) ruleEditorFeedback.textContent = ""
	}

	async function mutateRule(rule: AppliedRule, action: string) {
		const form = new FormData()
		form.set("action", action)
		form.set("ruleId", rule.id)
		form.set("category", rule.category)
		form.set("scope", rule.scope)
		form.set("scopeId", rule.scopeId)
		form.set("ratePlanId", rule.ratePlanId)
		form.set("type", rule.type)
		form.set("value", rule.value == null ? "" : String(rule.value))
		form.set("startDate", rule.startDate)
		form.set("endDate", rule.endDate)
		form.set("priority", String(rule.priority))
		form.set("contextKey", rule.contextKey || "")
		form.set("isActive", String(rule.isActive))
		rule.validDays.forEach((day) => form.append("validDays", String(day)))
		const response = await fetch("/api/rates/commercial-rules", { method: "POST", body: form })
		window.location.href = response.url || "/rates/multi-calendar?tab=rules"
	}

	ruleEditorCancel?.addEventListener("click", () => {
		editingRule = null
		ruleEditor?.classList.add("hidden")
		rulesContent?.classList.remove("hidden")
	})

	ruleEditor?.addEventListener("submit", async (event) => {
		event.preventDefault()
		if (!editingRule || !(ruleEditor instanceof HTMLFormElement)) return
		const submit = ruleEditor.querySelector<HTMLButtonElement>("[data-rule-editor-submit]")
		if (submit?.disabled) return
		const idleLabel = submit?.textContent || "Guardar cambios"
		if (submit) {
			submit.disabled = true
			submit.textContent = "Guardando..."
		}
		if (ruleEditorFeedback) ruleEditorFeedback.textContent = "Guardando cambios..."
		try {
			const form = new FormData(ruleEditor)
			editingRule.validDays.forEach((day) => form.append("validDays", String(day)))
			const response = await fetch(ruleEditor.action, { method: "POST", body: form })
			window.location.href = response.url || "/rates/multi-calendar?tab=rules"
		} catch {
			if (ruleEditorFeedback) {
				ruleEditorFeedback.textContent =
					"No se pudo guardar. Revisa la conexión e inténtalo otra vez."
			}
			if (submit) {
				submit.disabled = false
				submit.textContent = idleLabel
			}
		}
	})

	function setActionPanels(
		action: "detail" | "price" | "availability" | "rule" | "conditions" | "rules"
	) {
		priceForm?.classList.toggle("hidden", action !== "price")
		availabilityForm?.classList.toggle("hidden", action !== "availability")
		ruleForm?.classList.toggle("hidden", action !== "rule")
		rulesPanel?.classList.toggle("hidden", action !== "rules")
		conditionsPanel?.classList.toggle("hidden", action !== "conditions")
		selectionOverview?.classList.toggle("hidden", action === "rules")
		navigationActions?.classList.toggle(
			"hidden",
			action === "price" ||
				action === "availability" ||
				action === "rule" ||
				action === "rules" ||
				action === "conditions"
		)
		if (action !== "price") {
			pricePayload = null
			if (priceApply instanceof HTMLButtonElement) priceApply.disabled = true
			if (priceFeedback) priceFeedback.textContent = ""
		}
		if (action !== "availability") {
			inventoryPayload = null
			if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = true
			if (availabilityFeedback) availabilityFeedback.textContent = ""
		}
	}

	function updateDrawerFromSelection(
		action: "detail" | "price" | "availability" | "rule" | "conditions" | "rules" = "detail"
	) {
		const cells = selectedCells()
		if (!cells.length) return
		const selection = formatSelection(cells)
		const firstCell = cells[0]
		const actionLabel =
			action === "price"
				? (priceActionConfig[activeAction]?.title ?? "Cambiar precio")
				: action === "availability"
					? "Cambiar cupo"
					: action === "rule"
						? (ruleActionConfig[activeAction]?.title ?? "Crear regla de venta")
						: action === "conditions"
							? "Resolver condiciones"
							: action === "rules"
								? activeAction === "rules_conflicts"
									? "Conflictos"
									: activeAction === "rules_history"
										? "Historial"
										: "Reglas aplicadas"
								: "Selección"
		if (title) title.textContent = actionLabel
		if (summary) {
			summary.textContent = `${selection.rangeLabel} · ${selection.ratePlanIds.length} ${selection.ratePlanIds.length === 1 ? "tarifa" : "tarifas"}`
		}
		if (primary) {
			primary.textContent =
				selection.ratePlanNames.length === 1
					? selection.ratePlanNames[0] || ""
					: `${selection.ratePlanNames.length} tarifas seleccionadas`
		}
		if (secondary) {
			secondary.textContent = firstCell.getAttribute("data-context-summary") || ""
		}
		if (impactTitle) {
			impactTitle.textContent = `${selection.count} ${selection.count === 1 ? "noche-tarifa" : "noches-tarifa"} impactadas`
		}
		if (impactSummary) {
			impactSummary.textContent =
				action === "rule"
					? "La regla quedará aplicada a la selección y seguirá actuando mientras esté vigente."
					: action === "price"
						? "La regla de precio se aplicará sobre las fechas y tarifas seleccionadas."
						: action === "availability"
							? "El cupo se guardará sobre las habitaciones seleccionadas en el rango elegido."
							: action === "conditions"
								? "Revisa o completa el contrato de las tarifas seleccionadas."
								: action === "rules"
									? "Revisa automatizaciones activas, conflictos e historial."
									: "Elige una acción para operar esta selección."
		}
		const firstRatePlanId = selection.ratePlanIds[0] || firstCell.dataset.ratePlanId || ""
		const month = (selection.firstDate || firstCell.dataset.date || "").slice(0, 7)
		const focus =
			action === "availability"
				? "availability"
				: action === "rule" || action === "rules"
					? "restrictions"
					: "price"
		const calendarHref = `/rates/calendar?ratePlanId=${encodeURIComponent(firstRatePlanId)}&month=${encodeURIComponent(month)}&focus=${encodeURIComponent(focus)}&from=${encodeURIComponent(selection.firstDate)}&to=${encodeURIComponent(selection.lastDate)}`
		const rulesHref = `/rates/multi-calendar?tab=rules&ratePlanIds=${encodeURIComponent(selection.ratePlanIds.join(","))}&from=${encodeURIComponent(selection.firstDate)}&to=${encodeURIComponent(selection.lastDate)}`
		calendarLink?.setAttribute("href", calendarHref)
		rulesLink?.setAttribute("href", rulesHref)
		policiesLink?.setAttribute(
			"href",
			firstCell.getAttribute("data-policies-href") || "/provider/policies?vista=incomplete"
		)
		setActionPanels(action)
		if (action === "rules") renderRulesView(activeAction)
		if (action === "conditions") renderConditionsPanel()
		setDrawerOpen(true)
	}

	function openAction(action: string) {
		const cells = selectedCells()
		if (!cells.length && action !== "clear") return
		activeAction = action
		if (action.startsWith("price_")) {
			configurePriceAction(action)
			updateDrawerFromSelection("price")
			return
		}
		if (action === "availability_units") {
			configureAvailabilityAction(action)
			updateDrawerFromSelection("availability")
			return
		}
		if (action.startsWith("conditions_")) {
			updateDrawerFromSelection("conditions")
			return
		}
		if (action.startsWith("rules_")) {
			updateDrawerFromSelection("rules")
			return
		}
		configureRuleAction(action)
		updateDrawerFromSelection("rule")
	}

	function toggleCell(cell: HTMLElement, force?: boolean) {
		const key = cellKey(cell)
		if (!key.includes("::") || cell.hasAttribute("disabled")) return
		const next = typeof force === "boolean" ? force : !selectedKeys.has(key)
		if (next) selectedKeys.add(key)
		else selectedKeys.delete(key)
		syncSelectedStyles()
		syncSelectionBar()
	}

	getSelectableCells().forEach((cell) => {
		cell.addEventListener("click", () => {
			clearActivePreset()
			toggleCell(cell)
			if (drawer && !drawer.classList.contains("hidden")) updateDrawerFromSelection("detail")
		})
	})

	function setActiveTab(tab: string) {
		activeTab = tab
		activeAction = ""
		document.querySelectorAll<HTMLElement>("[data-multi-calendar-tab-button]").forEach((button) => {
			const active = button.dataset.tab === tab
			button.classList.toggle("border-slate-950", active)
			button.classList.toggle("bg-slate-950", active)
			button.classList.toggle("text-white", active)
			button.classList.toggle("is-active", active)
			button.classList.toggle("border-slate-200/80", !active)
			button.classList.toggle("bg-white", !active)
			button.classList.toggle("text-slate-700", !active)
			button.classList.toggle("hover:border-slate-300", !active)
			button.classList.toggle("hover:bg-slate-50", !active)
			button.classList.toggle("shadow-sm", active)
			if (active) {
				button.classList.remove(
					"border-slate-200/80",
					"bg-white",
					"text-slate-700",
					"hover:border-slate-300",
					"hover:bg-slate-50"
				)
			} else {
				button.classList.remove("border-slate-950", "bg-slate-950", "text-white", "shadow-sm")
			}
			button.setAttribute("aria-selected", String(active))
			button.querySelectorAll("span")[1]?.classList.toggle("text-slate-300", active)
			button.querySelectorAll("span")[1]?.classList.toggle("text-slate-500", !active)
		})
		getSelectableCells().forEach((cell) => {
			cell.classList.remove(...toneClasses)
			const tabAttr = tab.replaceAll("_", "-")
			const tone = cell.getAttribute(`data-tone-${tabAttr}`) || ""
			cell.classList.add(...tone.split(" ").filter(Boolean))
			const primaryText = cell.getAttribute(`data-primary-${tabAttr}`) || ""
			const secondaryText = cell.getAttribute(`data-secondary-${tabAttr}`) || ""
			const primaryNode = cell.querySelector("[data-cell-primary]")
			const secondaryNode = cell.querySelector("[data-cell-secondary]")
			if (primaryNode) primaryNode.textContent = primaryText
			if (secondaryNode) secondaryNode.textContent = secondaryText
		})
		const url = new URL(window.location.href)
		url.searchParams.set("tab", tab)
		window.history.replaceState({}, "", url)
		renderContextualActions()
	}

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-tab-button]").forEach((button) => {
		button.addEventListener("click", () => setActiveTab(button.dataset.tab || "price"))
	})

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-select-date]").forEach((button) => {
		button.addEventListener("click", () => {
			clearActivePreset()
			const date = button.dataset.date || ""
			const cells = getSelectableCells().filter((cell) => cell.dataset.date === date)
			const shouldSelect = cells.some((cell) => !selectedKeys.has(cellKey(cell)))
			cells.forEach((cell) => toggleCell(cell, shouldSelect))
		})
	})

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-select-row]").forEach((button) => {
		button.addEventListener("click", () => {
			clearActivePreset()
			const ratePlanId = button.dataset.ratePlanId || ""
			const cells = getSelectableCells().filter((cell) => cell.dataset.ratePlanId === ratePlanId)
			const shouldSelect = cells.some((cell) => !selectedKeys.has(cellKey(cell)))
			cells.forEach((cell) => toggleCell(cell, shouldSelect))
		})
	})

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-action]").forEach((button) => {
		button.addEventListener("click", () => {
			const action = button.dataset.multiCalendarAction
			if (action === "clear") {
				selectedKeys.clear()
				clearActivePreset()
				syncSelectedStyles()
				syncSelectionBar()
				return
			}
			if (action) openAction(action)
		})
	})

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-preset]").forEach((button) => {
		button.setAttribute("aria-pressed", "false")
		button.addEventListener("click", () =>
			applyPreset(button.dataset.multiCalendarPreset || "visible_month")
		)
	})

	document.querySelectorAll<HTMLElement>("[data-price-mode]").forEach((button) => {
		button.addEventListener("click", () => {
			activePriceMode = button.dataset.priceMode || "percentage_discount"
			updatePriceModeButtons()
			pricePayload = null
			if (priceApply instanceof HTMLButtonElement) priceApply.disabled = true
			if (priceFeedback) priceFeedback.textContent = ""
		})
	})

	function setFeedback(target: Element | null, message: string) {
		if (target) target.textContent = message
	}

	function buildSelectionPayload() {
		const cells = selectedCells()
		const selection = formatSelection(cells)
		if (!cells.length || !selection.firstDate || !selection.lastDate) return null
		return selection
	}

	pricePreview?.addEventListener("click", () => {
		const selection = buildSelectionPayload()
		const value = Number((priceValue as HTMLInputElement | null)?.value ?? Number.NaN)
		if (!selection) {
			setFeedback(priceFeedback, "Selecciona al menos una fecha.")
			return
		}
		if (!Number.isFinite(value) || value < 0) {
			setFeedback(priceFeedback, "Ingresa un precio final válido.")
			return
		}
		if (selection.currencies.length > 1) {
			setFeedback(priceFeedback, "Selecciona tarifas que usen la misma moneda.")
			return
		}
		const normalizedValue =
			activePriceMode === "percentage_discount" ? Math.abs(value) : Math.max(0, value)
		pricePayload = {
			ratePlanIds: selection.ratePlanIds,
			operation: {
				type: activePriceMode,
				value: normalizedValue,
				conditions: {
					priority: 1000,
					dateFrom: selection.firstDate,
					dateTo: selection.lastDate,
					previewFrom: selection.firstDate,
					effectiveFrom: selection.firstDate,
					effectiveTo: addDays(selection.lastDate, 1),
					contextKey: activePriceContextKey,
					currency: selection.currencies[0] || "USD",
				},
			},
			dryRun: false,
			concurrency: 3,
		}
		if (priceApply instanceof HTMLButtonElement) priceApply.disabled = false
		setFeedback(
			priceFeedback,
			`Listo para guardar ${selection.count} noches-tarifa en ${selection.ratePlanIds.length} tarifas.`
		)
	})

	priceApply?.addEventListener("click", async () => {
		if (!pricePayload) {
			setFeedback(priceFeedback, "Primero revisa el cambio.")
			return
		}
		if (priceApply instanceof HTMLButtonElement) priceApply.disabled = true
		setFeedback(priceFeedback, "Guardando precio...")
		try {
			const response = await fetch("/api/pricing/rules/v2/bulk-apply", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(pricePayload),
			})
			const body = await response.json().catch(() => ({}))
			const failed = Number(body?.summary?.failed ?? 0)
			if (!response.ok || failed > 0) {
				const firstFailure = Array.isArray(body?.failures) ? body.failures[0] : null
				const reason = String(firstFailure?.error ?? body?.error ?? response.status)
				setFeedback(priceFeedback, `No se pudo guardar: ${reason}`)
				if (priceApply instanceof HTMLButtonElement) priceApply.disabled = false
				return
			}
			setFeedback(priceFeedback, "Precio guardado. Actualizando vista...")
			window.setTimeout(() => window.location.reload(), 350)
		} catch {
			setFeedback(priceFeedback, "No se pudo guardar. Revisa la conexión e inténtalo otra vez.")
			if (priceApply instanceof HTMLButtonElement) priceApply.disabled = false
		}
	})

	availabilityPreview?.addEventListener("click", () => {
		const selection = buildSelectionPayload()
		const value = Number((availabilityValue as HTMLInputElement | null)?.value ?? Number.NaN)
		if (!selection) {
			setFeedback(availabilityFeedback, "Selecciona al menos una fecha.")
			return
		}
		if (!Number.isInteger(value) || value < 0) {
			setFeedback(availabilityFeedback, "Ingresa un cupo entero válido.")
			return
		}
		inventoryPayload = {
			selection: { variantIds: selection.variantIds },
			dateRange: { from: selection.firstDate, to: addDays(selection.lastDate, 1) },
			operation: { type: "SET_INVENTORY", value },
			context: { source: "multi-calendar" },
		}
		if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = false
		setFeedback(
			availabilityFeedback,
			`Listo para guardar cupo en ${selection.variantIds.length} habitaciones y ${selection.dates.length} fechas.`
		)
	})

	availabilityApply?.addEventListener("click", async () => {
		if (!inventoryPayload) {
			setFeedback(availabilityFeedback, "Primero revisa el cupo.")
			return
		}
		if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = true
		setFeedback(availabilityFeedback, "Guardando cupo...")
		const response = await fetch("/api/inventory/bulk-apply", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(inventoryPayload),
		})
		const body = await response.json().catch(() => ({}))
		if (!response.ok) {
			setFeedback(
				availabilityFeedback,
				`No se pudo guardar: ${String(body?.error ?? response.status)}`
			)
			if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = false
			return
		}
		setFeedback(availabilityFeedback, "Cupo guardado. Actualizando vista...")
		window.setTimeout(() => window.location.reload(), 500)
	})

	closeButton?.addEventListener("click", () => setDrawerOpen(false))
	backdrop?.addEventListener("click", () => setDrawerOpen(false))
	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") setDrawerOpen(false)
	})
</script>

