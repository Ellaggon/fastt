	function addDays(date: string, days: number): string {
		const value = new Date(`${date}T12:00:00.000Z`)
		value.setUTCDate(value.getUTCDate() + days)
		return value.toISOString().slice(0, 10)
	}

	function formatHotelDateLabel(value: string, options: { weekday?: boolean } = {}): string {
		if (!/^\d{4}-\d{2}-\d{2}$/.test(String(value || ""))) return value
		const date = new Date(`${value}T12:00:00.000Z`)
		if (Number.isNaN(date.getTime())) return value
		const day = new Intl.DateTimeFormat("es-BO", {
			day: "numeric",
			month: "short",
			timeZone: "UTC",
		})
			.format(date)
			.replace(".", "")
			.toLowerCase()
		if (!options.weekday) return day
		const weekday = new Intl.DateTimeFormat("es-BO", {
			weekday: "short",
			timeZone: "UTC",
		})
			.format(date)
			.replace(".", "")
			.toLowerCase()
		return `${weekday} ${day}`
	}

	function formatHotelDateRange(
		from: string,
		to: string,
		options: { weekday?: boolean } = {}
	): string {
		if (!from) return "Sin fechas"
		if (!to || from === to) return formatHotelDateLabel(from, options)
		return `${formatHotelDateLabel(from, options)} → ${formatHotelDateLabel(to, options)}`
	}

	function getSelectableCells(): HTMLElement[] {
		return Array.from(document.querySelectorAll<HTMLElement>("[data-multi-calendar-cell]")).filter(
			(cell) => !cell.hasAttribute("disabled")
		)
	}

	function cellKey(cell: HTMLElement): string {
		return `${cell.dataset.ratePlanId || ""}::${cell.dataset.date || ""}`
	}

	function selectedCells(): HTMLElement[] {
		return getSelectableCells().filter((cell) => selectedKeys.has(cellKey(cell)))
	}

	function todayIso(): string {
		const now = new Date()
		return new Date(Date.UTC(now.getFullYear(), now.getMonth(), now.getDate()))
			.toISOString()
			.slice(0, 10)
	}

	function isWeekend(date: string): boolean {
		const parsed = new Date(`${date}T12:00:00.000Z`)
		if (Number.isNaN(parsed.getTime())) return false
		const day = parsed.getUTCDay()
		return day === 0 || day === 6
	}

	function syncPresetButtons() {
		document.querySelectorAll<HTMLElement>("[data-multi-calendar-preset]").forEach((button) => {
			const active = button.dataset.multiCalendarPreset === activePreset
			button.classList.toggle("is-active", active)
			button.setAttribute("aria-pressed", active ? "true" : "false")
		})
	}

	function clearActivePreset() {
		if (!activePreset) return
		activePreset = ""
		syncPresetButtons()
	}

	function cellsForPreset(preset: string): HTMLElement[] {
		const cells = getSelectableCells()
		const today = todayIso()
		const next7 = addDays(today, 6)
		const next30 = addDays(today, 29)
		if (preset === "visible_weekend") {
			return cells.filter((cell) => isWeekend(cell.dataset.date || ""))
		}
		if (preset === "next_7") {
			return cells.filter((cell) => {
				const date = cell.dataset.date || ""
				return date >= today && date <= next7
			})
		}
		if (preset === "next_30") {
			return cells.filter((cell) => {
				const date = cell.dataset.date || ""
				return date >= today && date <= next30
			})
		}
		return cells
	}

	function applyPreset(preset: string) {
		const cells = cellsForPreset(preset)
		selectedKeys.clear()
		cells.forEach((cell) => selectedKeys.add(cellKey(cell)))
		activePreset = preset
		syncPresetButtons()
		syncSelectedStyles()
		syncSelectionBar()
		if (drawer && !drawer.classList.contains("hidden")) updateDrawerFromSelection("detail")
	}

	function formatSelection(cells: HTMLElement[]) {
		const dates = [...new Set(cells.map((cell) => cell.dataset.date || "").filter(Boolean))].sort()
		const ratePlanIds = [
			...new Set(cells.map((cell) => cell.dataset.ratePlanId || "").filter(Boolean)),
		]
		const ratePlanNames = [
			...new Set(cells.map((cell) => cell.dataset.ratePlanName || "").filter(Boolean)),
		]
		const variantIds = [
			...new Set(cells.map((cell) => cell.dataset.variantId || "").filter(Boolean)),
		]
		const productIds = [
			...new Set(cells.map((cell) => cell.dataset.productId || "").filter(Boolean)),
		]
		const currencies = [
			...new Set(cells.map((cell) => cell.dataset.currency || "").filter(Boolean)),
		]
		const firstDate = dates[0] || ""
		const lastDate = dates[dates.length - 1] || firstDate
		return {
			dates,
			ratePlanIds,
			ratePlanNames,
			variantIds,
			productIds,
			currencies,
			firstDate,
			lastDate,
			count: cells.length,
			rangeLabel: formatHotelDateRange(firstDate, lastDate, { weekday: true }),
		}
	}

	function syncSelectedStyles() {
		getSelectableCells().forEach((cell) => {
			cell.classList.toggle("ring-2", selectedKeys.has(cellKey(cell)))
			cell.classList.toggle("ring-slate-950", selectedKeys.has(cellKey(cell)))
		})
	}

	function syncSelectionBar() {
		const cells = selectedCells()
		const selection = formatSelection(cells)
		selectionBar?.classList.toggle("hidden", cells.length === 0)
		selectionBar?.classList.toggle("flex", cells.length > 0)
		if (selectionCount) {
			selectionCount.textContent = `${selection.count} ${selection.count === 1 ? "celda seleccionada" : "celdas seleccionadas"}`
		}
		if (selectionSummary) {
			selectionSummary.textContent = cells.length
				? `${selection.rangeLabel} · ${selection.ratePlanIds.length} ${selection.ratePlanIds.length === 1 ? "tarifa" : "tarifas"}`
				: "Selecciona fechas o tarifas para operar en escala."
		}
		scopeIdsInput?.setAttribute("value", selection.ratePlanIds.join(","))
		startDateInput?.setAttribute("value", selection.firstDate)
		endDateInput?.setAttribute("value", selection.lastDate)
		renderContextualActions()
	}

	function renderContextualActions() {
		if (!contextualActions) return
		contextualActions.innerHTML = ""
		const cells = selectedCells()
		const actions = actionCatalog[activeTab] || actionCatalog.price
		actions.forEach((action) => {
			const button = document.createElement("button")
			button.type = "button"
			button.dataset.multiCalendarAction = action.id
			button.className = [
				"multi-calendar-context-action inline-flex min-h-9 items-center justify-center rounded-lg border px-3 py-2 text-xs font-semibold transition duration-200",
				"focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-950 focus-visible:ring-offset-2",
				"disabled:cursor-not-allowed disabled:opacity-50",
				"border-slate-300 bg-white text-slate-700 shadow-sm hover:border-slate-400 hover:bg-slate-50",
			].join(" ")
			button.disabled = cells.length === 0
			button.setAttribute("aria-pressed", String(activeAction === action.id))
			button.textContent =
				activeTab === "conditions" && action.id === "conditions_manage"
					? conditionsActionLabel(cells)
					: action.label
			button.addEventListener("click", () => {
				activeAction = action.id
				syncContextualActionState()
				openAction(action.id)
			})
			contextualActions.appendChild(button)
		})
	}

	function syncContextualActionState() {
		contextualActions
			?.querySelectorAll<HTMLElement>("[data-multi-calendar-action]")
			.forEach((button) => {
				button.setAttribute(
					"aria-pressed",
					String(button.dataset.multiCalendarAction === activeAction)
				)
			})
	}

	function priceModeLabel(mode: string) {
		if (mode === "percentage_markup") return "% de aumento"
		if (mode === "fixed_override") return "Precio final"
		return "% de descuento"
	}

	function configurePriceAction(action: string) {
		const config = priceActionConfig[action] || priceActionConfig.price_base_adjustment
		activePriceMode = config.defaultMode
		activePriceContextKey = config.contextKey
		if (priceFormTitle) priceFormTitle.textContent = config.title
		if (priceFormDescription) priceFormDescription.textContent = config.description
		if (priceValueLabel)
			priceValueLabel.textContent = config.label || priceModeLabel(activePriceMode)
		if (priceValue instanceof HTMLInputElement) {
			priceValue.placeholder = config.placeholder
			priceValue.value = ""
		}
		if (priceModeGroup) {
			priceModeGroup.classList.toggle("hidden", action !== "price_base_adjustment")
		}
		updatePriceModeButtons()
	}

	function updatePriceModeButtons() {
		document.querySelectorAll<HTMLElement>("[data-price-mode]").forEach((button) => {
			const active = button.dataset.priceMode === activePriceMode
			button.classList.toggle("bg-white", active)
			button.classList.toggle("text-slate-950", active)
			button.classList.toggle("shadow-sm", active)
			button.classList.toggle("text-slate-600", !active)
		})
		if (priceValueLabel) priceValueLabel.textContent = priceModeLabel(activePriceMode)
	}

	function configureAvailabilityAction(action: string) {
		if (availabilityFormTitle) availabilityFormTitle.textContent = "Cambiar cupo"
		if (availabilityFormDescription) {
			availabilityFormDescription.textContent =
				action === "availability_units"
					? "Actualiza el cupo físico de las habitaciones incluidas en la selección."
					: "Actualiza la disponibilidad operativa de la selección."
		}
		if (availabilityValue instanceof HTMLInputElement) availabilityValue.value = ""
	}

	function configureRuleAction(action: string) {
		const config = ruleActionConfig[action] || ruleActionConfig.sellability_stop
		ruleTypeInput?.setAttribute("value", config.type)
		if (ruleFormTitle) ruleFormTitle.textContent = config.title
		if (ruleFormDescription) ruleFormDescription.textContent = config.description
		if (ruleImpact) ruleImpact.textContent = config.impact
		ruleValueField?.classList.toggle("hidden", !config.requiresValue)
		if (ruleValueLabel) ruleValueLabel.textContent = config.valueLabel
		if (ruleValueInput instanceof HTMLInputElement) {
			ruleValueInput.value = config.defaultValue
			ruleValueInput.required = config.requiresValue
		}
	}

	function escapeHtml(value: unknown): string {
		return String(value ?? "")
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
			.replaceAll("'", "&#039;")
	}

	function parseMissingPolicyCategories(cell: HTMLElement): string[] {
		try {
			const parsed = JSON.parse(cell.dataset.missingPolicyCategories || "[]")
			return Array.isArray(parsed) ? parsed.map(String) : []
		} catch {
			return []
		}
	}

	function conditionsSelectionState(cells: HTMLElement[]): "incomplete" | "complete" | "mixed" {
		const states = new Map<string, boolean>()
		cells.forEach((cell) => {
			const ratePlanId = cell.dataset.ratePlanId || ""
			if (ratePlanId && !states.has(ratePlanId)) {
				states.set(ratePlanId, parseMissingPolicyCategories(cell).length > 0)
			}
		})
		const values = [...states.values()]
		if (values.length && values.every(Boolean)) return "incomplete"
		if (values.length && values.every((value) => !value)) return "complete"
		return "mixed"
	}

	function conditionsActionLabel(cells: HTMLElement[]): string {
		const state = conditionsSelectionState(cells)
		if (state === "incomplete") return "Completar condiciones"
		if (state === "complete") return "Ver condiciones"
		return "Revisar condiciones"
	}

	function renderConditionsPanel() {
		if (!conditionsContent) return
		const categoryLabels: Record<string, string> = {
			Cancellation: "Cancelación",
			Payment: "Pago y depósito",
			NoShow: "No presentación",
			CheckIn: "Llegada y salida",
		}
		const byRatePlan = new Map<string, HTMLElement>()
		selectedCells().forEach((cell) => {
			const ratePlanId = cell.dataset.ratePlanId || ""
			if (ratePlanId && !byRatePlan.has(ratePlanId)) byRatePlan.set(ratePlanId, cell)
		})
		if (!byRatePlan.size) {
			conditionsContent.innerHTML =
				'<p class="text-sm text-slate-500">Selecciona al menos una tarifa.</p>'
			return
		}
		const state = conditionsSelectionState([...byRatePlan.values()])
		if (conditionsTitle) {
			conditionsTitle.textContent =
				state === "incomplete"
					? "Completar condiciones"
					: state === "complete"
						? "Condiciones aplicables"
						: "Revisar condiciones"
		}
		if (conditionsSummary) {
			conditionsSummary.textContent =
				state === "incomplete"
					? "Completa el contrato antes de vender. Los cambios se aplican a reservas futuras de la tarifa completa."
					: state === "complete"
						? "Consulta el contrato que verá el huésped. La fecha seleccionada aporta contexto y no modifica el contrato por noche."
						: "Las tarifas incompletas aparecen primero. Los cambios se aplican a reservas futuras de la tarifa completa."
		}
		conditionsContent.innerHTML = [...byRatePlan.entries()]
			.sort(
				([, left], [, right]) =>
					parseMissingPolicyCategories(right).length - parseMissingPolicyCategories(left).length
			)
			.map(([ratePlanId, cell]) => {
				const missing = parseMissingPolicyCategories(cell)
				const ratePlanName = cell.dataset.ratePlanName || "Tarifa"
				const context = [cell.dataset.productName, cell.dataset.variantName]
					.filter(Boolean)
					.join(" · ")
				const summary = cell.dataset.policySummary || "Sin resumen contractual."
				const policiesHref =
					cell.dataset.policiesHref || `/rates/plans/${encodeURIComponent(ratePlanId)}/policies`
				const productId = cell.dataset.productId || ""
				const completedCount = Math.max(0, 4 - missing.length)
				const missingActions = missing
					.map((category, index) => {
						const actionClass =
							index === 0
								? "bg-slate-950 text-white hover:bg-slate-800"
								: "border border-slate-300 bg-white text-slate-700 hover:bg-slate-50"
						if (category === "CheckIn") {
							return `<a class="inline-flex min-h-9 items-center justify-center rounded-lg px-3 py-2 text-xs font-semibold ${actionClass}" href="/provider/house-rules?productId=${encodeURIComponent(productId)}&focus=arrival">Configurar llegada y salida</a>`
						}
						return `<button type="button" class="policy-assignment-open inline-flex min-h-9 items-center justify-center rounded-lg px-3 py-2 text-xs font-semibold ${actionClass}" data-assignment-mode="preset" data-assignment-scope="rate_plan" data-assignment-scope-id="${escapeHtml(ratePlanId)}" data-assignment-category="${escapeHtml(category)}">Completar ${escapeHtml(categoryLabels[category] || category)}</button>`
					})
					.join("")
				return `<article class="rounded-xl border ${missing.length ? "border-amber-200 bg-amber-50/60" : "border-emerald-200 bg-emerald-50/60"} p-4">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0"><p class="font-semibold text-slate-950">${escapeHtml(ratePlanName)}</p><p class="mt-1 truncate text-xs text-slate-500">${escapeHtml(context)}</p></div>
						<span class="shrink-0 rounded-full px-2 py-1 text-[11px] font-semibold ${missing.length ? "bg-amber-100 text-amber-800" : "bg-emerald-100 text-emerald-800"}">${missing.length ? `${completedCount} de 4 completas` : "4 de 4 completas"}</span>
					</div>
					<p class="mt-3 text-sm leading-5 text-slate-700">${escapeHtml(summary)}</p>
					${missing.length ? `<p class="mt-2 text-xs font-medium text-amber-800">Falta: ${escapeHtml(missing.map((category) => categoryLabels[category] || category).join(", "))}</p>` : ""}
					<div class="mt-3 flex flex-wrap gap-2">${missingActions}<a class="inline-flex min-h-9 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50" href="${escapeHtml(policiesHref)}">${missing.length ? "Abrir contrato completo" : "Editar contrato"}</a></div>
				</article>`
			})
			.join("")
	}

	function ruleDateLabel(rule: AppliedRule): string {
		if (!rule.startDate && !rule.endDate) return "Siempre activa"
		if (!rule.endDate || rule.startDate === rule.endDate) {
			return formatHotelDateLabel(rule.startDate || rule.endDate)
		}
		return `${formatHotelDateLabel(rule.startDate)} → ${formatHotelDateLabel(rule.endDate)}`
	}

	function ruleMatchesSelection(rule: AppliedRule, selection: ReturnType<typeof formatSelection>) {
		const targetMatches =
			rule.category === "price" || rule.scope === "rate_plan"
				? selection.ratePlanIds.includes(rule.ratePlanId || rule.scopeId)
				: rule.scope === "variant"
					? selection.variantIds.includes(rule.variantId || rule.scopeId)
					: selection.productIds.includes(rule.productId || rule.scopeId)
		if (!targetMatches) return false
		if (!rule.startDate && !rule.endDate) return true
		const from = rule.startDate || "0000-01-01"
		const to = rule.endDate || "9999-12-31"
		return from <= selection.lastDate && to >= selection.firstDate
	}

	function selectedAppliedRules(): AppliedRule[] {
		const selection = formatSelection(selectedCells())
		return appliedRules
			.filter((rule) => ruleMatchesSelection(rule, selection))
			.sort((left, right) => {
				if (left.isActive !== right.isActive) return left.isActive ? -1 : 1
				if (left.priority !== right.priority) return left.priority - right.priority
				return right.createdAt.localeCompare(left.createdAt)
			})
	}

