---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import {
	buildRatesMultiCalendarSurface,
	type MultiCalendarCell,
	type MultiCalendarTab,
} from "@/lib/rates/multiCalendarSurface"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { SELLABILITY_RULES } from "@/lib/rates/restrictionsSurface"
import { routes } from "@/lib/routes"
import { CalendarRange, ChevronLeft, ChevronRight, ExternalLink } from "@lucide/astro"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

const professionalModeCookie = getProfessionalModeCookiePreference(Astro.request)
const sidebarData = await getProviderSidebarData(auth.providerId, {
	userId: auth.user.id,
	professionalToolsEnabled:
		typeof professionalModeCookie === "boolean" ? professionalModeCookie : undefined,
})
if (sidebarData.disclosureMode === "small-provider") {
	return Astro.redirect(`${routes.pricing()}?focus=price&source=multi-calendar-simple-redirect`)
}

const rows = await loadRatePlansReadModel({
	request: Astro.request,
	channel: "web",
})
const surface = await buildRatesMultiCalendarSurface({
	rows,
	url: Astro.url,
})

const tabs: Array<{ key: MultiCalendarTab; label: string; helper: string }> = [
	{ key: "price", label: "Precio", helper: "Precio final y brechas." },
	{ key: "availability", label: "Disponibilidad", helper: "Cupos, reservas y retenidos." },
	{ key: "sellability", label: "Venta", helper: "Vendible, cerrado o restringido." },
	{ key: "conditions", label: "Condiciones", helper: "Contrato de cada tarifa." },
	{ key: "rules", label: "Reglas", helper: "Reglas aplicadas por fecha." },
]

function hrefWith(params: Record<string, string | number | null | undefined>): string {
	const next = new URLSearchParams(Astro.url.searchParams)
	for (const [key, value] of Object.entries(params)) {
		if (value == null || value === "") next.delete(key)
		else next.set(key, String(value))
	}
	const query = next.toString()
	return query ? `${routes.ratesMultiCalendar()}?${query}` : routes.ratesMultiCalendar()
}

function cellToneFor(tab: MultiCalendarTab, cell: MultiCalendarCell): string {
	if (cell.isPast) return "border-slate-200 bg-slate-50 text-slate-400"
	if (tab === "conditions") {
		return cell.conditionsComplete
			? "border-emerald-200 bg-emerald-50 text-emerald-950"
			: "border-amber-200 bg-amber-50 text-amber-950"
	}
	if (tab === "availability") {
		return cell.availableUnits > 0
			? "border-emerald-200 bg-emerald-50 text-emerald-950"
			: "border-orange-200 bg-orange-50 text-orange-950"
	}
	if (tab === "sellability" || tab === "rules") {
		if (cell.hasCommercialBlocker) return "border-red-200 bg-red-50 text-red-950"
		if (cell.restrictionCount > 0) return "border-blue-200 bg-blue-50 text-blue-950"
		return "border-emerald-200 bg-emerald-50 text-emerald-950"
	}
	return cell.hasPrice
		? "border-emerald-200 bg-emerald-50 text-emerald-950"
		: "border-amber-200 bg-amber-50 text-amber-950"
}

function cellTone(cell: MultiCalendarCell): string {
	return cellToneFor(surface.tab, cell)
}

function cellPrimaryFor(tab: MultiCalendarTab, cell: MultiCalendarCell): string {
	if (cell.isPast) return "Pasado"
	if (tab === "availability") return `${cell.availableUnits}/${cell.totalUnits} cupos`
	if (tab === "sellability") return cell.operationalStatusLabel
	if (tab === "conditions") return cell.conditionsComplete ? "Listas" : "Faltan"
	if (tab === "rules") {
		if (cell.hasCommercialBlocker) return "Cerrado"
		if (cell.restrictionCount > 0) return `${cell.restrictionCount} reglas`
		return "Sin reglas"
	}
	return cell.price
}

function cellPrimary(cell: MultiCalendarCell): string {
	return cellPrimaryFor(surface.tab, cell)
}

function cellSecondaryFor(tab: MultiCalendarTab, cell: MultiCalendarCell): string {
	if (cell.isPast) return ""
	if (tab === "availability") return `${cell.bookedUnits} reservas · ${cell.heldUnits} holds`
	if (tab === "sellability") return cell.restrictionSummary
	if (tab === "conditions") return cell.conditionsMissingSummary || cell.conditionsSummary
	if (tab === "rules") return cell.restrictionSummary
	return cell.hasPrice ? cell.basePrice : "Completar precio"
}

function cellSecondary(cell: MultiCalendarCell): string {
	return cellSecondaryFor(surface.tab, cell)
}

function rowStatusLabel(row: (typeof surface.rows)[number]): string {
	if (
		row.readiness.priceReady &&
		row.readiness.availabilityReady &&
		row.readiness.conditionsReady
	) {
		return "Lista"
	}
	const missing: string[] = []
	if (!row.readiness.priceReady) missing.push("precio")
	if (!row.readiness.availabilityReady) missing.push("cupo")
	if (!row.readiness.conditionsReady) missing.push("condiciones")
	return `Falta ${missing.join(", ")}`
}
---

<WorkspaceLayout title="Multicalendario">
	<div class="space-y-5">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Habitaciones y tarifas · Herramienta Pro
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Multicalendario</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Opera varias tarifas por fecha sin entrar una por una. Usa esta vista para temporadas,
					eventos y cambios de escala.
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				<Button href={routes.pricing()} variant="secondary">Calendario</Button>
				<Button href={routes.rateRestrictions()} variant="primary">Crear regla</Button>
			</div>
		</header>

		<Section>
			<Card className="space-y-4 bg-white text-slate-900">
				<form method="get" class="grid gap-3 lg:grid-cols-[1fr_1fr_1fr_0.8fr_auto] lg:items-end">
					<input type="hidden" name="tab" value={surface.tab} />
					<input type="hidden" name="range" value={surface.rangeSize} />
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Hotel</span>
						<select name="productId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="">Todos los hoteles</option>
							{
								surface.options.products.map((product) => (
									<option value={product.id} selected={surface.filters.productId === product.id}>
										{product.name}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Habitación</span>
						<select name="variantId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="">Todas las habitaciones</option>
							{
								surface.options.variants.map((variant) => (
									<option value={variant.id} selected={surface.filters.variantId === variant.id}>
										{variant.productName} · {variant.name}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Tarifa</span>
						<select name="ratePlanId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="">Todas las tarifas</option>
							{
								surface.options.ratePlans.map((ratePlan) => (
									<option value={ratePlan.id} selected={surface.filters.ratePlanId === ratePlan.id}>
										{ratePlan.variantName} · {ratePlan.name}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Estado</span>
						<select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="all" selected={surface.filters.status === "all"}>Todas</option>
							<option value="ready" selected={surface.filters.status === "ready"}>Listas</option>
							<option value="attention" selected={surface.filters.status === "attention"}>
								Con pendientes
							</option>
						</select>
					</label>
					<Button type="submit" variant="primary">Filtrar</Button>
				</form>

				<div
					class="flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-4"
				>
					<div class="flex items-center gap-2">
						<a
							href={hrefWith({ month: surface.previousMonth })}
							class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-600 shadow-sm hover:bg-slate-50"
							aria-label="Mes anterior"
						>
							<ChevronLeft class="h-4 w-4" aria-hidden="true" />
						</a>
						<div>
							<p class="text-base font-semibold text-slate-950">
								{surface.startDate || "Sin fechas"}{surface.endDate ? ` al ${surface.endDate}` : ""}
							</p>
							<p class="text-xs text-slate-500">
								{surface.stats.totalRows} tarifas · {surface.stats.readyRows} listas ·{" "}
								{surface.stats.attentionRows} con pendientes
							</p>
						</div>
						<a
							href={hrefWith({ month: surface.nextMonth })}
							class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-600 shadow-sm hover:bg-slate-50"
							aria-label="Mes siguiente"
						>
							<ChevronRight class="h-4 w-4" aria-hidden="true" />
						</a>
					</div>
					<div class="flex flex-wrap items-center gap-1.5">
						{
							[14, 30, 60].map((range) => (
								<a
									href={hrefWith({ range })}
									class:list={[
										"rounded-md border px-3 py-1.5 text-xs font-semibold transition",
										surface.rangeSize === range
											? "border-slate-950 bg-slate-950 text-white"
											: "border-slate-200 text-slate-600 hover:bg-slate-50",
									]}
								>
									{range} días
								</a>
							))
						}
					</div>
				</div>

				<div class="flex gap-2 overflow-x-auto border-t border-slate-200 pt-4">
					{
						tabs.map((tab) => (
							<button
								type="button"
								data-multi-calendar-tab-button
								data-tab={tab.key}
								class:list={[
									"min-w-[9rem] rounded-lg border px-3 py-2 text-left text-sm transition",
									surface.tab === tab.key
										? "border-slate-950 bg-slate-950 text-white"
										: "border-slate-200 text-slate-700 hover:bg-slate-50",
								]}
							>
								<span class="block font-semibold">{tab.label}</span>
								<span
									class:list={[
										"mt-0.5 block text-xs",
										surface.tab === tab.key ? "text-slate-300" : "text-slate-500",
									]}
								>
									{tab.helper}
								</span>
							</button>
						))
					}
				</div>

				<div
					data-multi-calendar-selection-bar
					class="hidden items-center justify-between gap-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2"
				>
					<div class="min-w-0">
						<p class="text-sm font-semibold text-slate-950" data-multi-calendar-selection-count>
							0 fechas seleccionadas
						</p>
						<p class="text-xs text-slate-500" data-multi-calendar-selection-summary>
							Selecciona fechas o tarifas para operar en escala.
						</p>
					</div>
					<div class="flex flex-wrap items-center gap-1.5">
						<button
							type="button"
							data-multi-calendar-action="price"
							class="rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
						>
							Cambiar precio
						</button>
						<button
							type="button"
							data-multi-calendar-action="availability"
							class="rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
						>
							Cambiar cupo
						</button>
						<button
							type="button"
							data-multi-calendar-action="rule"
							class="rounded-md bg-slate-950 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-800"
						>
							Crear regla
						</button>
						<button
							type="button"
							data-multi-calendar-action="clear"
							class="rounded-md px-3 py-1.5 text-xs font-semibold text-slate-500 hover:bg-white"
						>
							Limpiar
						</button>
					</div>
				</div>
			</Card>
		</Section>

		<Section>
			<Card className="overflow-hidden bg-white p-0 text-slate-900">
				<div
					class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 px-4 py-3"
				>
					<div>
						<h2 class="text-base font-semibold text-slate-950">Operación por tarifa</h2>
						<p class="text-sm text-slate-500">
							Selecciona celdas para revisar impacto o continuar en Calendario.
						</p>
					</div>
					<div class="flex flex-wrap gap-1.5 text-xs">
						<Badge variant={surface.stats.missingPriceCells > 0 ? "warning" : "success"}>
							{surface.stats.missingPriceCells} sin precio
						</Badge>
						<Badge variant={surface.stats.noInventoryCells > 0 ? "warning" : "success"}>
							{surface.stats.noInventoryCells} sin cupo
						</Badge>
						<Badge variant={surface.stats.incompleteConditionRows > 0 ? "warning" : "success"}>
							{surface.stats.incompleteConditionRows} con condiciones pendientes
						</Badge>
					</div>
				</div>
				{
					surface.rows.length === 0 ? (
						<div class="p-8 text-center text-sm text-slate-500">
							<CalendarRange class="mx-auto mb-3 h-8 w-8 text-slate-300" aria-hidden="true" />
							<p class="font-semibold text-slate-800">No hay tarifas para esta vista.</p>
							<p class="mt-1">
								Cambia filtros o crea una tarifa antes de operar el multicalendario.
							</p>
						</div>
					) : (
						<div class="overflow-x-auto">
							<div
								class="grid min-w-max"
								style={`grid-template-columns: 18rem repeat(${surface.days.length}, minmax(6.25rem, 1fr));`}
								data-multi-calendar-grid
							>
								<div class="sticky left-0 z-20 border-r border-b border-slate-200 bg-white p-3">
									<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">Tarifa</p>
								</div>
								{surface.days.map((day) => (
									<div class="border-b border-slate-200 bg-slate-50 p-2 text-center">
										<button
											type="button"
											data-multi-calendar-select-date
											data-date={day.date}
											class="mx-auto block rounded-md px-2 py-1 hover:bg-white hover:shadow-sm"
										>
											<p class="text-[10px] font-semibold tracking-wide text-slate-500 uppercase">
												{day.weekday}
											</p>
											<p class="text-sm font-semibold text-slate-950">{day.day}</p>
											<p class="text-[10px] text-slate-400">{day.monthLabel}</p>
										</button>
									</div>
								))}
								{surface.rows.map((row) => (
									<>
										<div class="sticky left-0 z-10 border-r border-b border-slate-200 bg-white p-3">
											<div class="min-w-0 space-y-2">
												<div>
													<p class="truncate text-sm font-semibold text-slate-950">
														{row.ratePlanName}
													</p>
													<p class="truncate text-xs text-slate-500">
														{row.productName} · {row.variantName}
													</p>
												</div>
												<div class="flex flex-wrap items-center gap-1.5">
													<Badge
														variant={
															row.readiness.priceReady &&
															row.readiness.availabilityReady &&
															row.readiness.conditionsReady
																? "success"
																: "warning"
														}
													>
														{rowStatusLabel(row)}
													</Badge>
												</div>
												<div class="flex flex-wrap gap-1.5">
													<button
														type="button"
														data-multi-calendar-select-row
														data-rate-plan-id={row.ratePlanId}
														class="inline-flex items-center gap-1 rounded-md border border-slate-200 px-2 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-50"
													>
														Seleccionar
													</button>
													<a
														href={row.calendarHref}
														class="inline-flex items-center gap-1 rounded-md border border-slate-200 px-2 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-50"
													>
														Calendario
														<ExternalLink class="h-3 w-3" aria-hidden="true" />
													</a>
													<a
														href={surface.tab === "conditions" ? row.policiesHref : row.rulesHref}
														class="inline-flex items-center gap-1 rounded-md border border-slate-200 px-2 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-50"
													>
														{surface.tab === "conditions" ? "Resolver" : "Reglas"}
													</a>
												</div>
											</div>
										</div>
										{row.cells.map((cell) => (
											<button
												type="button"
												data-multi-calendar-cell
												data-date={cell.date}
												data-rate-plan-id={row.ratePlanId}
												data-rate-plan-name={row.ratePlanName}
												data-variant-id={row.variantId}
												data-product-name={row.productName}
												data-variant-name={row.variantName}
												data-context-title={`${cell.date} · ${row.ratePlanName}`}
												data-context-summary={`${row.productName} · ${row.variantName}`}
												data-context-primary={cellPrimary(cell)}
												data-context-secondary={cellSecondary(cell)}
												data-primary-price={cellPrimaryFor("price", cell)}
												data-secondary-price={cellSecondaryFor("price", cell)}
												data-tone-price={cellToneFor("price", cell)}
												data-primary-availability={cellPrimaryFor("availability", cell)}
												data-secondary-availability={cellSecondaryFor("availability", cell)}
												data-tone-availability={cellToneFor("availability", cell)}
												data-primary-sellability={cellPrimaryFor("sellability", cell)}
												data-secondary-sellability={cellSecondaryFor("sellability", cell)}
												data-tone-sellability={cellToneFor("sellability", cell)}
												data-primary-conditions={cellPrimaryFor("conditions", cell)}
												data-secondary-conditions={cellSecondaryFor("conditions", cell)}
												data-tone-conditions={cellToneFor("conditions", cell)}
												data-primary-rules={cellPrimaryFor("rules", cell)}
												data-secondary-rules={cellSecondaryFor("rules", cell)}
												data-tone-rules={cellToneFor("rules", cell)}
												data-calendar-href={row.calendarHref}
												data-policies-href={row.policiesHref}
												data-rules-href={row.rulesHref}
												disabled={cell.isPast}
												class:list={[
													"min-h-20 border-r border-b p-2 text-left transition focus:outline-none focus:ring-2 focus:ring-blue-500",
													cellTone(cell),
													cell.isPast ? "cursor-default" : "hover:shadow-sm",
												]}
											>
												<p class="truncate text-sm font-semibold" data-cell-primary>
													{cellPrimary(cell)}
												</p>
												<p class="mt-1 line-clamp-2 text-xs opacity-75" data-cell-secondary>
													{cellSecondary(cell)}
												</p>
											</button>
										))}
									</>
								))}
							</div>
						</div>
					)
				}
			</Card>
		</Section>
	</div>

	<div
		id="multiCalendarDrawerBackdrop"
		class="fixed inset-0 z-40 hidden bg-slate-950/40"
		aria-hidden="true"
	>
	</div>
	<aside
		id="multiCalendarDrawer"
		class="fixed top-0 right-0 z-50 hidden h-full w-full max-w-md overflow-y-auto border-l border-slate-200 bg-white p-5 text-slate-900 shadow-2xl"
		aria-label="Detalle del multicalendario"
	>
		<div class="flex items-start justify-between gap-4">
			<div>
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Selección</p>
				<h2 id="multiCalendarDrawerTitle" class="mt-1 text-xl font-semibold text-slate-950">
					Selecciona una fecha
				</h2>
				<p id="multiCalendarDrawerSummary" class="mt-1 text-sm text-slate-500"></p>
			</div>
			<button
				id="multiCalendarDrawerClose"
				type="button"
				class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600 hover:bg-slate-50"
			>
				Cerrar
			</button>
		</div>

		<div class="mt-5 rounded-lg border border-slate-200 p-4">
			<p id="multiCalendarDrawerPrimary" class="text-lg font-semibold text-slate-950"></p>
			<p id="multiCalendarDrawerSecondary" class="mt-1 text-sm text-slate-600"></p>
		</div>

		<div class="mt-5 rounded-lg border border-slate-200 bg-slate-50 p-4">
			<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Impacto</p>
			<p id="multiCalendarImpactTitle" class="mt-2 text-sm font-semibold text-slate-950">
				Selecciona fechas para ver el alcance.
			</p>
			<p id="multiCalendarImpactSummary" class="mt-1 text-sm text-slate-600"></p>
		</div>

		<div class="mt-5 grid gap-2" data-multi-calendar-navigation-actions>
			<a
				id="multiCalendarDrawerCalendarLink"
				href={routes.pricing()}
				class="rounded-lg bg-slate-950 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-slate-800"
			>
				Continuar en Calendario
			</a>
			<a
				id="multiCalendarDrawerRulesLink"
				href={routes.rateRestrictions()}
				class="rounded-lg border border-slate-200 px-4 py-2 text-center text-sm font-semibold text-slate-700 hover:bg-slate-50"
			>
				Abrir Reglas de venta
			</a>
			<a
				id="multiCalendarDrawerPoliciesLink"
				href={routes.providerPolicies()}
				class="rounded-lg border border-slate-200 px-4 py-2 text-center text-sm font-semibold text-slate-700 hover:bg-slate-50"
			>
				Resolver condiciones
			</a>
		</div>

		<form
			id="multiCalendarPriceForm"
			class="mt-5 hidden space-y-4 rounded-lg border border-slate-200 p-4"
		>
			<div>
				<p class="text-sm font-semibold text-slate-950">Cambio de precio en selección</p>
				<p class="mt-1 text-xs text-slate-500">
					Guarda un precio final puntual para todas las tarifas seleccionadas.
				</p>
			</div>
			<label class="block space-y-1.5 text-sm">
				<span class="font-medium text-slate-700">Precio final</span>
				<input
					id="multiCalendarPriceValue"
					type="number"
					min="0"
					step="0.01"
					placeholder="Ej. 120"
					class="w-full rounded-lg border border-slate-300 px-3 py-2"
				/>
			</label>
			<div class="grid grid-cols-2 gap-2">
				<button
					id="multiCalendarPricePreview"
					type="button"
					class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50"
				>
					Revisar
				</button>
				<button
					id="multiCalendarPriceApply"
					type="button"
					class="rounded-lg bg-slate-950 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-50"
					disabled
				>
					Guardar
				</button>
			</div>
			<p id="multiCalendarPriceFeedback" class="text-sm text-slate-600"></p>
		</form>

		<form
			id="multiCalendarAvailabilityForm"
			class="mt-5 hidden space-y-4 rounded-lg border border-slate-200 p-4"
		>
			<div>
				<p class="text-sm font-semibold text-slate-950">Cambio de cupo físico</p>
				<p class="mt-1 text-xs text-slate-500">
					Actualiza la disponibilidad física de las habitaciones incluidas en la selección.
				</p>
			</div>
			<label class="block space-y-1.5 text-sm">
				<span class="font-medium text-slate-700">Cupo disponible</span>
				<input
					id="multiCalendarAvailabilityValue"
					type="number"
					min="0"
					step="1"
					placeholder="Ej. 7"
					class="w-full rounded-lg border border-slate-300 px-3 py-2"
				/>
			</label>
			<div class="grid grid-cols-2 gap-2">
				<button
					id="multiCalendarAvailabilityPreview"
					type="button"
					class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50"
				>
					Revisar
				</button>
				<button
					id="multiCalendarAvailabilityApply"
					type="button"
					class="rounded-lg bg-slate-950 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-50"
					disabled
				>
					Guardar
				</button>
			</div>
			<p id="multiCalendarAvailabilityFeedback" class="text-sm text-slate-600"></p>
		</form>

		<form
			id="multiCalendarRuleForm"
			method="POST"
			action={routes.rateRestrictions()}
			class="mt-5 hidden space-y-4 rounded-lg border border-slate-200 p-4"
		>
			<input type="hidden" name="action" value="create-batch" />
			<input type="hidden" name="scope" value="rate_plan" />
			<input type="hidden" name="scopeIds" data-multi-calendar-scope-ids />
			<input type="hidden" name="startDate" data-multi-calendar-start-date />
			<input type="hidden" name="endDate" data-multi-calendar-end-date />
			<div>
				<p class="text-sm font-semibold text-slate-950">Crear regla para la selección</p>
				<p class="mt-1 text-xs text-slate-500">
					Se aplicará a las tarifas seleccionadas y quedará administrable en Reglas de venta.
				</p>
			</div>
			<label class="block space-y-1.5 text-sm">
				<span class="font-medium text-slate-700">Regla</span>
				<select name="type" class="w-full rounded-lg border border-slate-300 px-3 py-2">
					{SELLABILITY_RULES.map((rule) => <option value={rule.type}>{rule.label}</option>)}
				</select>
			</label>
			<label class="block space-y-1.5 text-sm">
				<span class="font-medium text-slate-700">Valor cuando aplique</span>
				<input
					name="value"
					type="number"
					min="1"
					step="1"
					placeholder="Ej. 2 noches"
					class="w-full rounded-lg border border-slate-300 px-3 py-2"
				/>
			</label>
			<Button type="submit" variant="primary">Crear regla de venta</Button>
		</form>
	</aside>
</WorkspaceLayout>

<script>
	const drawer = document.getElementById("multiCalendarDrawer")
	const backdrop = document.getElementById("multiCalendarDrawerBackdrop")
	const closeButton = document.getElementById("multiCalendarDrawerClose")
	const title = document.getElementById("multiCalendarDrawerTitle")
	const summary = document.getElementById("multiCalendarDrawerSummary")
	const primary = document.getElementById("multiCalendarDrawerPrimary")
	const secondary = document.getElementById("multiCalendarDrawerSecondary")
	const calendarLink = document.getElementById("multiCalendarDrawerCalendarLink")
	const rulesLink = document.getElementById("multiCalendarDrawerRulesLink")
	const policiesLink = document.getElementById("multiCalendarDrawerPoliciesLink")
	const navigationActions = document.querySelector("[data-multi-calendar-navigation-actions]")
	const impactTitle = document.getElementById("multiCalendarImpactTitle")
	const impactSummary = document.getElementById("multiCalendarImpactSummary")
	const selectionBar = document.querySelector("[data-multi-calendar-selection-bar]")
	const selectionCount = document.querySelector("[data-multi-calendar-selection-count]")
	const selectionSummary = document.querySelector("[data-multi-calendar-selection-summary]")
	const ruleForm = document.getElementById("multiCalendarRuleForm")
	const scopeIdsInput = document.querySelector("[data-multi-calendar-scope-ids]")
	const startDateInput = document.querySelector("[data-multi-calendar-start-date]")
	const endDateInput = document.querySelector("[data-multi-calendar-end-date]")
	const priceForm = document.getElementById("multiCalendarPriceForm")
	const priceValue = document.getElementById("multiCalendarPriceValue")
	const pricePreview = document.getElementById("multiCalendarPricePreview")
	const priceApply = document.getElementById("multiCalendarPriceApply")
	const priceFeedback = document.getElementById("multiCalendarPriceFeedback")
	const availabilityForm = document.getElementById("multiCalendarAvailabilityForm")
	const availabilityValue = document.getElementById("multiCalendarAvailabilityValue")
	const availabilityPreview = document.getElementById("multiCalendarAvailabilityPreview")
	const availabilityApply = document.getElementById("multiCalendarAvailabilityApply")
	const availabilityFeedback = document.getElementById("multiCalendarAvailabilityFeedback")
	const selectedKeys = new Set<string>()
	let pricePayload: any = null
	let inventoryPayload: any = null
	const toneClasses = [
		"border-slate-200",
		"bg-slate-50",
		"text-slate-400",
		"border-emerald-200",
		"bg-emerald-50",
		"text-emerald-950",
		"border-amber-200",
		"bg-amber-50",
		"text-amber-950",
		"border-orange-200",
		"bg-orange-50",
		"text-orange-950",
		"border-red-200",
		"bg-red-50",
		"text-red-950",
		"border-blue-200",
		"bg-blue-50",
		"text-blue-950",
	]

	function setDrawerOpen(open: boolean) {
		drawer?.classList.toggle("hidden", !open)
		backdrop?.classList.toggle("hidden", !open)
		document.documentElement.classList.toggle("multi-calendar-drawer-open", open)
	}

	function addDays(date: string, days: number): string {
		const value = new Date(`${date}T12:00:00.000Z`)
		value.setUTCDate(value.getUTCDate() + days)
		return value.toISOString().slice(0, 10)
	}

	function getSelectableCells(): HTMLElement[] {
		return Array.from(document.querySelectorAll<HTMLElement>("[data-multi-calendar-cell]")).filter(
			(cell) => !cell.hasAttribute("disabled")
		)
	}

	function cellKey(cell: HTMLElement): string {
		return `${cell.dataset.ratePlanId || ""}::${cell.dataset.date || ""}`
	}

	function selectedCells(): HTMLElement[] {
		return getSelectableCells().filter((cell) => selectedKeys.has(cellKey(cell)))
	}

	function formatSelection(cells: HTMLElement[]) {
		const dates = [...new Set(cells.map((cell) => cell.dataset.date || "").filter(Boolean))].sort()
		const ratePlanIds = [
			...new Set(cells.map((cell) => cell.dataset.ratePlanId || "").filter(Boolean)),
		]
		const ratePlanNames = [
			...new Set(cells.map((cell) => cell.dataset.ratePlanName || "").filter(Boolean)),
		]
		const variantIds = [
			...new Set(cells.map((cell) => cell.dataset.variantId || "").filter(Boolean)),
		]
		const firstDate = dates[0] || ""
		const lastDate = dates[dates.length - 1] || firstDate
		return {
			dates,
			ratePlanIds,
			ratePlanNames,
			variantIds,
			firstDate,
			lastDate,
			count: cells.length,
			rangeLabel:
				firstDate && lastDate && firstDate !== lastDate ? `${firstDate} a ${lastDate}` : firstDate,
		}
	}

	function syncSelectedStyles() {
		getSelectableCells().forEach((cell) => {
			cell.classList.toggle("ring-2", selectedKeys.has(cellKey(cell)))
			cell.classList.toggle("ring-slate-950", selectedKeys.has(cellKey(cell)))
		})
	}

	function syncSelectionBar() {
		const cells = selectedCells()
		const selection = formatSelection(cells)
		selectionBar?.classList.toggle("hidden", cells.length === 0)
		selectionBar?.classList.toggle("flex", cells.length > 0)
		if (selectionCount) {
			selectionCount.textContent = `${selection.count} ${selection.count === 1 ? "celda seleccionada" : "celdas seleccionadas"}`
		}
		if (selectionSummary) {
			selectionSummary.textContent = cells.length
				? `${selection.rangeLabel} · ${selection.ratePlanIds.length} ${selection.ratePlanIds.length === 1 ? "tarifa" : "tarifas"}`
				: "Selecciona fechas o tarifas para operar en escala."
		}
		scopeIdsInput?.setAttribute("value", selection.ratePlanIds.join(","))
		startDateInput?.setAttribute("value", selection.firstDate)
		endDateInput?.setAttribute("value", selection.lastDate)
	}

	function setActionPanels(action: "detail" | "price" | "availability" | "rule" | "conditions") {
		priceForm?.classList.toggle("hidden", action !== "price")
		availabilityForm?.classList.toggle("hidden", action !== "availability")
		ruleForm?.classList.toggle("hidden", action !== "rule")
		navigationActions?.classList.toggle("hidden", action === "price" || action === "availability")
		if (action !== "price") {
			pricePayload = null
			if (priceApply instanceof HTMLButtonElement) priceApply.disabled = true
			if (priceFeedback) priceFeedback.textContent = ""
		}
		if (action !== "availability") {
			inventoryPayload = null
			if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = true
			if (availabilityFeedback) availabilityFeedback.textContent = ""
		}
	}

	function updateDrawerFromSelection(
		action: "detail" | "price" | "availability" | "rule" | "conditions" = "detail"
	) {
		const cells = selectedCells()
		if (!cells.length) return
		const selection = formatSelection(cells)
		const firstCell = cells[0]
		const actionLabel =
			action === "price"
				? "Cambiar precio"
				: action === "availability"
					? "Cambiar cupo"
					: action === "rule"
						? "Crear regla de venta"
						: action === "conditions"
							? "Resolver condiciones"
							: "Selección"
		if (title) title.textContent = actionLabel
		if (summary) {
			summary.textContent = `${selection.rangeLabel} · ${selection.ratePlanIds.length} ${selection.ratePlanIds.length === 1 ? "tarifa" : "tarifas"}`
		}
		if (primary) {
			primary.textContent =
				selection.ratePlanNames.length === 1
					? selection.ratePlanNames[0] || ""
					: `${selection.ratePlanNames.length} tarifas seleccionadas`
		}
		if (secondary) {
			secondary.textContent = firstCell.getAttribute("data-context-summary") || ""
		}
		if (impactTitle) {
			impactTitle.textContent = `${selection.count} ${selection.count === 1 ? "noche-tarifa" : "noches-tarifa"} impactadas`
		}
		if (impactSummary) {
			impactSummary.textContent =
				action === "rule"
					? "La regla quedará guardada en Reglas de venta y seguirá actuando mientras esté vigente."
					: action === "price"
						? "El cambio de precio se aplicará como ajuste puntual sobre las fechas seleccionadas."
						: action === "availability"
							? "El cupo se guardará sobre las habitaciones seleccionadas en el rango elegido."
							: "Elige una acción para operar esta selección."
		}
		const firstRatePlanId = selection.ratePlanIds[0] || firstCell.dataset.ratePlanId || ""
		const month = (selection.firstDate || firstCell.dataset.date || "").slice(0, 7)
		const focus =
			action === "availability" ? "availability" : action === "rule" ? "restrictions" : "price"
		const calendarHref = `/rates/calendar?ratePlanId=${encodeURIComponent(firstRatePlanId)}&month=${encodeURIComponent(month)}&focus=${encodeURIComponent(focus)}&from=${encodeURIComponent(selection.firstDate)}&to=${encodeURIComponent(selection.lastDate)}`
		const rulesHref = `/rates/restrictions?source=multi-calendar&tab=${action === "rule" ? "availability" : "all"}&ratePlanIds=${encodeURIComponent(selection.ratePlanIds.join(","))}&from=${encodeURIComponent(selection.firstDate)}&to=${encodeURIComponent(selection.lastDate)}`
		calendarLink?.setAttribute("href", calendarHref)
		rulesLink?.setAttribute("href", rulesHref)
		policiesLink?.setAttribute(
			"href",
			firstCell.getAttribute("data-policies-href") || "/provider/policies?vista=incomplete"
		)
		setActionPanels(action)
		setDrawerOpen(true)
	}

	function toggleCell(cell: HTMLElement, force?: boolean) {
		const key = cellKey(cell)
		if (!key.includes("::") || cell.hasAttribute("disabled")) return
		const next = typeof force === "boolean" ? force : !selectedKeys.has(key)
		if (next) selectedKeys.add(key)
		else selectedKeys.delete(key)
		syncSelectedStyles()
		syncSelectionBar()
	}

	getSelectableCells().forEach((cell) => {
		cell.addEventListener("click", () => {
			toggleCell(cell)
			if (drawer && !drawer.classList.contains("hidden")) updateDrawerFromSelection("detail")
		})
	})

	function setActiveTab(tab: string) {
		document.querySelectorAll<HTMLElement>("[data-multi-calendar-tab-button]").forEach((button) => {
			const active = button.dataset.tab === tab
			button.classList.toggle("border-slate-950", active)
			button.classList.toggle("bg-slate-950", active)
			button.classList.toggle("text-white", active)
			button.classList.toggle("border-slate-200", !active)
			button.classList.toggle("text-slate-700", !active)
			button.classList.toggle("hover:bg-slate-50", !active)
			button.querySelectorAll("span")[1]?.classList.toggle("text-slate-300", active)
			button.querySelectorAll("span")[1]?.classList.toggle("text-slate-500", !active)
		})
		getSelectableCells().forEach((cell) => {
			cell.classList.remove(...toneClasses)
			const tone = cell.dataset[`tone${tab[0].toUpperCase()}${tab.slice(1)}`] || ""
			cell.classList.add(...tone.split(" ").filter(Boolean))
			const primaryText = cell.dataset[`primary${tab[0].toUpperCase()}${tab.slice(1)}`] || ""
			const secondaryText = cell.dataset[`secondary${tab[0].toUpperCase()}${tab.slice(1)}`] || ""
			const primaryNode = cell.querySelector("[data-cell-primary]")
			const secondaryNode = cell.querySelector("[data-cell-secondary]")
			if (primaryNode) primaryNode.textContent = primaryText
			if (secondaryNode) secondaryNode.textContent = secondaryText
		})
		const url = new URL(window.location.href)
		url.searchParams.set("tab", tab)
		window.history.replaceState({}, "", url)
	}

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-tab-button]").forEach((button) => {
		button.addEventListener("click", () => setActiveTab(button.dataset.tab || "price"))
	})

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-select-date]").forEach((button) => {
		button.addEventListener("click", () => {
			const date = button.dataset.date || ""
			const cells = getSelectableCells().filter((cell) => cell.dataset.date === date)
			const shouldSelect = cells.some((cell) => !selectedKeys.has(cellKey(cell)))
			cells.forEach((cell) => toggleCell(cell, shouldSelect))
		})
	})

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-select-row]").forEach((button) => {
		button.addEventListener("click", () => {
			const ratePlanId = button.dataset.ratePlanId || ""
			const cells = getSelectableCells().filter((cell) => cell.dataset.ratePlanId === ratePlanId)
			const shouldSelect = cells.some((cell) => !selectedKeys.has(cellKey(cell)))
			cells.forEach((cell) => toggleCell(cell, shouldSelect))
		})
	})

	document.querySelectorAll<HTMLElement>("[data-multi-calendar-action]").forEach((button) => {
		button.addEventListener("click", () => {
			const action = button.dataset.multiCalendarAction
			if (action === "clear") {
				selectedKeys.clear()
				syncSelectedStyles()
				syncSelectionBar()
				return
			}
			updateDrawerFromSelection(
				action === "availability" ? "availability" : action === "rule" ? "rule" : "price"
			)
		})
	})

	function setFeedback(target: Element | null, message: string) {
		if (target) target.textContent = message
	}

	function buildSelectionPayload() {
		const cells = selectedCells()
		const selection = formatSelection(cells)
		if (!cells.length || !selection.firstDate || !selection.lastDate) return null
		return selection
	}

	pricePreview?.addEventListener("click", () => {
		const selection = buildSelectionPayload()
		const value = Number((priceValue as HTMLInputElement | null)?.value ?? Number.NaN)
		if (!selection) {
			setFeedback(priceFeedback, "Selecciona al menos una fecha.")
			return
		}
		if (!Number.isFinite(value) || value < 0) {
			setFeedback(priceFeedback, "Ingresa un precio final válido.")
			return
		}
		pricePayload = {
			ratePlanIds: selection.ratePlanIds,
			operation: {
				type: "fixed_override",
				value,
				conditions: {
					priority: 1000,
					dateFrom: selection.firstDate,
					dateTo: selection.lastDate,
					previewFrom: selection.firstDate,
					effectiveFrom: selection.firstDate,
					effectiveTo: addDays(selection.lastDate, 1),
					contextKey: "multicalendar_manual_price",
				},
			},
			dryRun: false,
			concurrency: 3,
		}
		if (priceApply instanceof HTMLButtonElement) priceApply.disabled = false
		setFeedback(
			priceFeedback,
			`Listo para guardar ${selection.count} noches-tarifa en ${selection.ratePlanIds.length} tarifas.`
		)
	})

	priceApply?.addEventListener("click", async () => {
		if (!pricePayload) {
			setFeedback(priceFeedback, "Primero revisa el cambio.")
			return
		}
		if (priceApply instanceof HTMLButtonElement) priceApply.disabled = true
		setFeedback(priceFeedback, "Guardando precio...")
		const response = await fetch("/api/pricing/rules/v2/bulk-apply", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(pricePayload),
		})
		const body = await response.json().catch(() => ({}))
		if (!response.ok) {
			setFeedback(priceFeedback, `No se pudo guardar: ${String(body?.error ?? response.status)}`)
			if (priceApply instanceof HTMLButtonElement) priceApply.disabled = false
			return
		}
		setFeedback(priceFeedback, "Precio guardado. Actualizando vista...")
		window.setTimeout(() => window.location.reload(), 500)
	})

	availabilityPreview?.addEventListener("click", () => {
		const selection = buildSelectionPayload()
		const value = Number((availabilityValue as HTMLInputElement | null)?.value ?? Number.NaN)
		if (!selection) {
			setFeedback(availabilityFeedback, "Selecciona al menos una fecha.")
			return
		}
		if (!Number.isInteger(value) || value < 0) {
			setFeedback(availabilityFeedback, "Ingresa un cupo entero válido.")
			return
		}
		inventoryPayload = {
			selection: { variantIds: selection.variantIds },
			dateRange: { from: selection.firstDate, to: addDays(selection.lastDate, 1) },
			operation: { type: "SET_INVENTORY", value },
			context: { source: "multi-calendar" },
		}
		if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = false
		setFeedback(
			availabilityFeedback,
			`Listo para guardar cupo en ${selection.variantIds.length} habitaciones y ${selection.dates.length} fechas.`
		)
	})

	availabilityApply?.addEventListener("click", async () => {
		if (!inventoryPayload) {
			setFeedback(availabilityFeedback, "Primero revisa el cupo.")
			return
		}
		if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = true
		setFeedback(availabilityFeedback, "Guardando cupo...")
		const response = await fetch("/api/inventory/bulk-apply", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(inventoryPayload),
		})
		const body = await response.json().catch(() => ({}))
		if (!response.ok) {
			setFeedback(
				availabilityFeedback,
				`No se pudo guardar: ${String(body?.error ?? response.status)}`
			)
			if (availabilityApply instanceof HTMLButtonElement) availabilityApply.disabled = false
			return
		}
		setFeedback(availabilityFeedback, "Cupo guardado. Actualizando vista...")
		window.setTimeout(() => window.location.reload(), 500)
	})

	closeButton?.addEventListener("click", () => setDrawerOpen(false))
	backdrop?.addEventListener("click", () => setDrawerOpen(false))
	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") setDrawerOpen(false)
	})
</script>
