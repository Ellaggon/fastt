---
import PolicyAssignmentFlow from "@/components/policy/PolicyAssignmentFlow.astro"
import MultiCalendarWorkspace from "@/components/rates/MultiCalendarWorkspace"
import Button from "@/components/ui/Button.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import { loadMultiCalendarWorkspace } from "@/lib/rates/loadMultiCalendarWorkspace"
import { routes } from "@/lib/routes"

const auth = await requireProvider(Astro.request).catch((error: unknown) => {
	if (error instanceof Response && error.status === 401) return "__REDIRECT_LOGIN__"
	if (error instanceof Response && error.status === 403) return "__REDIRECT_PROVIDER__"
	throw error
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

const professionalModeCookie = getProfessionalModeCookiePreference(Astro.request)
const sidebarData = await getProviderSidebarData(auth.providerId, {
	userId: auth.user.id,
	professionalToolsEnabled:
		typeof professionalModeCookie === "boolean" ? professionalModeCookie : undefined,
})
if (sidebarData.disclosureMode === "small-provider") {
	return Astro.redirect(`${routes.calendar()}?focus=price&source=multi-calendar-simple-redirect`)
}

const workspace = await loadMultiCalendarWorkspace({
	request: Astro.request,
	providerId: auth.providerId,
	url: Astro.url,
})
---

<WorkspaceLayout title="Multicalendario">
	<div class="space-y-5">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Habitaciones y tarifas · Herramienta Pro
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Multicalendario</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Opera varias tarifas por fecha sin entrar una por una. La selección, los controles y los
					resultados permanecen en pantalla mientras trabajas.
				</p>
			</div>
			<Button href={routes.calendar()} variant="secondary"> Calendario </Button>
		</header>

		<MultiCalendarWorkspace
			client:load
			initialSurface={workspace.surface}
			initialRules={workspace.appliedRules}
		/>
	</div>

	<PolicyAssignmentFlow defaultScope="rate_plan" isProfessionalMode={true} />
</WorkspaceLayout>
