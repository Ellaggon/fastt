---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { formatHistoryDate, loadRatesContextualHistory } from "@/lib/audit/contextualHistory"
import { requireProvider } from "@/lib/auth/requireProvider"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { ratePlanIntentPresets } from "@/lib/rates/ratePlanIntentPresets"
import { routes } from "@/lib/routes"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const rows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})

const policyCategoryLabels: Record<string, string> = {
	Cancellation: "Cancelación",
	Payment: "Pago",
	CheckIn: "Ingreso/salida",
	NoShow: "No presentación",
}

function money(value: number | null | undefined, currency: string | null | undefined) {
	if (value == null || !Number.isFinite(Number(value))) return null
	return new Intl.NumberFormat("es-BO", {
		style: "currency",
		currency: String(currency ?? "BOB"),
		maximumFractionDigits: 0,
	}).format(Number(value))
}

function calendarResolveHref(ratePlanId: string, focus: "price" | "availability" | "restrictions") {
	const params = new URLSearchParams({
		ratePlanId,
		focus,
		checkIn,
		checkOut,
	})
	return `${routes.pricing()}?${params.toString()}`
}

function firstCommercialBlocker(row: (typeof rows)[number]) {
	const ratePlanId = String(row.ratePlanId)
	if (!row.isActive) {
		return {
			key: "inactive",
			label: "Activar tarifa",
			href: routes.ratePlanDetail(ratePlanId),
			reason: "La tarifa está inactiva.",
		}
	}
	if (!row.pricingReadiness?.hasBasePrice) {
		return {
			key: "price",
			label: "Precio base",
			href: calendarResolveHref(ratePlanId, "price"),
			reason: "Falta precio base.",
		}
	}
	if (!row.inventoryReadiness?.isReady) {
		return {
			key: "inventory",
			label: "Inventario",
			href: calendarResolveHref(ratePlanId, "availability"),
			reason: "Falta cupo físico vendible.",
		}
	}
	if (!row.policyCoverage?.isComplete) {
		const missing = row.policyCoverage?.missingCategories ?? []
		return {
			key: "policies",
			label: "Condiciones",
			href: routes.ratePlanPolicies(ratePlanId),
			reason: missing.length
				? `Faltan ${missing.map((category) => policyCategoryLabels[category] ?? category).join(", ")}.`
				: "Faltan condiciones.",
		}
	}
	if (Number(row.summary?.activeRestrictionsCount ?? 0) > 0) {
		return {
			key: "restrictions",
			label: "Reglas de venta",
			href: calendarResolveHref(ratePlanId, "restrictions"),
			reason: "Hay reglas de venta activas para revisar.",
		}
	}
	return {
		key: "ready",
		label: "Lista",
		href: routes.ratePlanDetail(ratePlanId),
		reason: "Sin bloqueos comerciales.",
	}
}

function isCommercialReady(row: (typeof rows)[number]) {
	return firstCommercialBlocker(row).key === "ready"
}

const activeRatePlans = rows.filter((row) => row.isActive).length
const readyRatePlans = rows.filter(isCommercialReady).length
const needsAttention = rows.length - readyRatePlans
const variantChoices = Array.from(
	new Map(
		rows.map((row) => [
			String(row.variantId),
			{
				variantId: String(row.variantId),
				label: `${row.productName} · ${row.variantName}`,
			},
		])
	).values()
)
const ratePlanHistory = await loadRatesContextualHistory({
	providerId: auth.providerId,
	ratePlans: rows,
	limit: 6,
	context: "rate_plans",
})
const historyToneClasses: Record<string, string> = {
	success: "border-emerald-200 bg-emerald-50 text-emerald-950",
	warning: "border-amber-200 bg-amber-50 text-amber-950",
	info: "border-blue-200 bg-blue-50 text-blue-950",
	neutral: "border-slate-200 bg-slate-50 text-slate-800",
}
---

<WorkspaceLayout title="Tarifas">
	<div class="space-y-6">
		<header class="rounded-3xl border border-slate-800 bg-slate-950 p-5 text-slate-100 shadow-sm">
			<div class="flex flex-wrap items-start justify-between gap-4">
				<div class="space-y-2">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
						Habitaciones y tarifas · Tarifas
					</p>
					<h1 class="text-3xl font-semibold text-slate-100">Tarifas</h1>
					<p class="max-w-2xl text-sm leading-6 text-slate-300">
						Revisa las ofertas que vendes, completa lo pendiente y vuelve rápido al calendario.
					</p>
				</div>
				<div class="flex flex-wrap items-center gap-2">
					<Button href={routes.pricing()} variant="primary">Calendario</Button>
				</div>
			</div>
			<div class="mt-5 flex flex-wrap gap-2 text-sm">
				<span class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-slate-200">
					{readyRatePlans} listas
				</span>
				<span class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-slate-200">
					{needsAttention} por revisar
				</span>
				<span class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-slate-200">
					{activeRatePlans} activas
				</span>
			</div>
		</header>

		<Section
			title="Lista de tarifas"
			description="Cada fila muestra lo necesario para saber si una tarifa está lista para vender."
		>
			{
				rows.length === 0 ? (
					<Card className="border-slate-200 bg-white text-slate-700">
						<p class="text-base font-semibold text-slate-950">No hay tarifas todavía.</p>
						<p class="mt-2 text-sm leading-6 text-slate-600">
							Cuando una habitación tenga una tarifa, aparecerá aquí para revisar precio base,
							condiciones y reglas de venta.
						</p>
					</Card>
				) : (
					<div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
						{rows.map((row, index) => {
							const restrictionsCount = Number(row.summary?.activeRestrictionsCount ?? 0)
							const policyCovered = Number(row.policyCoverage?.coveredCategories ?? 0)
							const policyTotal = Number(row.policyCoverage?.totalCategories ?? 4)
							const priceReady = Boolean(row.pricingReadiness?.hasBasePrice)
							const priceLabel =
								money(row.pricingReadiness?.basePrice, row.pricingReadiness?.currency) ?? "Falta"
							const inventoryReady = Boolean(row.inventoryReadiness?.isReady)
							const inventoryLabel = inventoryReady
								? `${row.inventoryReadiness?.availableDays ?? 0}/${row.inventoryReadiness?.expectedDays ?? 0} noches`
								: "Falta"
							const conditionsReady = Boolean(row.policyCoverage?.isComplete)
							const blocker = firstCommercialBlocker(row)
							const isReady = blocker.key === "ready"
							const stateLabel = !row.isActive
								? "No lista"
								: isReady
									? "Lista"
									: blocker.key === "restrictions"
										? "Revisar venta"
										: "No lista"
							const stateVariant = !row.isActive ? "warning" : isReady ? "success" : "warning"
							return (
								<article
									class={`grid gap-4 px-5 py-5 text-slate-800 xl:grid-cols-[1.1fr_2fr_auto] xl:items-center ${
										index > 0 ? "border-t border-slate-100" : ""
									}`}
								>
									<div class="min-w-0 space-y-2">
										<div class="flex flex-wrap items-center gap-2">
											<h2 class="text-base font-semibold text-slate-950">{row.ratePlanName}</h2>
											{row.isDefault && <Badge variant="info">Principal</Badge>}
											<Badge variant={stateVariant}>{stateLabel}</Badge>
										</div>
										<p class="text-sm text-slate-500">
											{row.productName} · {row.variantName}
										</p>
										<p class="text-xs font-medium text-slate-500">
											Bloqueo principal: {blocker.reason}
										</p>
									</div>

									<div class="grid grid-cols-2 gap-2 text-sm lg:grid-cols-5">
										<div
											class={`rounded-2xl px-3 py-2 ${
												priceReady ? "bg-emerald-50 text-emerald-950" : "bg-amber-50 text-amber-950"
											}`}
										>
											<p class="text-xs opacity-70">Precio base</p>
											<p class="mt-1 font-semibold">{priceReady ? "Listo" : "Falta"}</p>
											<p class="mt-0.5 text-xs opacity-80">{priceLabel}</p>
										</div>
										<div
											class={`rounded-2xl px-3 py-2 ${
												inventoryReady
													? "bg-emerald-50 text-emerald-950"
													: "bg-amber-50 text-amber-950"
											}`}
										>
											<p class="text-xs opacity-70">Inventario</p>
											<p class="mt-1 font-semibold">{inventoryReady ? "Listo" : "Falta"}</p>
											<p class="mt-0.5 text-xs opacity-80">{inventoryLabel}</p>
										</div>
										<div
											class={`rounded-2xl px-3 py-2 ${
												conditionsReady
													? "bg-emerald-50 text-emerald-950"
													: "bg-amber-50 text-amber-950"
											}`}
										>
											<p class="text-xs opacity-70">Condiciones</p>
											<p class="mt-1 font-semibold">
												{policyCovered}/{policyTotal}
											</p>
											<p class="mt-0.5 text-xs opacity-80">
												{conditionsReady ? "Completas" : "Faltantes"}
											</p>
										</div>
										<div class="rounded-2xl bg-slate-50 px-3 py-2 text-slate-900">
											<p class="text-xs text-slate-500">Reglas de venta</p>
											<p class="mt-1 font-semibold">
												{restrictionsCount > 0 ? "Activas" : "No activas"}
											</p>
											<p class="mt-0.5 text-xs text-slate-500">
												{restrictionsCount > 0 ? `${restrictionsCount} reglas` : "Sin reglas"}
											</p>
										</div>
										<div
											class={`rounded-2xl px-3 py-2 ${
												isReady ? "bg-emerald-100 text-emerald-950" : "bg-red-50 text-red-950"
											}`}
										>
											<p class="text-xs opacity-70">Estado vendible</p>
											<p class="mt-1 font-semibold">{isReady ? "Lista" : "No lista"}</p>
											<p class="mt-0.5 text-xs opacity-80">{blocker.label}</p>
										</div>
									</div>

									<div class="flex flex-wrap items-center gap-2 md:justify-end">
										<Button
											href={blocker.href}
											variant={isReady ? "secondary" : "primary"}
											size="sm"
										>
											Resolver
										</Button>
									</div>
								</article>
							)
						})}
					</div>
				)
			}
		</Section>

		<Section
			title="Crear tarifa"
			description="Elige una intención comercial. Fastt traduce eso a la configuración necesaria."
		>
			<Card className="space-y-5 bg-white text-slate-800">
				<div class="flex flex-wrap items-start justify-between gap-3">
					<div>
						<p class="text-base font-semibold text-slate-950">Nueva tarifa</p>
						<p class="mt-1 max-w-2xl text-sm leading-6 text-slate-600">
							Empieza por lo que quieres ofrecer al huésped, no por IDs ni reglas internas.
						</p>
					</div>
					<Badge variant="info">Intención humana</Badge>
				</div>

				{
					variantChoices.length === 0 ? (
						<p class="rounded-2xl bg-slate-50 p-4 text-sm text-slate-600">
							Primero crea una habitación o unidad vendible. Luego podrás agregar tarifas aquí.
						</p>
					) : (
						<form id="ratePlanIntentCreateForm" class="space-y-5" data-rate-plan-intent-form>
							<div class="grid gap-3 md:grid-cols-4">
								{ratePlanIntentPresets.map((preset, index) => (
									<button
										type="button"
										class={`rounded-2xl border p-4 text-left transition hover:border-slate-400 ${
											index === 0
												? "border-slate-950 bg-slate-950 text-white"
												: "border-slate-200 bg-slate-50 text-slate-800"
										}`}
										data-rate-plan-intent-card
										data-intent-id={preset.id}
										data-name={preset.name}
										data-description={preset.description}
										data-type={preset.type}
										data-value={String(preset.value)}
										data-min-nights={String(preset.minNights ?? "")}
										data-min-advance-days={String(preset.minAdvanceDays ?? "")}
									>
										<span class="block text-sm font-semibold">{preset.name}</span>
										<span class="mt-2 block text-xs leading-5 opacity-80">{preset.summary}</span>
										<span class="mt-3 flex flex-wrap gap-1">
											{preset.tags.map((tag) => (
												<span class="rounded-full bg-white/20 px-2 py-0.5 text-[11px] font-medium">
													{tag}
												</span>
											))}
										</span>
									</button>
								))}
							</div>

							<div class="grid gap-3 md:grid-cols-[1fr_1fr_auto] md:items-end">
								<label class="space-y-1 text-sm">
									<span class="font-medium text-slate-700">Habitación</span>
									<select
										name="variantId"
										class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm text-slate-900"
										required
									>
										{variantChoices.map((choice) => (
											<option value={choice.variantId}>{choice.label}</option>
										))}
									</select>
								</label>
								<label class="space-y-1 text-sm">
									<span class="font-medium text-slate-700">Nombre visible</span>
									<input
										name="name"
										class="h-11 w-full rounded-xl border border-slate-200 px-3 text-sm text-slate-900"
										value={ratePlanIntentPresets[0].name}
										required
									/>
								</label>
								<button
									type="submit"
									class="inline-flex h-11 items-center justify-center rounded-xl bg-slate-950 px-4 text-sm font-semibold text-white transition hover:bg-slate-800"
								>
									Crear tarifa
								</button>
							</div>

							<input
								type="hidden"
								name="description"
								value={ratePlanIntentPresets[0].description}
							/>
							<input type="hidden" name="type" value={ratePlanIntentPresets[0].type} />
							<input type="hidden" name="value" value={String(ratePlanIntentPresets[0].value)} />
							<input
								type="hidden"
								name="minNights"
								value={String(ratePlanIntentPresets[0].minNights ?? "")}
							/>
							<input
								type="hidden"
								name="minAdvanceDays"
								value={String(ratePlanIntentPresets[0].minAdvanceDays ?? "")}
							/>
							<input type="hidden" name="isActive" value="true" />
							<input type="hidden" name="isDefault" value="false" />
							<p class="text-sm text-slate-500" data-rate-plan-intent-feedback>
								{ratePlanIntentPresets[0].guestPromise}
							</p>
						</form>
					)
				}
			</Card>
		</Section>

		<div
			class="flex flex-wrap items-center justify-between gap-3 rounded-3xl border border-slate-200 bg-white/90 p-4 text-sm text-slate-600"
		>
			<p>
				Reglas de venta y condiciones siguen separadas para evitar mezclar precio, vendibilidad y
				contrato. Usa Resolver para abrir el bloqueo correcto.
			</p>
			<div class="flex flex-wrap gap-2">
				<Button href={routes.pricing()} variant="secondary" size="sm">Calendario</Button>
				<Button href={routes.providerPolicies()} variant="secondary" size="sm">
					Condiciones
				</Button>
			</div>
		</div>

		<Section
			title="Cambios recientes de tarifa"
			description="Cambios comerciales de tarifas y reglas de precio vinculadas directamente a este listado."
		>
			<Card className="space-y-4 bg-white text-slate-800">
				<div class="flex flex-wrap gap-2" aria-label="Filtrar historial de tarifas">
					<button
						type="button"
						class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
						data-history-filter="all"
					>
						Todo
					</button>
					<button
						type="button"
						class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
						data-history-filter="tarifa"
					>
						Tarifa
					</button>
				</div>
				{
					ratePlanHistory.length === 0 ? (
						<p class="text-sm text-slate-600">
							Todavía no hay cambios recientes para mostrar en este contexto.
						</p>
					) : (
						<ol class="space-y-3">
							{ratePlanHistory.map((item) => (
								<li
									class={`rounded-2xl border p-3 ${historyToneClasses[item.tone] ?? historyToneClasses.neutral}`}
									data-history-item
									data-history-object={item.objectType}
								>
									<div class="flex flex-wrap items-start justify-between gap-3">
										<div class="min-w-0">
											<div class="flex flex-wrap items-center gap-2">
												<p class="font-semibold">{item.title}</p>
												<span class="rounded-full bg-white/70 px-2 py-0.5 text-[11px] font-semibold tracking-wide uppercase opacity-80">
													{item.objectLabel}
												</span>
											</div>
											<p class="mt-1 text-sm opacity-80">{item.description}</p>
											<p class="mt-1 text-xs opacity-70">{item.meta}</p>
										</div>
										<time class="text-xs font-medium opacity-70">
											{formatHistoryDate(item.createdAt)}
										</time>
									</div>
									<div class="mt-3 grid gap-2 text-xs sm:grid-cols-2">
										<div class="rounded-xl bg-white/70 p-2">
											<p class="font-semibold tracking-wide uppercase opacity-60">Antes</p>
											<p class="mt-1">{item.beforeLabel ?? "Sin estado anterior visible"}</p>
										</div>
										<div class="rounded-xl bg-white/70 p-2">
											<p class="font-semibold tracking-wide uppercase opacity-60">Después</p>
											<p class="mt-1">{item.afterLabel ?? "Cambio aplicado"}</p>
										</div>
									</div>
								</li>
							))}
						</ol>
					)
				}
			</Card>
		</Section>
	</div>
</WorkspaceLayout>

<script>
	document.querySelectorAll("[data-history-filter]").forEach((button) => {
		button.addEventListener("click", () => {
			const filter = button.getAttribute("data-history-filter") || "all"
			document.querySelectorAll("[data-history-item]").forEach((item) => {
				const objectType = item.getAttribute("data-history-object") || ""
				item.classList.toggle("hidden", filter !== "all" && objectType !== filter)
			})
		})
	})

	const intentForm = document.querySelector("[data-rate-plan-intent-form]")
	const intentFeedback = document.querySelector("[data-rate-plan-intent-feedback]")

	function setHiddenValue(
		form: Element | null | undefined,
		name: string,
		value: string | undefined
	) {
		const input = form?.querySelector<HTMLInputElement>(`[name="${name}"]`)
		if (input) input.value = value ?? ""
	}

	function applyIntentPreset(card: HTMLElement) {
		const form = card?.closest("[data-rate-plan-intent-form]")
		if (!form) return
		form.querySelectorAll("[data-rate-plan-intent-card]").forEach((item) => {
			const active = item === card
			item.classList.toggle("border-slate-950", active)
			item.classList.toggle("bg-slate-950", active)
			item.classList.toggle("text-white", active)
			item.classList.toggle("border-slate-200", !active)
			item.classList.toggle("bg-slate-50", !active)
			item.classList.toggle("text-slate-800", !active)
		})
		setHiddenValue(form, "name", card.dataset.name)
		setHiddenValue(form, "description", card.dataset.description)
		setHiddenValue(form, "type", card.dataset.type)
		setHiddenValue(form, "value", card.dataset.value)
		setHiddenValue(form, "minNights", card.dataset.minNights)
		setHiddenValue(form, "minAdvanceDays", card.dataset.minAdvanceDays)
		if (intentFeedback) {
			const tags = Array.from(card.querySelectorAll("span span"))
				.map((tag) => tag.textContent?.trim())
				.filter(Boolean)
				.join(" · ")
			intentFeedback.textContent = tags
				? `${card.dataset.name}: ${tags}. Puedes ajustar condiciones después desde la ficha.`
				: `${card.dataset.name}: puedes ajustar condiciones después desde la ficha.`
		}
	}

	intentForm?.querySelectorAll<HTMLElement>("[data-rate-plan-intent-card]").forEach((card) => {
		card.addEventListener("click", () => applyIntentPreset(card))
	})

	intentForm?.addEventListener("submit", async (event) => {
		event.preventDefault()
		const form = event.currentTarget as HTMLFormElement
		const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]')
		const formData = new FormData(form)
		const payload = {
			variantId: String(formData.get("variantId") || ""),
			name: String(formData.get("name") || ""),
			description: String(formData.get("description") || ""),
			type: String(formData.get("type") || "package"),
			value: Number(formData.get("value") || 0),
			minNights: Number(formData.get("minNights") || 0) || undefined,
			minAdvanceDays: Number(formData.get("minAdvanceDays") || 0) || undefined,
			isActive: true,
			isDefault: false,
		}
		if (intentFeedback) intentFeedback.textContent = "Creando tarifa..."
		submit?.setAttribute("disabled", "true")
		try {
			const response = await fetch("/api/rateplans/create", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(payload),
			})
			const result = await response.json().catch(() => null)
			if (!response.ok || !result?.ratePlanId) {
				throw new Error(result?.error || "No se pudo crear la tarifa")
			}
			window.location.href = `/rates/plans/${encodeURIComponent(result.ratePlanId)}`
		} catch (error) {
			if (intentFeedback) {
				intentFeedback.textContent =
					error instanceof Error ? error.message : "No se pudo crear la tarifa"
			}
			submit?.removeAttribute("disabled")
		}
	})
</script>
