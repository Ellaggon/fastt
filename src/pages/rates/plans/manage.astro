---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const rows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})

const activeRatePlans = rows.filter((row) => row.isActive).length
const incompletePolicies = rows.filter((row) => !row.policyCoverage?.isComplete).length
const plansWithRestrictions = rows.filter(
	(row) => Number(row.summary?.activeRestrictionsCount ?? 0) > 0
).length
---

<WorkspaceLayout title="Rate Plans">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Rooms & Rates · Rate Plans
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Rate Plans</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Superficie explícita para mantener los productos comerciales que se venden sobre una
					variante física: estado, pricing, condiciones de reserva y señales de vendibilidad.
				</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.ratePlansHub()} variant="secondary">Rooms & Rates Hub</Button>
				<Button href={routes.pricingBulk()} variant="primary">Bulk Pricing</Button>
			</div>
		</header>

		<section class="grid gap-4 md:grid-cols-3">
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Rate plans</p>
				<p class="mt-2 text-2xl font-semibold">{rows.length}</p>
				<p class="mt-1 text-xs text-slate-400">{activeRatePlans} activos</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Booking policies</p>
				<p class="mt-2 text-2xl font-semibold">{incompletePolicies}</p>
				<p class="mt-1 text-xs text-slate-400">Rate plans con condiciones pendientes</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Restrictions</p>
				<p class="mt-2 text-2xl font-semibold">{plansWithRestrictions}</p>
				<p class="mt-1 text-xs text-slate-400">Rate plans con controles de vendibilidad activos</p>
			</Card>
		</section>

		<Section
			title="Commercial products"
			description="Rate Plans responde qué producto comercial se vende; pricing, restrictions y booking policies son superficies relacionadas."
		>
			{
				rows.length === 0 ? (
					<Card className="bg-white text-slate-700">
						<p>No hay rate plans activos para este proveedor.</p>
					</Card>
				) : (
					<div class="space-y-3">
						{rows.map((row) => (
							<Card className="bg-white text-slate-800">
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div class="space-y-1">
										<p class="text-base font-semibold">{row.ratePlanName}</p>
										<p class="text-sm text-slate-600">
											Producto: <span class="font-medium text-slate-800">{row.productName}</span>
										</p>
										<p class="text-sm text-slate-600">
											Variante física:{" "}
											<span class="font-medium text-slate-800">{row.variantName}</span>
										</p>
									</div>
									<div class="flex max-w-xl flex-col items-start gap-3 md:items-end">
										<div class="flex flex-wrap items-center gap-2">
											{row.isDefault && <Badge variant="info">Principal</Badge>}
											<Badge variant={row.isActive ? "success" : "warning"}>
												{row.isActive ? "Activo" : "Inactivo"}
											</Badge>
											<Badge variant={row.policyCoverage?.isComplete ? "success" : "warning"}>
												{row.policyCoverage?.isComplete
													? "Booking policies completas"
													: "Booking policies pendientes"}
											</Badge>
											<Badge
												variant={
													Number(row.summary?.activeRestrictionsCount ?? 0) > 0
														? "warning"
														: "neutral"
												}
											>
												{Number(row.summary?.activeRestrictionsCount ?? 0)} restrictions
											</Badge>
										</div>
										<div class="flex flex-wrap items-center gap-2">
											<Button
												href={routes.ratePlanPricing(String(row.ratePlanId))}
												variant="secondary"
												size="sm"
											>
												Pricing
											</Button>
											<Button href={routes.rateRestrictions()} variant="secondary" size="sm">
												Restrictions
											</Button>
											<Button
												href={routes.ratePlanPolicies(String(row.ratePlanId))}
												variant="secondary"
												size="sm"
											>
												Booking Policies
											</Button>
											<Button
												href={routes.ratePlanDetail(String(row.ratePlanId))}
												variant="primary"
												size="sm"
											>
												Ver detalle
											</Button>
										</div>
									</div>
								</div>
							</Card>
						))}
					</div>
				)
			}
		</Section>
	</div>
</WorkspaceLayout>
