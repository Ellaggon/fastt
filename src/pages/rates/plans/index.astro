---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { roomsAndRatesOperationalMap } from "@/lib/backoffice-governance"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const rows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})

const activeRatePlans = rows.filter((row) => row.isActive).length
const defaultRatePlans = rows.filter((row) => row.isDefault).length
const completePolicies = rows.filter((row) => row.policyCoverage?.isComplete).length
const physicalVariants = new Set(rows.map((row) => String(row.variantId))).size
const totalPricingRules = rows.reduce(
	(sum, row) => sum + Number(row.summary?.priceRulesCount ?? 0),
	0
)
const plansWithRestrictions = rows.filter(
	(row) => Number(row.summary?.activeRestrictionsCount ?? 0) > 0
).length
const totalRestrictionSignals = rows.reduce(
	(sum, row) => sum + Number(row.summary?.activeRestrictionsCount ?? 0),
	0
)
const incompletePolicies = Math.max(0, rows.length - completePolicies)

type AriDomainStatus = "operational" | "attention"

const ariDomains: {
	label: string
	owner: string
	status: AriDomainStatus
	metric: string
	signal: string
	description: string
	href: string
	action: string
}[] = [
	{
		label: "Rate Plans",
		owner: "Commercial product",
		status: rows.length > 0 ? "operational" : "attention",
		metric: String(rows.length),
		signal: `${activeRatePlans} activos · ${defaultRatePlans} principales`,
		description: "Define qué producto comercial se vende sobre una variante física.",
		href: routes.ratePlansList(),
		action: "Abrir Rate Plans",
	},
	{
		label: "Pricing",
		owner: "Rate coverage",
		status: rows.length > 0 ? "operational" : "attention",
		metric: String(totalPricingRules),
		signal: "Reglas de precio vinculadas a rate plans",
		description: "Define cuánto se cobra: baseline, cobertura y ajustes comerciales.",
		href: routes.pricing(),
		action: "Abrir Pricing",
	},
	{
		label: "Inventory",
		owner: "Physical capacity",
		status: physicalVariants > 0 ? "operational" : "attention",
		metric: String(physicalVariants),
		signal: "Variantes físicas con contexto de inventario",
		description: "Define cupos, disponibilidad física y capacidad vendible por variante.",
		href: routes.inventory(),
		action: "Abrir Inventory",
	},
	{
		label: "Restrictions",
		owner: "Sellability",
		status: "operational",
		metric: String(totalRestrictionSignals),
		signal: `${plansWithRestrictions} rate plans con controles activos`,
		description: "Define cuándo se puede vender: LOS, CTA/CTD, stop-sell y booking windows.",
		href: routes.rateRestrictions(),
		action: "Abrir Restrictions",
	},
	{
		label: "Booking Policies",
		owner: "Reservation contract",
		status: incompletePolicies === 0 && rows.length > 0 ? "operational" : "attention",
		metric: `${completePolicies}/${rows.length}`,
		signal: incompletePolicies > 0 ? `${incompletePolicies} pendientes` : "Condiciones completas",
		description: "Define cancelación, pago, no-show y condiciones de check-in/out.",
		href: routes.providerPolicies(),
		action: "Abrir Policies",
	},
]

const ownershipLabel = {
	commercial: "Commercial",
	physical: "Physical",
	financial: "Financial dependency",
	planned: "Roadmap",
}

const statusLabel = {
	operational: "Operational",
	transitional: "Transitional",
	planned: "Planned",
}

const statusBadgeVariant = {
	"canonical": "success",
	"transitional": "warning",
	"planned": "neutral",
	"legacy": "neutral",
	"internal-only": "neutral",
	"public": "neutral",
}

const domainBadgeVariant: Record<AriDomainStatus, "success" | "warning"> = {
	operational: "success",
	attention: "warning",
}
---

<WorkspaceLayout title="Rooms & Rates Hub">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Rooms & Rates · ARI Core
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Rooms & Rates Hub</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					ARI Command Center: organiza qué se vende, cuánto cuesta, qué capacidad física existe, qué
					restricciones afectan vendibilidad y qué contrato de reserva aplica.
				</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.ratePlansList()} variant="secondary">Rate Plans</Button>
				<Button href={routes.pricing()} variant="primary">Pricing</Button>
				<Button href={routes.inventory()} variant="secondary">Inventory</Button>
				<Button href={routes.rateRestrictions()} variant="secondary">Restrictions</Button>
			</div>
		</header>

		<section class="grid gap-4 md:grid-cols-4">
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Rate plans</p>
				<p class="mt-2 text-2xl font-semibold">{rows.length}</p>
				<p class="mt-1 text-xs text-slate-400">{activeRatePlans} activos</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Physical variants</p>
				<p class="mt-2 text-2xl font-semibold">{physicalVariants}</p>
				<p class="mt-1 text-xs text-slate-400">Contexto físico, no selector comercial</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Policy readiness</p>
				<p class="mt-2 text-2xl font-semibold">{completePolicies}/{rows.length}</p>
				<p class="mt-1 text-xs text-slate-400">Rate plans con condiciones completas</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Primary commercial plans</p>
				<p class="mt-2 text-2xl font-semibold">{defaultRatePlans}</p>
				<p class="mt-1 text-xs text-slate-400">Rate-plan ownership explícito</p>
			</Card>
		</section>

		<Section
			title="ARI command domains"
			description="Cada dominio responde una pregunta operacional distinta. El Hub coordina señales y handoffs sin mezclar ownership."
		>
			<div class="grid gap-4 lg:grid-cols-5">
				{
					ariDomains.map((domain) => (
						<Card className="border-slate-800 bg-slate-950 text-slate-100">
							<div class="flex items-start justify-between gap-3">
								<div>
									<p class="text-xs font-semibold tracking-wide text-blue-300 uppercase">
										{domain.owner}
									</p>
									<h2 class="mt-1 text-lg font-semibold">{domain.label}</h2>
								</div>
								<Badge variant={domainBadgeVariant[domain.status]}>
									{domain.status === "operational" ? "Operational" : "Attention"}
								</Badge>
							</div>
							<p class="mt-4 text-3xl font-semibold">{domain.metric}</p>
							<p class="mt-1 text-xs leading-5 text-slate-400">{domain.signal}</p>
							<p class="mt-3 min-h-16 text-sm leading-6 text-slate-300">{domain.description}</p>
							<div class="mt-4">
								<Button href={domain.href} variant="secondary" size="sm">
									{domain.action}
								</Button>
							</div>
						</Card>
					))
				}
			</div>
		</Section>

		<Section
			title="Operational readiness lanes"
			description="Rooms & Rates coordina readiness física, comercial, vendibilidad y contrato de reserva sin mezclar ownership."
		>
			<div class="grid gap-4 lg:grid-cols-3">
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs font-semibold uppercase tracking-wide text-blue-300">
						Physical readiness
					</p>
					<h2 class="mt-2 text-xl font-semibold">Inventory, capacity, availability</h2>
					<p class="mt-2 text-sm leading-6 text-slate-300">
						La capa física responde si existen unidades, cupo y disponibilidad por variante. Puede
						señalar dependencias comerciales, pero no administra pricing.
					</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs font-semibold uppercase tracking-wide text-emerald-300">
						Commercial readiness
					</p>
					<h2 class="mt-2 text-xl font-semibold">Rate plans, coverage, conditions</h2>
					<p class="mt-2 text-sm leading-6 text-slate-300">
						La capa comercial define cobertura de venta por rate plan, condiciones, políticas y
						dependencias financieras. Variant permanece como contexto físico relacionado.
					</p>
				</Card>
				<Card className="border-slate-800 bg-slate-950 text-slate-100">
					<p class="text-xs font-semibold uppercase tracking-wide text-amber-300">
						Sellability readiness
					</p>
					<h2 class="mt-2 text-xl font-semibold">Restrictions, blockers, booking windows</h2>
					<p class="mt-2 text-sm leading-6 text-slate-300">
						La capa de vendibilidad responde si una estadía puede venderse: LOS, CTA/CTD, stop-sell
						y ventanas de reserva. No cambia precios ni cupos físicos.
					</p>
				</Card>
			</div>
		</Section>

		<Section
			title="ARI ownership map"
			description="Mapa operacional de Rooms & Rates. Las capas físicas y comerciales conviven, pero no comparten ownership."
		>
			<div class="grid gap-4 lg:grid-cols-2">
				{
					roomsAndRatesOperationalMap.map((lane) => (
						<Card className="border-slate-800 bg-slate-950 text-slate-100">
							<div class="flex flex-wrap items-start justify-between gap-3">
								<div class="space-y-1">
									<p class="text-xs font-semibold tracking-wide text-blue-300 uppercase">
										{ownershipLabel[lane.ownership]}
									</p>
									<h3 class="text-lg font-semibold">{lane.title}</h3>
								</div>
								<Badge
									variant={
										lane.status === "operational"
											? "success"
											: lane.status === "transitional"
												? "warning"
												: "neutral"
									}
								>
									{statusLabel[lane.status]}
								</Badge>
							</div>
							<p class="mt-3 text-sm leading-6 text-slate-400">{lane.intent}</p>
							<div class="mt-4 space-y-2">
								{lane.surfaces.map((surface) => (
									<div class="rounded-xl border border-slate-800 bg-black/25 p-3">
										<div class="flex flex-wrap items-center justify-between gap-2">
											<div>
												<p class="text-sm font-semibold text-slate-100">{surface.label}</p>
												<p class="mt-1 text-xs leading-5 text-slate-400">{surface.description}</p>
											</div>
											<div class="flex items-center gap-2">
												<Badge variant={statusBadgeVariant[surface.status]}>
													{surface.status === "canonical"
														? "Operational"
														: surface.status === "transitional"
															? "Transitional"
															: "Planned"}
												</Badge>
												{surface.href ? (
													<Button href={surface.href} variant="secondary" size="sm">
														Open
													</Button>
												) : null}
											</div>
										</div>
									</div>
								))}
							</div>
						</Card>
					))
				}
			</div>
		</Section>

		<Section
			title="Commercial rate plans"
			description="RatePlan es el selector comercial. Variant aparece solo como contexto físico de operación."
		>
			{
				rows.length === 0 ? (
					<Card className="bg-white text-slate-700">
						<p>No hay rate plans activos para este proveedor.</p>
					</Card>
				) : (
					<div class="space-y-3">
						<Card className="bg-slate-100 text-slate-800">
							<div class="flex flex-wrap items-center justify-between gap-3">
								<label class="inline-flex items-center gap-2 text-sm text-slate-700">
									<input
										id="bulkSelectAll"
										type="checkbox"
										class="h-4 w-4 rounded border-slate-300"
									/>
									Seleccionar todos
								</label>
								<div class="flex items-center gap-2">
									<span id="bulkSelectionCount" class="text-sm text-slate-600">
										0 seleccionados
									</span>
									<Button
										id="bulkEditOpenBtn"
										variant="primary"
										size="sm"
										className="disabled:cursor-not-allowed disabled:opacity-50"
										disabled
									>
										Abrir Bulk Pricing
									</Button>
								</div>
							</div>
						</Card>
						{rows.map((row) => (
							<Card className="bg-white text-slate-800">
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div class="flex items-start gap-3">
										<input
											type="checkbox"
											class="mt-1 h-4 w-4 rounded border-slate-300"
											data-rateplan-checkbox
											value={String(row.ratePlanId)}
										/>
										<div class="space-y-1">
											<p class="text-base font-semibold">{row.ratePlanName}</p>
											<p class="text-sm text-slate-600">
												Producto: <span class="font-medium text-slate-800">{row.productName}</span>
											</p>
											<p class="text-sm text-slate-600">
												Contexto físico:{" "}
												<span class="font-medium text-slate-800">{row.variantName}</span>
											</p>
										</div>
									</div>
									<div class="flex flex-col items-end gap-2">
										<div class="flex items-center gap-2">
											{row.isDefault && <Badge variant="info">Plan comercial principal</Badge>}
											<Badge variant={row.isActive ? "success" : "warning"}>
												{row.isActive ? "Activo" : "Inactivo"}
											</Badge>
											<Badge variant={row.policyCoverage?.isComplete ? "success" : "warning"}>
												{row.policyCoverage?.isComplete
													? "Condiciones completas"
													: "Faltan condiciones"}
											</Badge>
										</div>
										<div class="flex items-center gap-2">
											<Button
												href={routes.ratePlanPolicies(String(row.ratePlanId))}
												variant="primary"
												size="sm"
											>
												Gestionar condiciones
											</Button>
											<Button
												href={routes.ratePlanPricing(String(row.ratePlanId))}
												variant="secondary"
												size="sm"
											>
												Gestionar cobertura comercial
											</Button>
											<Button
												href={routes.ratePlanDetail(String(row.ratePlanId))}
												variant="secondary"
												size="sm"
											>
												Ver detalle
											</Button>
										</div>
									</div>
								</div>
							</Card>
						))}
					</div>
				)
			}
		</Section>
	</div>

	<script type="module">
		const STORAGE_KEY = "bulkPricing.selection"
		const selectedRatePlanIds = new Set()
		const selectAll = document.getElementById("bulkSelectAll")
		const openBtn = document.getElementById("bulkEditOpenBtn")
		const selectionCount = document.getElementById("bulkSelectionCount")
		const checkboxes = Array.from(document.querySelectorAll("[data-rateplan-checkbox]"))

		function readPersistedSelection() {
			try {
				const raw = localStorage.getItem(STORAGE_KEY)
				if (!raw) return []
				const parsed = JSON.parse(raw)
				return Array.isArray(parsed) ? parsed.map((id) => String(id)) : []
			} catch {
				return []
			}
		}

		function persistSelection() {
			localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(selectedRatePlanIds)))
		}

		function updateSelectionUI() {
			const count = selectedRatePlanIds.size
			if (selectionCount) selectionCount.textContent = `${count} seleccionados`
			if (openBtn instanceof HTMLButtonElement) openBtn.disabled = count === 0
			if (selectAll instanceof HTMLInputElement) {
				const total = checkboxes.length
				selectAll.checked = total > 0 && count === total
				selectAll.indeterminate = count > 0 && count < total
			}
			persistSelection()
		}

		const restored = readPersistedSelection()
		for (const checkbox of checkboxes) {
			const ratePlanId = String(checkbox.value ?? "").trim()
			if (!ratePlanId) continue
			if (restored.includes(ratePlanId)) {
				checkbox.checked = true
				selectedRatePlanIds.add(ratePlanId)
			}
			checkbox.addEventListener("change", () => {
				if (checkbox.checked) selectedRatePlanIds.add(ratePlanId)
				else selectedRatePlanIds.delete(ratePlanId)
				updateSelectionUI()
			})
		}

		selectAll?.addEventListener("change", () => {
			const checked = Boolean(selectAll.checked)
			for (const checkbox of checkboxes) {
				const ratePlanId = String(checkbox.value ?? "").trim()
				if (!ratePlanId) continue
				checkbox.checked = checked
				if (checked) selectedRatePlanIds.add(ratePlanId)
				else selectedRatePlanIds.delete(ratePlanId)
			}
			updateSelectionUI()
		})

		openBtn?.addEventListener("click", () => {
			if (!selectedRatePlanIds.size) return
			const ids = Array.from(selectedRatePlanIds)
			const params = new URLSearchParams({ ratePlanIds: ids.join(",") })
			window.location.href = `/pricing/bulk?${params.toString()}`
		})

		updateSelectionUI()
	</script>
</WorkspaceLayout>
