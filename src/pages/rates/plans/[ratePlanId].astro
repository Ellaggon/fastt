---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import RatePlanPricingSurface from "@/components/pricing/RatePlanPricingSurface.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { loadRatePlanPricingData } from "@/lib/pricing/loadRatePlanPricingData"
import { loadRatePlanReadModelById } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())
void auth

const ratePlanId = String(Astro.params.ratePlanId ?? "").trim()
if (!ratePlanId) return Astro.redirect(routes.ratePlansList())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const row = await loadRatePlanReadModelById({
	request: Astro.request,
	ratePlanId,
	checkIn,
	checkOut,
	channel: "web",
})

if (!row) {
	return new Response("Tarifa no encontrada", { status: 404 })
}

const loadedRatePlan = await loadRatePlanPricingData({
	request: Astro.request,
	ratePlanId,
})
if ("redirectTo" in loadedRatePlan) return Astro.redirect(loadedRatePlan.redirectTo)
const { loaded } = loadedRatePlan

const policyCoverageDone = Number(row.policyCoverage?.coveredCategories ?? 0)
const policyReady = Boolean(row.policyCoverage?.isComplete)
const policyMissingCategories = row.policyCoverage?.missingCategories ?? []
const hasCommercialBaseline = Number(String(loaded.initialBasePrice ?? 0)) > 0
const restrictionCount = Number(row.summary?.activeRestrictionsCount ?? 0)
const saleStatusLabel = row.isActive
	? policyReady && hasCommercialBaseline
		? "Lista para vender"
		: "Necesita revisión"
	: "Inactiva"
const saleStatusVariant =
	row.isActive && policyReady && hasCommercialBaseline ? "success" : "warning"
const policyCategoryLabels: Record<string, string> = {
	Cancellation: "Cancelación",
	Payment: "Pago",
	CheckIn: "Ingreso/salida",
	NoShow: "No presentación",
}
---

<WorkspaceLayout title="Tarifa · Detalle">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Habitaciones y tarifas · Tarifa
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">{row.ratePlanName}</h1>
				<p class="text-sm text-slate-300">{row.productName} · {row.variantName}</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.ratePlansList()} variant="secondary">Volver a tarifas</Button>
				<Button href={routes.pricing()} variant="primary">Calendario</Button>
				<Button href={routes.ratePlanPolicies(String(row.ratePlanId))} variant="secondary"
					>Condiciones</Button
				>
			</div>
		</header>

		<Section
			title="Ficha de tarifa"
			description="Resumen operativo de la oferta que el huésped puede comprar."
		>
			<Card className="space-y-6 bg-white text-slate-800">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div class="space-y-2">
						<div class="flex flex-wrap items-center gap-2">
							<Badge variant={saleStatusVariant}>{saleStatusLabel}</Badge>
							<Badge variant={row.isActive ? "success" : "warning"}>
								{row.isActive ? "Activa" : "Inactiva"}
							</Badge>
							{row.isDefault && <Badge variant="info">Principal</Badge>}
						</div>
						<div>
							<p class="text-xs uppercase tracking-wide text-slate-500">Tarifa</p>
							<p class="mt-1 text-xl font-semibold text-slate-950">{row.ratePlanName}</p>
							<p class="mt-1 text-sm text-slate-600">
								{row.productName} · {row.variantName}
							</p>
						</div>
					</div>
					<div class="flex flex-wrap items-center gap-2">
						<Button href={routes.pricing()} variant="primary" size="sm"> Calendario </Button>
						<Button
							href={routes.ratePlanPolicies(String(row.ratePlanId))}
							variant="secondary"
							size="sm"
						>
							Condiciones
						</Button>
						<Button href={`${routes.ratesMultiCalendar()}?tab=rules`} variant="secondary" size="sm">
							Multicalendario
						</Button>
					</div>
				</div>

				<div class="grid gap-3 md:grid-cols-4">
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
						<p class="text-xs uppercase tracking-wide text-slate-500">Precio base</p>
						<p class="mt-1 text-lg font-semibold text-slate-950">
							{loaded.initialCurrency}
							{loaded.initialBasePrice || "Sin configurar"}
						</p>
						<p class="mt-1 text-xs text-slate-500">Punto de partida de esta tarifa.</p>
					</div>
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
						<p class="text-xs uppercase tracking-wide text-slate-500">Condiciones</p>
						<p class="mt-1 text-lg font-semibold text-slate-950">
							{policyCoverageDone}/4
						</p>
						<p class="mt-1 text-xs text-slate-500">
							{
								policyReady
									? "Contrato listo para vender."
									: "No lista para vender por contrato incompleto."
							}
						</p>
					</div>
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
						<p class="text-xs uppercase tracking-wide text-slate-500">Reglas de venta</p>
						<p class="mt-1 text-lg font-semibold text-slate-950">{restrictionCount}</p>
						<p class="mt-1 text-xs text-slate-500">
							{restrictionCount > 0 ? "Hay controles activos." : "Sin controles activos."}
						</p>
					</div>
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
						<p class="text-xs uppercase tracking-wide text-slate-500">Ayudas recurrentes</p>
						<p class="mt-1 text-lg font-semibold text-slate-950">
							{row.summary?.priceRulesCount ?? 0}
						</p>
						<p class="mt-1 text-xs text-slate-500">Actúan después sobre el calendario.</p>
					</div>
				</div>

				<p class="rounded-lg border border-slate-200 bg-white p-3 text-sm text-slate-600">
					{row.policySummary ?? "Sin resumen de condiciones todavía."}
				</p>

				<div
					class:list={[
						"rounded-lg border p-4",
						policyReady
							? "border-emerald-200 bg-emerald-50 text-emerald-900"
							: "border-rose-200 bg-rose-50 text-rose-900",
					]}
					data-rate-plan-contract-lock
				>
					<p class="text-sm font-semibold">
						{policyReady ? "Tarifa lista por contrato" : "Tarifa no lista para vender"}
					</p>
					<p class="mt-1 text-sm">
						{
							policyReady
								? "Las condiciones que verá el huésped están completas. Puedes revisarlas o cambiarlas desde esta tarifa."
								: "Completa las condiciones obligatorias antes de permitir venta pública de esta tarifa."
						}
					</p>
					{
						policyMissingCategories.length > 0 && (
							<ul class="mt-2 list-disc space-y-1 pl-5 text-sm">
								{policyMissingCategories.map((category) => (
									<li>Falta {policyCategoryLabels[category] ?? category}</li>
								))}
							</ul>
						)
					}
					<div class="mt-3">
						<Button
							href={routes.ratePlanPolicies(String(row.ratePlanId))}
							variant={policyReady ? "secondary" : "primary"}
							size="sm"
						>
							Revisar contrato de tarifa
						</Button>
					</div>
				</div>

				<details class="rounded-lg border border-slate-200 bg-slate-50 p-4">
					<summary class="cursor-pointer text-sm font-semibold text-slate-800">
						Editar precio base
					</summary>
					<div class="mt-4">
						<RatePlanPricingSurface
							ratePlanId={String(row.ratePlanId)}
							initialCurrency={loaded.initialCurrency}
							initialBasePrice={loaded.initialBasePrice}
							backHref={routes.ratePlansList()}
						/>
					</div>
				</details>

				<details class="rounded-lg border border-slate-200 bg-slate-50 p-4">
					<summary class="cursor-pointer text-sm font-semibold text-slate-800">
						Editar datos de tarifa
					</summary>
					<form
						class="mt-4 space-y-4"
						data-rate-plan-edit-form
						data-rate-plan-id={String(row.ratePlanId)}
					>
						<div class="grid gap-3 md:grid-cols-2">
							<label class="space-y-1 text-sm">
								<span class="font-medium text-slate-700">Nombre visible</span>
								<input
									name="name"
									class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm text-slate-900"
									value={row.ratePlanName}
									required
								/>
							</label>
							<label class="space-y-1 text-sm">
								<span class="font-medium text-slate-700">Descripción interna</span>
								<input
									name="description"
									class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm text-slate-900"
									value={row.description ?? ""}
								/>
							</label>
						</div>
						<label class="flex items-center gap-2 text-sm text-slate-700">
							<input name="isActive" type="checkbox" class="h-4 w-4" checked={row.isActive} />
							Tarifa activa
						</label>
						<label class="flex items-center gap-2 text-sm text-slate-700">
							<input name="isDefault" type="checkbox" class="h-4 w-4" checked={row.isDefault} />
							Tarifa principal de la habitación
						</label>
						<div class="flex items-center justify-between gap-3">
							<p class="text-sm text-slate-500" data-rate-plan-edit-feedback>
								Las reglas y condiciones se editan en sus controles propios.
							</p>
							<button
								type="submit"
								class="inline-flex h-10 items-center justify-center rounded-lg bg-slate-950 px-4 text-sm font-semibold text-white hover:bg-slate-800"
								>Guardar</button
							>
						</div>
					</form>
				</details>
			</Card>
		</Section>
	</div>
</WorkspaceLayout>

<script>
	document.querySelectorAll<HTMLFormElement>("[data-rate-plan-edit-form]").forEach((form) => {
		form.addEventListener("submit", async (event) => {
			event.preventDefault()
			const feedback = form.querySelector("[data-rate-plan-edit-feedback]")
			const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]')
			const formData = new FormData(form)
			const payload = {
				id: form.dataset.ratePlanId,
				name: String(formData.get("name") || ""),
				description: String(formData.get("description") || ""),
				isActive: Boolean(formData.get("isActive")),
				isDefault: Boolean(formData.get("isDefault")),
			}
			if (feedback) feedback.textContent = "Guardando..."
			submit?.setAttribute("disabled", "true")
			try {
				const response = await fetch("/api/rateplans/update", {
					method: "PUT",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				})
				const result = await response.json().catch(() => null)
				if (!response.ok) throw new Error(result?.error || "No se pudo guardar la tarifa")
				window.location.reload()
			} catch (error) {
				if (feedback) {
					feedback.textContent =
						error instanceof Error ? error.message : "No se pudo guardar la tarifa"
				}
				submit?.removeAttribute("disabled")
			}
		})
	})
</script>
