---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Input from "@/components/ui/Input.astro"
import RatePlanPoliciesSurface from "@/components/policy/RatePlanPoliciesSurface.astro"
import RatePlanPricingSurface from "@/components/pricing/RatePlanPricingSurface.astro"
import SegmentedControl from "@/components/ui/SegmentedControl.astro"
import Textarea from "@/components/ui/Textarea.astro"
import { Hotel } from "@lucide/astro"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import {
	buildAddRoomHref,
	getNextAddRoomStep,
	resolveAddRoomPlaybookFromUrl,
} from "@/lib/playbook/add-room"
import {
	getNextLaunchStep,
	resolveLaunchPlaybookFromUrl,
} from "@/lib/playbook/launch-accommodation"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import { loadRatePlanPoliciesData } from "@/lib/policies/loadRatePlanPoliciesData"
import { loadRatePlanPricingData } from "@/lib/pricing/loadRatePlanPricingData"
import { getRatePlanRemovalReadiness } from "@/lib/rates/getRatePlanRemovalReadiness"
import { loadRatePlanReadModelById } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { REQUIRED_POLICY_CATEGORIES, resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

const professionalModeCookie = getProfessionalModeCookiePreference(Astro.request)
const sidebarData = await getProviderSidebarData(auth.providerId, {
	userId: auth.user.id,
	professionalToolsEnabled:
		typeof professionalModeCookie === "boolean" ? professionalModeCookie : undefined,
})
const isProfessionalMode = sidebarData.disclosureMode !== "small-provider"

const ratePlanId = String(Astro.params.ratePlanId ?? "").trim()
if (!ratePlanId) return Astro.redirect(routes.rates())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const ratePlanDetailViews = ["conditions", "price", "details"] as const
type RatePlanDetailView = (typeof ratePlanDetailViews)[number]
const requestedView = String(Astro.url.searchParams.get("vista") ?? "conditions")
const activeView: RatePlanDetailView = ratePlanDetailViews.includes(
	requestedView as RatePlanDetailView
)
	? (requestedView as RatePlanDetailView)
	: "conditions"

const [row, loadedRatePlan, loadedPolicies] = await Promise.all([
	loadRatePlanReadModelById({
		request: Astro.request,
		ratePlanId,
		checkIn,
		checkOut,
		channel: "web",
	}),
	loadRatePlanPricingData({ request: Astro.request, ratePlanId }),
	loadRatePlanPoliciesData({ request: Astro.request, ratePlanId, checkIn, checkOut }),
])

if (!row) {
	return new Response("Tarifa no encontrada", { status: 404 })
}

if ("redirectTo" in loadedRatePlan) return Astro.redirect(loadedRatePlan.redirectTo)
const { loaded } = loadedRatePlan
if ("redirectTo" in loadedPolicies) return Astro.redirect(loadedPolicies.redirectTo)
const { context, policyPlans } = loadedPolicies

const policyCoverageDone = Number(row.policyCoverage?.coveredCategories ?? 0)
const removalReadiness = await getRatePlanRemovalReadiness({
	ratePlanId,
	variantId: String(row.variantId),
	isActive: Boolean(row.isActive),
	isDefault: Boolean(row.isDefault),
})
const viewTitles = {
	conditions: `Condiciones tarifarias de ${row.ratePlanName}`,
	price: `Precio base de ${row.ratePlanName}`,
	details: `Datos de ${row.ratePlanName}`,
} as const
const viewDescriptions = {
	conditions:
		"Define lo que verá y aceptará el huésped antes de reservar. Los cambios se aplican a reservas futuras.",
	price: "Ajusta el precio base de referencia. Los cambios por fecha se hacen desde el calendario.",
	details: "Gestiona el nombre visible, estado comercial y configuración principal de esta tarifa.",
} as const
const tabs = [
	{ id: "conditions", label: "Condiciones", meta: `${policyCoverageDone}/4` },
	{
		id: "price",
		label: "Precio base",
		meta: Number(String(loaded.initialBasePrice ?? 0)) > 0 ? "Listo" : "Falta",
	},
	{ id: "details", label: "Datos de tarifa", meta: row.isActive ? "Activa" : "Inactiva" },
]
const calendarHref = `${routes.calendar()}?ratePlanId=${encodeURIComponent(ratePlanId)}&focus=price`

const addRoomPlaybook = resolveAddRoomPlaybookFromUrl(Astro.url)
const launchPlaybook = resolveLaunchPlaybookFromUrl(Astro.url)
const flow = Astro.url.searchParams.get("flow")
if (!addRoomPlaybook.active && flow === "add-room") {
	return Astro.redirect(
		buildAddRoomHref(
			`${routes.ratePlanDetail(ratePlanId)}?vista=conditions&variantId=${encodeURIComponent(String(row.variantId))}`,
			"conditions"
		)
	)
}
if (!launchPlaybook.active && flow === "create") {
	const params = new URLSearchParams(Astro.url.searchParams)
	params.set("playbook", "launch")
	params.set("step", "conditions")
	if (!params.get("variantId")) params.set("variantId", String(row.variantId))
	return Astro.redirect(`${routes.ratePlanDetail(ratePlanId)}?${params.toString()}`)
}
const addRoomCtx = {
	productId: String(row.productId),
	variantId: String(row.variantId),
	ratePlanId,
}
const launchCtx = {
	productId: String(row.productId),
	isHotel: true,
	variantId: String(row.variantId),
	ratePlanId,
}
const addRoomContinueHref = addRoomPlaybook.active
	? (getNextAddRoomStep(addRoomPlaybook.stepId ?? "conditions", addRoomCtx)?.buildHref(
			addRoomCtx
		) ?? null)
	: null
const launchContinueHref = launchPlaybook.active
	? (getNextLaunchStep(launchPlaybook.stepId ?? "conditions", launchCtx)?.buildHref(launchCtx) ??
		null)
	: null
const activePlaybook = addRoomPlaybook.active ? "add-room" : launchPlaybook.active ? "launch" : null
const isPlaybookMode = Boolean(activePlaybook)
const effectiveActiveView = isPlaybookMode ? "conditions" : activeView
const Layout = activePlaybook ? PlaybookLayout : WorkspaceLayout
const layoutProps =
	activePlaybook === "add-room"
		? {
				title: `Tarifa · ${row.ratePlanName}`,
				playbookId: "add-room" as const,
				active: true,
				stepId: addRoomPlaybook.stepId ?? "conditions",
				productId: addRoomCtx.productId,
				variantId: addRoomCtx.variantId,
				ratePlanId,
				isHotel: true,
				continueHref: addRoomContinueHref,
				continueLabel: "Confirmar condiciones y continuar →",
			}
		: activePlaybook === "launch"
			? {
					title: `Tarifa · ${row.ratePlanName}`,
					playbookId: "launch" as const,
					active: true,
					stepId: launchPlaybook.stepId ?? "conditions",
					productId: launchCtx.productId,
					variantId: launchCtx.variantId,
					ratePlanId,
					isHotel: true,
					continueHref: launchContinueHref,
					continueLabel: "Confirmar condiciones y continuar →",
				}
			: { title: `Tarifa · ${row.ratePlanName}` }
---

<Layout {...layoutProps}>
	<div class="space-y-5">
		<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
			<div class="space-y-1.5">
				<p
					class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400"
				>
					{
						isPlaybookMode ? (
							<>
								<Hotel class="h-4 w-4" />
								{row.productName} · Nueva habitación
							</>
						) : (
							<>
								<Hotel class="h-4 w-4" />
								{row.productName} · {row.variantName}
							</>
						)
					}
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">
					{isPlaybookMode ? "Condiciones de la tarifa" : viewTitles[effectiveActiveView]}
				</h1>
				<p class="max-w-2xl text-sm leading-6 text-slate-300">
					{
						isPlaybookMode
							? "Creamos condiciones iniciales para esta tarifa. Revísalas o ajústalas antes de abrir disponibilidad."
							: viewDescriptions[effectiveActiveView]
					}
				</p>
			</div>
			{
				isPlaybookMode ? null : (
					<div class="flex flex-wrap gap-2">
						<Button href={routes.rates()} variant="secondary">
							Volver a tarifas
						</Button>
						<Button href={calendarHref} variant="primary">
							Calendario
						</Button>
					</div>
				)
			}
		</header>

		<section
			class:list={[
				"fastt-workspace-panel overflow-hidden text-slate-900",
				isPlaybookMode ? "bg-white" : "",
			]}
		>
			{
				isPlaybookMode ? null : (
					<div
						class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 px-4 pt-4"
						aria-label="Configurar tarifa"
						data-rate-plan-tabs
					>
						<SegmentedControl class="mb-3" aria-label="Configurar tarifa">
							{tabs.map((tab) => (
								<a
									href={`?vista=${tab.id}`}
									data-rate-plan-tab={tab.id}
									aria-current={effectiveActiveView === tab.id ? "page" : undefined}
									data-active={effectiveActiveView === tab.id ? "true" : "false"}
									class={`fastt-segmented-item px-3 py-2 text-sm font-semibold whitespace-nowrap ${
										effectiveActiveView === tab.id
											? ""
											: "text-slate-500 hover:bg-white/70 hover:text-slate-900"
									}`}
								>
									{tab.label} <span class="ml-1 text-xs opacity-70">{tab.meta}</span>
								</a>
							))}
						</SegmentedControl>
						<p class="pb-3 text-xs text-slate-500">Configuración de la tarifa</p>
					</div>
				)
			}

			<div
				class={effectiveActiveView === "conditions"
					? isPlaybookMode
						? "px-5"
						: "p-5"
					: "hidden p-5"}
				data-rate-plan-panel="conditions"
			>
				<RatePlanPoliciesSurface
					title={viewTitles.conditions}
					description={isPlaybookMode
						? "Revisa las condiciones iniciales. Puedes cambiarlas ahora o confirmarlas para continuar."
						: "Define lo que verá y aceptará el huésped antes de reservar. Los cambios se aplican a reservas futuras."}
					policyPlans={policyPlans}
					checkIn={checkIn}
					checkOut={checkOut}
					requiredCategories={[...REQUIRED_POLICY_CATEGORIES]}
					productId={context.productId}
					isProfessionalMode={isProfessionalMode}
					showPlanSummary={false}
					showHeader={false}
				/>
			</div>

			{
				isPlaybookMode ? null : (
					<div
						class={effectiveActiveView === "price" ? "p-5" : "hidden p-5"}
						data-rate-plan-panel="price"
					>
						<div class="mx-auto max-w-2xl space-y-1">
							<h2 class="text-xl font-semibold text-slate-950">Editar precio base</h2>
							<p class="pb-4 text-sm text-slate-500">
								Define el punto de partida de esta tarifa. Los cambios por fecha se hacen en el
								calendario.
							</p>
							<RatePlanPricingSurface
								ratePlanId={String(row.ratePlanId)}
								initialCurrency={loaded.initialCurrency}
								initialBasePrice={loaded.initialBasePrice}
								backHref={routes.rates()}
							/>
						</div>
					</div>
				)
			}

			{
				isPlaybookMode ? null : (
					<div
						class={effectiveActiveView === "details" ? "p-5" : "hidden p-5"}
						data-rate-plan-panel="details"
					>
						<form
							class="mx-auto max-w-2xl space-y-5"
							data-rate-plan-edit-form
							data-rate-plan-id={String(row.ratePlanId)}
						>
							<input type="hidden" name="isActive" value={row.isActive ? "true" : ""} />
							<div>
								<h2 class="text-xl font-semibold text-slate-950">Editar datos de tarifa</h2>
								<p class="mt-1 text-sm text-slate-500">
									Identidad y estado comercial de esta tarifa.
								</p>
							</div>
							<label class="block space-y-1.5 text-sm">
								<span class="font-medium text-slate-700">Nombre visible</span>
								<Input name="name" value={row.ratePlanName} required />
							</label>
							<label class="block space-y-1.5 text-sm">
								<span class="font-medium text-slate-700">Descripción interna</span>
								<Textarea name="description" rows="3" value={row.description ?? ""} />
							</label>
							<div class="fastt-soft-box divide-y divide-slate-100 border border-slate-200">
								<label class="flex items-center justify-between gap-4 p-4 text-sm text-slate-700">
									<span>
										<strong class="block text-slate-950">Tarifa principal</strong>Referencia de esta
										habitación.
									</span>
									<input name="isDefault" type="checkbox" class="size-4" checked={row.isDefault} />
								</label>
							</div>
							<div class="flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-4">
								<p class="text-sm text-slate-500" data-rate-plan-edit-feedback />
								<Button type="submit">Guardar cambios</Button>
							</div>
						</form>

						<div class="mx-auto mt-8 max-w-2xl space-y-6 border-t border-slate-200 pt-6">
							<section class="flex flex-wrap items-center justify-between gap-4">
								<div>
									<div class="flex items-center gap-2">
										<h3 class="font-semibold text-slate-950">Estado de venta</h3>
										<Badge variant={row.isActive ? "success" : "neutral"}>
											{row.isActive ? "Activa" : "Inactiva"}
										</Badge>
									</div>
									<p class="mt-1 max-w-xl text-sm text-slate-500">
										{row.isActive
											? "Desactivar detiene reservas nuevas sin borrar precio, condiciones ni historial."
											: "La tarifa está fuera de venta y puede reactivarse conservando su configuración."}
									</p>
									{row.isActive && row.isDefault && removalReadiness.activeAlternatives > 0 && (
										<p class="mt-2 text-sm text-amber-700">
											Designa otra tarifa principal antes de desactivar esta.
										</p>
									)}
								</div>
								<Button
									type="button"
									variant="secondary"
									data-rate-plan-toggle-status
									data-next-active={row.isActive ? "false" : "true"}
									disabled={
										row.isActive && row.isDefault && removalReadiness.activeAlternatives > 0
									}
								>
									{row.isActive ? "Desactivar tarifa" : "Activar tarifa"}
								</Button>
							</section>

							<section
								id="eliminar-tarifa"
								class="rounded-lg border border-rose-200 bg-rose-50 p-4"
							>
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div>
										<h3 class="font-semibold text-rose-950">Eliminar tarifa</h3>
										<p class="mt-1 max-w-xl text-sm text-rose-800">
											Solo puede eliminarse si está inactiva y nunca tuvo reservas ni retenciones.
										</p>
										{removalReadiness.blockers.length > 0 && (
											<ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-800">
												{removalReadiness.blockers.map((blocker) => (
													<li>{blocker}</li>
												))}
											</ul>
										)}
									</div>
									<Button
										type="button"
										variant="danger"
										data-open-rate-plan-delete
										disabled={!removalReadiness.canDelete}
									>
										Eliminar definitivamente
									</Button>
								</div>
							</section>
						</div>
					</div>
				)
			}
		</section>
	</div>

	{
		isPlaybookMode ? null : (
			<dialog
				class="calendar-dialog fastt-dialog m-auto w-[min(520px,calc(100%-2rem))] border bg-white p-0 text-slate-900"
				data-rate-plan-delete-dialog
			>
				<form
					class="space-y-5 p-5"
					data-rate-plan-delete-form
					data-rate-plan-id={ratePlanId}
					data-rate-plan-name={row.ratePlanName}
				>
					<div>
						<h2 class="text-lg font-semibold text-slate-950">Eliminar {row.ratePlanName}</h2>
						<p class="mt-2 text-sm leading-6 text-slate-600">
							Se eliminarán su precio, reglas y asignaciones. Esta acción no puede deshacerse.
						</p>
					</div>
					<label class="block space-y-1.5 text-sm">
						<span class="font-medium">
							Escribe <strong>{row.ratePlanName}</strong> para confirmar
						</span>
						<Input data-rate-plan-delete-confirmation autocomplete="off" />
					</label>
					<p class="text-sm text-rose-700" data-rate-plan-delete-feedback />
					<div class="flex justify-end gap-2 border-t border-slate-200 pt-4">
						<Button type="button" variant="secondary" data-close-rate-plan-delete>
							Cancelar
						</Button>
						<Button type="submit" variant="danger" data-confirm-rate-plan-delete disabled>
							Eliminar tarifa
						</Button>
					</div>
				</form>
			</dialog>
		)
	}
</Layout>

<script>
	const ratePlanTabs = Array.from(
		document.querySelectorAll<HTMLAnchorElement>("[data-rate-plan-tab]")
	)
	const ratePlanPanels = Array.from(
		document.querySelectorAll<HTMLElement>("[data-rate-plan-panel]")
	)

	function renderRatePlanTab(view: string, updateUrl = false) {
		for (const panel of ratePlanPanels) {
			panel.classList.toggle("hidden", panel.dataset.ratePlanPanel !== view)
		}
		for (const tab of ratePlanTabs) {
			const active = tab.dataset.ratePlanTab === view
			tab.dataset.active = active ? "true" : "false"
			tab.classList.toggle("text-slate-500", !active)
			tab.classList.toggle("hover:bg-white/70", !active)
			tab.classList.toggle("hover:text-slate-900", !active)
			if (active) tab.setAttribute("aria-current", "page")
			else tab.removeAttribute("aria-current")
		}
		if (updateUrl) {
			const url = new URL(window.location.href)
			url.searchParams.set("vista", view)
			window.history.pushState({ ratePlanView: view }, "", url)
		}
	}

	for (const tab of ratePlanTabs) {
		tab.addEventListener("click", (event) => {
			event.preventDefault()
			renderRatePlanTab(String(tab.dataset.ratePlanTab ?? "conditions"), true)
		})
	}
	window.addEventListener("popstate", () => {
		renderRatePlanTab(new URL(window.location.href).searchParams.get("vista") ?? "conditions")
	})

	const editForm = document.querySelector<HTMLFormElement>("[data-rate-plan-edit-form]")
	const statusButton = document.querySelector<HTMLButtonElement>("[data-rate-plan-toggle-status]")
	statusButton?.addEventListener("click", async () => {
		if (!editForm) return
		const feedback = editForm.querySelector<HTMLElement>("[data-rate-plan-edit-feedback]")
		const formData = new FormData(editForm)
		const nextActive = statusButton.dataset.nextActive === "true"
		statusButton.disabled = true
		if (feedback)
			feedback.textContent = nextActive ? "Activando tarifa..." : "Desactivando tarifa..."
		try {
			const response = await fetch("/api/rateplans/update", {
				method: "PUT",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					id: editForm.dataset.ratePlanId,
					name: String(formData.get("name") || ""),
					description: String(formData.get("description") || ""),
					isActive: nextActive,
					isDefault: Boolean(formData.get("isDefault")),
				}),
			})
			const result = await response.json().catch(() => null)
			if (!response.ok) throw new Error(result?.error || "No se pudo cambiar el estado")
			window.location.reload()
		} catch (error) {
			if (feedback)
				feedback.textContent =
					error instanceof Error ? error.message : "No se pudo cambiar el estado"
			statusButton.disabled = false
		}
	})

	const deleteDialog = document.querySelector<HTMLDialogElement>("[data-rate-plan-delete-dialog]")
	const deleteForm = document.querySelector<HTMLFormElement>("[data-rate-plan-delete-form]")
	const deleteInput = deleteForm?.querySelector<HTMLInputElement>(
		"[data-rate-plan-delete-confirmation]"
	)
	const deleteSubmit = deleteForm?.querySelector<HTMLButtonElement>(
		"[data-confirm-rate-plan-delete]"
	)
	document
		.querySelector("[data-open-rate-plan-delete]")
		?.addEventListener("click", () => deleteDialog?.showModal())
	if (
		new URL(window.location.href).searchParams.get("accion") === "eliminar" &&
		!document.querySelector<HTMLButtonElement>("[data-open-rate-plan-delete]")?.disabled
	) {
		deleteDialog?.showModal()
	}
	document
		.querySelector("[data-close-rate-plan-delete]")
		?.addEventListener("click", () => deleteDialog?.close())
	deleteDialog?.addEventListener("click", (event) => {
		if (event.target === deleteDialog) deleteDialog.close()
	})
	deleteInput?.addEventListener("input", () => {
		if (deleteSubmit)
			deleteSubmit.disabled =
				deleteInput.value.trim() !== String(deleteForm?.dataset.ratePlanName ?? "")
	})
	deleteForm?.addEventListener("submit", async (event) => {
		event.preventDefault()
		if (!deleteSubmit || deleteSubmit.disabled) return
		const feedback = deleteForm.querySelector<HTMLElement>("[data-rate-plan-delete-feedback]")
		deleteSubmit.disabled = true
		if (feedback) feedback.textContent = "Eliminando tarifa..."
		try {
			const response = await fetch("/api/rateplans/delete", {
				method: "DELETE",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ id: deleteForm.dataset.ratePlanId }),
			})
			const result = await response.json().catch(() => null)
			if (!response.ok) throw new Error(result?.error || "No se pudo eliminar la tarifa")
			window.location.href = "/rates/plans/manage?vista=all"
		} catch (error) {
			if (feedback)
				feedback.textContent =
					error instanceof Error ? error.message : "No se pudo eliminar la tarifa"
			deleteSubmit.disabled = false
		}
	})

	document.querySelectorAll<HTMLFormElement>("[data-rate-plan-edit-form]").forEach((form) => {
		form.addEventListener("submit", async (event) => {
			event.preventDefault()
			const feedback = form.querySelector("[data-rate-plan-edit-feedback]")
			const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]')
			const formData = new FormData(form)
			const payload = {
				id: form.dataset.ratePlanId,
				name: String(formData.get("name") || ""),
				description: String(formData.get("description") || ""),
				isActive: Boolean(formData.get("isActive")),
				isDefault: Boolean(formData.get("isDefault")),
			}
			if (feedback) feedback.textContent = "Guardando..."
			submit?.setAttribute("disabled", "true")
			try {
				const response = await fetch("/api/rateplans/update", {
					method: "PUT",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				})
				const result = await response.json().catch(() => null)
				if (!response.ok) throw new Error(result?.error || "No se pudo guardar la tarifa")
				window.location.reload()
			} catch (error) {
				if (feedback) {
					feedback.textContent =
						error instanceof Error ? error.message : "No se pudo guardar la tarifa"
				}
				submit?.removeAttribute("disabled")
			}
		})
	})
</script>
