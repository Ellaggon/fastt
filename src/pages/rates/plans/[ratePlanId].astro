---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { loadRatePlanPricingData } from "@/lib/pricing/loadRatePlanPricingData"
import { loadRatePlanReadModelById } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())
void auth

const ratePlanId = String(Astro.params.ratePlanId ?? "").trim()
if (!ratePlanId) return Astro.redirect(routes.ratePlansHub())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const row = await loadRatePlanReadModelById({
	request: Astro.request,
	ratePlanId,
	checkIn,
	checkOut,
	channel: "web",
})

if (!row) {
	return new Response("Rate plan no encontrado", { status: 404 })
}

const loadedRatePlan = await loadRatePlanPricingData({
	request: Astro.request,
	ratePlanId,
})
if ("redirectTo" in loadedRatePlan) return Astro.redirect(loadedRatePlan.redirectTo)
const { loaded } = loadedRatePlan

const policyCoverageDone = Number(row.policyCoverage?.coveredCategories ?? 0)
const policyReady = Boolean(row.policyCoverage?.isComplete)
const hasBasePrice = Number(String(loaded.initialBasePrice ?? 0)) > 0
---

<WorkspaceLayout title="Rate Plan · Detalle">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Nueva arquitectura (fase 1)
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Detalle de Rate Plan</h1>
				<p class="text-sm text-slate-300">
					Hub operativo de la tarifa: estado comercial, precio y condiciones.
				</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.ratePlansHub()} variant="secondary">Volver al hub</Button>
				<Button href={routes.ratePlanPricing(String(row.ratePlanId))} variant="secondary"
					>Editar precios</Button
				>
				<Button href={routes.ratePlanPolicies(String(row.ratePlanId))} variant="secondary"
					>Gestionar condiciones</Button
				>
			</div>
		</header>

		<Section title="Resumen comercial" description="Estado de operación de esta tarifa.">
			<div class="grid gap-4 md:grid-cols-2">
				<Card className="bg-white text-slate-800">
					<p class="text-xs uppercase tracking-wide text-slate-500">Condiciones de reserva</p>
					<p class="mt-2 text-base font-semibold text-slate-900">
						{policyReady ? "Listas para vender" : "Faltan condiciones por completar"}
					</p>
					<p class="mt-1 text-sm text-slate-600">Cobertura: {policyCoverageDone}/4 categorías</p>
					<div class="mt-3">
						<Badge variant={policyReady ? "success" : "warning"}>
							{policyReady ? "Condiciones completas" : "Configuración incompleta"}
						</Badge>
					</div>
				</Card>
				<Card className="bg-white text-slate-800">
					<p class="text-xs uppercase tracking-wide text-slate-500">Precio base</p>
					<p class="mt-2 text-base font-semibold text-slate-900">
						{loaded.initialCurrency}
						{loaded.initialBasePrice || "No configurada"}
					</p>
					<p class="mt-1 text-sm text-slate-600">
						{hasBasePrice ? "Precio base operativo" : "Tarifa pendiente de precio base"}
					</p>
					<div class="mt-3">
						<Badge variant={hasBasePrice ? "success" : "warning"}>
							{hasBasePrice ? "Precio listo" : "Precio pendiente"}
						</Badge>
					</div>
				</Card>
			</div>
		</Section>

		<Section
			title="Datos de la tarifa"
			description="Información comercial relevante para identificar la tarifa."
		>
			<Card className="bg-white text-slate-800">
				<div class="grid gap-4 md:grid-cols-2">
					<div>
						<p class="text-xs uppercase tracking-wide text-slate-500">Rate Plan</p>
						<p class="mt-1 text-lg font-semibold">{row.ratePlanName}</p>
						<p class="text-sm text-slate-600">
							{row.policySummary ?? "Sin resumen de condiciones"}
						</p>
					</div>
					<div class="space-y-1">
						<p class="text-sm text-slate-700">
							Producto: <span class="font-medium">{row.productName}</span>
						</p>
						<p class="text-sm text-slate-700">
							Variante: <span class="font-medium">{row.variantName}</span>
						</p>
					</div>
				</div>
				<div class="mt-4 flex flex-wrap items-center gap-2">
					<Badge variant={row.isActive ? "success" : "warning"}
						>{row.isActive ? "Activo" : "Inactivo"}</Badge
					>
					{row.isDefault && <Badge variant="info">Default</Badge>}
					<Badge variant="neutral">Reglas de precio: {row.summary?.priceRulesCount ?? 0}</Badge>
					<Badge variant="neutral"
						>Restricciones activas: {row.summary?.activeRestrictionsCount ?? 0}</Badge
					>
				</div>
			</Card>
		</Section>
	</div>
</WorkspaceLayout>
