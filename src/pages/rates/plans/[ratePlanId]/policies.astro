---
import RatePlanPoliciesSurface from "@/components/policy/RatePlanPoliciesSurface.astro"
import Button from "@/components/ui/Button.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { loadRatePlanPoliciesData } from "@/lib/policies/loadRatePlanPoliciesData"
import { routes } from "@/lib/routes"
import {
	handleRatePlanPoliciesPost,
	REQUIRED_POLICY_CATEGORIES,
	resolvePolicyDateRange,
} from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())
const { user } = auth

const ratePlanId = String(Astro.params.ratePlanId ?? "").trim()
if (!ratePlanId) return Astro.redirect(routes.ratePlansHub())
const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const loadedPolicies = await loadRatePlanPoliciesData({
	request: Astro.request,
	ratePlanId,
	checkIn,
	checkOut,
})
if ("redirectTo" in loadedPolicies) return Astro.redirect(loadedPolicies.redirectTo)
const { context, selectedRatePlans, policyPlans, wizardPlans } = loadedPolicies

if (Astro.request.method === "POST") {
	return handleRatePlanPoliciesPost({
		request: Astro.request,
		ratePlans: selectedRatePlans,
		userId: user.id,
	})
}
---

<WorkspaceLayout title="Rate Plan · Condiciones">
	<section class="space-y-8 text-neutral-100">
		<header class="space-y-2">
			<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Rate Plans Hub</p>
			<h1 class="text-3xl font-semibold text-slate-100">Condiciones del rate plan</h1>
			<p class="text-sm text-slate-400">
				{context.productName} · {context.variantName} · {context.ratePlanName}
			</p>
			<div class="flex flex-wrap items-center gap-2 pt-2">
				<Button href={routes.ratePlansHub()} variant="secondary">Volver al hub</Button>
				<Button href={routes.ratePlanDetail(ratePlanId)} variant="secondary"
					>Volver al detalle</Button
				>
			</div>
		</header>

		<RatePlanPoliciesSurface
			title="Condiciones de reserva"
			description={`Cobertura contractual para ${context.ratePlanName} · ${checkIn} → ${checkOut}.`}
			policyPlans={policyPlans}
			wizardPlans={wizardPlans}
			checkIn={checkIn}
			checkOut={checkOut}
			requiredCategories={[...REQUIRED_POLICY_CATEGORIES]}
		/>
	</section>
</WorkspaceLayout>
