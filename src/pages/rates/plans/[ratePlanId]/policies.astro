---
import { routes } from "@/lib/routes"

const ratePlanId = String(Astro.params.ratePlanId ?? "").trim()
if (!ratePlanId) return Astro.redirect(routes.ratePlansList())

const target = new URL(routes.ratePlanPolicies(ratePlanId), Astro.url)
for (const [key, value] of Astro.url.searchParams) {
	if (key !== "vista") target.searchParams.set(key, value)
}

return Astro.redirect(`${target.pathname}${target.search}`, 308)
---
