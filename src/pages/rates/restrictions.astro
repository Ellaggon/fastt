---
import PricingAutomationPanel from "@/components/rates/PricingAutomationPanel.astro"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import {
	loadPricingAutomationSurface,
	type PricingAutomationTemplate,
} from "@/lib/pricing/pricingAutomationSurface"
import {
	createRestrictionsSurfaceRule,
	loadRestrictionsSurface,
	SELLABILITY_RULES,
	setRestrictionsSurfaceRuleActive,
	type RestrictionScope,
	type SellabilityRuleType,
} from "@/lib/rates/restrictionsSurface"
import { routes } from "@/lib/routes"
import { resolveVerticalVocabulary } from "@/lib/verticalVocabulary"
import { POST as createPricingRulePost } from "@/pages/api/pricing/rules/v2/create"
import { and, db, eq, PriceRule } from "astro:db"

type RuleTab =
	| "all"
	| "price"
	| "availability"
	| "arrival_departure"
	| "stay"
	| "booking_window"
	| "paused"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

const professionalModeCookie = getProfessionalModeCookiePreference(Astro.request)
const sidebarData = await getProviderSidebarData(auth.providerId, {
	userId: auth.user.id,
	professionalToolsEnabled:
		typeof professionalModeCookie === "boolean" ? professionalModeCookie : undefined,
})
if (sidebarData.disclosureMode === "small-provider") {
	const params = new URLSearchParams({ focus: "restrictions" })
	const ratePlanId = String(Astro.url.searchParams.get("ratePlanId") ?? "").trim()
	const variantId = String(Astro.url.searchParams.get("variantId") ?? "").trim()
	if (ratePlanId) params.set("ratePlanId", ratePlanId)
	if (variantId) params.set("variantId", variantId)
	return Astro.redirect(`${routes.pricing()}?${params.toString()}`)
}

let actionError: string | null = null
let actionErrorTitle = "No se pudo guardar la regla"

const mapTemplatePayload = (template: PricingAutomationTemplate, rawValue: number) => {
	const value =
		template.kind === "fixed_discount" ? -Math.abs(rawValue) : Math.max(0, Number(rawValue))
	return { type: template.internalType, value, contextKey: template.contextKey }
}

const eligibilityForForm = (kind: string, form: FormData): Record<string, number> => {
	if (kind === "early_bird") {
		const minLeadDays = Number(form.get("minLeadDays") ?? 30)
		if (!Number.isFinite(minLeadDays) || minLeadDays < 1) {
			throw new Error("Reserva anticipada necesita al menos 1 día de anticipación")
		}
		return { minLeadDays: Math.trunc(minLeadDays) }
	}
	if (kind === "last_minute") {
		const maxLeadDays = Number(form.get("maxLeadDays") ?? 3)
		if (!Number.isFinite(maxLeadDays) || maxLeadDays < 1) {
			throw new Error("Último minuto necesita una ventana de llegada de al menos 1 día")
		}
		return { maxLeadDays: Math.trunc(maxLeadDays) }
	}
	if (kind === "los_discount") {
		const minNights = Number(form.get("minNights") ?? 5)
		if (!Number.isFinite(minNights) || minNights < 1) {
			throw new Error("El descuento por estadía necesita al menos 1 noche")
		}
		return { minNights: Math.trunc(minNights) }
	}
	return {}
}

function jsonRequest(path: string, body: Record<string, unknown>) {
	const headers = new Headers({ "Content-Type": "application/json" })
	const cookie = Astro.request.headers.get("cookie")
	if (cookie) headers.set("cookie", cookie)
	return new Request(new URL(path, Astro.url), {
		method: "POST",
		headers,
		body: JSON.stringify(body),
	})
}

async function deletePriceRuleDirectly(ruleId: string, ratePlanId: string) {
	const existing = await db
		.select({ id: PriceRule.id })
		.from(PriceRule)
		.where(and(eq(PriceRule.id, ruleId), eq(PriceRule.ratePlanId, ratePlanId)))
		.get()
	if (!existing?.id) throw new Error("La regla de precio ya no existe o pertenece a otra tarifa")

	const statement = db
		.delete(PriceRule)
		.where(and(eq(PriceRule.id, ruleId), eq(PriceRule.ratePlanId, ratePlanId)))
	if (typeof (statement as any).run === "function") await (statement as any).run()
	else await statement
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData()
	const action = String(form.get("action") ?? "").trim()
	try {
		if (action === "create") {
			await createRestrictionsSurfaceRule(auth.providerId, form)
			return Astro.redirect(`${routes.rateRestrictions()}?tab=all&success=created`)
		}
		if (action === "create-batch") {
			const scope = String(form.get("scope") ?? "rate_plan").trim()
			const scopeIds = String(form.get("scopeIds") ?? "")
				.split(",")
				.map((value) => value.trim())
				.filter(Boolean)
			if (scope !== "rate_plan") throw new Error("La selección múltiple solo soporta tarifas")
			if (scopeIds.length === 0) throw new Error("Selecciona al menos una tarifa")
			for (const scopeId of scopeIds) {
				const item = new FormData()
				item.set("scope", scope)
				item.set("scopeId", scopeId)
				item.set("type", String(form.get("type") ?? ""))
				item.set("startDate", String(form.get("startDate") ?? ""))
				item.set("endDate", String(form.get("endDate") ?? ""))
				const value = String(form.get("value") ?? "").trim()
				if (value) item.set("value", value)
				for (const validDay of form.getAll("validDays")) item.append("validDays", validDay)
				await createRestrictionsSurfaceRule(auth.providerId, item)
			}
			return Astro.redirect(
				`${routes.rateRestrictions()}?tab=all&success=batch-created&count=${scopeIds.length}`
			)
		}
		if (action === "activate" || action === "deactivate") {
			const ruleId = String(form.get("ruleId") ?? "").trim()
			await setRestrictionsSurfaceRuleActive(auth.providerId, ruleId, action === "activate")
			return Astro.redirect(
				`${routes.rateRestrictions()}?tab=all&success=${action === "activate" ? "activated" : "deactivated"}`
			)
		}
		if (action === "create-pricing-automation") {
			const automation = await loadPricingAutomationSurface(auth.providerId)
			const ratePlanId = String(form.get("ratePlanId") ?? "").trim()
			const kind = String(form.get("kind") ?? "").trim()
			const template = automation.templates.find((item) => item.kind === kind)
			if (!template) throw new Error("Tipo de regla de precio no soportado")
			if (!automation.ratePlanOptions.some((item) => item.id === ratePlanId)) {
				throw new Error("La tarifa no está disponible para este proveedor")
			}
			const value = Number(form.get("value") ?? Number.NaN)
			if (!Number.isFinite(value) || value < 0) {
				throw new Error("El valor de la regla debe ser cero o mayor")
			}
			const priority = Number(form.get("priority") ?? 20)
			if (!Number.isFinite(priority) || priority < 0 || priority > 1000) {
				throw new Error("La prioridad debe estar entre 0 y 1000")
			}
			const dateFrom = String(form.get("dateFrom") ?? "").trim()
			const dateTo = String(form.get("dateTo") ?? "").trim()
			const mapped = mapTemplatePayload(template, value)
			const body: Record<string, unknown> = {
				ratePlanId,
				type: mapped.type,
				value: mapped.value,
				priority,
				contextKey: mapped.contextKey,
			}
			if (dateFrom) body.dateFrom = dateFrom
			if (dateTo) body.dateTo = dateTo
			Object.assign(body, eligibilityForForm(kind, form))

			const response = await createPricingRulePost({
				request: jsonRequest("/api/pricing/rules/v2/create", body),
				url: new URL("/api/pricing/rules/v2/create", Astro.url),
			} as any)
			if (!response.ok) {
				const payload = await response.json().catch(() => null)
				throw new Error(String(payload?.error ?? "No se pudo crear la regla de precio"))
			}
			return Astro.redirect(`${routes.rateRestrictions()}?tab=price&success=price-created`)
		}
		if (action === "delete-pricing-automation") {
			const automation = await loadPricingAutomationSurface(auth.providerId)
			const ruleId = String(form.get("ruleId") ?? "").trim()
			const ratePlanId = String(form.get("ratePlanId") ?? "").trim()
			if (!automation.rules.some((rule) => rule.id === ruleId && rule.ratePlanId === ratePlanId)) {
				throw new Error("La regla de precio no está disponible para este proveedor")
			}
			await deletePriceRuleDirectly(ruleId, ratePlanId)
			return Astro.redirect(`${routes.rateRestrictions()}?tab=price&success=price-deleted`)
		}
		actionError = "Acción de regla no soportada"
	} catch (error) {
		actionErrorTitle =
			action === "create-pricing-automation"
				? "No se pudo crear la regla de precio"
				: action === "delete-pricing-automation"
					? "No se pudo eliminar la regla de precio"
					: "No se pudo guardar la regla de venta"
		actionError = error instanceof Error ? error.message : "Falló la acción de regla"
	}
}

const requestedTab = String(Astro.url.searchParams.get("tab") ?? "all").trim() as RuleTab
const activeTab: RuleTab = [
	"all",
	"price",
	"availability",
	"arrival_departure",
	"stay",
	"booking_window",
	"paused",
].includes(requestedTab)
	? requestedTab
	: "all"

const tabTypeMap: Partial<Record<RuleTab, SellabilityRuleType[]>> = {
	availability: ["stop_sell"],
	arrival_departure: ["cta", "ctd"],
	stay: ["min_los", "max_los"],
	booking_window: ["min_lead_time", "max_lead_time"],
}

const filters = {
	productId: String(Astro.url.searchParams.get("productId") ?? "").trim() || undefined,
	variantId: String(Astro.url.searchParams.get("variantId") ?? "").trim() || undefined,
	ratePlanId: String(Astro.url.searchParams.get("ratePlanId") ?? "").trim() || undefined,
	status: (activeTab === "paused" ? "inactive" : "all") as "active" | "inactive" | "all",
	type:
		(String(Astro.url.searchParams.get("type") ?? "all").trim() as SellabilityRuleType | "all") ||
		"all",
}

const [surface, automationSurface] = await Promise.all([
	loadRestrictionsSurface(auth.providerId, filters),
	loadPricingAutomationSurface(auth.providerId),
])
const vocabulary = resolveVerticalVocabulary(surface.productTypes)
const success = String(Astro.url.searchParams.get("success") ?? "").trim()
const multiCalendarSource = String(Astro.url.searchParams.get("source") ?? "").trim()
const multiCalendarRatePlanIds = String(Astro.url.searchParams.get("ratePlanIds") ?? "")
	.split(",")
	.map((value) => value.trim())
	.filter(Boolean)
const multiCalendarFrom = String(Astro.url.searchParams.get("from") ?? "").trim()
const multiCalendarTo = String(Astro.url.searchParams.get("to") ?? "").trim()
const hasMultiCalendarContext =
	multiCalendarSource === "multi-calendar" &&
	multiCalendarRatePlanIds.length > 0 &&
	Boolean(multiCalendarFrom)

const automationTemplates = automationSurface.templates
const automationDefaultRatePlanId = automationSurface.ratePlanOptions[0]?.id ?? ""
const automationDefaultTemplate =
	automationTemplates.find((item) => item.kind === "percentage_discount") ??
	automationTemplates[0] ??
	automationSurface.templates[0]
const automationTemplateCatalog = automationSurface.templates.map((template) => ({
	kind: template.kind,
	label: template.label,
	shortLabel: template.shortLabel,
	description: template.description,
	internalType: template.internalType,
	defaultValue: template.defaultValue,
	valueSuffix: template.valueSuffix,
	contextKey: template.contextKey,
	eligibilityHint: template.eligibilityHint ?? "",
}))
const automationTemplateGroups = [
	{
		label: "Descuentos",
		templates: automationTemplates.filter((template) =>
			[
				"percentage_discount",
				"fixed_discount",
				"early_bird",
				"last_minute",
				"los_discount",
			].includes(template.kind)
		),
	},
	{
		label: "Aumentos",
		templates: automationTemplates.filter((template) =>
			["percentage_markup", "fixed_markup"].includes(template.kind)
		),
	},
	{
		label: "Precio fijo",
		templates: automationTemplates.filter((template) => template.kind === "manual_override"),
	},
].filter((group) => group.templates.length > 0)

const statusVariant = {
	active: "success",
	inactive: "neutral",
} as const

const ruleBadgeVariant: Record<string, "success" | "warning" | "info" | "neutral"> = {
	stop_sell: "warning",
	min_los: "info",
	max_los: "info",
	cta: "warning",
	ctd: "warning",
	min_lead_time: "neutral",
	max_lead_time: "neutral",
}

const scopeLabel: Record<RestrictionScope, string> = {
	product: vocabulary.scopeProduct,
	variant: vocabulary.scopeVariant,
	rate_plan: vocabulary.scopeRatePlan,
}

const successMessage: Record<string, string> = {
	"created": "Regla de venta creada.",
	"batch-created": "Reglas de venta creadas para la selección.",
	"activated": "Regla de venta activada.",
	"deactivated": "Regla de venta pausada.",
	"price-created": "Regla de precio creada.",
	"price-deleted": "Regla de precio eliminada.",
}

const tabs: Array<{ key: RuleTab; label: string; count?: number }> = [
	{ key: "all", label: "Todas", count: surface.rules.length + automationSurface.rules.length },
	{ key: "price", label: "Precio", count: automationSurface.rules.length },
	{ key: "availability", label: "Disponibilidad" },
	{ key: "arrival_departure", label: "Llegada/salida" },
	{ key: "stay", label: "Estadía" },
	{ key: "booking_window", label: "Ventana de reserva" },
	{ key: "paused", label: "Pausadas", count: surface.stats.inactiveRules },
]

function selected(value: string | undefined, expected: string): boolean {
	return String(value ?? "") === expected
}

const allowedTypes = tabTypeMap[activeTab]
const visibleRules = surface.rules.filter((rule) => {
	if (activeTab === "all" || activeTab === "paused") return true
	if (!allowedTypes) return true
	return allowedTypes.includes(rule.type)
})

const showPricePanel = activeTab === "price"
const showPriceSummary = activeTab === "all"
const showSellability = activeTab !== "price"
---

<WorkspaceLayout title="Reglas de venta">
	<div class="space-y-5">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Habitaciones y tarifas · Herramientas Pro
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Reglas de venta</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Automatiza precio y vendibilidad para temporadas, eventos y reglas recurrentes.
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				<Button href={`${routes.rateRestrictions()}?tab=price`} variant="primary">
					Crear regla
				</Button>
				<Button href={`${routes.ratesMultiCalendar()}?tab=rules`} variant="secondary">
					Multicalendario
				</Button>
				<Button href={`${routes.pricing()}?focus=restrictions`} variant="secondary">
					Ver calendario
				</Button>
			</div>
		</header>

		{
			actionError && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">{actionErrorTitle}</p>
					<p class="mt-1 text-sm">{actionError}</p>
				</Card>
			)
		}
		{
			successMessage[success] && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">{successMessage[success]}</p>
				</Card>
			)
		}
		{
			hasMultiCalendarContext && (
				<Card className="border-blue-200 bg-blue-50 text-blue-950">
					<div class="flex flex-wrap items-center justify-between gap-3">
						<div>
							<p class="text-sm font-semibold">Selección desde Multicalendario</p>
							<p class="mt-1 text-sm text-blue-900/80">
								{multiCalendarRatePlanIds.length}{" "}
								{multiCalendarRatePlanIds.length === 1 ? "tarifa" : "tarifas"} · {multiCalendarFrom}
								{multiCalendarTo && multiCalendarTo !== multiCalendarFrom
									? ` a ${multiCalendarTo}`
									: ""}
							</p>
						</div>
						<Button
							href={`${routes.ratesMultiCalendar()}?tab=rules&from=${encodeURIComponent(
								multiCalendarFrom
							)}&to=${encodeURIComponent(multiCalendarTo || multiCalendarFrom)}`}
							variant="secondary"
							size="sm"
						>
							Volver al multicalendario
						</Button>
					</div>
				</Card>
			)
		}

		<nav class="flex gap-2 overflow-x-auto rounded-lg border border-slate-200 bg-white p-1">
			{
				tabs.map((tab) => (
					<a
						href={`${routes.rateRestrictions()}?tab=${tab.key}`}
						class:list={[
							"whitespace-nowrap rounded-md px-3 py-2 text-sm font-semibold transition",
							activeTab === tab.key
								? "bg-slate-950 text-white"
								: "text-slate-600 hover:bg-slate-100 hover:text-slate-950",
						]}
					>
						{tab.label}
						{typeof tab.count === "number" ? (
							<span class="ml-1 opacity-70">{tab.count}</span>
						) : null}
					</a>
				))
			}
		</nav>

		{
			showPricePanel && (
				<PricingAutomationPanel
					automationSurface={automationSurface}
					automationTemplateCatalog={automationTemplateCatalog}
					automationTemplateGroups={automationTemplateGroups}
					automationDefaultTemplate={automationDefaultTemplate}
					automationDefaultRatePlanId={automationDefaultRatePlanId}
					statusVariant={statusVariant}
					formAction={`${routes.rateRestrictions()}?tab=price`}
				/>
			)
		}

		{
			showPriceSummary && (
				<Card className="space-y-3 bg-white text-slate-900">
					<div class="flex flex-wrap items-center justify-between gap-3">
						<div>
							<h2 class="text-lg font-semibold">Reglas de precio</h2>
							<p class="text-sm text-slate-500">
								{automationSurface.stats.activeRules} activas ·{" "}
								{automationSurface.stats.inactiveRules} inactivas
							</p>
						</div>
						<Button href={`${routes.rateRestrictions()}?tab=price`} variant="secondary" size="sm">
							Administrar
						</Button>
					</div>
					{automationSurface.rules.length ? (
						<div class="grid gap-3 lg:grid-cols-2">
							{automationSurface.rules.slice(0, 6).map((rule) => (
								<div class="rounded-lg border border-slate-200 p-3">
									<div class="flex flex-wrap items-center gap-2">
										<Badge variant={rule.status === "active" ? "success" : "neutral"}>
											{rule.statusLabel}
										</Badge>
										<Badge variant="info">{rule.kindLabel}</Badge>
									</div>
									<p class="mt-2 font-semibold text-slate-950">{rule.valueLabel}</p>
									<p class="mt-1 text-sm text-slate-600">
										{rule.productName} · {rule.variantName} · {rule.ratePlanName}
									</p>
									<p class="mt-1 text-xs text-slate-500">{rule.validityLabel}</p>
								</div>
							))}
						</div>
					) : (
						<p class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">
							No hay reglas automáticas de precio.
						</p>
					)}
				</Card>
			)
		}

		{
			showSellability && (
				<Card className="space-y-5 bg-white text-slate-900">
					<div class="flex flex-wrap items-center justify-between gap-3">
						<div>
							<h2 class="text-lg font-semibold">Reglas de venta</h2>
							<p class="text-sm text-slate-500">
								{surface.stats.activeRules} activas · {surface.stats.inactiveRules} pausadas
							</p>
						</div>
						<Button href={`${routes.pricing()}?focus=restrictions`} variant="secondary" size="sm">
							Crear desde calendario
						</Button>
					</div>

					<form method="GET" class="grid gap-3 lg:grid-cols-4">
						<input type="hidden" name="tab" value={activeTab} />
						<label class="space-y-1 text-sm lg:col-span-2">
							<span class="font-medium text-slate-700">Destino</span>
							<select name="ratePlanId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
								<option value="">Todas las {vocabulary.ratePlanPlural}</option>
								{surface.ratePlans.map((ratePlan) => (
									<option value={ratePlan.id} selected={selected(filters.ratePlanId, ratePlan.id)}>
										{ratePlan.productName} · {ratePlan.variantName} · {ratePlan.name}
									</option>
								))}
							</select>
						</label>
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Tipo</span>
							<select name="type" class="w-full rounded-lg border border-slate-300 px-3 py-2">
								<option value="all" selected={filters.type === "all"}>
									Todas
								</option>
								{SELLABILITY_RULES.map((rule) => (
									<option value={rule.type} selected={filters.type === rule.type}>
										{rule.label}
									</option>
								))}
							</select>
						</label>
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Estado</span>
							<select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2">
								<option value="all" selected={filters.status === "all"}>
									Todas
								</option>
								<option value="active" selected={filters.status === "active"}>
									Activas
								</option>
								<option value="inactive" selected={filters.status === "inactive"}>
									Pausadas
								</option>
							</select>
						</label>
						<div class="flex flex-wrap items-end gap-2 lg:col-span-4">
							<Button type="submit" variant="primary">
								Aplicar filtros
							</Button>
							<Button href={`${routes.rateRestrictions()}?tab=${activeTab}`} variant="secondary">
								Limpiar
							</Button>
						</div>
					</form>

					{visibleRules.length === 0 ? (
						<div class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">
							<p class="font-semibold text-slate-800">No hay reglas para esta vista.</p>
							<p class="mt-1">Crea una regla desde Calendario o cambia de pestaña.</p>
						</div>
					) : (
						<div class="space-y-3">
							{visibleRules.map((rule) => (
								<div class="rounded-lg border border-slate-200 p-3">
									<div class="grid gap-3 lg:grid-cols-[1fr_auto] lg:items-start">
										<div class="min-w-0 space-y-2">
											<div class="flex flex-wrap items-center gap-2">
												<Badge variant={ruleBadgeVariant[rule.type] ?? "neutral"}>
													{rule.typeLabel}
												</Badge>
												<Badge variant={rule.isActive ? "success" : "neutral"}>
													{rule.isActive ? "Activa" : "Pausada"}
												</Badge>
												<Badge variant="neutral">{scopeLabel[rule.scope]}</Badge>
											</div>
											<div>
												<h3 class="truncate text-base font-semibold text-slate-950">
													{rule.targetName}
												</h3>
												<p class="text-sm text-slate-600">
													{rule.productName}
													{rule.variantName ? ` · ${rule.variantName}` : ""}
													{rule.ratePlanName ? ` · ${rule.ratePlanName}` : ""}
												</p>
											</div>
											<p class="text-sm leading-5 text-slate-700">
												<span class="font-semibold">Impacto:</span> {rule.impactLabel} ·{" "}
												{rule.startDate} a {rule.endDate}
											</p>
										</div>
										<div class="flex flex-wrap justify-start gap-2 lg:justify-end">
											<form method="POST">
												<input type="hidden" name="ruleId" value={rule.id} />
												<input
													type="hidden"
													name="action"
													value={rule.isActive ? "deactivate" : "activate"}
												/>
												<Button type="submit" variant="secondary" size="sm">
													{rule.isActive ? "Pausar" : "Activar"}
												</Button>
											</form>
											{rule.ratePlanId && (
												<Button
													href={`${routes.pricing()}?ratePlanId=${encodeURIComponent(rule.ratePlanId)}&focus=restrictions`}
													variant="secondary"
													size="sm"
												>
													Ver calendario
												</Button>
											)}
										</div>
									</div>
								</div>
							))}
						</div>
					)}
				</Card>
			)
		}
	</div>
</WorkspaceLayout>
