---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { buildRestrictionOperationalCopyRegistry } from "@/lib/rates/restrictionOperationalCopy"
import {
	createRestrictionsSurfaceRule,
	loadRestrictionsSurface,
	SELLABILITY_RULES,
	setRestrictionsSurfaceRuleActive,
	updateRestrictionsSurfaceRule,
	type RestrictionScope,
	type SellabilityRuleType,
} from "@/lib/rates/restrictionsSurface"
import { routes } from "@/lib/routes"
import { resolveVerticalVocabulary } from "@/lib/verticalVocabulary"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

let actionError: string | null = null

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData()
	const action = String(form.get("action") ?? "").trim()
	try {
		if (action === "create") {
			await createRestrictionsSurfaceRule(auth.providerId, form)
			return Astro.redirect(`${routes.rateRestrictions()}?success=created`)
		}
		if (action === "update") {
			await updateRestrictionsSurfaceRule(auth.providerId, form)
			return Astro.redirect(`${routes.rateRestrictions()}?success=updated`)
		}
		if (action === "activate" || action === "deactivate") {
			const ruleId = String(form.get("ruleId") ?? "").trim()
			await setRestrictionsSurfaceRuleActive(auth.providerId, ruleId, action === "activate")
			return Astro.redirect(
				`${routes.rateRestrictions()}?success=${action === "activate" ? "activated" : "deactivated"}`
			)
		}
		actionError = "Unsupported restriction action"
	} catch (error) {
		actionError = error instanceof Error ? error.message : "Restriction action failed"
	}
}

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const ratePlanRows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})

const filters = {
	productId: String(Astro.url.searchParams.get("productId") ?? "").trim() || undefined,
	variantId: String(Astro.url.searchParams.get("variantId") ?? "").trim() || undefined,
	ratePlanId: String(Astro.url.searchParams.get("ratePlanId") ?? "").trim() || undefined,
	status:
		(String(Astro.url.searchParams.get("status") ?? "active").trim() as
			| "active"
			| "inactive"
			| "all") || "active",
	type:
		(String(Astro.url.searchParams.get("type") ?? "all").trim() as SellabilityRuleType | "all") ||
		"all",
}

const surface = await loadRestrictionsSurface(auth.providerId, filters)
const vocabulary = resolveVerticalVocabulary(surface.productTypes)
const operationalCopyRegistry = buildRestrictionOperationalCopyRegistry(vocabulary)
const plansWithSignals = ratePlanRows.filter(
	(row) => Number(row.summary?.activeRestrictionsCount ?? 0) > 0
).length
const activeRestrictionSignals = ratePlanRows.reduce(
	(sum, row) => sum + Number(row.summary?.activeRestrictionsCount ?? 0),
	0
)
const success = String(Astro.url.searchParams.get("success") ?? "").trim()

const firstProductId = surface.products[0]?.id ?? ""
const firstVariantId = surface.variants[0]?.id ?? ""
const firstRatePlanId = surface.ratePlans[0]?.id ?? ""
const defaultStartDate = checkIn
const defaultEndDate = checkOut

const ruleBadgeVariant: Record<string, "success" | "warning" | "info" | "neutral"> = {
	stop_sell: "warning",
	min_los: "info",
	max_los: "info",
	cta: "warning",
	ctd: "warning",
	min_lead_time: "neutral",
	max_lead_time: "neutral",
}

const scopeLabel: Record<RestrictionScope, string> = {
	product: vocabulary.scopeProduct,
	variant: vocabulary.scopeVariant,
	rate_plan: vocabulary.scopeRatePlan,
}

const successMessage: Record<string, string> = {
	created: "Restriccion creada.",
	updated: "Restriccion actualizada.",
	activated: "Restriccion activada.",
	deactivated: "Restriccion desactivada.",
}

function selected(value: string | undefined, expected: string): boolean {
	return String(value ?? "") === expected
}
---

<WorkspaceLayout title="Restrictions">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<h1 class="text-3xl font-semibold text-slate-100">Restrictions</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">{vocabulary.contextLine}</p>
			</div>
			<div class="flex items-center gap-2">
				<Button href={routes.ratePlansHub()} variant="secondary">ARI Hub</Button>
				<Button href={routes.ratePlansList()} variant="secondary">Rate Plans</Button>
			</div>
		</header>

		{
			actionError && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">No se pudo guardar la restriccion</p>
					<p class="mt-1 text-sm">{actionError}</p>
				</Card>
			)
		}
		{
			successMessage[success] && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">{successMessage[success]}</p>
				</Card>
			)
		}

		<section class="grid gap-4 md:grid-cols-4">
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Reglas activas</p>
				<p class="mt-2 text-2xl font-semibold">{surface.stats.activeRules}</p>
				<p class="mt-1 text-xs text-slate-400">{surface.stats.inactiveRules} inactivas</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">
					{vocabulary.ratePlanPlural} con señales
				</p>
				<p class="mt-2 text-2xl font-semibold">{plansWithSignals}</p>
				<p class="mt-1 text-xs text-slate-400">{activeRestrictionSignals} señales activas</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Dias condicionados</p>
				<p class="mt-2 text-2xl font-semibold">
					{surface.stats.estimatedBlockedOrConditionedDays}
				</p>
				<p class="mt-1 text-xs text-slate-400">Estimado desde reglas activas</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Cobertura operativa</p>
				<p class="mt-2 text-2xl font-semibold">
					{
						surface.stats.stopSellRules +
							surface.stats.lengthOfStayRules +
							surface.stats.arrivalDepartureRules
					}
				</p>
				<p class="mt-1 text-xs text-slate-400">Stop Sell, LOS, CTA y CTD</p>
			</Card>
		</section>

		<Section
			title="Filtros"
			description={`Encuentra reglas por ${vocabulary.product}, ${vocabulary.variant}, ${vocabulary.ratePlan}, tipo o estado.`}
		>
			<Card className="bg-white text-slate-800">
				<form method="GET" class="grid gap-4 lg:grid-cols-5">
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">{vocabulary.scopeProduct}</span>
						<select name="productId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="">Todos los {vocabulary.productPlural}</option>
							{
								surface.products.map((product) => (
									<option value={product.id} selected={selected(filters.productId, product.id)}>
										{product.name}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">{vocabulary.scopeVariant}</span>
						<select name="variantId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="">Todas las {vocabulary.variantPlural}</option>
							{
								surface.variants.map((variant) => (
									<option value={variant.id} selected={selected(filters.variantId, variant.id)}>
										{variant.productName} · {variant.name}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">{vocabulary.scopeRatePlan}</span>
						<select name="ratePlanId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="">Todos los {vocabulary.ratePlanPlural}</option>
							{
								surface.ratePlans.map((ratePlan) => (
									<option value={ratePlan.id} selected={selected(filters.ratePlanId, ratePlan.id)}>
										{ratePlan.productName} · {ratePlan.variantName} · {ratePlan.name}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Tipo</span>
						<select name="type" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="all" selected={filters.type === "all"}>Todas las reglas</option>
							{
								SELLABILITY_RULES.map((rule) => (
									<option value={rule.type} selected={filters.type === rule.type}>
										{rule.label}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Estado</span>
						<select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							<option value="active" selected={filters.status === "active"}>Activas</option>
							<option value="inactive" selected={filters.status === "inactive"}>Inactivas</option>
							<option value="all" selected={filters.status === "all"}>Todas</option>
						</select>
					</label>
					<div class="flex items-end gap-2 lg:col-span-5">
						<Button type="submit" variant="primary">Aplicar filtros</Button>
						<Button href={routes.rateRestrictions()} variant="secondary">Limpiar</Button>
					</div>
				</form>
			</Card>
		</Section>

		<Section
			title="Crear restriccion"
			description={`Crea una regla de vendibilidad sobre ${vocabulary.product}, ${vocabulary.variant} o ${vocabulary.ratePlan}.`}
		>
			<Card className="bg-white text-slate-800">
				<form method="POST" class="space-y-5" data-restriction-form>
					<input type="hidden" name="action" value="create" />
					<div class="grid gap-4 lg:grid-cols-4">
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Scope</span>
							<select
								name="scope"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
								data-scope-select
							>
								<option value="rate_plan" selected>{vocabulary.scopeRatePlan}</option>
								<option value="variant">{vocabulary.scopeVariant}</option>
								<option value="product">{vocabulary.scopeProduct}</option>
							</select>
						</label>
						<label class="space-y-1 text-sm" data-scope-target="product">
							<span class="font-medium text-slate-700">{vocabulary.scopeProduct}</span>
							<select
								name="productScopeId"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
							>
								{
									surface.products.map((product) => (
										<option value={product.id} selected={product.id === firstProductId}>
											{product.name}
										</option>
									))
								}
							</select>
						</label>
						<label class="space-y-1 text-sm" data-scope-target="variant">
							<span class="font-medium text-slate-700">{vocabulary.scopeVariant}</span>
							<select
								name="variantScopeId"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
							>
								{
									surface.variants.map((variant) => (
										<option value={variant.id} selected={variant.id === firstVariantId}>
											{variant.productName} · {variant.name}
										</option>
									))
								}
							</select>
						</label>
						<label class="space-y-1 text-sm" data-scope-target="rate_plan">
							<span class="font-medium text-slate-700">{vocabulary.scopeRatePlan}</span>
							<select
								name="rate_planScopeId"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
							>
								{
									surface.ratePlans.map((ratePlan) => (
										<option value={ratePlan.id} selected={ratePlan.id === firstRatePlanId}>
											{ratePlan.productName} · {ratePlan.variantName} · {ratePlan.name}
										</option>
									))
								}
							</select>
						</label>
					</div>
					<div class="grid gap-4 lg:grid-cols-4">
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Restriccion</span>
							<select
								name="type"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
								data-rule-type
							>
								{
									SELLABILITY_RULES.map((rule) => (
										<option
											value={rule.type}
											data-requires-value={rule.requiresValue ? "true" : "false"}
											data-default-value={rule.defaultValue ?? ""}
										>
											{rule.label}
										</option>
									))
								}
							</select>
						</label>
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Valor</span>
							<input
								type="number"
								name="value"
								min="1"
								step="1"
								value="2"
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
								data-rule-value
							/>
						</label>
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Desde</span>
							<input
								type="date"
								name="startDate"
								value={defaultStartDate}
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
								required
								data-start-date
							/>
						</label>
						<label class="space-y-1 text-sm">
							<span class="font-medium text-slate-700">Hasta</span>
							<input
								type="date"
								name="endDate"
								value={defaultEndDate}
								class="w-full rounded-lg border border-slate-300 px-3 py-2"
								required
								data-end-date
							/>
						</label>
					</div>
					<div class="grid gap-4 lg:grid-cols-[1.4fr_1fr]">
						<div class="space-y-2">
							<p class="text-sm font-medium text-slate-700">Dias de semana</p>
							<div class="flex flex-wrap gap-2">
								{
									[
										[1, "Lun"],
										[2, "Mar"],
										[3, "Mie"],
										[4, "Jue"],
										[5, "Vie"],
										[6, "Sab"],
										[7, "Dom"],
									].map(([value, label]) => (
										<label class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm">
											<input type="checkbox" name="validDays" value={value} />
											<span>{label}</span>
										</label>
									))
								}
							</div>
						</div>
						<Card className="border-blue-100 bg-blue-50 text-blue-950 shadow-none">
							<p class="text-xs font-semibold uppercase tracking-wide text-blue-700">
								Impacto operativo
							</p>
							<p class="mt-2 text-sm font-medium leading-5" data-impact-preview>
								Esta regla afectara la venta del alcance y rango seleccionados.
							</p>
							<p class="mt-2 text-xs leading-5 text-blue-900/80">
								<span class="font-semibold text-blue-950">Ejemplo:</span>{" "}
								<span data-impact-example>Configura la regla para ver un caso practico.</span>
							</p>
							<p class="mt-1 text-xs leading-5 text-blue-900/70" data-impact-non-effect-row hidden>
								<span class="font-semibold text-blue-950">No afecta:</span>{" "}
								<span data-impact-non-effect></span>
							</p>
							<p class="mt-1 text-xs leading-5 text-blue-900/70" data-impact-range-row hidden>
								<span class="font-semibold text-blue-950">Rango:</span>{" "}
								<span data-impact-range></span>
							</p>
						</Card>
					</div>
					<div class="flex flex-wrap items-center gap-2">
						<Button type="submit" variant="primary">Crear restriccion</Button>
						<p class="text-xs text-slate-500">
							Search evalua estas señales cuando el read model existente las materializa.
						</p>
					</div>
				</form>
			</Card>
		</Section>

		<Section
			title="Reglas de restricciones"
			description="Reglas que bloquean venta, condicionan llegadas/salidas o limitan ventanas de reserva."
		>
			{
				surface.rules.length === 0 ? (
					<Card className="bg-white text-slate-700">
						<p class="text-sm font-semibold">No hay reglas para estos filtros.</p>
						<p class="mt-1 text-sm text-slate-500">
							Crea una restriccion o limpia los filtros para revisar reglas inactivas.
						</p>
					</Card>
				) : (
					<div class="space-y-4">
						{surface.rules.map((rule) => (
							<Card className="bg-white text-slate-800">
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div class="space-y-2">
										<div class="flex flex-wrap items-center gap-2">
											<Badge variant={ruleBadgeVariant[rule.type] ?? "neutral"}>
												{rule.typeLabel}
											</Badge>
											<Badge variant={rule.isActive ? "success" : "neutral"}>
												{rule.isActive ? "Activa" : "Inactiva"}
											</Badge>
											<Badge variant="neutral">{scopeLabel[rule.scope]}</Badge>
										</div>
										<div>
											<h2 class="text-lg font-semibold text-slate-950">{rule.targetName}</h2>
											<p class="text-sm text-slate-600">
												{rule.productName}
												{rule.variantName ? ` · ${rule.variantName}` : ""}
												{rule.ratePlanName ? ` · ${rule.ratePlanName}` : ""}
											</p>
										</div>
									</div>
									<div class="flex flex-wrap items-center gap-2">
										<form method="POST">
											<input type="hidden" name="ruleId" value={rule.id} />
											<input
												type="hidden"
												name="action"
												value={rule.isActive ? "deactivate" : "activate"}
											/>
											<Button type="submit" variant="secondary" size="sm">
												{rule.isActive ? "Desactivar" : "Activar"}
											</Button>
										</form>
										{rule.ratePlanId && (
											<Button
												href={routes.ratePlanDetail(rule.ratePlanId)}
												variant="secondary"
												size="sm"
											>
												Rate plan
											</Button>
										)}
									</div>
								</div>

								<div class="mt-5 grid gap-3 md:grid-cols-4">
									<div class="rounded-lg bg-slate-50 p-3">
										<p class="text-xs tracking-wide text-slate-500 uppercase">Fechas</p>
										<p class="mt-1 text-sm font-medium text-slate-900">
											{rule.startDate} to {rule.endDate}
										</p>
										<p class="mt-1 text-xs text-slate-500">{rule.validDaysLabel}</p>
									</div>
									<div class="rounded-lg bg-slate-50 p-3">
										<p class="text-xs tracking-wide text-slate-500 uppercase">Valor</p>
										<p class="mt-1 text-sm font-medium text-slate-900">{rule.valueLabel}</p>
										<p class="mt-1 text-xs text-slate-500">{rule.category}</p>
									</div>
									<div class="rounded-lg bg-slate-50 p-3">
										<p class="text-xs tracking-wide text-slate-500 uppercase">Impacto</p>
										<p class="mt-1 text-sm font-medium text-slate-900">{rule.impactDays} dias</p>
										<p class="mt-1 text-xs text-slate-500">Cobertura estimada</p>
									</div>
									<div class="rounded-lg bg-slate-50 p-3">
										<p class="text-xs tracking-wide text-slate-500 uppercase">Vendibilidad</p>
										<p class="mt-1 text-sm font-medium text-slate-900">{rule.impactLabel}</p>
									</div>
								</div>

								<details class="mt-5 rounded-lg border border-slate-200 bg-slate-50 p-4">
									<summary class="cursor-pointer text-sm font-semibold text-slate-800">
										Editar restriccion
									</summary>
									<form method="POST" class="mt-4 space-y-4" data-restriction-form>
										<input type="hidden" name="action" value="update" />
										<input type="hidden" name="ruleId" value={rule.id} />
										<div class="grid gap-4 lg:grid-cols-4">
											<label class="space-y-1 text-sm">
												<span class="font-medium text-slate-700">Scope</span>
												<select
													name="scope"
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
													data-scope-select
												>
													<option value="rate_plan" selected={rule.scope === "rate_plan"}>
														{vocabulary.scopeRatePlan}
													</option>
													<option value="variant" selected={rule.scope === "variant"}>
														{vocabulary.scopeVariant}
													</option>
													<option value="product" selected={rule.scope === "product"}>
														{vocabulary.scopeProduct}
													</option>
												</select>
											</label>
											<label class="space-y-1 text-sm" data-scope-target="product">
												<span class="font-medium text-slate-700">{vocabulary.scopeProduct}</span>
												<select
													name="productScopeId"
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
												>
													{surface.products.map((product) => (
														<option
															value={product.id}
															selected={rule.scope === "product" && product.id === rule.scopeId}
														>
															{product.name}
														</option>
													))}
												</select>
											</label>
											<label class="space-y-1 text-sm" data-scope-target="variant">
												<span class="font-medium text-slate-700">{vocabulary.scopeVariant}</span>
												<select
													name="variantScopeId"
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
												>
													{surface.variants.map((variant) => (
														<option
															value={variant.id}
															selected={rule.scope === "variant" && variant.id === rule.scopeId}
														>
															{variant.productName} · {variant.name}
														</option>
													))}
												</select>
											</label>
											<label class="space-y-1 text-sm" data-scope-target="rate_plan">
												<span class="font-medium text-slate-700">{vocabulary.scopeRatePlan}</span>
												<select
													name="rate_planScopeId"
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
												>
													{surface.ratePlans.map((ratePlan) => (
														<option
															value={ratePlan.id}
															selected={rule.scope === "rate_plan" && ratePlan.id === rule.scopeId}
														>
															{ratePlan.productName} · {ratePlan.variantName} · {ratePlan.name}
														</option>
													))}
												</select>
											</label>
										</div>
										<div class="grid gap-4 lg:grid-cols-4">
											<label class="space-y-1 text-sm">
												<span class="font-medium text-slate-700">Restriccion</span>
												<select
													name="type"
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
													data-rule-type
												>
													{SELLABILITY_RULES.map((definition) => (
														<option
															value={definition.type}
															selected={definition.type === rule.type}
															data-requires-value={definition.requiresValue ? "true" : "false"}
															data-default-value={definition.defaultValue ?? ""}
														>
															{definition.label}
														</option>
													))}
												</select>
											</label>
											<label class="space-y-1 text-sm">
												<span class="font-medium text-slate-700">Valor</span>
												<input
													type="number"
													name="value"
													min="1"
													step="1"
													value={rule.value ?? 1}
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
													data-rule-value
												/>
											</label>
											<label class="space-y-1 text-sm">
												<span class="font-medium text-slate-700">Desde</span>
												<input
													type="date"
													name="startDate"
													value={rule.startDate}
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
													required
													data-start-date
												/>
											</label>
											<label class="space-y-1 text-sm">
												<span class="font-medium text-slate-700">Hasta</span>
												<input
													type="date"
													name="endDate"
													value={rule.endDate}
													class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
													required
													data-end-date
												/>
											</label>
										</div>
										<div class="grid gap-4 lg:grid-cols-[1.4fr_1fr]">
											<div class="space-y-2">
												<p class="text-sm font-medium text-slate-700">Dias de semana</p>
												<div class="flex flex-wrap gap-2">
													{[
														[1, "Lun"],
														[2, "Mar"],
														[3, "Mie"],
														[4, "Jue"],
														[5, "Vie"],
														[6, "Sab"],
														[7, "Dom"],
													].map(([value, label]) => (
														<label class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
															<input
																type="checkbox"
																name="validDays"
																value={value}
																checked={rule.validDays.includes(Number(value))}
															/>
															<span>{label}</span>
														</label>
													))}
												</div>
											</div>
											<Card className="border-blue-100 bg-blue-50 text-blue-950 shadow-none">
												<p class="text-xs font-semibold tracking-wide text-blue-700 uppercase">
													Impacto operativo
												</p>
												<p class="mt-2 text-sm leading-5 font-medium" data-impact-preview>
													{rule.impactLabel}
												</p>
												<p class="mt-2 text-xs leading-5 text-blue-900/80">
													<span class="font-semibold text-blue-950">Ejemplo:</span>{" "}
													<span data-impact-example>
														Actualiza la regla para ver un caso practico.
													</span>
												</p>
												<p
													class="mt-1 text-xs leading-5 text-blue-900/70"
													data-impact-non-effect-row
													hidden
												>
													<span class="font-semibold text-blue-950">No afecta:</span>{" "}
													<span data-impact-non-effect />
												</p>
												<p
													class="mt-1 text-xs leading-5 text-blue-900/70"
													data-impact-range-row
													hidden
												>
													<span class="font-semibold text-blue-950">Rango:</span>{" "}
													<span data-impact-range />
												</p>
											</Card>
										</div>
										<Button type="submit" variant="primary">
											Guardar restriccion
										</Button>
									</form>
								</details>
							</Card>
						))}
					</div>
				)
			}
		</Section>

		<Section
			title="Limites operativos"
			description="Restrictions controla vendibilidad; los otros dominios conservan su ownership."
		>
			<div class="grid gap-4 md:grid-cols-3">
				<Card className="bg-white text-slate-800">
					<h2 class="text-base font-semibold text-slate-950">Pricing</h2>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						Promociones, markups y automatizacion comercial viven en Commercial Rules.
					</p>
				</Card>
				<Card className="bg-white text-slate-800">
					<h2 class="text-base font-semibold text-slate-950">Inventory</h2>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						Cupos, unidades fisicas y disponibilidad base viven en Inventory.
					</p>
				</Card>
				<Card className="bg-white text-slate-800">
					<h2 class="text-base font-semibold text-slate-950">Booking Policies</h2>
					<p class="mt-2 text-sm leading-6 text-slate-600">
						Cancelacion, pago, no-show y check-in/out viven en Booking Policies.
					</p>
				</Card>
			</div>
		</Section>
	</div>
</WorkspaceLayout>

<script define:vars={{ operationalCopyRegistry }}>
	// @ts-nocheck
	function applyTemplate(template, context) {
		return String(template || "").replace(/\{\{(\w+)\}\}/g, (_, key) => context[key] || "")
	}

	function wireRestrictionForm(form) {
		const scopeSelect = form.querySelector("[data-scope-select]")
		const typeSelect = form.querySelector("[data-rule-type]")
		const valueInput = form.querySelector("[data-rule-value]")
		const preview = form.querySelector("[data-impact-preview]")
		const example = form.querySelector("[data-impact-example]")
		const nonEffect = form.querySelector("[data-impact-non-effect]")
		const nonEffectRow = form.querySelector("[data-impact-non-effect-row]")
		const range = form.querySelector("[data-impact-range]")
		const rangeRow = form.querySelector("[data-impact-range-row]")
		const startInput = form.querySelector("[data-start-date]")
		const endInput = form.querySelector("[data-end-date]")

		function updateScopeTargets() {
			const scope = scopeSelect?.value || "rate_plan"
			form.querySelectorAll("[data-scope-target]").forEach((target) => {
				const visible = target.getAttribute("data-scope-target") === scope
				target.classList.toggle("hidden", !visible)
			})
		}

		function updateImpact() {
			const option = typeSelect?.selectedOptions?.[0]
			const type = typeSelect?.value || "stop_sell"
			const requiresValue = option?.dataset?.requiresValue === "true"
			if (valueInput) {
				valueInput.disabled = !requiresValue
				valueInput.closest("label")?.classList.toggle("opacity-50", !requiresValue)
				const defaultValue = option?.dataset?.defaultValue
				if (requiresValue && !valueInput.value && defaultValue) valueInput.value = defaultValue
			}
			const start = startInput?.value
			const end = endInput?.value
			const ruleCopy = operationalCopyRegistry?.[type] || {}
			const value = valueInput?.value || option?.dataset?.defaultValue || "N"
			const context = { value, start, end }
			if (preview) {
				preview.textContent =
					applyTemplate(ruleCopy.impact, context) || "Esta regla afecta vendibilidad."
			}
			if (example) {
				example.textContent =
					applyTemplate(ruleCopy.example, context) ||
					"Configura la regla para ver un caso practico."
			}
			if (nonEffect && nonEffectRow) {
				const text = applyTemplate(ruleCopy.nonEffect, context)
				nonEffect.textContent = text
				nonEffectRow.hidden = !text
			}
			if (range && rangeRow) {
				range.textContent = start && end ? `${start} a ${end}` : ""
				rangeRow.hidden = !(start && end)
			}
		}

		scopeSelect?.addEventListener("change", updateScopeTargets)
		typeSelect?.addEventListener("change", updateImpact)
		valueInput?.addEventListener("input", updateImpact)
		startInput?.addEventListener("change", updateImpact)
		endInput?.addEventListener("change", updateImpact)
		updateScopeTargets()
		updateImpact()
	}

	document.querySelectorAll("[data-restriction-form]").forEach(wireRestrictionForm)
</script>
