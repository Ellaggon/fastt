---
import SingleCalendarWorkspace from "@/components/rates/SingleCalendarWorkspace"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import { getNextAddRoomStep, resolveAddRoomPlaybookFromUrl } from "@/lib/playbook/add-room"
import {
	getNextLaunchStep,
	resolveLaunchPlaybookFromUrl,
} from "@/lib/playbook/launch-accommodation"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { buildSingleCalendarSurface } from "@/lib/rates/singleCalendarSurface"
import { routes } from "@/lib/routes"
import { count, DailyInventory, db, eq, first } from "@/shared/infrastructure/db/compat"

const auth = await requireProvider(Astro.request).catch((error: unknown) => {
	if (error instanceof Response && error.status === 401) return "__REDIRECT_LOGIN__"
	if (error instanceof Response && error.status === 403) return "__REDIRECT_PROVIDER__"
	throw error
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.providerSettingsProfile())

const professionalModeCookie = getProfessionalModeCookiePreference(Astro.request)
const sidebarData = await getProviderSidebarData(auth.providerId, {
	userId: auth.user.id,
	professionalToolsEnabled:
		typeof professionalModeCookie === "boolean" ? professionalModeCookie : undefined,
})
const isProfessionalCalendar = sidebarData.disclosureMode !== "small-provider"
const rows = await loadRatePlansReadModel({ request: Astro.request, channel: "web" })
const surface = await buildSingleCalendarSurface({
	rows,
	ratePlanId: Astro.url.searchParams.get("ratePlanId"),
	variantId: Astro.url.searchParams.get("variantId"),
	month: Astro.url.searchParams.get("month"),
})
const requestedFocus = String(Astro.url.searchParams.get("focus") ?? "price")
const initialMode =
	requestedFocus === "availability"
		? "availability"
		: ["restrictions", "sellability"].includes(requestedFocus)
			? "sellability"
			: isProfessionalCalendar && ["policies", "conditions"].includes(requestedFocus)
				? "conditions"
				: "price"

const addRoomPlaybook = resolveAddRoomPlaybookFromUrl(Astro.url)
const launchPlaybook = resolveLaunchPlaybookFromUrl(Astro.url)
const flow = Astro.url.searchParams.get("flow")
const variantIdParam = String(Astro.url.searchParams.get("variantId") ?? "").trim()
const ratePlanIdParam = String(Astro.url.searchParams.get("ratePlanId") ?? "").trim()
const matchedRow = rows.find(
	(row) =>
		(variantIdParam && String(row.variantId) === variantIdParam) ||
		(ratePlanIdParam && String(row.ratePlanId) === ratePlanIdParam)
)
const playbookProductId = matchedRow?.productId ?? addRoomPlaybook.productId

if (!addRoomPlaybook.active && flow === "add-room" && playbookProductId) {
	const params = new URLSearchParams(Astro.url.searchParams)
	params.set("playbook", "add-room")
	params.set("step", "availability")
	return Astro.redirect(`${routes.calendar()}?${params.toString()}`)
}
if (!launchPlaybook.active && flow === "create" && playbookProductId) {
	const params = new URLSearchParams(Astro.url.searchParams)
	params.set("playbook", "launch")
	params.set("step", "calendar")
	return Astro.redirect(`${routes.calendar()}?${params.toString()}`)
}

const addRoomCtx = {
	productId: playbookProductId,
	variantId: variantIdParam || addRoomPlaybook.variantId || undefined,
	ratePlanId: ratePlanIdParam || addRoomPlaybook.ratePlanId || undefined,
}
const launchCtx = {
	productId: playbookProductId,
	isHotel: true,
	variantId: variantIdParam || undefined,
	ratePlanId: ratePlanIdParam || undefined,
}
const addRoomContinueHref = addRoomPlaybook.active
	? (getNextAddRoomStep(addRoomPlaybook.stepId ?? "availability", addRoomCtx)?.buildHref(
			addRoomCtx
		) ?? null)
	: null
const launchContinueHref = launchPlaybook.active
	? (getNextLaunchStep(launchPlaybook.stepId ?? "calendar", launchCtx)?.buildHref(launchCtx) ??
		null)
	: null
const activePlaybook = addRoomPlaybook.active ? "add-room" : launchPlaybook.active ? "launch" : null
const isGuidedAvailabilityStep = Boolean(
	activePlaybook &&
	(addRoomPlaybook.stepId === "availability" || launchPlaybook.stepId === "calendar")
)
const guidedVariantId = String(addRoomCtx.variantId || launchCtx.variantId || "").trim()
const guidedInventoryDays =
	isGuidedAvailabilityStep && guidedVariantId
		? Number(
				(
					await db
						.select({ value: count() })
						.from(DailyInventory)
						.where(eq(DailyInventory.variantId, guidedVariantId))
						.then(first)
				)?.value ?? 0
			)
		: 0
const Layout = activePlaybook ? PlaybookLayout : WorkspaceLayout
const layoutProps =
	activePlaybook === "add-room"
		? {
				title: "Calendario",
				playbookId: "add-room" as const,
				active: true,
				stepId: addRoomPlaybook.stepId ?? "availability",
				productId: playbookProductId,
				variantId: addRoomCtx.variantId ?? "",
				ratePlanId: addRoomCtx.ratePlanId ?? "",
				isHotel: true,
				continueHref: addRoomContinueHref,
			}
		: activePlaybook === "launch"
			? {
					title: "Calendario",
					playbookId: "launch" as const,
					active: true,
					stepId: launchPlaybook.stepId ?? "calendar",
					productId: launchCtx.productId,
					variantId: launchCtx.variantId ?? "",
					ratePlanId: launchCtx.ratePlanId ?? "",
					isHotel: true,
					continueHref: launchContinueHref,
				}
			: { title: "Calendario" }
---

<Layout {...layoutProps}>
	<div class="space-y-5">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					{
						isGuidedAvailabilityStep && matchedRow
							? `${matchedRow.productName} · Nueva habitación`
							: "Habitaciones y tarifas"
					}
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">
					{isGuidedAvailabilityStep ? "Disponibilidad inicial" : "Calendario"}
				</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					{
						isGuidedAvailabilityStep
							? "Elige las primeras fechas en las que esta habitación podrá recibir reservas. Después podrás operar el calendario completo."
							: "Opera una tarifa por fecha. Selecciona noches y cambia precio, cupo o venta desde un solo lugar."
					}
				</p>
			</div>
		</header>

		<SingleCalendarWorkspace
			client:load
			initialSurface={surface}
			isProfessional={isProfessionalCalendar}
			initialMode={initialMode}
			guidedAvailability={isGuidedAvailabilityStep
				? {
						playbook: activePlaybook,
						productName: matchedRow?.productName ?? "",
						variantName: matchedRow?.variantName ?? "",
						ratePlanName: matchedRow?.ratePlanName ?? "",
						requiredDays: 30,
						initialInventoryDays: guidedInventoryDays,
					}
				: undefined}
		/>
	</div>
</Layout>
