										Añadir mes siguiente
									</button>
								</div>
							) : null}
						</>
					)
				}
				<p id="pricingCalendarFeedback" class="text-sm text-slate-600"></p>
				<div
					id="pricingOperationResult"
					data-pricing-apply-result-card
					class="hidden rounded-lg border p-3 text-sm"
				>
				</div>
			</Card>
