																	"mt-1 h-2 w-2 rounded-full md:hidden",
																	day.operationalStatus === "sellable" && "bg-emerald-500",
																	day.operationalStatus === "restricted" && "bg-blue-500",
																	day.operationalStatus === "no_price" && "bg-amber-500",
																	day.operationalStatus === "no_inventory" && "bg-orange-500",
																	day.operationalStatus === "closed" && "bg-red-500",
																	day.status === "past" && "bg-slate-300",
