---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import CalendarOperationalPanel from "@/components/rates/CalendarOperationalPanel.astro"
import MobileCalendarSheetStyles from "@/components/rates/MobileCalendarSheetStyles.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { ChevronLeft, ChevronRight, RefreshCw } from "@lucide/astro"
import { formatHistoryDate, loadRatesContextualHistory } from "@/lib/audit/contextualHistory"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProfessionalModeCookiePreference } from "@/lib/dashboard/professionalModeCookie"
import { getProviderSidebarData } from "@/lib/dashboard/providerSidebarReadiness"
import { pricingExtensionOperationOptions } from "@/lib/pricing/pricingExtensionPresenter"
import { pricingOperationCopy } from "@/lib/pricing/pricingOperationCopy"
import { buildPricingCalendarSurface } from "@/lib/rates/calendarSurfaces"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { ratePlanPricingReadRepository } from "@/container"
import { resolvePolicyDateRange } from "@/modules/policies/public"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const rows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})
const professionalModeCookie = getProfessionalModeCookiePreference(Astro.request)
const sidebarData = await getProviderSidebarData(auth.providerId, {
	userId: auth.user.id,
	professionalToolsEnabled:
		typeof professionalModeCookie === "boolean" ? professionalModeCookie : undefined,
})
const isProfessionalCalendar = sidebarData.disclosureMode !== "small-provider"
const surface = await buildPricingCalendarSurface({
	rows,
	ratePlanId: Astro.url.searchParams.get("ratePlanId"),
	variantId: Astro.url.searchParams.get("variantId"),
	month: Astro.url.searchParams.get("month"),
	visibleMonths: 2,
})
const selected = surface.selectedRatePlan
const vocabulary = surface.vocabulary
const selectedPolicyCoverage = selected?.policyCoverage
const hasIncompleteConditions = selectedPolicyCoverage ? !selectedPolicyCoverage.isComplete : true
const selectedPolicySummary =
	String(selected?.policySummary ?? "").trim() ||
	(hasIncompleteConditions ? "Faltan condiciones de la tarifa" : "Condiciones listas")
const selectedPolicyMissingSummary = selectedPolicyCoverage?.missingCategories?.length
	? `Faltan ${selectedPolicyCoverage.missingCategories.length} categoría${selectedPolicyCoverage.missingCategories.length === 1 ? "" : "s"} del contrato`
	: ""

function money(amount: number | null, currency: string): string {
	if (amount == null) return "Sin precio"
	return `${currency} ${Number(amount).toFixed(0)}`
}

const pricingRangeDays = surface.days.map((day) => ({
	date: day.date,
	status: day.status,
	ruleAdjustment: day.ruleAdjustment,
	restrictionCount: day.restrictionSignals.count,
	restrictionBlocker: day.restrictionSignals.hasCommercialBlocker,
	availableUnits: day.availableUnits,
	bookedUnits: day.bookedUnits,
	heldUnits: day.heldUnits,
	operationalStatus: day.operationalStatus,
}))
const operationalCalendarDays = surface.days.map((day) => ({
	date: day.date,
	weekday: day.weekday,
	day: day.day,
	price: money(day.finalPrice, day.currency),
	basePrice: day.baseComponent == null ? "Sin base" : money(day.baseComponent, day.currency),
	currency: day.currency,
	availableUnits: day.availableUnits,
	totalUnits: day.totalUnits,
	bookedUnits: day.bookedUnits,
	heldUnits: day.heldUnits,
	status: day.operationalStatus,
	statusLabel: day.operationalStatusLabel,
	priceStatus: day.status,
	capacityLabel: day.capacitySignalLabel,
	utilizationPercent: day.utilizationPercent,
	restrictionSummary: day.restrictionSignals.summary,
	restrictionCount: day.restrictionSignals.count,
	stopSell: day.restrictionSignals.stopSell,
	cta: day.restrictionSignals.cta,
	ctd: day.restrictionSignals.ctd,
	minStay: day.restrictionSignals.minStay,
	maxStay: day.restrictionSignals.maxStay,
	minLeadTime: day.restrictionSignals.minLeadTime,
	maxLeadTime: day.restrictionSignals.maxLeadTime,
	conditionsIncomplete: hasIncompleteConditions,
	conditionsSummary: selectedPolicySummary,
	conditionsMissingSummary: selectedPolicyMissingSummary,
}))
const monthFormatter = new Intl.DateTimeFormat("es-CL", {
	month: "long",
	year: "numeric",
	timeZone: "UTC",
})
const pricingCalendarMonths = Array.from(
	surface.days.reduce((months, day) => {
		const key = day.date.slice(0, 7)
		const days = months.get(key) ?? []
		days.push(day)
		months.set(key, days)
		return months
	}, new Map<string, typeof surface.days>())
).map(([month, days]) => ({
	month,
	label: monthFormatter.format(new Date(`${month}-01T12:00:00.000Z`)),
	days,
	leadingBlankDays: days[0] ? (new Date(`${days[0].date}T00:00:00.000Z`).getUTCDay() + 6) % 7 : 0,
}))
const pricingRatePlanCatalog = rows.map((row) => ({
	ratePlanId: String(row.ratePlanId),
	ratePlanName: String(row.ratePlanName),
	productName: String(row.productName),
	variantName: String(row.variantName),
}))
const selectedRatePlanId = String(selected?.ratePlanId ?? "")
const selectedRatePlanName = String(selected?.ratePlanName ?? "")
const selectedVariantId = String(selected?.variantId ?? "")
const calendarHistory = await loadRatesContextualHistory({
	providerId: auth.providerId,
	ratePlans: selected ? [selected] : rows,
	limit: 6,
	context: "calendar",
})
const historyToneClasses: Record<string, string> = {
	success: "border-emerald-200 bg-emerald-50 text-emerald-950",
	warning: "border-amber-200 bg-amber-50 text-amber-950",
	info: "border-blue-200 bg-blue-50 text-blue-950",
	neutral: "border-slate-200 bg-slate-50 text-slate-800",
}
function pricingCalendarHref(month: string): string {
	const params = new URLSearchParams()
	if (selectedRatePlanId) params.set("ratePlanId", selectedRatePlanId)
	params.set("month", month)
	return `${routes.pricing()}?${params.toString()}`
}
function shiftMonth(month: string, delta: number): string {
	const date = new Date(`${month}-01T12:00:00.000Z`)
	date.setUTCMonth(date.getUTCMonth() + delta)
	return date.toISOString().slice(0, 7)
}
const extensionTargetOptions = await Promise.all(
	rows
		.filter((row) => String(row.ratePlanId) !== selectedRatePlanId)
		.map(async (row) => {
			const pricingSummary = await ratePlanPricingReadRepository.getRatePlanPricingSummary(
				String(row.ratePlanId)
			)
			return {
				row,
				isPricingReady: Boolean(pricingSummary),
				basePrice: pricingSummary?.basePrice ?? null,
				currency: pricingSummary?.currency ?? null,
			}
		})
)
---

<WorkspaceLayout title="Calendario">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Habitaciones y tarifas
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Calendario</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Revisa qué noches se pueden vender y ajusta precio, cupos, reglas y condiciones desde un
					solo lugar.
				</p>
			</div>
			{
				isProfessionalCalendar ? (
					<div class="flex flex-wrap items-center gap-2">
						<Button
							href={`${routes.ratesMultiCalendar()}?ratePlanId=${encodeURIComponent(selectedRatePlanId)}&month=${encodeURIComponent(surface.month)}`}
							variant="secondary"
						>
							Multicalendario
						</Button>
					</div>
				) : null
			}
		</header>

		<Section>
			<Card className="space-y-5 bg-white text-slate-800">
				<form method="get" class="grid gap-3 lg:grid-cols-[1.6fr_0.8fr_auto] lg:items-end">
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">{vocabulary.scopeRatePlan}</span>
						<select name="ratePlanId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							{
								rows.map((row) => (
									<option
										value={String(row.ratePlanId)}
										selected={selected?.ratePlanId === row.ratePlanId}
									>
										{row.productName} · {row.variantName} · {row.ratePlanName}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Mes inicial</span>
						<input
							type="month"
							name="month"
							value={surface.month}
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
						/>
					</label>
					<div class="flex items-end gap-2">
						<Button type="submit" variant="primary">Ver calendario</Button>
						<button
							id="generatePricingCoverageBtn"
							type="button"
							class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-700 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-blue-500"
							data-rate-plan-id={String(selected?.ratePlanId ?? "")}
							data-from={surface.startDate}
							data-to={surface.endDate}
							aria-label="Actualizar calendario"
							title="Actualizar calendario"
						>
							<RefreshCw class="h-4 w-4" aria-hidden="true" />
						</button>
					</div>
				</form>

				<p class="text-xs text-slate-500 sm:hidden">
					Toca una fecha para editarla; toca otra fecha para crear un rango.
				</p>

				{
					!selected ? (
						<div class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
							No hay {vocabulary.ratePlanPlural} para operar precios todavia.
						</div>
					) : (
						<>
							<div class="space-y-5">
								<CalendarOperationalPanel
									isProfessionalCalendar={isProfessionalCalendar}
									ratePlanId={selectedRatePlanId}
								/>
								<div class="space-y-5" data-pricing-two-month-calendar>
									{pricingCalendarMonths.map((monthGroup, monthIndex) => (
										<section
											class:list={["space-y-2", monthIndex > 0 && "hidden"]}
											data-pricing-calendar-month={monthGroup.month}
											data-pricing-extra-month={monthIndex > 0 ? "true" : undefined}
										>
											<div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 pb-3">
												<div class="flex min-w-0 items-center gap-2">
													<a
														href={pricingCalendarHref(shiftMonth(monthGroup.month, -1))}
														class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 shadow-sm transition hover:bg-slate-50 hover:text-slate-950 focus:ring-2 focus:ring-blue-500 focus:outline-none"
														aria-label="Mes anterior"
														title="Mes anterior"
													>
														<ChevronLeft class="h-4 w-4" aria-hidden="true" />
													</a>
													<h3 class="truncate text-base font-semibold text-slate-950 capitalize">
														{monthGroup.label}
													</h3>
													<a
														href={pricingCalendarHref(shiftMonth(monthGroup.month, 1))}
														class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 shadow-sm transition hover:bg-slate-50 hover:text-slate-950 focus:ring-2 focus:ring-blue-500 focus:outline-none"
														aria-label="Mes siguiente"
														title="Mes siguiente"
													>
														<ChevronRight class="h-4 w-4" aria-hidden="true" />
													</a>
												</div>
												<div class="flex flex-wrap items-center gap-1.5">
													<Badge
														variant={
															monthGroup.days.filter((day) => day.status === "missing").length > 0
																? "warning"
																: "success"
														}
													>
														{monthGroup.days.filter((day) => day.status === "missing").length > 0
															? `${monthGroup.days.filter((day) => day.status === "missing").length} días sin precio`
															: "Cobertura lista"}
													</Badge>
													<Badge
														variant={
															monthGroup.days.filter(
																(day) => !day.isPast && day.operationalStatus === "no_inventory"
															).length > 0
																? "warning"
																: "success"
														}
													>
														{monthGroup.days.filter(
															(day) => !day.isPast && day.operationalStatus === "no_inventory"
														).length > 0
															? `${monthGroup.days.filter((day) => !day.isPast && day.operationalStatus === "no_inventory").length} días sin cupo`
															: "Cupo disponible"}
													</Badge>
													{monthGroup.days.filter(
														(day) => !day.isPast && day.operationalStatus === "closed"
													).length > 0 ? (
														<Badge variant="warning">
															{
																monthGroup.days.filter(
																	(day) => !day.isPast && day.operationalStatus === "closed"
																).length
															}{" "}
															días cerrados
														</Badge>
													) : null}
												</div>
											</div>
											<div class="mobile-calendar-grid grid grid-cols-7 gap-1 md:gap-2">
												{Array.from({ length: monthGroup.leadingBlankDays }).map((_, index) => (
													<div
														aria-hidden="true"
														data-pricing-calendar-empty-cell
														class="min-h-[4.75rem] rounded-lg border border-transparent md:min-h-32"
														data-empty-cell-index={String(index)}
													/>
												))}
												{monthGroup.days.map((day) => (
													<div
														data-pricing-day-card
														data-date={day.date}
														data-current-price={
															day.finalPrice == null ? "" : String(day.finalPrice)
														}
														data-has-price={day.finalPrice == null ? "false" : "true"}
														data-is-past={day.isPast ? "true" : "false"}
														data-base-price={
															day.baseComponent == null ? "" : String(day.baseComponent)
														}
														data-operational-status={day.operationalStatus}
														data-operational-status-label={day.operationalStatusLabel}
														data-available-units={String(day.availableUnits)}
														data-total-units={String(day.totalUnits)}
														data-booked-units={String(day.bookedUnits)}
														data-held-units={String(day.heldUnits)}
														data-restriction-summary={day.restrictionSignals.summary ?? ""}
														data-restriction-count={String(day.restrictionSignals.count)}
														data-min-stay={day.restrictionSignals.minStay ?? ""}
														data-max-stay={day.restrictionSignals.maxStay ?? ""}
														data-cta={day.restrictionSignals.cta ? "true" : "false"}
														data-ctd={day.restrictionSignals.ctd ? "true" : "false"}
														data-stop-sell={day.restrictionSignals.stopSell ? "true" : "false"}
														data-conditions-incomplete={hasIncompleteConditions ? "true" : "false"}
														data-conditions-summary={selectedPolicySummary}
														data-conditions-missing-summary={selectedPolicyMissingSummary}
														role={day.isPast ? undefined : "button"}
														tabindex={day.isPast ? undefined : "0"}
														aria-label={`Seleccionar ${day.date}: ${day.operationalStatusLabel}`}
														class:list={[
															"mobile-calendar-cell min-h-[4.75rem] rounded-lg border p-1.5 transition hover:-translate-y-0.5 hover:shadow-sm md:min-h-32 md:p-3",
															!day.isPast &&
																"cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500",
															day.operationalStatus === "sellable" &&
																"border-emerald-200 bg-emerald-50",
															day.operationalStatus === "restricted" &&
																"border-blue-200 bg-blue-50",
															day.operationalStatus === "no_price" &&
																"border-amber-200 bg-amber-50",
															day.operationalStatus === "no_inventory" &&
																"border-orange-200 bg-orange-50",
															day.operationalStatus === "closed" && "border-red-200 bg-red-50",
															day.status === "past" &&
																"border-slate-200 bg-slate-50 text-slate-500",
														]}
													>
														<div class="flex items-start justify-between gap-1">
															<div>
																<p class="text-[10px] text-slate-500 md:text-xs">{day.weekday}</p>
																<p class="text-sm font-semibold text-slate-950 md:text-lg">
																	{day.day}
																</p>
															</div>
															<span
																aria-hidden="true"
																class:list={[
																	"mt-1 h-2 w-2 rounded-full md:hidden",
																	day.operationalStatus === "sellable" && "bg-emerald-500",
																	day.operationalStatus === "restricted" && "bg-blue-500",
																	day.operationalStatus === "no_price" && "bg-amber-500",
																	day.operationalStatus === "no_inventory" && "bg-orange-500",
																	day.operationalStatus === "closed" && "bg-red-500",
																	day.status === "past" && "bg-slate-300",
																]}
															/>
														</div>
														{!day.isPast && day.finalPrice != null ? (
															<div
																data-price-primary-signal
																class="mobile-priority-signal mt-1 space-y-0.5 truncate text-[10px] text-slate-950 md:mt-3 md:text-sm"
															>
																<span data-price-default-row class="block font-semibold">
																	<span data-pricing-output>
																		{money(day.finalPrice, day.currency)}
																	</span>
																</span>
																<span
																	data-price-adjustment-row
																	class="flex hidden items-baseline gap-1"
																>
																	<span class="text-[9px] font-medium tracking-wide text-slate-400 uppercase md:text-[10px]">
																		Base
																	</span>
																	<span
																		data-pricing-base-output
																		class="font-semibold text-slate-950"
																	>
																		{day.baseComponent == null
																			? "sin materializar"
																			: money(day.baseComponent, day.currency)}
																	</span>
																</span>
																<span
																	data-price-adjustment-row
																	class="flex hidden items-baseline gap-1"
																>
																	<span class="text-[9px] font-medium tracking-wide text-slate-400 uppercase md:text-[10px]">
																		Final
																	</span>
																	<span
																		data-pricing-final-compare-output
																		class="font-semibold text-slate-950"
																	>
																		{money(day.finalPrice, day.currency)}
																	</span>
																</span>
															</div>
														) : null}
														<div class="mt-1 flex flex-wrap items-center gap-1 text-[10px] text-slate-600 md:text-xs">
															{day.availableUnits > 0 && !day.isPast ? (
																<span data-availability-status-signal class="hidden truncate">
																	{day.availableUnits} cupos
																</span>
															) : null}
															{isProfessionalCalendar && day.bookedUnits > 0 ? (
																<span data-availability-status-signal class="hidden truncate">
																	{day.bookedUnits} reservas
																</span>
															) : null}
															{isProfessionalCalendar && day.heldUnits > 0 ? (
																<span data-availability-status-signal class="hidden truncate">
																	{day.heldUnits} holds
																</span>
															) : null}
														</div>
														{!day.isPast ? (
															<div
																data-availability-detail-signal
																class="mt-1 hidden space-y-0.5 text-[10px] leading-4 text-slate-600 md:text-xs"
															>
																<p class="font-medium text-slate-700">
																	{day.utilizationPercent ?? 0}% comprometido físicamente
																</p>
																<p>
																	<span class="text-slate-400">Total</span>{" "}
																	<span class="font-semibold text-slate-900">{day.totalUnits}</span>
																</p>
																<p>
																	<span class="text-slate-400">Reservado</span>{" "}
																	<span class="font-semibold text-slate-900">
																		{day.bookedUnits}
																	</span>
																</p>
																<p>
																	<span class="text-slate-400">Retenido</span>{" "}
																	<span class="font-semibold text-slate-900">{day.heldUnits}</span>
																</p>
															</div>
														) : null}
														<div data-pricing-signal-row class="mt-1 flex flex-wrap gap-1 md:mt-2">
															<span
																data-price-status-signal
																class:list={[
																	"rounded-full px-1.5 py-0.5 text-[10px] font-medium md:px-2 md:text-[11px]",
																	day.operationalStatus === "sellable" &&
																		"bg-emerald-100 text-emerald-800",
																	day.operationalStatus === "restricted" &&
																		"bg-blue-100 text-blue-800",
																	day.operationalStatus === "no_price" &&
																		"bg-amber-100 text-amber-800",
																	day.operationalStatus === "no_inventory" &&
																		"bg-orange-100 text-orange-800",
																	day.operationalStatus === "closed" && "bg-red-100 text-red-800",
																	day.operationalStatus === "past" && "bg-slate-100 text-slate-700",
																]}
															>
																{day.operationalStatusLabel}
															</span>
															{isProfessionalCalendar && day.availableUnits <= 0 && !day.isPast ? (
																<span
																	data-availability-status-signal
																	class="hidden rounded-full bg-orange-100 px-1.5 py-0.5 text-[10px] font-medium text-orange-800 md:px-2 md:text-[11px]"
																>
																	Sin cupo
																</span>
															) : null}
															{isProfessionalCalendar &&
															!day.isPast &&
															day.finalPrice != null &&
															Number(day.ruleAdjustment ?? 0) !== 0 ? (
																<span
																	data-pricing-adjustment-line
																	data-pricing-applied-aid
																	class="hidden rounded-full bg-blue-100 px-1.5 py-0.5 text-[10px] font-medium text-blue-800 md:px-2 md:text-[11px]"
																>
																	Ajuste{" "}
																	<span data-pricing-adjustment-output>
																		{money(day.ruleAdjustment, day.currency)}
																	</span>
																</span>
															) : null}
															{!day.isPast ? (
																<span
																	data-restriction-status-signal
																	class:list={[
																		"hidden rounded-full px-1.5 py-0.5 text-[10px] font-medium md:px-2 md:text-[11px]",
																		day.restrictionSignals.hasCommercialBlocker
																			? "bg-red-100 text-red-800"
																			: day.restrictionSignals.count > 0
																				? "bg-blue-100 text-blue-800"
																				: "bg-emerald-100 text-emerald-800",
																	]}
																>
																	{day.restrictionSignals.hasCommercialBlocker
																		? "Venta cerrada"
																		: day.restrictionSignals.count > 0
																			? "Con reglas"
																			: "Venta abierta"}
																</span>
															) : null}
															{isProfessionalCalendar && day.restrictionSignals.count > 0 ? (
																<span
																	data-restriction-status-signal
																	class:list={[
																		"hidden rounded-full px-1.5 py-0.5 text-[10px] font-medium md:px-2 md:text-[11px]",
																		day.restrictionSignals.hasCommercialBlocker
																			? "bg-red-100 text-red-800"
																			: "bg-blue-100 text-blue-800",
																	]}
																>
																	<span class="md:hidden">Restr.</span>
																	<span class="hidden md:inline">
																		{day.restrictionSignals.summary ?? "Reglas de venta"}
																	</span>
																</span>
															) : null}
															{isProfessionalCalendar && day.restrictionSignals.minStay != null ? (
																<span
																	data-restriction-status-signal
																	class="hidden rounded-full bg-slate-100 px-1.5 py-0.5 text-[10px] font-medium text-slate-700 md:px-2 md:text-[11px]"
																>
																	Min. {day.restrictionSignals.minStay} noches
																</span>
															) : null}
															{isProfessionalCalendar && day.restrictionSignals.cta ? (
																<span
																	data-restriction-status-signal
																	class="hidden rounded-full bg-red-100 px-1.5 py-0.5 text-[10px] font-medium text-red-800 md:px-2 md:text-[11px]"
																>
																	No llegada
																</span>
															) : null}
															{isProfessionalCalendar && day.restrictionSignals.ctd ? (
																<span
																	data-restriction-status-signal
																	class="hidden rounded-full bg-red-100 px-1.5 py-0.5 text-[10px] font-medium text-red-800 md:px-2 md:text-[11px]"
																>
																	No salida
																</span>
															) : null}
															{isProfessionalCalendar && hasIncompleteConditions && !day.isPast ? (
																<span
																	data-conditions-signal
																	class="hidden rounded-full bg-purple-100 px-1.5 py-0.5 text-[10px] font-medium text-purple-800 md:px-2 md:text-[11px]"
																>
																	Condiciones incompletas
																</span>
															) : null}
														</div>
													</div>
												))}
											</div>
										</section>
									))}
								</div>
							</div>
							{pricingCalendarMonths.length > 1 ? (
								<div class="flex flex-wrap items-center justify-center gap-3 border-t border-slate-200 pt-4">
									<p id="pricingCalendarViewFeedback" class="text-xs text-slate-500">
										Mostrando solo el mes inicial para mantener la vista limpia.
									</p>
									<button
										id="pricingAddMonthBtn"
										type="button"
										class="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-800 shadow-sm hover:bg-slate-50"
									>
										Añadir mes siguiente
									</button>
								</div>
							) : null}
						</>
					)
				}
				<p id="pricingCalendarFeedback" class="text-sm text-slate-600"></p>
				<div
					id="pricingOperationResult"
					data-pricing-apply-result-card
					class="hidden rounded-lg border p-3 text-sm"
				>
				</div>
			</Card>
		</Section>

		<div
			id="restrictionSimpleBackdrop"
			class="pricing-extension-backdrop hidden"
			aria-hidden="true"
		>
		</div>
		<aside
			id="restrictionSimpleDrawer"
			data-restriction-simple-drawer
			class="pricing-extension-drawer hidden bg-white text-slate-800"
			aria-labelledby="restrictionSimpleTitle"
			aria-modal="true"
			role="dialog"
		>
			<div class="flex items-start justify-between gap-4 border-b border-slate-200 px-5 py-5">
				<div class="max-w-sm space-y-1.5">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Regla de venta puntual
					</p>
					<h2 id="restrictionSimpleTitle" class="text-lg font-semibold text-slate-950">
						Crear regla de venta
					</h2>
					<p class="text-sm leading-5 text-slate-600" data-restriction-simple-context>
						Selecciona una fecha o rango para crear una regla de venta sobre esta tarifa.
					</p>
				</div>
				<button
					id="restrictionSimpleCloseBtn"
					type="button"
					class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
				>
					Cerrar
				</button>
			</div>
			<form
				method="POST"
				action={routes.ratesCommercialRulesApi()}
				class="grid h-full grid-rows-[1fr_auto]"
			>
				<div class="space-y-5 overflow-y-auto px-5 py-5">
					<input type="hidden" name="action" value="create" />
					<input type="hidden" name="scope" value="rate_plan" />
					<input type="hidden" name="rate_planScopeId" value={selectedRatePlanId} />
					<input type="hidden" name="startDate" value={checkIn} data-restriction-start-date />
					<input type="hidden" name="endDate" value={checkOut} data-restriction-end-date />
					<div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
						<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Aplicación</p>
						<div class="mt-2 space-y-1">
							<p class="font-semibold text-slate-950">
								{selectedRatePlanName || "Tarifa seleccionada"}
							</p>
							<p class="text-xs text-slate-500" data-restriction-range-label>
								Rango: {checkIn} a {checkOut}
							</p>
						</div>
					</div>
					<div class="space-y-4">
						<label class="block space-y-1.5 text-sm">
							<span class="font-medium text-slate-700">Regla</span>
							<select
								name="type"
								class="h-11 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-900"
								data-simple-restriction-type
							>
								<option value="stop_sell" data-requires-value="false">Cerrar venta</option>
								<option value="min_los" data-requires-value="true" data-default-value="2">
									Estadía mínima
								</option>
								<option value="cta" data-requires-value="false">No llegada</option>
								<option value="ctd" data-requires-value="false">No salida</option>
								<option value="min_lead_time" data-requires-value="true" data-default-value="1">
									Anticipación mínima
								</option>
							</select>
						</label>
						<label class="block space-y-1.5 text-sm" data-simple-restriction-value-row>
							<span class="font-medium text-slate-700">Valor</span>
							<input
								type="number"
								name="value"
								min="1"
								step="1"
								value="2"
								class="h-11 w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900"
								data-simple-restriction-value
							/>
						</label>
					</div>
					<div class="rounded-lg border border-amber-100 bg-amber-50 px-4 py-3 text-amber-950">
						<p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Impacto</p>
						<p class="mt-2 text-sm leading-5" data-simple-restriction-impact>
							Cerrará la venta de esta tarifa en el rango seleccionado.
						</p>
						<p class="mt-1 text-xs leading-5 text-amber-900/80">
							No cambia precio ni cupo físico; solo vendibilidad.
						</p>
					</div>
				</div>
				<div class="border-t border-slate-200 bg-white px-5 py-4">
					<div class="grid grid-cols-2 gap-2">
						<Button href={`${routes.ratesMultiCalendar()}?tab=rules`} variant="secondary">
							Ver en multicalendario
						</Button>
						<Button type="submit" variant="primary"> Crear regla de venta </Button>
					</div>
				</div>
			</form>
		</aside>

		<div id="pricingExtensionBackdrop" class="pricing-extension-backdrop hidden" aria-hidden="true">
		</div>
		<aside
			id="pricingExtensionDrawer"
			data-pricing-extension-drawer
			class="pricing-extension-drawer hidden bg-white text-slate-800"
			aria-labelledby="pricingExtensionTitle"
			aria-modal="true"
			role="dialog"
		>
			<div class="flex items-start justify-between gap-3 border-b border-slate-200 p-4">
				<div class="space-y-1">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
						Extensión contextual
					</p>
					<h2 id="pricingExtensionTitle" class="text-lg font-semibold text-slate-950">
						{pricingOperationCopy.extension.drawerTitle}
					</h2>
					<p id="pricingExtensionContext" class="text-sm leading-5 text-slate-600">
						Selecciona un rango en el calendario para copiar ese precio a otros planes.
					</p>
				</div>
				<button
					id="pricingExtensionCloseBtn"
					type="button"
					class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
				>
					Cerrar
				</button>
			</div>
			<div class="space-y-4 overflow-y-auto p-4">
				<div class="grid gap-3 sm:grid-cols-2">
					<input id="pricingExtensionOperationType" type="hidden" value="fixed_override" />
					<label class="space-y-1 text-sm">
						<span id="pricingExtensionValueLabel" class="font-medium text-slate-800">
							Precio a copiar
						</span>
						<input
							id="pricingExtensionValue"
							type="number"
							min="0"
							step="1"
							class="w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900"
							placeholder="Precio"
						/>
					</label>
				</div>
				<div class="grid gap-3 sm:grid-cols-2">
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm">
						<p class="font-semibold text-slate-900">Plan de origen</p>
						<p id="pricingExtensionOrigin" class="mt-1 text-slate-600">
							{selectedRatePlanName || "Plan seleccionado"}
						</p>
					</div>
				</div>

				<details open class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm">
					<summary class="cursor-pointer font-semibold text-slate-900">
						{pricingOperationCopy.extension.targetsTitle}
					</summary>
					<p class="mt-1 text-xs leading-5 text-slate-600">
						Elige dónde quieres copiar este precio. Si solo hay un destino disponible, queda
						preseleccionado.
					</p>
					<div class="mt-3 grid gap-2" data-pricing-extension-targets>
						{
							extensionTargetOptions.map(({ row, isPricingReady }) => (
								<label
									class:list={[
										"flex items-start gap-2 rounded border p-2",
										isPricingReady
											? "border-slate-200 bg-white hover:bg-slate-50"
											: "border-amber-200 bg-amber-50 text-amber-950",
									]}
								>
									<input
										type="checkbox"
										data-pricing-extension-target
										value={String(row.ratePlanId)}
										checked={extensionTargetOptions.length === 1 && isPricingReady}
										disabled={!isPricingReady}
										class="mt-1 h-4 w-4 rounded border-slate-300"
									/>
									<span>
										<span class="block font-medium text-slate-900">{row.ratePlanName}</span>
										<span class="block text-xs text-slate-600">
											{row.productName} · {row.variantName}
										</span>
										<span class="mt-1 block text-xs">
											{isPricingReady
												? "Listo para recibir este precio."
												: "Necesita un precio configurado antes de copiar."}
										</span>
									</span>
								</label>
							))
						}
					</div>
					<p id="pricingExtensionTargetHint" class="mt-2 text-xs text-slate-500">
						Elige solo planes donde este mismo precio tenga sentido.
					</p>
				</details>

				<input id="pricingExtensionPreviewDays" type="hidden" value="7" />
				<input id="pricingExtensionPriority" type="hidden" value="1000" />

				<div
					id="pricingExtensionPreview"
					class="hidden rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm"
				>
				</div>
				<div
					id="pricingExtensionResult"
					class="hidden rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm"
				>
				</div>
			</div>
			<div class="border-t border-slate-200 bg-white p-4">
				<p id="pricingExtensionFeedback" class="mb-3 text-sm text-slate-600">
					Revisa el impacto antes de extender el cambio.
				</p>
				<div class="grid grid-cols-2 gap-2">
					<button
						id="pricingExtensionPreviewBtn"
						type="button"
						class="rounded bg-blue-700 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-800 disabled:opacity-50"
					>
						Revisar extensión
					</button>
					<button
						id="pricingExtensionApplyBtn"
						type="button"
						disabled
						class="rounded border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50 disabled:opacity-50"
					>
						Revisa primero
					</button>
				</div>
			</div>
		</aside>

		{
			isProfessionalCalendar && (
				<>
					<div
						id="pricingCalendarHistoryBackdrop"
						class="pricing-extension-backdrop hidden"
						aria-hidden="true"
					/>
					<aside
						id="pricingCalendarHistoryDrawer"
						data-calendar-history-drawer
						class="pricing-extension-drawer hidden bg-white text-slate-800"
						aria-labelledby="pricingCalendarHistoryTitle"
						aria-modal="true"
						role="dialog"
					>
						<div class="flex items-start justify-between gap-3 border-b border-slate-200 p-4">
							<div class="space-y-1">
								<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
									Herramienta Pro
								</p>
								<h2 id="pricingCalendarHistoryTitle" class="text-lg font-semibold text-slate-950">
									Historial del calendario
								</h2>
								<p class="text-sm leading-5 text-slate-600">
									Cambios de precio, disponibilidad y reglas de venta que afectan la operación.
								</p>
							</div>
							<button
								id="pricingCalendarHistoryCloseBtn"
								type="button"
								class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
							>
								Cerrar
							</button>
						</div>
						<div class="overflow-y-auto p-4">
							<Card className="space-y-4 border-0 bg-white text-slate-800 shadow-none">
								<div class="flex flex-wrap gap-2" aria-label="Filtrar historial del calendario">
									<button
										type="button"
										class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
										data-calendar-history-filter="all"
									>
										Todo
									</button>
									<button
										type="button"
										class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
										data-calendar-history-filter="fecha"
									>
										Fecha
									</button>
								</div>
								{calendarHistory.length === 0 ? (
									<p class="text-sm text-slate-600">
										Todavía no hay cambios recientes para mostrar en este calendario.
									</p>
								) : (
									<ol class="space-y-3">
										{calendarHistory.map((item) => (
											<li
												class={`rounded-2xl border p-3 ${historyToneClasses[item.tone] ?? historyToneClasses.neutral}`}
												data-calendar-history-item
												data-calendar-history-object={item.objectType}
											>
												<div class="flex flex-wrap items-start justify-between gap-3">
													<div class="min-w-0">
														<div class="flex flex-wrap items-center gap-2">
															<p class="font-semibold">{item.title}</p>
															<span class="rounded-full bg-white/70 px-2 py-0.5 text-[11px] font-semibold tracking-wide uppercase opacity-80">
																{item.objectLabel}
															</span>
														</div>
														<p class="mt-1 text-sm opacity-80">{item.description}</p>
														<p class="mt-1 text-xs opacity-70">{item.meta}</p>
													</div>
													<time class="text-xs font-medium opacity-70">
														{formatHistoryDate(item.createdAt)}
													</time>
												</div>
												<div class="mt-3 grid gap-2 text-xs sm:grid-cols-2">
													<div class="rounded-xl bg-white/70 p-2">
														<p class="font-semibold tracking-wide uppercase opacity-60">Antes</p>
														<p class="mt-1">{item.beforeLabel ?? "Sin estado anterior visible"}</p>
													</div>
													<div class="rounded-xl bg-white/70 p-2">
														<p class="font-semibold tracking-wide uppercase opacity-60">Después</p>
														<p class="mt-1">{item.afterLabel ?? "Cambio aplicado"}</p>
													</div>
												</div>
											</li>
										))}
									</ol>
								)}
							</Card>
						</div>
					</aside>
				</>
			)
		}

		<script is:inline>
			document.querySelectorAll("[data-calendar-history-filter]").forEach((button) => {
				button.addEventListener("click", () => {
					const filter = button.getAttribute("data-calendar-history-filter") || "all"
					document.querySelectorAll("[data-calendar-history-item]").forEach((item) => {
						const objectType = item.getAttribute("data-calendar-history-object") || ""
						item.classList.toggle("hidden", filter !== "all" && objectType !== filter)
					})
				})
			})
		</script>
	</div>

	<style is:global>
		.pricing-extension-backdrop:not(.hidden) {
			position: fixed;
			inset: 0;
			z-index: 60;
			background: rgb(15 23 42 / 0.24);
			backdrop-filter: blur(2px);
		}

		.pricing-extension-drawer:not(.hidden) {
			position: fixed;
			inset-block: 0;
			inset-inline-end: 0;
			z-index: 70;
			display: grid;
			width: min(30rem, calc(100vw - 1rem));
			grid-template-rows: auto 1fr auto;
			border-left: 1px solid rgb(226 232 240);
			box-shadow: -24px 0 70px rgb(15 23 42 / 0.2);
			animation: pricing-extension-drawer-enter 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
		}

		@media (max-width: 767px), (max-height: 480px) and (pointer: coarse) {
			.pricing-extension-drawer:not(.hidden) {
				inset-inline: 0.75rem;
				inset-block-start: auto;
				inset-block-end: calc(0.75rem + env(safe-area-inset-bottom));
				width: auto;
				max-height: min(86dvh, 44rem);
				border: 1px solid rgb(226 232 240);
				border-radius: 1rem;
				box-shadow: 0 28px 90px rgb(15 23 42 / 0.28);
				animation-name: pricing-extension-sheet-enter;
			}
		}

		@keyframes pricing-extension-drawer-enter {
			from {
				opacity: 0;
				transform: translateX(1rem);
			}
			to {
				opacity: 1;
				transform: translateX(0);
			}
		}

		@keyframes pricing-extension-sheet-enter {
			from {
				opacity: 0;
				transform: translateY(1rem) scale(0.98);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}
	</style>

	<div
		hidden
		id="pricingRangeData"
		data-range={JSON.stringify({
			days: pricingRangeDays,
			ratePlans: pricingRatePlanCatalog,
			ratePlanId: selectedRatePlanId,
			ratePlanName: selectedRatePlanName,
			variantId: selectedVariantId,
			focus: String(Astro.url.searchParams.get("focus") ?? "").trim(),
			checkIn,
			checkOut,
			currency: surface.baseline.currency,
			copy: pricingOperationCopy,
			extensionOperations: pricingExtensionOperationOptions,
			isProfessional: isProfessionalCalendar,
			operationalDays: operationalCalendarDays,
		})}
	>
	</div>

	<script>
		import { initRatesCalendar } from "@/lib/rates/calendarOperationalController"

		initRatesCalendar()
	</script>
	<MobileCalendarSheetStyles />
</WorkspaceLayout>
