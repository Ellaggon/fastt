---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import MobileCalendarSheetStyles from "@/components/rates/MobileCalendarSheetStyles.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { and, db, eq, PriceRule } from "astro:db"
import { requireProvider } from "@/lib/auth/requireProvider"
import {
	loadPricingAutomationSurface,
	type PricingAutomationTemplate,
} from "@/lib/pricing/pricingAutomationSurface"
import { pricingExtensionOperationOptions } from "@/lib/pricing/pricingExtensionPresenter"
import { pricingOperationCopy } from "@/lib/pricing/pricingOperationCopy"
import { buildPricingCalendarSurface } from "@/lib/rates/calendarSurfaces"
import { loadRatePlansReadModel } from "@/lib/rates/loadRatePlansReadModel"
import { routes } from "@/lib/routes"
import { ratePlanPricingReadRepository } from "@/container"
import { resolvePolicyDateRange } from "@/modules/policies/public"
import { POST as createPricingRulePost } from "@/pages/api/pricing/rules/v2/create"

const auth = await requireProvider(Astro.request).catch((e: any) => {
	if (e instanceof Response && e.status === 401) return "__REDIRECT_LOGIN__"
	if (e instanceof Response && e.status === 403) return "__REDIRECT_PROVIDER__"
	throw e
})
if (auth === "__REDIRECT_LOGIN__") return Astro.redirect("/SignInPage")
if (auth === "__REDIRECT_PROVIDER__") return Astro.redirect(routes.provider())

let actionError: string | null = null
let actionErrorTitle = "No se pudo guardar la ayuda recurrente"

const mapTemplatePayload = (template: PricingAutomationTemplate, rawValue: number) => {
	const value =
		template.kind === "fixed_discount" ? -Math.abs(rawValue) : Math.max(0, Number(rawValue))
	return {
		type: template.internalType,
		value,
		contextKey: template.contextKey,
	}
}

const eligibilityForForm = (kind: string, form: FormData): Record<string, number> => {
	if (kind === "early_bird") {
		const minLeadDays = Number(form.get("minLeadDays") ?? 30)
		if (!Number.isFinite(minLeadDays) || minLeadDays < 1) {
			throw new Error("Reserva anticipada necesita al menos 1 día de anticipación")
		}
		return { minLeadDays: Math.trunc(minLeadDays) }
	}
	if (kind === "last_minute") {
		const maxLeadDays = Number(form.get("maxLeadDays") ?? 3)
		if (!Number.isFinite(maxLeadDays) || maxLeadDays < 1) {
			throw new Error("Último minuto necesita una ventana de llegada de al menos 1 día")
		}
		return { maxLeadDays: Math.trunc(maxLeadDays) }
	}
	if (kind === "los_discount") {
		const minNights = Number(form.get("minNights") ?? 5)
		if (!Number.isFinite(minNights) || minNights < 1) {
			throw new Error("El descuento por estadía necesita al menos 1 noche")
		}
		return { minNights: Math.trunc(minNights) }
	}
	return {}
}

function jsonRequest(path: string, body: Record<string, unknown>) {
	const headers = new Headers({ "Content-Type": "application/json" })
	const cookie = Astro.request.headers.get("cookie")
	if (cookie) headers.set("cookie", cookie)
	return new Request(new URL(path, Astro.url), {
		method: "POST",
		headers,
		body: JSON.stringify(body),
	})
}

async function deletePriceRuleDirectly(ruleId: string, ratePlanId: string) {
	const existing = await db
		.select({ id: PriceRule.id })
		.from(PriceRule)
		.where(and(eq(PriceRule.id, ruleId), eq(PriceRule.ratePlanId, ratePlanId)))
		.get()
	if (!existing?.id) {
		throw new Error("La ayuda recurrente ya no existe o pertenece a otro plan")
	}

	const statement = db
		.delete(PriceRule)
		.where(and(eq(PriceRule.id, ruleId), eq(PriceRule.ratePlanId, ratePlanId)))
	if (typeof (statement as any).run === "function") {
		await (statement as any).run()
	} else {
		await statement
	}

	const stillThere = await db
		.select({ id: PriceRule.id })
		.from(PriceRule)
		.where(and(eq(PriceRule.id, ruleId), eq(PriceRule.ratePlanId, ratePlanId)))
		.get()
	if (stillThere?.id) {
		throw new Error("No se pudo confirmar la eliminación. Intenta nuevamente.")
	}
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData()
	const action = String(form.get("action") ?? "").trim()
	if (action === "create-pricing-automation") {
		try {
			const automation = await loadPricingAutomationSurface(auth.providerId)
			const ratePlanId = String(form.get("ratePlanId") ?? "").trim()
			const kind = String(form.get("kind") ?? "").trim()
			const template = automation.templates.find((item) => item.kind === kind)
			if (!template) throw new Error("Tipo de regla automática no soportado")
			if (!automation.ratePlanOptions.some((item) => item.id === ratePlanId)) {
				throw new Error("El plan tarifario no está disponible para este proveedor")
			}
			const value = Number(form.get("value") ?? Number.NaN)
			if (!Number.isFinite(value) || value < 0)
				throw new Error("El valor de la regla automática debe ser cero o mayor")
			const priority = Number(form.get("priority") ?? 20)
			if (!Number.isFinite(priority) || priority < 0 || priority > 1000) {
				throw new Error("La prioridad debe estar entre 0 y 1000")
			}
			const dateFrom = String(form.get("dateFrom") ?? "").trim()
			const dateTo = String(form.get("dateTo") ?? "").trim()
			const mapped = mapTemplatePayload(template, value)
			const body: Record<string, unknown> = {
				ratePlanId,
				type: mapped.type,
				value: mapped.value,
				priority,
				contextKey: mapped.contextKey,
			}
			if (dateFrom) body.dateFrom = dateFrom
			if (dateTo) body.dateTo = dateTo
			Object.assign(body, eligibilityForForm(kind, form))

			const response = await createPricingRulePost({
				request: jsonRequest("/api/pricing/rules/v2/create", body),
				url: new URL("/api/pricing/rules/v2/create", Astro.url),
			} as any)
			if (!response.ok) {
				const payload = await response.json().catch(() => null)
				throw new Error(String(payload?.error ?? "No se pudo crear la regla automática"))
			}
			return Astro.redirect(`${routes.pricing()}?success=automation-created#pricing-automation`)
		} catch (error) {
			actionErrorTitle = "No se pudo crear la ayuda recurrente"
			actionError = error instanceof Error ? error.message : "Falló la regla automática"
		}
	}
	if (action === "delete-pricing-automation") {
		try {
			const automation = await loadPricingAutomationSurface(auth.providerId)
			const ruleId = String(form.get("ruleId") ?? "").trim()
			const ratePlanId = String(form.get("ratePlanId") ?? "").trim()
			if (!ruleId || !ratePlanId) {
				throw new Error("Falta identificar la ayuda recurrente")
			}
			if (!automation.rules.some((rule) => rule.id === ruleId && rule.ratePlanId === ratePlanId)) {
				throw new Error("La ayuda recurrente no está disponible para este proveedor")
			}
			await deletePriceRuleDirectly(ruleId, ratePlanId)
			return Astro.redirect(`${routes.pricing()}?success=automation-deleted#pricing-automation`)
		} catch (error) {
			actionErrorTitle = "No se pudo eliminar la ayuda recurrente"
			actionError = error instanceof Error ? error.message : "Falló la ayuda recurrente"
		}
	}
}

const { checkIn, checkOut } = resolvePolicyDateRange(Astro.url)
const rows = await loadRatePlansReadModel({
	request: Astro.request,
	checkIn,
	checkOut,
	channel: "web",
})
const surface = await buildPricingCalendarSurface({
	rows,
	ratePlanId: Astro.url.searchParams.get("ratePlanId"),
	month: Astro.url.searchParams.get("month"),
	visibleMonths: 2,
})
const selected = surface.selectedRatePlan
const vocabulary = surface.vocabulary
const selectedPolicyCoverage = selected?.policyCoverage
const hasIncompleteConditions = selectedPolicyCoverage ? !selectedPolicyCoverage.isComplete : true
const selectedPolicySummary =
	String(selected?.policySummary ?? "").trim() ||
	(hasIncompleteConditions ? "Faltan condiciones de la tarifa" : "Condiciones listas")
const selectedPolicyMissingSummary = selectedPolicyCoverage?.missingCategories?.length
	? `Faltan ${selectedPolicyCoverage.missingCategories.length} categoría${selectedPolicyCoverage.missingCategories.length === 1 ? "" : "s"} del contrato`
	: ""

function money(amount: number | null, currency: string): string {
	if (amount == null) return "Sin precio"
	return `${currency} ${Number(amount).toFixed(0)}`
}

const primaryMonthDays = surface.days.filter((day) => day.date.startsWith(surface.month))
const primaryMissingDays = primaryMonthDays.filter((day) => day.status === "missing").length
const primaryNoInventoryDays = primaryMonthDays.filter(
	(day) => !day.isPast && day.operationalStatus === "no_inventory"
).length
const primaryClosedDays = primaryMonthDays.filter(
	(day) => !day.isPast && day.operationalStatus === "closed"
).length
const pricingRangeDays = surface.days.map((day) => ({
	date: day.date,
	status: day.status,
	ruleAdjustment: day.ruleAdjustment,
	restrictionCount: day.restrictionSignals.count,
	restrictionBlocker: day.restrictionSignals.hasCommercialBlocker,
	availableUnits: day.availableUnits,
	bookedUnits: day.bookedUnits,
	heldUnits: day.heldUnits,
	operationalStatus: day.operationalStatus,
}))
const operationalCalendarDays = surface.days.map((day) => ({
	date: day.date,
	weekday: day.weekday,
	day: day.day,
	price: money(day.finalPrice, day.currency),
	basePrice: day.baseComponent == null ? "Sin base" : money(day.baseComponent, day.currency),
	currency: day.currency,
	availableUnits: day.availableUnits,
	totalUnits: day.totalUnits,
	bookedUnits: day.bookedUnits,
	heldUnits: day.heldUnits,
	status: day.operationalStatus,
	statusLabel: day.operationalStatusLabel,
	priceStatus: day.status,
	capacityLabel: day.capacitySignalLabel,
	utilizationPercent: day.utilizationPercent,
	restrictionSummary: day.restrictionSignals.summary,
	restrictionCount: day.restrictionSignals.count,
	stopSell: day.restrictionSignals.stopSell,
	cta: day.restrictionSignals.cta,
	ctd: day.restrictionSignals.ctd,
	minStay: day.restrictionSignals.minStay,
	maxStay: day.restrictionSignals.maxStay,
	minLeadTime: day.restrictionSignals.minLeadTime,
	maxLeadTime: day.restrictionSignals.maxLeadTime,
	conditionsIncomplete: hasIncompleteConditions,
	conditionsSummary: selectedPolicySummary,
	conditionsMissingSummary: selectedPolicyMissingSummary,
}))
const monthFormatter = new Intl.DateTimeFormat("es-CL", {
	month: "long",
	year: "numeric",
	timeZone: "UTC",
})
const pricingCalendarMonths = Array.from(
	surface.days.reduce((months, day) => {
		const key = day.date.slice(0, 7)
		const days = months.get(key) ?? []
		days.push(day)
		months.set(key, days)
		return months
	}, new Map<string, typeof surface.days>())
).map(([month, days]) => ({
	month,
	label: monthFormatter.format(new Date(`${month}-01T12:00:00.000Z`)),
	days,
	leadingBlankDays: days[0] ? (new Date(`${days[0].date}T00:00:00.000Z`).getUTCDay() + 6) % 7 : 0,
}))
const pricingRatePlanCatalog = rows.map((row) => ({
	ratePlanId: String(row.ratePlanId),
	ratePlanName: String(row.ratePlanName),
	productName: String(row.productName),
	variantName: String(row.variantName),
}))
const selectedRatePlanId = String(selected?.ratePlanId ?? "")
const selectedRatePlanName = String(selected?.ratePlanName ?? "")
const selectedVariantId = String(selected?.variantId ?? "")
function pricingCalendarHref(month: string): string {
	const params = new URLSearchParams()
	if (selectedRatePlanId) params.set("ratePlanId", selectedRatePlanId)
	params.set("month", month)
	return `${routes.pricing()}?${params.toString()}`
}
const extensionTargetOptions = await Promise.all(
	rows
		.filter((row) => String(row.ratePlanId) !== selectedRatePlanId)
		.map(async (row) => {
			const pricingSummary = await ratePlanPricingReadRepository.getRatePlanPricingSummary(
				String(row.ratePlanId)
			)
			return {
				row,
				isPricingReady: Boolean(pricingSummary),
				basePrice: pricingSummary?.basePrice ?? null,
				currency: pricingSummary?.currency ?? null,
			}
		})
)
const automationSurface = await loadPricingAutomationSurface(auth.providerId)
const automationDefaultRatePlanId = automationSurface.ratePlanOptions[0]?.id ?? ""
const automationTemplates = automationSurface.templates
const automationDefaultTemplate =
	automationTemplates.find((item) => item.kind === "percentage_discount") ??
	automationTemplates[0] ??
	automationSurface.templates[0]
const automationTemplateCatalog = automationSurface.templates.map((template) => ({
	kind: template.kind,
	label: template.label,
	shortLabel: template.shortLabel,
	description: template.description,
	internalType: template.internalType,
	defaultValue: template.defaultValue,
	valueSuffix: template.valueSuffix,
	contextKey: template.contextKey,
	eligibilityHint: template.eligibilityHint ?? "",
}))
const automationTemplateGroups = [
	{
		label: "Descuentos",
		templates: automationTemplates.filter((template) =>
			[
				"percentage_discount",
				"fixed_discount",
				"early_bird",
				"last_minute",
				"los_discount",
			].includes(template.kind)
		),
	},
	{
		label: "Aumentos",
		templates: automationTemplates.filter((template) =>
			["percentage_markup", "fixed_markup"].includes(template.kind)
		),
	},
	{
		label: "Precio fijo",
		templates: automationTemplates.filter((template) => template.kind === "manual_override"),
	},
].filter((group) => group.templates.length > 0)
const success = String(Astro.url.searchParams.get("success") ?? "").trim()
const visibleSuccess = actionError ? "" : success
const statusVariant = {
	active: "success",
	inactive: "neutral",
} as const
---

<WorkspaceLayout title="Calendario">
	<div class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Habitaciones y tarifas · Calendario
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Calendario</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Opera precio, cupo, venta y condiciones por fecha desde una sola superficie. Las
					herramientas avanzadas siguen disponibles dentro de su contexto.
				</p>
			</div>
		</header>

		{
			actionError && (
				<Card className="border-red-200 bg-red-50 text-red-900">
					<p class="text-sm font-semibold">{actionErrorTitle}</p>
					<p class="mt-1 text-sm">{actionError}</p>
				</Card>
			)
		}
		{
			visibleSuccess === "automation-created" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">Ayuda recurrente creada.</p>
					<p class="mt-1 text-sm">
						La regla quedó guardada y seguirá actuando cuando el rango o la elegibilidad coincidan.
					</p>
				</Card>
			)
		}
		{
			visibleSuccess === "automation-deleted" && (
				<Card className="border-green-200 bg-green-50 text-green-900">
					<p class="text-sm font-semibold">Ayuda recurrente eliminada.</p>
					<p class="mt-1 text-sm">
						Dejó de actuar automáticamente. Si la cobertura necesita refrescarse, el calendario la
						actualizará con el próximo recompute.
					</p>
				</Card>
			)
		}

		<Section
			title="Calendario operativo"
			description={`Selecciona ${vocabulary.ratePlan}, revisa vendibilidad diaria y toca fechas para operar precio, disponibilidad, restricciones y contrato de tarifa.`}
		>
			<Card className="space-y-5 bg-white text-slate-800">
				<form method="get" class="grid gap-3 lg:grid-cols-[1.6fr_0.8fr_auto] lg:items-end">
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">{vocabulary.scopeRatePlan}</span>
						<select name="ratePlanId" class="w-full rounded-lg border border-slate-300 px-3 py-2">
							{
								rows.map((row) => (
									<option
										value={String(row.ratePlanId)}
										selected={selected?.ratePlanId === row.ratePlanId}
									>
										{row.productName} · {row.variantName} · {row.ratePlanName}
									</option>
								))
							}
						</select>
					</label>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Mes inicial</span>
						<input
							type="month"
							name="month"
							value={surface.month}
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
						/>
					</label>
					<Button type="submit" variant="primary">Ver calendario</Button>
				</form>

				<div
					class="flex flex-wrap items-center justify-between gap-3 border-y border-slate-200 py-3"
				>
					<div class="flex flex-wrap items-center gap-2">
						<Button href={pricingCalendarHref(surface.previousMonth)} variant="secondary" size="sm">
							Mes anterior
						</Button>
						<Button href={pricingCalendarHref(surface.nextMonth)} variant="secondary" size="sm">
							Mes siguiente
						</Button>
						<Badge variant={primaryMissingDays > 0 ? "warning" : "success"}>
							{primaryMissingDays > 0 ? `${primaryMissingDays} dias sin precio` : "Cobertura lista"}
						</Badge>
						<Badge variant={primaryNoInventoryDays > 0 ? "warning" : "success"}>
							{
								primaryNoInventoryDays > 0
									? `${primaryNoInventoryDays} dias sin cupo`
									: "Cupo visible"
							}
						</Badge>
						<Badge variant={primaryClosedDays > 0 ? "warning" : "success"}>
							{primaryClosedDays > 0 ? `${primaryClosedDays} dias cerrados` : "Venta abierta"}
						</Badge>
						<Badge variant={hasIncompleteConditions ? "warning" : "success"}>
							{hasIncompleteConditions ? "Condiciones incompletas" : "Condiciones listas"}
						</Badge>
						<button
							id="pricingAppliedAidToggle"
							type="button"
							class="rounded-full bg-blue-100 px-2 py-1 text-xs font-medium text-blue-800 hover:bg-blue-200"
							aria-pressed="false"
						>
							Ajuste solo si existe
						</button>
					</div>
					<div class="flex flex-wrap items-center gap-2">
						<Button
							id="generatePricingCoverageBtn"
							type="button"
							variant="ghost"
							size="sm"
							data-rate-plan-id={String(selected?.ratePlanId ?? "")}
							data-from={surface.startDate}
							data-to={surface.endDate}
						>
							Actualizar calendario
						</Button>
					</div>
				</div>
				<p class="text-xs text-slate-500 sm:hidden">
					Toca una fecha para editarla; toca otra fecha para crear un rango.
				</p>

				{
					!selected ? (
						<div class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
							No hay {vocabulary.ratePlanPlural} para operar pricing todavia.
						</div>
					) : (
						<>
							<div
								id="pricingSheetBackdrop"
								class="mobile-calendar-sheet-backdrop hidden"
								aria-hidden="true"
							/>
							<div
								id="pricingRangePanel"
								data-mobile-calendar-action-sheet
								data-sheet-state="compact"
								class="mobile-calendar-action-sheet sticky top-3 z-20 hidden rounded-lg border border-blue-200 bg-blue-50/95 p-4 text-sm text-blue-950 shadow-sm backdrop-blur"
							>
								<div
									data-mobile-sheet-handle
									class="mobile-sheet-handle mx-auto mb-3 hidden h-1 w-12 rounded-full bg-blue-200"
								/>
								<div class="grid gap-3 md:grid-cols-[minmax(16rem,1fr)_auto] md:items-start">
									<div class="min-w-0 space-y-1.5">
										<div class="flex items-start justify-between gap-2">
											<p class="text-sm leading-5 font-semibold sm:text-base">
												Cambio manual de precio
											</p>
											<div class="flex items-center gap-1 md:hidden">
												<button
													id="pricingSheetExpandBtn"
													type="button"
													class="rounded border border-blue-200 bg-white px-2 py-1 text-[11px] font-semibold text-blue-900"
												>
													Expandir
												</button>
												<button
													id="pricingSheetCloseBtn"
													type="button"
													class="rounded border border-blue-200 bg-white px-2 py-1 text-[11px] font-semibold text-blue-900"
												>
													Cerrar
												</button>
											</div>
										</div>
										<p id="pricingRangeSummary" class="text-xs text-blue-900 sm:text-sm">
											Toca una fecha para editarla o toca otra para completar el rango.
										</p>
										<p id="pricingRangePreview" class="hidden text-xs text-blue-800 sm:block" />
									</div>
									<div class="flex w-full flex-wrap items-center gap-2 md:w-auto md:justify-end">
										<div class="hidden w-full gap-1 overflow-x-auto pb-1 sm:flex sm:flex-wrap sm:overflow-visible sm:pb-0">
											<button
												type="button"
												data-pricing-range-preset="visible_weekend"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Fin de semana
											</button>
											<button
												type="button"
												data-pricing-range-preset="visible_month"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Vista visible
											</button>
											<button
												type="button"
												data-pricing-range-preset="next_7"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Prox. 7 dias
											</button>
											<button
												type="button"
												data-pricing-range-preset="next_30"
												class="shrink-0 rounded border border-blue-200 bg-white px-2 py-1 text-xs font-medium text-blue-950 hover:bg-blue-100"
											>
												Prox. 30 dias
											</button>
										</div>
										<div class="grid w-full gap-2 sm:w-auto sm:grid-cols-[10rem_auto_auto_auto_auto] sm:items-start">
											<input id="pricingRangeOperationType" type="hidden" value="fixed_override" />
											<label class="space-y-1">
												<span id="pricingRangeValueLabel" class="text-xs font-medium text-blue-950">
													Precio final
												</span>
												<input
													id="pricingRangeValue"
													type="number"
													min="0"
													step="1"
													placeholder="Precio"
													class="w-full rounded border border-blue-200 px-3 py-2 text-slate-900"
												/>
											</label>
											<button
												id="pricingRangePreviewBtn"
												type="button"
												class="hidden rounded border border-blue-300 px-3 py-2 text-xs font-semibold text-blue-950 hover:bg-blue-100 sm:mt-5 sm:block"
											>
												{pricingOperationCopy.reviewAction}
											</button>
											<button
