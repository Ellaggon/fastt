																	: money(day.baseComponent, day.currency)}
															</span>
														</div>
														<div class="mt-1 flex flex-wrap items-center gap-1 text-[10px] text-slate-600 md:text-xs">
															{day.availableUnits > 0 && !day.isPast ? (
																<span class="truncate">{day.availableUnits} cupos</span>
															) : null}
															{day.bookedUnits > 0 ? (
																<span class="truncate">{day.bookedUnits} reservas</span>
															) : null}
															{day.heldUnits > 0 ? (
																<span class="truncate">{day.heldUnits} holds</span>
															) : null}
														</div>
														<div data-pricing-signal-row class="mt-1 flex flex-wrap gap-1 md:mt-2">
															<span
																class:list={[
																	"rounded-full px-1.5 py-0.5 text-[10px] font-medium md:px-2 md:text-[11px]",
																	day.operationalStatus === "sellable" &&
																		"bg-emerald-100 text-emerald-800",
																	day.operationalStatus === "restricted" &&
																		"bg-blue-100 text-blue-800",
																	day.operationalStatus === "no_price" &&
																		"bg-amber-100 text-amber-800",
																	day.operationalStatus === "no_inventory" &&
																		"bg-orange-100 text-orange-800",
																	day.operationalStatus === "closed" && "bg-red-100 text-red-800",
																	day.operationalStatus === "past" && "bg-slate-100 text-slate-700",
																]}
															>
																{day.operationalStatusLabel}
															</span>
															{day.availableUnits <= 0 && !day.isPast ? (
																<span class="rounded-full bg-orange-100 px-1.5 py-0.5 text-[10px] font-medium text-orange-800 md:px-2 md:text-[11px]">
																	Sin cupo
																</span>
															) : null}
															{Number(day.ruleAdjustment ?? 0) !== 0 ? (
																<span
																	data-pricing-adjustment-line
																	data-pricing-applied-aid
																	class="hidden rounded-full bg-blue-100 px-1.5 py-0.5 text-[10px] font-medium text-blue-800 md:px-2 md:text-[11px]"
																>
																	Ajuste{" "}
																	<span data-pricing-adjustment-output>
																		{money(day.ruleAdjustment, day.currency)}
																	</span>
																</span>
															) : null}
															{day.restrictionSignals.count > 0 ? (
																<span
																	class:list={[
																		"rounded-full px-1.5 py-0.5 text-[10px] font-medium md:px-2 md:text-[11px]",
																		day.restrictionSignals.hasCommercialBlocker
																			? "bg-red-100 text-red-800"
																			: "bg-blue-100 text-blue-800",
																	]}
																>
																	<span class="md:hidden">Restr.</span>
																	<span class="hidden md:inline">
																		{day.restrictionSignals.summary ?? "Reglas de venta"}
																	</span>
																</span>
															) : null}
															{day.restrictionSignals.minStay != null ? (
																<span class="rounded-full bg-slate-100 px-1.5 py-0.5 text-[10px] font-medium text-slate-700 md:px-2 md:text-[11px]">
																	Min. {day.restrictionSignals.minStay} noches
																</span>
															) : null}
															{day.restrictionSignals.cta ? (
																<span class="rounded-full bg-red-100 px-1.5 py-0.5 text-[10px] font-medium text-red-800 md:px-2 md:text-[11px]">
																	No llegada
																</span>
															) : null}
															{day.restrictionSignals.ctd ? (
																<span class="rounded-full bg-red-100 px-1.5 py-0.5 text-[10px] font-medium text-red-800 md:px-2 md:text-[11px]">
																	No salida
																</span>
															) : null}
															{hasIncompleteConditions ? (
																<span
																	data-conditions-signal
																	class="hidden rounded-full bg-purple-100 px-1.5 py-0.5 text-[10px] font-medium text-purple-800 md:px-2 md:text-[11px]"
																>
																	Condiciones incompletas
																</span>
															) : null}
														</div>
													</div>
												))}
											</div>
										</section>
									))}
								</div>
							</div>
							{pricingCalendarMonths.length > 1 ? (
