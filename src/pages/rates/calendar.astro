					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm">
						<p class="font-semibold text-slate-900">Tarifa</p>
						<p class="mt-1 text-slate-600">{selectedRatePlanName || "Tarifa seleccionada"}</p>
						<p class="mt-1 text-xs text-slate-500" data-restriction-range-label>
							Rango: {checkIn} a {checkOut}
						</p>
					</div>
					<label class="space-y-1 text-sm">
						<span class="font-medium text-slate-700">Regla</span>
						<select
							name="type"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							data-simple-restriction-type
						>
							<option value="stop_sell" data-requires-value="false">Cerrar venta</option>
							<option value="min_los" data-requires-value="true" data-default-value="2">
								Estadía mínima
							</option>
							<option value="cta" data-requires-value="false">No llegada</option>
							<option value="ctd" data-requires-value="false">No salida</option>
							<option value="min_lead_time" data-requires-value="true" data-default-value="1">
								Anticipación mínima
							</option>
						</select>
					</label>
					<label class="space-y-1 text-sm" data-simple-restriction-value-row>
						<span class="font-medium text-slate-700">Valor</span>
						<input
							type="number"
							name="value"
							min="1"
							step="1"
							value="2"
							class="w-full rounded-lg border border-slate-300 px-3 py-2"
							data-simple-restriction-value
						/>
					</label>
					<div class="space-y-2">
						<p class="text-sm font-medium text-slate-700">Días aplicables</p>
						<div class="flex flex-wrap gap-2">
							{
								[
									[1, "Lun"],
									[2, "Mar"],
									[3, "Mié"],
									[4, "Jue"],
									[5, "Vie"],
									[6, "Sáb"],
									[7, "Dom"],
								].map(([value, label]) => (
									<label class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm">
										<input type="checkbox" name="validDays" value={value} />
										<span>{label}</span>
									</label>
								))
							}
						</div>
						<p class="text-xs leading-5 text-slate-500">
							Si no marcas días, la regla aplica a todos los días del rango.
						</p>
					</div>
					<Card className="border-amber-100 bg-amber-50 text-amber-950 shadow-none">
						<p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Impacto</p>
						<p class="mt-2 text-sm leading-5" data-simple-restriction-impact>
							Cerrará la venta de esta tarifa en el rango seleccionado.
						</p>
						<p class="mt-1 text-xs leading-5 text-amber-900/80">
							No cambia precio ni cupo físico; solo vendibilidad.
						</p>
					</Card>
				</div>
				<div class="border-t border-slate-200 bg-white p-4">
					<div class="grid grid-cols-2 gap-2">
						<Button href={routes.rateRestrictions()} variant="secondary"> Avanzado </Button>
						<Button type="submit" variant="primary"> Crear restricción </Button>
					</div>
				</div>
			</form>
		</aside>

		<div id="pricingExtensionBackdrop" class="pricing-extension-backdrop hidden" aria-hidden="true">
		</div>
		<aside
			id="pricingExtensionDrawer"
			data-pricing-extension-drawer
			class="pricing-extension-drawer hidden bg-white text-slate-800"
			aria-labelledby="pricingExtensionTitle"
			aria-modal="true"
			role="dialog"
		>
			<div class="flex items-start justify-between gap-3 border-b border-slate-200 p-4">
				<div class="space-y-1">
					<p class="text-xs font-semibold uppercase tracking-wide text-blue-700">
						Extensión contextual
					</p>
					<h2 id="pricingExtensionTitle" class="text-lg font-semibold text-slate-950">
						{pricingOperationCopy.extension.drawerTitle}
					</h2>
					<p id="pricingExtensionContext" class="text-sm leading-5 text-slate-600">
						Selecciona un rango en el calendario para copiar ese precio a otros planes.
					</p>
				</div>
				<button
					id="pricingExtensionCloseBtn"
					type="button"
					class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50"
				>
					Cerrar
				</button>
			</div>
			<div class="space-y-4 overflow-y-auto p-4">
				<div class="grid gap-3 sm:grid-cols-2">
					<input id="pricingExtensionOperationType" type="hidden" value="fixed_override" />
					<label class="space-y-1 text-sm">
						<span id="pricingExtensionValueLabel" class="font-medium text-slate-800">
							Precio a copiar
						</span>
						<input
							id="pricingExtensionValue"
							type="number"
							min="0"
							step="1"
							class="w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900"
							placeholder="Precio"
						/>
					</label>
				</div>
				<div class="grid gap-3 sm:grid-cols-2">
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm">
						<p class="font-semibold text-slate-900">Plan de origen</p>
						<p id="pricingExtensionOrigin" class="mt-1 text-slate-600">
							{selectedRatePlanName || "Plan seleccionado"}
						</p>
					</div>
				</div>

				<details open class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm">
					<summary class="cursor-pointer font-semibold text-slate-900">
						{pricingOperationCopy.extension.targetsTitle}
					</summary>
					<p class="mt-1 text-xs leading-5 text-slate-600">
						Elige dónde quieres copiar este precio. Si solo hay un destino disponible, queda
						preseleccionado.
					</p>
					<div class="mt-3 grid gap-2" data-pricing-extension-targets>
						{
							extensionTargetOptions.map(({ row, isPricingReady }) => (
								<label
									class:list={[
										"flex items-start gap-2 rounded border p-2",
										isPricingReady
											? "border-slate-200 bg-white hover:bg-slate-50"
											: "border-amber-200 bg-amber-50 text-amber-950",
									]}
								>
									<input
										type="checkbox"
										data-pricing-extension-target
										value={String(row.ratePlanId)}
										checked={extensionTargetOptions.length === 1 && isPricingReady}
										disabled={!isPricingReady}
										class="mt-1 h-4 w-4 rounded border-slate-300"
									/>
									<span>
										<span class="block font-medium text-slate-900">{row.ratePlanName}</span>
										<span class="block text-xs text-slate-600">
											{row.productName} · {row.variantName}
										</span>
										<span class="mt-1 block text-xs">
											{isPricingReady
												? "Listo para recibir este precio."
												: "Necesita un precio configurado antes de copiar."}
										</span>
									</span>
								</label>
							))
						}
					</div>
					<p id="pricingExtensionTargetHint" class="mt-2 text-xs text-slate-500">
						Elige solo planes donde este mismo precio tenga sentido.
					</p>
				</details>

				<input id="pricingExtensionPreviewDays" type="hidden" value="7" />
				<input id="pricingExtensionPriority" type="hidden" value="1000" />

				<div
					id="pricingExtensionPreview"
					class="hidden rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm"
				>
				</div>
				<div
					id="pricingExtensionResult"
					class="hidden rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm"
				>
				</div>
			</div>
			<div class="border-t border-slate-200 bg-white p-4">
				<p id="pricingExtensionFeedback" class="mb-3 text-sm text-slate-600">
					Revisa el impacto antes de extender el cambio.
				</p>
				<div class="grid grid-cols-2 gap-2">
					<button
						id="pricingExtensionPreviewBtn"
						type="button"
						class="rounded bg-blue-700 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-800 disabled:opacity-50"
					>
						Revisar extensión
					</button>
					<button
						id="pricingExtensionApplyBtn"
						type="button"
						disabled
						class="rounded border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50 disabled:opacity-50"
					>
						Revisa primero
					</button>
				</div>
			</div>
		</aside>

		<Section
			title="Ayudas recurrentes"
			description="Reglas simples que actúan después. Para cambiar fechas visibles una sola vez, usa el calendario."
		>
			<Card id="pricing-automation" className="space-y-5 bg-white text-slate-800">
				<div class="space-y-5" data-pricing-automation-panel>
					<div class="flex flex-wrap items-start justify-between gap-3">
						<div class="space-y-1">
							<p class="text-sm font-semibold text-slate-950">Crear ayuda recurrente</p>
							<p class="max-w-2xl text-sm leading-6 text-slate-600">
								Elige una lógica que debe repetirse automáticamente. El calendario sigue siendo el
								lugar para cambios puntuales.
							</p>
						</div>
						<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
							{automationSurface.stats.activeRules} activas
						</span>
					</div>

					<div
						hidden
						id="pricingAutomationTemplates"
						data-templates={JSON.stringify(automationTemplateCatalog)}
					>
					</div>

					<div data-pricing-automation-presets class="space-y-3">
						{
							automationTemplateGroups.map((group) => (
								<div class="space-y-2">
									<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
										{group.label}
									</p>
									<div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
										{group.templates.map((template) => (
											<button
												type="button"
												data-pricing-automation-card
												data-kind={template.kind}
												aria-pressed={
													template.kind === automationDefaultTemplate?.kind ? "true" : "false"
												}
												class:list={[
													"rounded-lg border bg-white p-3 text-left text-sm transition hover:border-blue-300 hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-blue-500",
													template.kind === automationDefaultTemplate?.kind
														? "border-blue-400 bg-blue-50"
														: "border-slate-200",
												]}
											>
												<p class="font-semibold text-slate-950">{template.shortLabel}</p>
												<p class="mt-1 text-xs leading-5 text-slate-600">{template.description}</p>
											</button>
										))}
									</div>
								</div>
							))
						}
					</div>

					{
						!automationSurface.ratePlanOptions.length ? (
							<p class="text-sm text-slate-600">
								No hay planes tarifarios activos disponibles para reglas automáticas.
							</p>
						) : (
							<div
								data-pricing-automation-create
								class="rounded-xl border border-slate-200 bg-slate-50 p-3"
							>
								<form
									method="POST"
									action={routes.pricingAutomation()}
									class="grid gap-4 lg:grid-cols-6"
									data-pricing-automation-form
								>
									<input type="hidden" name="action" value="create-pricing-automation" />
									<input
										type="hidden"
										name="kind"
										value={automationDefaultTemplate?.kind}
										data-pricing-automation-kind
									/>
									<div class="rounded-lg border border-slate-200 bg-white p-3 text-sm text-slate-700 lg:col-span-6">
										<p class="font-semibold" data-pricing-automation-selected-title>
											{automationDefaultTemplate?.label}
										</p>
										<p class="mt-1 leading-5" data-pricing-automation-selected-description>
											{automationDefaultTemplate?.description}
										</p>
									</div>
									<label class="space-y-1 text-sm lg:col-span-3">
										<span class="font-medium text-slate-700">Plan tarifario</span>
										<select
											name="ratePlanId"
											data-pricing-automation-rate-plan
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										>
											{automationSurface.ratePlanOptions.map((option) => (
												<option
													value={option.id}
													selected={option.id === automationDefaultRatePlanId}
												>
													{option.label}
												</option>
											))}
										</select>
									</label>
									<label class="space-y-1 text-sm lg:col-span-3">
										<span class="font-medium text-slate-700" data-pricing-automation-value-label>
											Porcentaje
										</span>
										<input
											name="value"
											type="number"
											min="0"
											step="0.01"
											value={String(automationDefaultTemplate?.defaultValue ?? 10)}
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
											data-pricing-automation-value
										/>
										<p class="text-xs text-slate-500" data-pricing-automation-value-help>
											{automationDefaultTemplate?.valueSuffix ?? "% de descuento"}
										</p>
									</label>
									<label class="space-y-1 text-sm lg:col-span-3">
										<span class="font-medium text-slate-700">Vigencia desde</span>
										<input
											name="dateFrom"
											type="date"
											data-pricing-automation-date-from
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<label class="space-y-1 text-sm lg:col-span-3">
										<span class="font-medium text-slate-700">Vigencia hasta</span>
										<input
											name="dateTo"
											type="date"
											data-pricing-automation-date-to
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
									</label>
									<label
										class="hidden space-y-1 text-sm lg:col-span-2"
										data-pricing-eligibility="early_bird"
									>
										<span class="font-medium text-slate-700">Anticipación mínima</span>
										<input
											name="minLeadDays"
											type="number"
											min="1"
											value="30"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
										<p class="text-xs text-slate-500">
											Aplica si reservan al menos estos días antes.
										</p>
									</label>
									<label
										class="hidden space-y-1 text-sm lg:col-span-2"
										data-pricing-eligibility="last_minute"
									>
										<span class="font-medium text-slate-700">Anticipación máxima</span>
										<input
											name="maxLeadDays"
											type="number"
											min="1"
											value="3"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
										<p class="text-xs text-slate-500">Aplica si reservan dentro de esta ventana.</p>
									</label>
									<label
										class="hidden space-y-1 text-sm lg:col-span-2"
										data-pricing-eligibility="los_discount"
									>
										<span class="font-medium text-slate-700">Noches mínimas</span>
										<input
											name="minNights"
											type="number"
											min="1"
											value="5"
											class="w-full rounded-lg border border-slate-300 px-3 py-2"
										/>
										<p class="text-xs text-slate-500">
											Aplica cuando la estadía cumple este mínimo.
										</p>
									</label>
									<div
										class="hidden rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm lg:col-span-6"
										data-pricing-automation-review
									/>
									<details class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm lg:col-span-6">
										<summary class="cursor-pointer font-semibold text-slate-800">
											Detalle avanzado
										</summary>
										<div class="mt-3 grid gap-4 lg:grid-cols-6">
											<label class="space-y-1 lg:col-span-2">
												<span class="font-medium text-slate-700">Prioridad avanzada</span>
												<input
													name="priority"
													type="number"
													min="0"
													max="1000"
													value="20"
													class="w-full rounded-lg border border-slate-300 px-3 py-2"
												/>
												<p class="text-xs text-slate-500">
													Solo para resolver conflictos entre varias ayudas recurrentes.
												</p>
											</label>
										</div>
									</details>
									<div class="flex flex-wrap items-end gap-2 lg:col-span-6">
										<button
											type="button"
											data-pricing-automation-preview
											class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-800 shadow-sm hover:bg-slate-50"
										>
											Revisar impacto
										</button>
										<Button type="submit" variant="primary">
											Crear ayuda recurrente
										</Button>
									</div>
								</form>
							</div>
						)
					}

					<div class="space-y-3">
						<div class="flex flex-wrap items-center justify-between gap-3">
							<div>
								<p class="text-sm font-semibold text-slate-900">Ayudas activas</p>
								<p class="text-xs text-slate-500">
									Automatizaciones que seguirán actuando después.
								</p>
							</div>
						</div>
						{
							automationSurface.rules.length ? (
								<div class="grid gap-3">
									{automationSurface.rules.map((rule) => (
										<div class="rounded-xl border border-slate-200 bg-white p-3 shadow-sm">
											<div class="flex flex-wrap items-start justify-between gap-3">
												<div>
													<div class="flex flex-wrap items-center gap-2">
														<Badge variant="info">{rule.kindLabel}</Badge>
														<Badge variant={statusVariant[rule.status]}>{rule.statusLabel}</Badge>
													</div>
													<p class="mt-2 text-sm text-slate-700">{rule.summary}</p>
													<p class="mt-1 text-xs text-slate-500">
														{rule.productName} · {rule.variantName} · {rule.ratePlanName}
													</p>
													<details class="mt-2 text-xs text-slate-500">
														<summary class="cursor-pointer font-semibold text-slate-600">
															Detalle
														</summary>
														<p class="mt-1">
															Vigencia: {rule.validityLabel} · Condición: {rule.eligibilityLabel} ·
															Prioridad interna {rule.priority}
														</p>
														<p class="mt-1">
															Creada: {rule.createdAt.toLocaleString("es-CL")} · Ref.{" "}
															{rule.id.slice(0, 8)}
														</p>
													</details>
												</div>
												<div class="flex flex-wrap justify-end gap-2">
													<details class="text-right text-xs text-slate-500">
														<summary class="cursor-pointer rounded-lg border border-slate-200 bg-white px-3 py-2 font-semibold text-slate-700 hover:bg-slate-50">
															Eliminar
														</summary>
														<div class="mt-2 max-w-xs rounded-lg border border-red-100 bg-white p-3 text-left shadow-sm">
															<p class="font-semibold text-red-800">Eliminar ayuda recurrente</p>
															<p class="mt-1 leading-5 text-slate-600">
																Esta ayuda dejará de actuar automáticamente. El cambio manual del
																calendario y las reservas no se eliminan.
															</p>
															<form method="POST" action={routes.pricingAutomation()} class="mt-3">
																<input
																	type="hidden"
																	name="action"
																	value="delete-pricing-automation"
																/>
																<input type="hidden" name="ruleId" value={rule.id} />
																<input type="hidden" name="ratePlanId" value={rule.ratePlanId} />
																<Button type="submit" variant="secondary" size="sm">
																	Confirmar eliminación
																</Button>
															</form>
														</div>
													</details>
												</div>
											</div>
										</div>
									))}
								</div>
							) : (
								<div class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">
									Todavía no hay ayudas recurrentes. Crea descuentos, aumentos o precios programados
									solo cuando necesites lógica que actúe automáticamente después.
								</div>
							)
						}
					</div>
				</div>
			</Card>
		</Section>
	</div>

	<style is:global>
		.pricing-extension-backdrop:not(.hidden) {
			position: fixed;
			inset: 0;
			z-index: 60;
			background: rgb(15 23 42 / 0.24);
			backdrop-filter: blur(2px);
		}

		.pricing-extension-drawer:not(.hidden) {
			position: fixed;
			inset-block: 0;
			inset-inline-end: 0;
			z-index: 70;
			display: grid;
			width: min(30rem, calc(100vw - 1rem));
			grid-template-rows: auto 1fr auto;
			border-left: 1px solid rgb(226 232 240);
			box-shadow: -24px 0 70px rgb(15 23 42 / 0.2);
			animation: pricing-extension-drawer-enter 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
		}

		@media (max-width: 767px), (max-height: 480px) and (pointer: coarse) {
			[data-pricing-selected-label] {
				display: none !important;
			}

			.pricing-extension-drawer:not(.hidden) {
				inset-inline: 0.75rem;
				inset-block-start: auto;
				inset-block-end: calc(0.75rem + env(safe-area-inset-bottom));
				width: auto;
				max-height: min(86dvh, 44rem);
				border: 1px solid rgb(226 232 240);
				border-radius: 1rem;
				box-shadow: 0 28px 90px rgb(15 23 42 / 0.28);
				animation-name: pricing-extension-sheet-enter;
			}
		}

		@keyframes pricing-extension-drawer-enter {
			from {
				opacity: 0;
				transform: translateX(1rem);
			}
			to {
				opacity: 1;
