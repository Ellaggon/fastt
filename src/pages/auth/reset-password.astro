---
import Layout from "@/layouts/Layout.astro"

const error = Astro.url.searchParams.get("error")
const hasFormError = Boolean(error)

const errorMessages: Record<string, string> = {
	missing_fields: "Completa los dos campos de contraseña.",
	password_mismatch: "Las contraseñas no coinciden.",
	password_too_short: "La contraseña debe tener al menos 6 caracteres.",
	update_failed: "No se pudo actualizar la contraseña. Solicita un nuevo enlace.",
}
---

<Layout title="Recuperar contraseña">
	<main class="flex min-h-screen items-center justify-center px-6 py-10">
		<section
			class="mt-20 flex w-full max-w-md flex-col rounded-xl border border-gray-700 px-8 py-10 text-white"
		>
			<h1 class="text-3xl">Crear nueva contraseña</h1>
			<p class="mt-3 text-sm text-gray-400" id="status">
				{hasFormError ? "Elige una nueva contraseña." : "Validando el enlace de recuperación..."}
			</p>

			{
				error && (
					<p class="mt-6 rounded-md bg-red-900/40 px-3 py-2 text-sm text-red-200">
						{errorMessages[error] || "No se pudo actualizar la contraseña."}
					</p>
				)
			}

			<form
				method="post"
				action="/api/auth/update-password"
				class:list={["mt-8 flex-col gap-3", hasFormError ? "flex" : "hidden"]}
				id="reset-form"
				autocomplete="on"
			>
				<label class="block text-sm font-medium text-gray-400">
					Nueva contraseña
					<input
						type="password"
						name="password"
						required
						minlength="6"
						class="mt-1 block w-full rounded-xl border border-gray-600 bg-gray-700 px-3 py-2 text-white shadow-sm focus:border-slate-300 focus:outline-none focus:ring-slate-300 sm:text-sm"
					/>
				</label>
				<label class="block text-sm font-medium text-gray-400">
					Confirmar contraseña
					<input
						type="password"
						name="confirmPassword"
						required
						minlength="6"
						class="mt-1 block w-full rounded-xl border border-gray-600 bg-gray-700 px-3 py-2 text-white shadow-sm focus:border-slate-300 focus:outline-none focus:ring-slate-300 sm:text-sm"
					/>
				</label>
				<button
					type="submit"
					class="mt-2 w-full rounded-xl bg-slate-950 px-3 py-2 text-white shadow-sm transition hover:bg-slate-800"
				>
					Guardar contraseña
				</button>
			</form>

			<a href="/SignInPage" class="mt-6 text-sm text-gray-300 underline underline-offset-4">
				Volver a iniciar sesión
			</a>
		</section>
	</main>

	<script is:inline>
		;(async function () {
			const $status = document.getElementById("status")
			const $form = document.getElementById("reset-form")

			const setStatus = (msg) => {
				if ($status) $status.textContent = msg
			}

			const hash =
				window.location.hash && window.location.hash.startsWith("#")
					? window.location.hash.slice(1)
					: ""

			if (!hash) {
				if ($form && !$form.classList.contains("hidden")) return
				setStatus("Abre esta pagina desde el enlace enviado a tu email.")
				return
			}

			const params = new URLSearchParams(hash)
			const error = params.get("error")
			const errorDescription = params.get("error_description")
			if (error) {
				setStatus(errorDescription || `Error de recuperacion: ${error}`)
				return
			}

			const access_token = params.get("access_token")
			const refresh_token = params.get("refresh_token")
			const expires_in_raw = params.get("expires_in")
			const expires_in = expires_in_raw ? Number(expires_in_raw) : 0

			try {
				window.history.replaceState(null, "", window.location.pathname + window.location.search)
			} catch {}

			if (!access_token || !refresh_token || !Number.isFinite(expires_in) || expires_in <= 0) {
				setStatus("El enlace de recuperacion es invalido o expiro.")
				return
			}

			try {
				const res = await fetch("/api/auth/set-session", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					credentials: "include",
					body: JSON.stringify({ access_token, refresh_token, expires_in }),
				})

				if (!res.ok) {
					setStatus("No se pudo validar el enlace. Solicita uno nuevo.")
					return
				}

				setStatus("Elige una nueva contraseña.")
				if ($form) $form.classList.remove("hidden")
				if ($form) $form.classList.add("flex")
			} catch (e) {
				setStatus("Error de red validando el enlace.")
			}
		})()
	</script>
</Layout>
