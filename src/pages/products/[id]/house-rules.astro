---
import { HOUSE_RULE_PRESETS } from "@/data/house-rules/house-rule-presets"
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProductById } from "@/modules/catalog/public"
import {
	createHouseRule,
	deleteHouseRule,
	listHouseRulesByProduct,
} from "@/modules/house-rules/public"

const productId = String(Astro.params.id ?? "").trim()
if (!productId) return Astro.redirect("/dashboard")

let providerId: string | null = null
try {
	const res = await requireProvider(Astro.request)
	providerId = res.providerId
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

const product = await getProductById(productId)
if (!product || String(product.providerId ?? "") !== providerId)
	return new Response("Not found", { status: 404 })

const saved = Astro.url.searchParams.get("saved") === "1"
let error: string | null = null

const TYPES = ["Children", "Pets", "Smoking", "ExtraBeds", "Access", "Other"] as const
const TYPE_LABELS: Record<(typeof TYPES)[number], string> = {
	Children: "Children",
	Pets: "Pets",
	Smoking: "Smoking",
	ExtraBeds: "Extra beds",
	Access: "Access",
	Other: "Other",
}

if (Astro.request.method === "POST") {
	try {
		const form = await Astro.request.formData()
		const intent = String(form.get("intent") ?? "").trim()

		if (intent === "create") {
			const type = String(form.get("type") ?? "").trim()
			const description = String(form.get("description") ?? "").trim()
			await createHouseRule({ productId, type, description })
			return Astro.redirect(`${Astro.url.pathname}?saved=1`)
		}

		if (intent === "delete") {
			const id = String(form.get("id") ?? "").trim()
			if (!id) throw new Error("Missing id")
			await deleteHouseRule(id)
			return Astro.redirect(`${Astro.url.pathname}?saved=1`)
		}

		error = "Invalid action"
	} catch (e: any) {
		error = String(e?.message ?? e)
	}
}

const rules = await listHouseRulesByProduct(productId)
const byType: Record<string, any[]> = {}
for (const t of TYPES) byType[t] = []
for (const r of rules) {
	const t = String(r.type ?? "")
	if (!byType[t]) continue
	byType[t].push(r)
}
---

<DashboardLayout>
	<main class="space-y-6 p-6">
		<header class="flex items-center justify-between">
			<h1 class="text-xl font-semibold">House Rules</h1>
			<nav class="space-x-3">
				<a class="underline" href={`/products/${productId}`}>Product</a>
				<a class="underline" href={`/products/${productId}/rate-plans`}>Rate plans</a>
			</nav>
		</header>

		<p class="text-sm text-neutral-700">
			House rules are informational only. They are not part of booking policies or snapshots.
		</p>

		{
			saved && (
				<div class="border p-3">
					<strong>OK:</strong> Saved.
				</div>
			)
		}
		{
			error && (
				<div class="border p-3">
					<strong>Error:</strong> {error}
				</div>
			)
		}

		<div class="space-y-8">
			{
				TYPES.map((t) => (
					<section class="space-y-3 rounded border p-4">
						<h2 class="text-lg font-semibold">{TYPE_LABELS[t]}</h2>

						{byType[t].length === 0 ? (
							<p class="text-sm text-neutral-700">No rules yet.</p>
						) : (
							<ul class="space-y-2">
								{byType[t].map((r) => (
									<li class="space-y-2 rounded border p-3">
										<p class="whitespace-pre-line text-sm">{r.description}</p>
										<form method="POST">
											<input type="hidden" name="intent" value="delete" />
											<input type="hidden" name="id" value={r.id} />
											<button type="submit" class="border px-3 py-2 text-sm">
												Delete
											</button>
										</form>
									</li>
								))}
							</ul>
						)}

						<form method="POST" class="house-rule-form space-y-2" data-type={t}>
							<input type="hidden" name="intent" value="create" />
							<input type="hidden" name="type" value={t} />

							<div class="space-y-1">
								<label class="block text-sm">Preset</label>
								<select class="preset-select w-full border p-2">
									<option value="">Select…</option>
									{(HOUSE_RULE_PRESETS as any)[t]?.map((p: any) => (
										<option value={p.description}>{p.name}</option>
									))}
								</select>
							</div>

							<div class="space-y-1">
								<label class="block text-sm">Custom description</label>
								<textarea name="description" rows="3" class="desc-textarea w-full border p-2" />
							</div>

							<button type="submit" class="border px-4 py-2 text-sm">
								Add rule
							</button>
						</form>
					</section>
				))
			}
		</div>
	</main>
</DashboardLayout>

<script>
	// @ts-nocheck
	// Minimal preset→textarea helper.
	for (const form of document.querySelectorAll(".house-rule-form")) {
		const sel = form.querySelector(".preset-select")
		const ta = form.querySelector(".desc-textarea")
		if (!sel || !ta) continue
		sel.addEventListener("change", () => {
			const v = sel.value || ""
			if (!v) return
			ta.value = v
		})
	}
</script>
