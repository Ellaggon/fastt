<!-- ---
import { WEEK_DAYS } from "@/data/week-days"
import DashboardLayout from "@/layouts/DashboardLayout.astro"

const { variantId, id } = Astro.params
// if (!variantId) return Astro.redirect("/dashboard")

// (legacy) variant fetching removed from comment to keep pages free of DB imports
--- 

<DashboardLayout title="Crear Temporada">
	<main class="h-full w-full pt-6 md:pt-20">
		<div
			class="mx-auto w-[98%] rounded-3xl border border-neutral-300 bg-neutral-200 p-8 text-neutral-800 shadow-lg sm:p-10 md:w-[80%] lg:max-w-4xl lg:p-20"
		>
			<header class="space-y-1">
				<h1 class="text-lg font-bold md:text-2xl lg:text-3xl">
					NUEVA TEMPORADA / AJUSTE DE PRECIO
				</h1>
				<p class="hidden text-xs text-neutral-600 md:block md:text-sm">
					Configura reglas de precio por temporada, fechas o días específicos.
				</p>
			</header>

			<form id="seasonForm" class="mt-6 flex flex-col gap-10 space-y-20">
				<section class="space-y-3">
					<h3 class="text-lg font-semibold text-neutral-800">Información básica</h3>

					<label class="flex flex-col text-sm">
						<span class="font-medium text-neutral-600">Nombre de la temporada</span>
						<input
							name="name"
							required
							placeholder="Ej: Temporada Alta Verano"
							class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
						/>
					</label>
				</section>

				<section class="space-y-6">
					<h2 class="text-lg font-semibold text-neutral-800">Configuración de precios</h2>

					<div class="rounded-xl border border-white p-4 text-xs md:text-sm">
						<p class="text-neutral-600">
							Precio base habitación:
							<strong class="ml-2 text-neutral-800">
								{variant.currency}
								{variant.basePrice}
							</strong>
						</p>
					</div>

					<div class="mt-10 grid gap-10 md:grid-cols-2">
						<label class="flex flex-col space-y-3 text-sm">
							<span class="font-medium text-neutral-600">Tipo de ajuste</span>
							<select name="type" class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base">
								<option value="modifier">Sumar al precio base</option>
								<option value="percentage">Aumento porcentual</option>
								<option value="fixed">Precio fijo</option>
							</select>
						</label>

						<label class="relative flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Valor</span>

							<div class="relative">
								<input
									type="number"
									name="value"
									step="0.01"
									class="mt-1 w-full rounded-md bg-neutral-100 px-3 py-2 pr-8 text-base"
								/>
								<span
									id="percentIcon"
									class="absolute right-3 top-1/2 hidden -translate-y-1/2 font-semibold text-neutral-600"
								>
									%
								</span>
							</div>
						</label>
					</div>

					<output
						class="block rounded-xl border border-blue-300 bg-gradient-to-br from-blue-50 to-blue-100 p-4 text-blue-900"
					>
						<p class="text-sm font-medium">Precio con ajuste de temporada</p>

						<p
							class="mt-1 text-lg font-bold"
							id="pricePreview"
							data-base-price={variant.basePrice}
							data-currency={variant.currency}
						>
							<strong>
								<span id="previewCurrency">{variant.currency}</span>
								<span id="previewPrice">{variant.basePrice}</span>
							</strong>
						</p>

						<p id="priceHelper" class="mt-3 text-xs text-blue-900"></p>
					</output>
				</section>

				<section class="grid gap-10 md:grid-cols-2">
					<section class="space-y-6">
						<div class="space-y-3">
							<h2 class="font-semibold text-neutral-700">Días válidos</h2>
							<p class="text-xs text-neutral-600">
								Selecciona los días en que este ajuste de temporada aplicará.
							</p>
						</div>

						<div class="grid grid-cols-2 gap-3 text-sm text-neutral-700 md:text-base">
							{
								WEEK_DAYS.map(({ label, value }) => (
									<label class="relative cursor-pointer">
										<input type="checkbox" name="validDays" value={value} class="peer sr-only" />

										<span class="flex select-none items-center justify-center rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-2 text-neutral-700 transition-all duration-150 hover:bg-neutral-100 active:scale-95 peer-checked:border-blue-600 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:hover:bg-blue-700">
											{label}
										</span>
									</label>
								))
							}
						</div>
					</section>

					<div class="space-y-6">
						<div class="space-y-3">
							<h2 class="font-semibold text-neutral-700">Vigencia del ajuste de temporada</h2>

							<p class="text-xs text-neutral-600">
								Define en qué fechas estara vigente este ajuste de temporada.
							</p>
						</div>
						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Fecha inicio de vigencia</span>
							<input
								type="date"
								name="startDate"
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Fecha de fín de vigencia</span>
							<input
								type="date"
								name="endDate"
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>
					</div>
				</section>

				<footer class="flex justify-end py-16">
					<button
						type="submit"
						class="h-14 w-44 rounded-xl bg-blue-600 px-4 py-1 font-medium text-white shadow-md transition-colors duration-200 hover:bg-blue-700"
					>
						Guardar Temporada
					</button>
				</footer>
			</form>
		</div>
		<main></main>
	</main>
</DashboardLayout>
<script type="module">
	;(() => {
		const root = document.getElementById("pricePreview")
		if (!root) return

		const state = {
			basePrice: Number(root.dataset.basePrice || 0),
			currency: root.dataset.currency || "",
		}

		const els = {
			type: document.querySelector('[name="type"]'),
			value: document.querySelector('[name="value"]'),
			newPrice: document.getElementById("previewPrice"),
			newCurrency: document.getElementById("previewCurrency"),
			percentIcon: document.getElementById("percentIcon"),
			helper: document.getElementById("priceHelper"),
			submitBtn: document.querySelector("button[type='submit']"),
		}

		if (!els.type || !els.value) return

		function clamp(value, min, max) {
			return Math.min(Math.max(value, min), max)
		}

		function applyUX() {
			const t = els.type.value
			els.percentIcon?.classList.add("hidden")

			switch (t) {
				case "fixed":
					els.helper.textContent = "Este valor reemplaza el precio base."
					break

				case "percentage":
					els.percentIcon?.classList.remove("hidden")
					els.helper.textContent = "Aumento porcentual aplicado al precio base."
					break

				default:
					els.helper.textContent = "Se suma este valor al precio base."
			}
		}

		function calculate() {
			let price = state.basePrice
			let value = Number(els.value.value || 0)

			switch (els.type.value) {
				case "modifier":
					price += value
					break

				case "fixed":
					if (value > 0) price = value
					break

				case "percentage":
					value = clamp(value, 0, 300)
					els.value.value = value
					price += price * (value / 100)
					break
			}

			price = Math.max(price, 0)

			els.newPrice.textContent = price.toFixed(2)
			els.newCurrency.textContent = state.currency

			if (price <= 0) {
				els.helper.textContent = "⚠ El precio final no puede ser 0 o negativo."
				els.submitBtn.disabled = true
			} else {
				els.submitBtn.disabled = false
			}
		}

		els.type.addEventListener("change", () => {
			applyUX()
			calculate()
		})

		els.value.addEventListener("input", calculate)

		applyUX()
		calculate()
	})()
</script>
