---
import {
	INCOMPATIBLE_PRESETS,
	OPERATIONAL_RULE_PRESETS,
	SCOPE_EXPLANATIONS,
} from "@/data/operating-rules/or-presets"
import Layout from "@/layouts/Layout.astro"

const { id: productId } = Astro.params
const presets = OPERATIONAL_RULE_PRESETS
---

<Layout title="Reglas Operativas">
	<main class="mx-auto mt-20 max-w-3xl rounded-3xl bg-neutral-100 p-8">
		<h1 class="text-xl font-semibold text-neutral-800">Reglas Operativas</h1>

		<button id="btnAdd" class="mt-4 rounded-xl bg-blue-600 px-4 py-2 text-white">
			+ Nueva Regla
		</button>

		<div id="ruleList" class="mt-6 space-y-3"></div>

		<!-- MODAL -->
		<dialog id="modal" class="w-full max-w-md rounded-2xl p-6">
			<form id="form" class="space-y-4">
				<h3 class="text-lg font-semibold">Regla Operativa</h3>

				<div id="presetList" class="space-y-4">
					{
						Object.entries(presets).map(([category, rules]) => {
							if (category === "Availability") category = "Disponibilidad"
							else if (category === "LengthOfStay") category = "Estancia mínima/máxima"
							else if (category === "ArrivalDeparture") category = "Llegada/Salida"
							else if (category === "BookingWindow") category = "Ventana de Reserva"
							else if (category === "Pricing") category = "Precios"
							else if (category === "Occupancy") category = "Ocupación"
							else if (category === "Inventory") category = "Inventario"

							return (
								<div class="preset-category space-y-2" data-category={category}>
									<h4 class="mt-6 text-sm font-semibold uppercase text-neutral-500">{category}</h4>
									<div class="space-y-2">
										{rules.map((p) => (
											<button
												type="button"
												data-key={p.key}
												data-category={category}
												class="preset-btn w-full rounded-xl border p-3 text-left hover:bg-neutral-50"
											>
												<div class="font-medium">{p.name}</div>
												<div class="text-sm text-neutral-500">{p.description}</div>
											</button>
										))}
									</div>
								</div>
							)
						})
					}
				</div>

				<button type="button" id="changePreset" class="text-sm text-blue-600">
					Cambiar tipo de regla
				</button>

				<input type="hidden" name="preset" id="preset" required />

				<div class="flex gap-2">
					<input
						id="from"
						name="from"
						type="date"
						required
						class="w-full rounded-xl border px-3 py-2"
					/>
					<input
						id="to"
						name="to"
						type="date"
						required
						class="w-full rounded-xl border px-3 py-2"
					/>
				</div>

				<div id="params" class="space-y-2"></div>

				<label class="flex items-center gap-2 text-sm">
					<input type="checkbox" id="enabled" name="enabled" checked />
					Regla activa
				</label>

				<div class="flex justify-end gap-2">
					<button type="button" id="cancel">Cancelar</button>
					<button type="submit" class="rounded-xl bg-blue-600 px-4 py-2 text-white">
						Guardar
					</button>
				</div>
			</form>
		</dialog>
	</main>

	<script
		type="module"
		define:vars={{ OPERATIONAL_RULE_PRESETS, productId, SCOPE_EXPLANATIONS, INCOMPATIBLE_PRESETS }}
	>
		/* -------------------- STATE -------------------- */
		const presets = OPERATIONAL_RULE_PRESETS

		const ruleList = document.getElementById("ruleList")
		const modal = document.getElementById("modal")
		const form = document.getElementById("form")
		const presetSelect = document.getElementById("preset")
		const paramsDiv = document.getElementById("params")
		const enabledCheckbox = document.getElementById("enabled")
		const fromInput = document.getElementById("from")
		const toInput = document.getElementById("to")

		let rulesCache = []
		let editingRule = null

		function syncDateLimits() {
			if (fromInput.value) {
				toInput.min = fromInput.value
			}

			if (toInput.value) {
				fromInput.max = toInput.value
			}
		}

		function explainRule(rule) {
			const preset = Object.values(OPERATIONAL_RULE_PRESETS)
				.flat()
				.find((p) => p.key === rule.presetKey)

			if (!preset || !preset.explain) return ""

			let text = preset.explain

			if (rule.params) {
				for (const [key, value] of Object.entries(rule.params)) {
					text = text.replaceAll(`{{${key}}}`, value)
				}
			}

			return text
		}

		function explainScope(rule) {
			return SCOPE_EXPLANATIONS[rule.scope] ?? "Ámbito no definido"
		}

		/* -------------------- LOAD -------------------- */

		async function loadRules() {
			const res = await fetch(`/api/products/${productId}/operating-rules/get`)
			const { rules } = await res.json()

			rulesCache = rules
			renderRules()
		}

		/* -------------------- RENDER -------------------- */

		function renderRules() {
			ruleList.innerHTML = ""

			rulesCache.forEach((rule) => {
				const preset = Object.values(presets)
					.flat()
					.find((p) => p.key === rule.presetKey)

				ruleList.innerHTML += `
          <div class="flex justify-between rounded-xl bg-white p-4 shadow">
            <div>
              <div class="font-medium text-neutral-800">
                ${preset?.name ?? rule.presetKey}
                ${!rule.enabled ? '<span class="ml-2 text-xs text-red-500">(Inactiva)</span>' : ""}
              </div>

              <div class="text-sm text-neutral-500">
                ${new Date(rule.dateFrom).toLocaleDateString()} →
                ${new Date(rule.dateTo).toLocaleDateString()}
              </div>

              <div class="text-sm text-neutral-700 mt-1">
					<strong class="text-neutral-400">Aplica a:</strong> ${explainScope(rule)}
				</div>

				<div class="text-sm text-neutral-600 mt-1">
					<strong class="text-neutral-400">Condición:</strong> ${explainRule(rule, preset)}
				</div>
            </div>

            <div class="flex gap-2">
              <button data-edit="${rule.id}" class="text-neutral-700">
                Editar
              </button>
              <button data-delete="${rule.id}" class="text-red-500">
                Eliminar
              </button>
            </div>
          </div>
        `
			})
		}

		function applyIncompatibilities(selectedKey) {
			const incompatible = INCOMPATIBLE_PRESETS[selectedKey] ?? []

			document.querySelectorAll(".preset-btn").forEach((btn) => {
				const key = btn.dataset.key

				if (incompatible.includes(key)) {
					btn.disabled = true
					btn.classList.add("opacity-40", "cursor-not-allowed")
				} else {
					btn.disabled = false
					btn.classList.remove("opacity-40", "cursor-not-allowed")
				}
			})
		}

		function selectPreset(presetKey) {
			presetSelect.value = presetKey

			const selectedBtn = document.querySelector(`.preset-btn[data-key="${presetKey}"]`)

			if (!selectedBtn) return

			const selectedCategory = selectedBtn.closest(".preset-category")

			// Ocultar TODAS las categorías excepto la seleccionada
			document.querySelectorAll(".preset-category").forEach((cat) => {
				const isActiveCategory = cat === selectedCategory
				cat.classList.toggle("hidden", !isActiveCategory)
			})

			// Dentro de la categoría activa, mostrar solo el preset elegido
			selectedCategory.querySelectorAll(".preset-btn").forEach((btn) => {
				const isActive = btn.dataset.key === presetKey

				btn.classList.toggle("hidden", !isActive)
				btn.classList.toggle("ring-2", isActive)
				btn.classList.toggle("ring-blue-500", isActive)
				btn.classList.toggle("bg-blue-50", isActive)
			})

			// Cargar params
			presetSelect.dispatchEvent(new Event("change"))
			applyIncompatibilities(presetKey)
		}

		function hasDateOverlap(newRule) {
			return rulesCache.some((rule) => {
				if (editingRule && rule.id === editingRule.id) return false
				if (rule.presetKey !== newRule.presetKey) return false

				return (
					new Date(newRule.dateFrom) <= new Date(rule.dateTo) &&
					new Date(newRule.dateTo) >= new Date(rule.dateFrom)
				)
			})
		}

		fromInput.addEventListener("change", syncDateLimits)
		toInput.addEventListener("change", syncDateLimits)

		/* -------------------- PRESET PARAMS -------------------- */

		presetSelect.addEventListener("change", () => {
			paramsDiv.innerHTML = ""

			const preset = Object.values(presets)
				.flat()
				.find((p) => p.key === presetSelect.value)

			preset?.params?.forEach((p) => {
				paramsDiv.innerHTML += `
		<input
			name="${p.key}"
			type="${p.type}"
			placeholder="${p.label}"
			${p.step ? `step="${p.step}"` : ""}
			${p.min ? `min="${p.min}"` : ""}
			class="w-full rounded-xl border px-3 py-2"
		/>
	`
			})
		})

		/* -------------------- LIST ACTIONS -------------------- */

		ruleList.addEventListener("click", async (e) => {
			const editId = e.target.dataset.edit
			const deleteId = e.target.dataset.delete

			/* ---- EDIT ---- */
			if (editId) {
				editingRule = rulesCache.find((r) => r.id === editId)
				if (!editingRule) return

				selectPreset(editingRule.presetKey)
				document.getElementById("from").value = editingRule.dateFrom?.slice(0, 10)
				document.getElementById("to").value = editingRule.dateTo?.slice(0, 10)

				syncDateLimits()
				enabledCheckbox.checked = editingRule.enabled

				presetSelect.dispatchEvent(new Event("change"))

				for (const [k, v] of Object.entries(editingRule.params ?? {})) {
					const input = form.querySelector(`[name="${k}"]`)
					if (input) input.value = v
				}

				modal.showModal()
			}

			/* ---- DELETE ---- */
			if (deleteId) {
				await fetch(`/api/products/${productId}/operating-rules/${deleteId}/delete`, {
					method: "DELETE",
				})
				loadRules()
			}
		})

		document.getElementById("presetList").onclick = (e) => {
			const btn = e.target.closest("button")
			if (!btn) return

			selectPreset(btn.dataset.key)
		}

		document.getElementById("changePreset").onclick = () => {
			presetSelect.value = ""
			paramsDiv.innerHTML = ""

			// Mostrar todas las categorías
			document.querySelectorAll(".preset-category").forEach((cat) => {
				cat.classList.remove("hidden")
			})

			// Mostrar todos los presets
			document.querySelectorAll("#presetList .preset-btn").forEach((btn) => {
				btn.classList.remove("hidden", "ring-2", "ring-blue-500", "bg-blue-50")
			})
		}

		/* -------------------- CREATE -------------------- */

		document.getElementById("btnAdd").onclick = () => {
			editingRule = null
			form.reset()
			enabledCheckbox.checked = true
			paramsDiv.innerHTML = ""

			// Mostrar todos los presets
			document.querySelectorAll("#presetList button").forEach((btn) => {
				btn.classList.remove("hidden", "ring-2", "ring-blue-500", "bg-blue-50")
			})

			presetSelect.value = ""
			modal.showModal()
		}

		/* -------------------- CANCEL -------------------- */

		document.getElementById("cancel").onclick = () => {
			editingRule = null
			modal.close()
		}

		/* -------------------- SUBMIT -------------------- */

		form.addEventListener("submit", async (e) => {
			e.preventDefault()

			const from = form.from.value
			const to = form.to.value

			if (new Date(from) > new Date(to)) {
				alert("La fecha ´Desde´ no puede ser posterior a la fecha ´Hasta´")
			}

			const formData = new FormData(form)

			const payload = {
				presetKey: formData.get("preset"),
				dateFrom: formData.get("from"),
				dateTo: formData.get("to"),
				enabled: formData.get("enabled") === "on",
				params: {},
			}

			for (const [key, value] of formData.entries()) {
				if (!["preset", "from", "to", "enabled"].includes(key)) {
					payload.params[key] = Number(value) || value
				}
			}

			if (
				hasDateOverlap({
					presetKey: payload.presetKey,
					dateFrom: payload.dateFrom,
					dateTo: payload.dateTo,
				})
			) {
				alert("Ya existe una regla de este tipo que se solapa en fechas.")
				return
			}

			if (editingRule) {
				await fetch(`/api/products/${productId}/operating-rules/${editingRule.id}/update`, {
					method: "PUT",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				})
			} else {
				await fetch(`/api/products/${productId}/operating-rules/create`, {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				})
			}

			editingRule = null
			modal.close()
			loadRules()
		})

		loadRules()
	</script>
</Layout>
