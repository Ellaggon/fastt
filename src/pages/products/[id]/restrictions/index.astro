---
import { CATEGORY_LABELS } from "@/data/restrictions/restrictions-categories"
import {
	INCOMPATIBLE_PRESETS,
	OPERATIONAL_RULE_PRESETS,
} from "@/data/restrictions/restrictions-presets"
import { RESTRICTION_CATEGORIES, SCOPE_LABELS } from "@/data/restrictions/restrictions-types"

import DashboardLayout from "@/layouts/DashboardLayout.astro"

const { id: productId } = Astro.params
const presets = OPERATIONAL_RULE_PRESETS
---

<DashboardLayout title="Restricciones de Venta">
	<main
		class="mx-auto mt-6 w-[95%] max-w-3xl rounded-3xl border border-neutral-300 bg-neutral-200 p-8 text-neutral-800 shadow-lg md:mt-20 md:p-12 lg:p-16"
	>
		<div class="flex items-center justify-between">
			<h1 class="text-xl font-semibold uppercase text-neutral-800 md:text-2xl">Restricciones</h1>
			<button
				id="btnAdd"
				class="rounded-xl bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700"
			>
				+ Nueva Restricción
			</button>
		</div>

		<div id="ruleList" class="mt-6 space-y-3"></div>

		<dialog id="modal" class="w-full max-w-md rounded-2xl p-6 backdrop:bg-black/50">
			<form id="form" class="space-y-4">
				<h3 class="text-lg font-semibold" id="modalTitle">Nueva Restricción</h3>

				<div id="presetList" class="max-h-[60vh] space-y-4 overflow-y-auto">
					{
						RESTRICTION_CATEGORIES.map((category) => {
							const rules = presets[category]
							const catLabel = CATEGORY_LABELS[category] || category
							return (
								<div class="preset-category space-y-2">
									<h4 class="text-xs font-bold uppercase tracking-wider text-neutral-400">
										{catLabel}
									</h4>
									<div class="grid gap-2">
										{rules.map((p) => (
											<button
												type="button"
												data-key={p.key}
												class="preset-btn w-full rounded-xl border border-neutral-200 p-3 text-left transition hover:border-blue-300 hover:bg-blue-50/50"
											>
												<div class="text-sm font-medium">{p.name}</div>
												<div class="text-xs text-neutral-500">{p.description}</div>
											</button>
										))}
									</div>
								</div>
							)
						})
					}
				</div>

				<div id="configFields" class="hidden space-y-4">
					<button
						type="button"
						id="changePreset"
						class="text-xs font-medium text-blue-600 hover:underline">← Cambiar tipo</button
					>
					<div class="rounded-xl border border-neutral-100 bg-neutral-50 p-3">
						<div id="selectedRuleName" class="text-sm font-bold"></div>
					</div>

					<input type="hidden" name="type" id="ruleType" required />

					<div class="space-y-1">
						<label class="text-[10px] font-bold uppercase text-neutral-400"
							>Ámbito de aplicación:</label
						>
						<select
							name="scope"
							id="scopeSelector"
							class="w-full rounded-xl border px-3 py-2 text-sm"
						>
							<option value="product">Todo el alojamiento</option>
							<option value="variant">Habitación específica...</option>
							<option value="rate_plan">Plan tarifario específico...</option>
						</select>
					</div>

					<div id="scopeTargetContainer" class="hidden space-y-1">
						<label class="text-[10px] font-bold uppercase text-neutral-400" id="scopeTargetLabel"
						></label>
						<select id="scopeTarget" class="w-full rounded-xl border px-3 py-2 text-sm"></select>
					</div>

					<div class="space-y-1">
						<label class="text-[10px] font-bold uppercase text-neutral-400"
							>Días de la semana:</label
						>
						<div class="flex justify-between gap-1">
							{
								["L", "M", "X", "J", "V", "S", "D"].map((day, i) => (
									<label class="flex flex-col items-center gap-1">
										<span class="text-[10px] font-bold text-neutral-400">{day}</span>
										<input type="checkbox" name="validDays" value={i + 1} checked class="rounded" />
									</label>
								))
							}
						</div>
					</div>

					<div class="grid grid-cols-2 gap-2">
						<div class="space-y-1">
							<label class="text-[10px] font-bold uppercase text-neutral-400">Desde</label>
							<input
								id="startDate"
								name="startDate"
								type="date"
								required
								class="w-full rounded-xl border px-3 py-2 text-sm"
							/>
						</div>
						<div class="space-y-1">
							<label class="text-[10px] font-bold uppercase text-neutral-400">Hasta</label>
							<input
								id="endDate"
								name="endDate"
								type="date"
								required
								class="w-full rounded-xl border px-3 py-2 text-sm"
							/>
						</div>
					</div>

					<div id="paramsContainer" class="space-y-1"></div>
					<div
						id="previewBox"
						class="hidden rounded-xl border border-yellow-200 bg-yellow-50 p-3 text-sm"
					>
					</div>

					<label class="flex cursor-pointer items-center gap-2 py-2">
						<input
							type="checkbox"
							id="isActive"
							name="isActive"
							checked
							class="rounded text-blue-600"
						/>
						<span class="text-sm font-medium">Restricción activa</span>
					</label>
				</div>

				<div class="flex justify-end gap-2 border-t border-neutral-100 pt-4">
					<button
						type="button"
						id="cancel"
						class="px-4 py-2 text-sm font-medium text-neutral-500 hover:text-neutral-700"
						>Cancelar</button
					>
					<button
						type="submit"
						class="rounded-xl bg-blue-600 px-6 py-2 text-sm font-bold text-white shadow-md transition-all hover:bg-blue-700"
						>Guardar</button
					>
				</div>
			</form>
		</dialog>
	</main>

	<script
		type="module"
		define:vars={{ OPERATIONAL_RULE_PRESETS, productId, INCOMPATIBLE_PRESETS, SCOPE_LABELS }}
	>
		const ruleList = document.getElementById("ruleList")
		const modal = document.getElementById("modal")
		const form = document.getElementById("form")
		const ruleTypeInput = document.getElementById("ruleType")
		const paramsContainer = document.getElementById("paramsContainer")
		const configFields = document.getElementById("configFields")
		const presetList = document.getElementById("presetList")
		const selectedRuleName = document.getElementById("selectedRuleName")
		const scopeSelector = document.getElementById("scopeSelector")
		const scopeTargetContainer = document.getElementById("scopeTargetContainer")
		const scopeTarget = document.getElementById("scopeTarget")
		const scopeTargetLabel = document.getElementById("scopeTargetLabel")
		const previewBox = document.getElementById("previewBox")

		let rulesCache = []
		let editingId = null

		async function loadRestrictions() {
			const res = await fetch(`/api/products/${productId}/restrictions/get`)
			const { restrictions } = await res.json()
			rulesCache = restrictions
			renderRules()
		}

		async function previewImpact() {
			const formData = new FormData(form)

			if (!formData.get("type") || !formData.get("startDate") || !formData.get("endDate")) return

			const payload = {
				scope: formData.get("scope"),
				scopeId: formData.get("scope") === "product" ? productId : scopeTarget.value,
				type: formData.get("type"),
				value: formData.get("value") ? Number(formData.get("value")) : null,
				startDate: formData.get("startDate"),
				endDate: formData.get("endDate"),
			}

			const res = await fetch(`/api/products/${productId}/restrictions/preview`, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(payload),
			})

			const data = await res.json()

			renderPreview(data)
		}

		function renderPreview(data) {
			let html = ""

			if (data.blockedDates?.length) {
				html += `<div>⚠ Bloqueará <b>${data.blockedDates.length}</b> fechas</div>`
			}

			if (data.conflicts?.length) {
				html += `<div class="mt-2 text-red-600">
            Conflictos con:
            ${data.conflicts.map((c) => c.type).join(", ")}
        </div>`
			}

			if (!html) {
				previewBox.classList.add("hidden")
				return
			}

			previewBox.innerHTML = html
			previewBox.classList.remove("hidden")
		}

		function renderRules() {
			ruleList.innerHTML =
				rulesCache.length === 0
					? '<div class="text-center py-10 text-neutral-400 text-sm italic">No hay restricciones</div>'
					: ""
			rulesCache.forEach((rule) => {
				const preset = Object.values(OPERATIONAL_RULE_PRESETS)
					.flat()
					.find((p) => p.key === rule.type)
				const scopeText = SCOPE_LABELS[rule.scope] || rule.scope

				ruleList.innerHTML += `
                    <div class="group flex justify-between items-center rounded-2xl bg-white p-5 shadow-sm border border-neutral-100 hover:border-blue-200 transition-all">
                        <div class="flex-1">
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-neutral-800">${preset?.name ?? rule.type}</span>
                                <span class="px-2 py-0.5 rounded-md bg-neutral-100 text-[9px] font-bold text-neutral-500 uppercase">${scopeText}</span>
                                ${!rule.isActive ? '<span class="text-[10px] font-bold text-red-500 uppercase italic">Inactiva</span>' : ""}
                            </div>
                            <div class="text-xs text-neutral-400 mt-0.5">
                                ${new Date(rule.startDate).toLocaleDateString()} — ${new Date(rule.endDate).toLocaleDateString()}
                            </div>
                            <div class="text-sm text-neutral-600 mt-2 bg-neutral-50 px-3 py-1.5 rounded-lg border border-neutral-100">
                                ${preset?.explain ? preset.explain.replace(/\{\{.*?\}\}/g, rule.value || "") : rule.value || ""}
                            </div>
                        </div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button data-edit="${rule.id}" class="text-sm font-bold text-blue-600 hover:bg-blue-50 px-3 py-1 rounded-lg">Editar</button>
                            <button data-delete="${rule.id}" class="text-sm font-bold text-red-600 hover:bg-red-50 px-3 py-1 rounded-lg">Eliminar</button>
                        </div>
                    </div>
                `
			})
		}

		function selectPreset(key) {
			const preset = Object.values(OPERATIONAL_RULE_PRESETS)
				.flat()
				.find((p) => p.key === key)
			if (!preset) return

			ruleTypeInput.value = key
			selectedRuleName.innerText = preset.name

			// Filtrar opciones de Scope permitidas por el preset
			Array.from(scopeSelector.options).forEach((opt) => {
				opt.disabled = !preset.allowedScopes.includes(opt.value)
			})
			scopeSelector.value = preset.allowedScopes[0]
			scopeSelector.dispatchEvent(new Event("change"))

			paramsContainer.innerHTML = ""
			if (preset.params?.length > 0) {
				const p = preset.params[0]
				paramsContainer.innerHTML = `
                    <label class="text-[10px] font-bold uppercase text-neutral-400">${p.label}</label>
                    <input name="value" type="${p.type}" step="${p.step || "1"}" required class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                `
			}

			presetList.classList.add("hidden")
			configFields.classList.remove("hidden")
		}

		scopeSelector.onchange = async () => {
			const scope = scopeSelector.value
			scopeTarget.innerHTML = ""
			if (scope === "product") {
				scopeTargetContainer.classList.add("hidden")
				return
			}
			scopeTargetContainer.classList.remove("hidden")
			scopeTargetLabel.innerText =
				scope === "variant" ? "Seleccionar Habitación" : "Seleccionar Plan"

			const endpoint = scope === "variant" ? "rooms" : "rate-plans"
			const res = await fetch(`/api/products/${productId}/restrictions/${endpoint}`)
			const data = await res.json()
			const items = data.variants || data.ratePlans || []

			items.forEach((item) => {
				scopeTarget.innerHTML += `<option value="${item.id}">${item.name}</option>`
			})
		}
		
		form.addEventListener("change", previewImpact)
		form.onsubmit = async (e) => {
			e.preventDefault()
			const formData = new FormData(form)
			const validDays = Array.from(form.querySelectorAll('input[name="validDays"]:checked')).map(
				(el) => Number(el.value)
			)

			const payload = {
				scope: formData.get("scope"),
				scopeId: formData.get("scope") === "product" ? productId : scopeTarget.value,
				type: formData.get("type"),
				value: formData.get("value") ? Number(formData.get("value")) : null,
				validDays, // Enviamos array para la DB
				startDate: formData.get("startDate"),
				endDate: formData.get("endDate"),
				isActive: formData.get("isActive") === "on",
			}

			const method = editingId ? "PUT" : "POST"
			const url = editingId
				? `/api/products/${productId}/restrictions/${editingId}/update`
				: `/api/products/${productId}/restrictions/create`

			await fetch(url, {
				method,
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(payload),
			})

			modal.close()
			loadRestrictions()
		}

		document.getElementById("btnAdd").onclick = () => {
			editingId = null
			form.reset()
			presetList.classList.remove("hidden")
			configFields.classList.add("hidden")
			modal.showModal()
		}
		document.getElementById("cancel").onclick = () => modal.close()
		document
			.querySelectorAll(".preset-btn")
			.forEach((b) => (b.onclick = () => selectPreset(b.dataset.key)))
		document.getElementById("changePreset").onclick = () => {
			configFields.classList.add("hidden")
			presetList.classList.remove("hidden")
		}

		ruleList.onclick = (e) => {
			const editId = e.target.dataset.edit
			if (editId) {
				const rule = rulesCache.find((r) => r.id === editId)
				editingId = editId
				selectPreset(rule.type)
				document.getElementById("startDate").value = rule.startDate.split("T")[0]
				document.getElementById("endDate").value = rule.endDate.split("T")[0]
				document.getElementById("isActive").checked = rule.isActive
				if (rule.value) form.querySelector('[name="value"]').value = rule.value

				// Cargar Scope
				scopeSelector.value = rule.scope
				scopeSelector.dispatchEvent(new Event("change"))
				setTimeout(() => {
					scopeTarget.value = rule.scopeId
				}, 200)

				modal.showModal()
			}
		}

		loadRestrictions()
	</script>
</DashboardLayout>
