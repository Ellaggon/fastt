---
import { SERVICE_ATTRIBUTES } from "@/data/service/service-attributes"
import { SERVICE_CATALOG } from "@/data/service/service-catalog"
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { and, db, eq, ProductService, ProductServiceAttribute } from "astro:db"

const { id: productId, serviceId } = Astro.params
if (!productId || !serviceId) return Astro.redirect("/dashboard")

let productService = await db
	.select()
	.from(ProductService)
	.where(and(eq(ProductService.productId, productId), eq(ProductService.serviceId, serviceId)))
	.get()

// SSR must be read-only. If this row doesn't exist yet, it will be created via the POST endpoint.
const ps =
	productService ??
	({
		id: "",
		price: null,
		priceUnit: null,
		currency: null,
		appliesTo: "both",
		notes: "",
	} as const)

const attributesDef = SERVICE_ATTRIBUTES[serviceId] ?? []
const serviceDef = SERVICE_CATALOG.find((s) => s.id === serviceId)

const existingAttrs = productService
	? await db
			.select()
			.from(ProductServiceAttribute)
			.where(eq(ProductServiceAttribute.productServiceId, productService.id))
			.all()
	: []

const attrMap = Object.fromEntries(existingAttrs.map((a) => [a.key, a.value]))
const isInitiallyIncluded = ps.price === null || ps.price === 0
---

<DashboardLayout title={`Configurar ${serviceDef?.name}`}>
	<section class="h-full w-full pb-20 pt-6 md:pt-20">
		<article
			class="mx-auto w-[98%] rounded-3xl border border-neutral-300 bg-neutral-200 p-8 text-neutral-800 shadow-lg backdrop-blur-md sm:p-10 md:w-[80%] lg:max-w-3xl lg:p-16"
		>
			<header class="mb-10">
				<h1 class="text-xl font-bold uppercase tracking-tight md:text-3xl">Configurar Servicio</h1>
				<div class="mt-2 flex items-center gap-2">
					<span class="h-2 w-2 rounded-full bg-blue-600"></span>
					<p class="text-lg font-semibold text-neutral-700">{serviceDef?.name}</p>
				</div>
			</header>

			<form id="serviceConfigForm" class="space-y-12">
				<input type="hidden" name="psId" value={ps.id} />
				<input type="hidden" name="mode" value={ps.id ? "update" : "create"} />
				<input type="hidden" name="productId" value={productId} />

				<fieldset class="space-y-4 rounded-2xl border p-6 shadow-sm">
					<h3 class="text-lg font-semibold text-neutral-800">Precio y Cargo</h3>

					<label class="flex cursor-pointer items-center gap-3 font-medium text-neutral-800">
						<div class="relative flex items-center">
							<input
								type="checkbox"
								name="isIncluded"
								id="isIncluded"
								checked={isInitiallyIncluded}
								class="peer h-5 w-5 cursor-pointer appearance-none rounded-md bg-white transition-all checked:border-blue-600 checked:bg-blue-600"
							/>
							<svg
								class="pointer-events-none absolute left-1 top-1 h-3 w-3 text-white opacity-0 peer-checked:opacity-100"
								fill="none"
								stroke="currentColor"
								stroke-width="4"
								viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg
							>
						</div>
						<span class="text-sm">Este servicio es gratuito (Incluido en el precio)</span>
					</label>

					<hr class="border-neutral-200" />

					<div
						id="priceFields"
						class="grid grid-cols-1 gap-4 transition-all duration-300 md:grid-cols-3"
					>
						<div class="flex flex-col gap-1">
							<label class="text-sm font-medium text-neutral-600">Precio</label>
							<input
								type="number"
								name="price"
								step="0.01"
								value={ps.price ?? ""}
								class="text-medium rounded-lg border border-neutral-300 bg-white px-3 py-2 outline-none focus:ring-2 focus:ring-blue-500"
								placeholder="0.00"
							/>
						</div>

						<div class="flex flex-col gap-1">
							<label class="text-sm font-medium text-neutral-600">Unidad</label>
							<select
								name="priceUnit"
								class="text-medium rounded-lg border border-neutral-300 bg-white px-3 py-2 outline-none"
							>
								<option value="night" selected={ps.priceUnit === "night"}>Por noche</option>
								<option value="stay" selected={ps.priceUnit === "stay"}>Por estadía</option>
								<option value="person" selected={ps.priceUnit === "person"}>Por persona</option>
							</select>
						</div>

						<div class="flex flex-col gap-1">
							<label class="text-sm font-medium text-neutral-600">Moneda</label>
							<select
								name="currency"
								class="text-medium rounded-lg border border-neutral-300 bg-white px-3 py-2 outline-none"
							>
								<option value="BOB" selected={ps.currency === "BOB"}>BOB</option>
								<option value="USD" selected={ps.currency === "USD"}>USD</option>
							</select>
						</div>
					</div>
				</fieldset>

				<fieldset class="space-y-4 rounded-2xl border p-6 shadow-sm">
					<h3 class="text-lg font-semibold text-neutral-800">Alcance del Servicio</h3>
					<div class="flex flex-col gap-1">
						<label class="text-sm font-medium text-neutral-600">¿Dónde está disponible?</label>
						<select
							name="appliesTo"
							class="text-medium rounded-lg border border-neutral-300 bg-white px-3 py-2 outline-none"
						>
							<option value="room" selected={ps.appliesTo === "room"}>Solo en Habitaciones</option>
							<option value="common" selected={ps.appliesTo === "common"}
								>Solo en Áreas Comunes</option
							>
							<option value="both" selected={ps.appliesTo === "both"}
								>En todo el establecimiento</option
							>
						</select>
					</div>
				</fieldset>

				{
					attributesDef.length > 0 && (
						<fieldset class="space-y-4 rounded-2xl border p-6 shadow-sm">
							<h3 class="text-lg font-semibold text-neutral-800">Detalles Técnicos</h3>
							<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
								{attributesDef.map((attr) => (
									<div class="flex flex-col gap-1">
										<label class="text-sm font-medium text-neutral-600">{attr.label}</label>

										{attr.type === "select" ? (
											<select
												name={`attr_${attr.key}`}
												class="text-medium rounded-lg border border-neutral-300 bg-white px-3 py-2 outline-none"
											>
												<option value="">No especificado</option>
												{attr.options?.map((opt) => (
													<option value={opt.value} selected={opt.value === attrMap[attr.key]}>
														{opt.label}
													</option>
												))}
											</select>
										) : attr.type === "boolean" ? (
											<div class="flex h-full items-center">
												<input
													type="checkbox"
													name={`attr_${attr.key}`}
													value="true"
													checked={attrMap[attr.key] === "true"}
													class="h-5 w-5 rounded bg-white"
												/>
											</div>
										) : (
											<input
												type={attr.type === "number" ? "number" : "text"}
												name={`attr_${attr.key}`}
												value={attrMap[attr.key] ?? ""}
												placeholder={attr.placeholder}
												class="text-medium rounded-lg border border-neutral-300 bg-white px-3 py-2 outline-none focus:ring-2 focus:ring-blue-500"
											/>
										)}
									</div>
								))}
							</div>
						</fieldset>
					)
				}

				<div class="flex flex-col gap-1">
					<label class="px-2 font-semibold text-neutral-700">Notas adicionales (opcional)</label>
					<textarea
						name="notes"
						rows="3"
						class="w-full rounded-2xl border border-neutral-300 bg-white px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-blue-500"
						placeholder="Ej: Solo disponible bajo petición previa...">{ps.notes || ""}</textarea
					>
				</div>

				<div class="flex flex-col-reverse justify-end gap-4 pt-6 md:flex-row">
					<button
						type="button"
						id="removeService"
						class="rounded-xl px-6 py-3 text-sm font-bold text-red-500 transition-colors hover:bg-red-50"
					>
						Quitar del inventario
					</button>
					<button
						type="submit"
						class="rounded-xl bg-blue-600 px-10 py-3 font-bold text-white shadow-lg shadow-blue-200 transition-all hover:bg-blue-700 active:scale-95"
					>
						Guardar Cambios
					</button>
				</div>
				<p id="message" class="text-sm font-medium"></p>
			</form>
		</article>
	</section>

	<script type="module">
		const includedCheckbox = document.getElementById("isIncluded")
		const priceFields = document.getElementById("priceFields")
		const priceInput = document.querySelector('[name="price"]')

		function syncPriceUI() {
			if (includedCheckbox.checked) {
				priceFields.classList.add("opacity-40", "pointer-events-none", "grayscale")
				priceInput.value = ""
			} else {
				priceFields.classList.remove("opacity-40", "pointer-events-none", "grayscale")
			}
		}

		includedCheckbox.addEventListener("change", syncPriceUI)
		syncPriceUI()
	</script>

	<script type="module" define:vars={{ PRODUCT_ID: productId, SERVICE_ID: serviceId }}>
		const form = document.getElementById("serviceConfigForm")
		const message = document.getElementById("message")

		document.getElementById("removeService")?.addEventListener("click", async () => {
			if (!confirm("¿Seguro que deseas eliminar este servicio de tu lista?")) return

			const res = await fetch("/api/products/services/delete", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ productId: PRODUCT_ID, serviceId: SERVICE_ID }),
			})

			if (res.ok) window.location.href = `/products/${PRODUCT_ID}/services`
		})

		form.addEventListener("submit", async (e) => {
			e.preventDefault()
			message.textContent = "Guardando cambios..."
			message.className = "text-sm text-blue-600 font-medium"

			const res = await fetch(`/api/products/services/${SERVICE_ID}/update`, {
				method: "POST",
				body: new FormData(form),
			})

			if (res.ok) {
				message.textContent = "Actualizado correctamente"
				message.className = "text-sm text-green-600 font-bold"
				setTimeout(() => (window.location.href = `/products/${PRODUCT_ID}/services`), 800)
			} else {
				message.textContent = "Error al guardar"
				message.className = "text-sm text-red-600"
			}
		})
	</script>
</DashboardLayout>
