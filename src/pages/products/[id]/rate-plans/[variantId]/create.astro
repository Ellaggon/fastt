---
// import { WEEK_DAYS } from "@/data/week-days"
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { listActiveCancellationPolicies } from "@/modules/catalog/public"
import { getVariantById } from "@/modules/pricing/public"

const { variantId, id } = Astro.params
if (!variantId) return Astro.redirect("/dashboard")

const variant = await getVariantById(variantId)
const policies = await listActiveCancellationPolicies()

if (!variant) return Astro.redirect("/dashboard")
---

<DashboardLayout title="Crear Rate Plan">
	<section class="h-full w-full pt-6 md:pt-20">
		<article
			class="mx-auto w-[98%] rounded-3xl border border-neutral-300 bg-neutral-200 p-8 text-neutral-800 shadow-lg sm:p-10 md:w-[80%] lg:max-w-4xl lg:p-20"
		>
			<header>
				<h1 class="text-lg font-bold md:mb-1 md:text-2xl lg:text-3xl">CREAR PLAN TARIFARIO</h1>
				<p class="hidden text-xs text-neutral-600 md:block md:text-sm">
					Completa toda la información del plan tarifario.
				</p>
			</header>

			<div
				id="errorBanner"
				class="mb-4 hidden rounded-lg bg-red-100 p-3 text-sm text-red-700 md:text-base"
			>
				<span id="errorMsg"></span>
			</div>

			<p class="mt-7 text-end text-base font-semibold text-neutral-600 md:mb-6">{variant?.name}</p>

			<form id="rpForm" class="mt-6 flex flex-col gap-10 space-y-20">
				<section class="space-y-3">
					<h3 class="text-lg font-semibold text-neutral-800">Información básica</h3>
					<label class="flex flex-col text-sm">
						<span class="font-medium text-neutral-600">Nombre</span>
						<input
							name="name"
							required
							placeholder="Ej: Tarifa No Reembolsable 10% OFF"
							class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
						/>
					</label>
					<label class="flex flex-col text-sm">
						<span class="font-medium text-neutral-600">Descripción</span>
						<textarea
							name="description"
							placeholder="Ej: Descuento especial para reservas prepagadas. No permite cancelaciones."
							class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"></textarea>
					</label>
				</section>

				<div class="grid max-w-full gap-10 md:grid-cols-2">
					<section class="space-y-2">
						<h2 class="font-semibold text-neutral-700">Método de Pago</h2>

						<label class="flex flex-col text-sm">
							<select
								name="paymentType"
								class="mt-1 w-full rounded-md bg-neutral-100 px-3 py-2 text-base transition"
							>
								<option value="Prepaid">Pago anticipado</option>
								<option value="PayAtProperty">Pago en el alojamiento</option>
								<option value="PartialPrepaid">Pago parcial</option>
							</select>
						</label>

						<p class="mt-1 text-xs text-neutral-600">
							Define cómo paga el huésped. Algunos canales requieren pago anticipado para
							descuentos.
						</p>
					</section>

					<section class="space-y-3">
						<h2 class="font-semibold text-neutral-700">Política de Cancelación</h2>
						<label class="flex flex-col text-sm">
							<select
								name="cancellationPolicyId"
								class="mt-1 w-full rounded-md bg-neutral-100 px-3 py-2 text-base transition"
							>
								<option value="">Sin política</option>

								{policies.map((p) => <option value={p.id}>{p.description}</option>)}
							</select>
						</label>
						<p class="mt-1 text-xs text-neutral-600">
							Define cómo se maneja la cancelación para este plan. Las políticas se administran en
							la sección de <a
								target="_blank"
								href={`/products/${variant?.productId}/policies/cancellation`}
								class="inline-block max-w-full break-words border-b border-neutral-900 font-semibold text-neutral-900 hover:border-blue-500 hover:text-blue-500"
								>Políticas</a
							>.
						</p>
						<label class="flex cursor-pointer items-center justify-between gap-4 text-sm">
							<span class="font-medium text-neutral-700">Plan Reembolsable</span>

							<div class="relative h-6 w-11 flex-shrink-0">
								<input type="checkbox" name="refundable" checked class="peer sr-only" />

								<span
									class="absolute inset-0 rounded-full bg-neutral-300 transition-colors duration-200 peer-checked:bg-blue-600"
								></span>

								<span
									class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform duration-200 peer-checked:translate-x-5"
								></span>
							</div>
						</label>
					</section>
				</div>

				<section class="space-y-6">
					<h2 class="text-lg font-semibold text-neutral-800">Configuración de precios</h2>

					<div class="rounded-xl border border-white p-4 text-xs md:text-sm">
						<p class="text-neutral-600">
							Precio base habitación:
							<strong class="ml-2 text-neutral-800">
								{variant.currency}
								{variant.basePrice}
							</strong>
						</p>
					</div>

					<div class="mt-10 grid gap-10 md:grid-cols-2">
						<label class="flex flex-col space-y-3 text-sm">
							<span class="font-medium text-neutral-600">Tipo de precio</span>
							<select
								id="rateType"
								name="type"
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							>
								<option value="fixed_adjustment">Ajuste al precio (sumar o restar)</option>
								<option value="override">Precio fijo (reemplazar el precio base)</option>
								<option value="percentage_discount">Descuento (%)</option>
								<option value="percentage_markup">Aumento (%)</option>
								<option value="package">Paquete (no modifica el precio)</option>
							</select>

							<p class="mt-1 text-xs text-neutral-600">
								Selecciona cómo quieres que este plan afecte el precio
							</p>
						</label>

						<label class="relative flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Valor</span>

							<div class="relative">
								<input
									type="number"
									id="priceValue"
									name="value"
									value="0"
									step="0.01"
									class="mt-1 w-full rounded-md bg-neutral-100 px-3 py-2 pr-8 text-base"
								/>
								<span
									id="percentIcon"
									class="absolute right-3 top-1/2 hidden -translate-y-1/2 font-semibold text-neutral-600"
								>
									%
								</span>
							</div>
						</label>
					</div>

					<output
						class="block rounded-xl border border-blue-300 bg-gradient-to-br from-blue-50 to-blue-100 p-4 text-blue-900"
					>
						<p class="text-sm font-medium">Precio con la nueva tarifa</p>
						<p
							class="mt-1 text-lg font-bold"
							id="pricePreview"
							data-base-price={variant.basePrice}
							data-currency={variant.currency}
						>
							<strong>
								<span id="newCurrency">{variant.currency}</span>
								<span id="newPrice">{variant.basePrice}</span>
							</strong>
						</p>
						<p id="priceHelper" class="mt-3 text-xs text-blue-900"></p>
					</output>
				</section>

				<div class="grid gap-10 md:grid-cols-2">
					<section class="space-y-3">
						<h2 class="font-semibold text-neutral-700">Estancia</h2>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Noches mínimas</span>
							<input
								type="number"
								name="minNights"
								value="1"
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Noches máximas</span>
							<input
								type="number"
								name="maxNights"
								placeholder="Opcional"
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>
					</section>

					<section class="space-y-3">
						<h2 class="font-semibold text-neutral-700">Anticipación</h2>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Mínimo días de anticipación</span>
							<input
								type="number"
								name="minAdvanceDays"
								value="0"
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Máximo días de anticipación</span>
							<input
								type="number"
								name="maxAdvanceDays"
								placeholder="Opcional"
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>
					</section>
				</div>

				<!-- <div class="grid gap-10 md:grid-cols-2">
					<section class="space-y-6">
						<div class="space-y-3">
							<h2 class="font-semibold text-neutral-700">Días Válidos</h2>
							<p class="text-xs text-neutral-600">
								Elige los días válidos para este plan tarifario.
							</p>
						</div>

						<div class="grid grid-cols-2 gap-3 text-sm text-neutral-700 md:text-base">
							{
								WEEK_DAYS.map(({ label, value }) => (
									<label class="relative cursor-pointer">
										<input type="checkbox" name="validDays" value={value} class="peer sr-only" />

										<span class="flex select-none items-center justify-center rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-2 text-neutral-700 transition-all duration-150 hover:bg-neutral-100 active:scale-95 peer-checked:border-blue-600 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:hover:bg-blue-700">
											{label}
										</span>
									</label>
								))
							}
						</div>
					</section>

					<section class="space-y-6">
						<div class="space-y-3">
							<h2 class="font-semibold text-neutral-700">Vigencia del Plan Tarifario</h2>

							<p class="text-xs text-neutral-600">
								Define en qué fechas este plan estará disponible para reservas. Aplica según la
								fecha de check-in del huésped.
							</p>
						</div>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Fecha de inicio de vigencia</span>
							<input
								type="date"
								name="startDate"
								class="mt-1 rounded-xl bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Fecha de fín de vigencia</span>
							<input
								type="date"
								name="endDate"
								class="mt-1 rounded-xl bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>
					</section>
				</div> -->

				<label
					class="group flex cursor-pointer items-center justify-between gap-4 rounded-xl border border-neutral-200 bg-white p-4 shadow-sm transition-all hover:border-blue-300"
				>
					<div class="flex flex-col">
						<span class="font-bold text-neutral-800 transition-colors group-hover:text-blue-600"
							>Plan Tarifario</span
						>
						<span class="text-xs text-neutral-600">Estado actual: Activo</span>
					</div>

					<div class="relative h-7 w-12 flex-shrink-0">
						<input type="checkbox" name="isActive" checked class="peer sr-only" />

						<span
							class="absolute inset-0 rounded-full bg-neutral-200 transition-all duration-300 peer-checked:bg-gradient-to-r peer-checked:from-blue-700 peer-checked:to-cyan-500"
						></span>

						<span
							class="absolute inset-0 rounded-full opacity-0 blur-md transition-opacity duration-300 peer-checked:bg-blue-400 peer-checked:opacity-40"
						></span>

						<span
							class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white shadow-lg transition-all duration-300 peer-checked:translate-x-5 peer-checked:scale-110"
						></span>
					</div>
				</label>

				<footer class="flex justify-end py-16">
					<button
						type="submit"
						class="h-10 w-40 rounded-xl bg-blue-600 px-4 py-1 font-medium text-white shadow-md transition-colors duration-200 hover:bg-blue-700"
					>
						Crear Plan
					</button>
				</footer>
			</form>
		</article>
	</section>
</DashboardLayout>
<script type="module">
	;(() => {
		const root = document.getElementById("pricePreview")
		if (!root) return

		const state = {
			basePrice: Number(root.dataset.basePrice || 0),
			currency: root.dataset.currency,
		}

		const els = {
			type: document.getElementById("rateType"),
			value: document.getElementById("priceValue"),
			newPrice: document.getElementById("newPrice"),
			newCurrency: document.getElementById("newCurrency"),
			percentIcon: document.getElementById("percentIcon"),
			helper: document.getElementById("priceHelper"),
			submitBtn: document.querySelector("button[type='submit']"),
		}

		function applyUX() {
			const t = els.type.value
			els.percentIcon.classList.add("hidden")

			switch (t) {
				case "package":
					els.value.disabled = true
					els.helper.textContent = "Este plan no modifica el precio."
					break
				case "override":
					els.value.disabled = false
					els.helper.textContent = "Este valor reemplaza el precio base."
					break
				case "percentage_discount":
					els.value.disabled = false
					els.percentIcon.classList.remove("hidden")
					els.helper.textContent = "Descuento porcentual aplicado."
					break
				case "percentage_markup":
					els.value.disabled = false
					els.percentIcon.classList.remove("hidden")
					els.helper.textContent = "Aumento porcentual aplicado."
					break
				default:
					els.value.disabled = false
					els.helper.textContent = "Suma o resta al precio base."
			}
		}

		function clamp(value, min, max) {
			return Math.min(Math.max(value, min), max)
		}

		function calculate() {
			let price = state.basePrice
			let value = Number(els.value.value || 0)

			switch (els.type.value) {
				case "override":
					if (value > 0) price = value
					break
				case "percentage_discount":
					value = clamp(value, 0, 100)
					els.value.value = value
					price -= price * (value / 100)
					break
				case "percentage_markup":
					const markupVal = Math.max(0, value)
					price += price * (markupVal / 100)
					break
				case "fixed_adjustment":
					price += value
					break
			}

			price = Math.max(price, 0)
			els.newPrice.textContent = price.toFixed(2)
			els.newCurrency.textContent = state.currency

			if (price <= 0) {
				els.helper.textContent = "⚠ El precio final no puede ser negativo."
				els.submitBtn.disabled = true
			} else {
				els.submitBtn.disabled = false
			}
		}

		els.type.addEventListener("change", () => {
			applyUX()
			calculate()
		})

		els.value.addEventListener("input", calculate)

		applyUX()
		calculate()
	})()
</script>
<script
	type="module"
	define:vars={{
		PRODUCT_ID: id,
		VARIANT_ID: variantId,
		VARIANT_TYPE: variant.entityType,
	}}
>
	const form = document.getElementById("rpForm")
	const errorBanner = document.getElementById("errorBanner")
	const errorMsg = document.getElementById("errorMsg")

	function showError(msg) {
		errorMsg.textContent = msg
		errorBanner.classList.remove("hidden")
		window.scrollTo({ top: 0, behavior: "smooth" })
	}

	form.addEventListener("submit", async (e) => {
		e.preventDefault()
		const fd = new FormData(form)
		// const validDays = fd.getAll("validDays").map(Number)

		const body = {
			variantId: VARIANT_ID,
			name: fd.get("name"),
			description: fd.get("description") || null,
			type: fd.get("type"),
			value: Number(fd.get("value")),
			refundable: fd.get("refundable") === "on",
			cancellationPolicyId: fd.get("cancellationPolicyId") || null,
			paymentType: fd.get("paymentType"),
			minNights: Number(fd.get("minNights")),
			maxNights: fd.get("maxNights") ? Number(fd.get("maxNights")) : null,
			minAdvanceDays: Number(fd.get("minAdvanceDays")),
			maxAdvanceDays: fd.get("maxAdvanceDays") ? Number(fd.get("maxAdvanceDays")) : null,
			isActive: fd.get("isActive") === "on",
		}

		const res = await fetch("/api/rateplans/create", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(body),
		})
		if (!res.ok) {
			let msg = "Error al crear plan tarifario"
			try {
				const data = await res.json()
				if (data.error) msg = data.error
			} catch {
				showError(msg)
				return
			}
		}

		if (VARIANT_TYPE === "hotel_room") {
			window.location.href = `/products/${PRODUCT_ID}/rate-plans/${VARIANT_ID}`
		}
	})
</script>
