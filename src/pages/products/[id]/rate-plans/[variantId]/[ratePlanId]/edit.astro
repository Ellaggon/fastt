---
// import { WEEK_DAYS } from "@/data/week-days"
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import {
	and,
	db,
	eq,
	Policy,
	PolicyGroup,
	PriceRule,
	RatePlan,
	RatePlanTemplate,
	Restriction,
	Variant,
} from "astro:db"

const { id, variantId, ratePlanId } = Astro.params
if (!id) throw new Error("id from product is required")
if (!variantId) throw new Error("variantId is required")
if (!ratePlanId) throw new Error("ratePlanId is required")

const ratePlan = await db.select().from(RatePlan).where(eq(RatePlan.id, ratePlanId)).get()
if (!ratePlan) throw new Error("Rate plan not found")

const variant = await db.select().from(Variant).where(eq(Variant.id, variantId)).get()
if (!variant) throw new Error("Variant not found")

const template = ratePlan.templateId
	? await db
			.select()
			.from(RatePlanTemplate)
			.where(eq(RatePlanTemplate.id, ratePlan.templateId))
			.get()
	: null

const priceRules = await db
	.select()
	.from(PriceRule)
	.where(eq(PriceRule.ratePlanId, ratePlan.id))
	.all()

const restrictions = await db
	.select()
	.from(Restriction)
	.where(eq(Restriction.scopeId, ratePlan.id))
	.all()

const policies = await db
	.select({
		id: Policy.id,
		groupId: Policy.groupId,
		version: Policy.version,
		status: Policy.status,
		description: Policy.description,
	})
	.from(Policy)
	.innerJoin(PolicyGroup, eq(Policy.groupId, PolicyGroup.id))
	.where(and(eq(PolicyGroup.category, "Cancellation"), eq(Policy.status, "active")))
	.all()

const priceRule = priceRules[0] ?? null
const priceType = priceRule?.type ?? "fixed_adjustment"

function getRestriction(type: string) {
	return restrictions.find((r) => r.type === type) ?? null
}

const minLos = getRestriction("min_los")
const maxLos = getRestriction("max_los")
const minLead = getRestriction("min_lead_time")
const maxLead = getRestriction("max_lead_time")

// fechas y días: salen de cualquiera (todas comparten rango)
// const base = restrictions[0] ?? null

// const validDays: number[] = (() => {
// 	if (!base?.validDays) return []
// 	if (Array.isArray(base.validDays)) return base.validDays.map(Number)
// 	if (typeof base.validDays === "string") {
// 		try {
// 			const parsed = JSON.parse(base.validDays)
// 			return Array.isArray(parsed) ? parsed.map(Number) : []
// 		} catch {
// 			return []
// 		}
// 	}
// 	return []
