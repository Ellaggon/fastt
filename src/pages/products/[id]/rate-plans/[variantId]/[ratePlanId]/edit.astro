---

<DashboardLayout title="Editar Rate Plan">
	<section class="h-full w-full pt-6 md:pt-20">
		<article
			class="mx-auto w-[98%] rounded-3xl border border-neutral-300 bg-neutral-200 p-8 text-neutral-800 shadow-lg sm:p-10 md:w-[80%] lg:max-w-4xl lg:p-20"
		>
			<header>
				<h1 class="text-lg font-bold md:mb-1 md:text-2xl lg:text-3xl">EDITAR PLAN TARIFARIO</h1>
				<p class="hidden text-xs text-neutral-500 md:block md:text-sm">
					Configura precios, restricciones y vigencia del plan.
				</p>
			</header>

			<div id="errorBanner" class="mb-4 hidden rounded-lg bg-red-100 p-3 text-sm text-red-700">
				<span id="errorMsg"></span>
			</div>

			<p class="mt-7 text-end text-base font-semibold text-neutral-600 md:mb-6">
				{variant?.name}
			</p>

			<form id="editForm" class="mt-6 flex flex-col gap-10 space-y-20">
				<section class="space-y-3">
					<h3 class="text-lg font-semibold text-neutral-800">Información básica</h3>

					<label class="flex flex-col text-sm">
						<span class="font-medium text-neutral-600">Nombre</span>
						<input
							name="name"
							value={template?.name}
							required
							class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
						/>
					</label>

					<label class="flex flex-col text-sm">
						<span class="font-medium text-neutral-600">Descripción</span>
						<textarea
							name="description"
							rows="3"
							class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							>{template?.description}</textarea
						>
					</label>
				</section>

				<div class="grid max-w-full gap-10 md:grid-cols-2">
					<section class="space-y-2">
						<h2 class="font-semibold text-neutral-700">Método de Pago</h2>

						<select
							name="paymentType"
							class="mt-1 w-full rounded-md bg-neutral-100 px-3 py-2 text-base transition"
						>
							<option value="Prepaid" selected={template?.paymentType === "Prepaid"}>
								Pago anticipado
							</option>
							<option value="PayAtProperty" selected={template?.paymentType === "PayAtProperty"}>
								Pago en el alojamiento
							</option>
							<option value="PartialPrepaid" selected={template?.paymentType === "PartialPrepaid"}>
								Pago parcial
							</option>
						</select>
					</section>

					<section class="space-y-3">
						<h2 class="font-semibold text-neutral-700">Política de Cancelación</h2>
						<select
							name="cancellationPolicyId"
							class="mt-1 w-full rounded-md bg-neutral-100 px-3 py-2 text-base transition"
						>
							<option value="">Sin política</option>
							{
								policies.map((p) => (
									<option value={p.id} selected={p.id === template?.cancellationPolicyId}>
										{p.description}
									</option>
								))
							}
						</select>

						<label class="flex cursor-pointer items-center justify-between gap-4 text-sm">
							<span class="font-medium text-neutral-700">Plan Reembolsable</span>

							<div class="relative h-6 w-11 flex-shrink-0">
								<input
									type="checkbox"
									name="refundable"
									checked={template?.refundable}
									class="peer sr-only"
								/>

								<span
									class="absolute inset-0 rounded-full bg-neutral-300 transition-colors duration-200 peer-checked:bg-blue-600"
								></span>

								<span
									class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform duration-200 peer-checked:translate-x-5"
								></span>
							</div>
						</label>
					</section>
				</div>

				<section class="space-y-6">
					<h2 class="text-lg font-semibold text-neutral-800">Configuración de precios</h2>

					<div class="rounded-xl border border-white p-4 text-xs md:text-sm">
						<p class="text-neutral-600">
							Precio base habitación:
							<strong class="ml-2 text-neutral-800">
								{variant.currency}
								{variant.basePrice}
							</strong>
						</p>
					</div>

					<div class="mt-10 grid gap-10 md:grid-cols-2">
						<label class="flex flex-col space-y-3 text-sm">
							<span class="font-medium text-neutral-600">Tipo de precio</span>
							<select
								id="rateType"
								name="type"
								class="rounded-md bg-neutral-100 px-3 py-2 text-base"
							>
								<option value="fixed_adjustment" selected={priceType === "fixed_adjustment"}>
									Ajuste al precio
								</option>
								<option value="override" selected={priceType === "override"}> Precio fijo </option>
								<option value="package" selected={priceType === "package"}> Paquete </option>
								<option value="percentage_discount" selected={priceType === "percentage_discount"}>
									Descuento (%)
								</option>
								<option value="percentage_markup" selected={priceType === "percentage_markup"}>
									Aumento (%)
								</option>
							</select>
						</label>

						<label class="flex flex-col space-y-3 text-sm">
							<span class="font-medium text-neutral-600">Valor</span>
							<div class="relative">
								<input
									type="number"
									id="priceValue"
									name="value"
									value={priceRule?.value ?? 0}
									step="0.01"
									class="w-full rounded-md bg-neutral-100 px-3 py-2 pr-8 text-base"
								/>
								<span
									id="percentIcon"
									class="absolute right-3 top-1/2 hidden -translate-y-1/2 font-semibold text-neutral-600"
								>
									%
								</span>
							</div>
						</label>
					</div>

					<output
						class="block rounded-xl border border-blue-300 bg-gradient-to-br from-blue-50 to-blue-100 p-4 text-blue-900"
					>
						<p class="text-sm font-medium">Precio con la nueva tarifa</p>
						<p
							class="mt-1 text-lg font-bold"
							id="pricePreview"
							data-base-price={variant.basePrice}
							data-currency={variant.currency}
						>
							<strong>
								<span id="newCurrency">{variant.currency}</span>
								<span id="newPrice">{variant.basePrice}</span>
							</strong>
						</p>
						<p id="priceHelper" class="mt-3 text-xs"></p>
					</output>
				</section>

				<div class="grid gap-10 md:grid-cols-2">
					<section class="space-y-3">
						<h2 class="font-semibold text-neutral-700">Estancia</h2>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Noches mínimas</span>
							<input
								type="number"
								name="minNights"
								value={minLos?.value ?? 1}
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Noches máximas</span>
							<input
								type="number"
								name="maxNights"
								value={maxLos?.value ?? ""}
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>
					</section>

					<section class="space-y-3">
						<h2 class="font-semibold text-neutral-700">Anticipación</h2>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Mínimo días de anticipación</span>
							<input
								type="number"
								name="minAdvanceDays"
								value={minLead?.value ?? 0}
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Máximo días de anticipación</span>
							<input
								type="number"
								name="maxAdvanceDays"
								value={maxLead?.value ?? ""}
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>
					</section>
				</div>

				<!-- <div class="grid gap-10 md:grid-cols-2">
					<section class="space-y-6">
						<h2 class="font-semibold text-neutral-700">Días Válidos</h2>

						<div class="grid grid-cols-2 gap-3 text-sm text-neutral-700">
							{
								WEEK_DAYS.map(({ label, value }) => (
									<label class="relative cursor-pointer">
										<input
											type="checkbox"
											name="validDays"
											value={value}
											checked={validDays.includes(value)}
											class="peer sr-only"
										/>
										<span class="flex select-none items-center justify-center rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-2 text-base transition-all peer-checked:border-blue-600 peer-checked:bg-blue-600 peer-checked:text-white">
											{label}
										</span>
									</label>
								))
							}
						</div>
					</section>

					<section class="space-y-6">
						<h2 class="font-semibold text-neutral-700">Vigencia del Plan Tarifario</h2>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Fecha inicio</span>
							<input
								type="date"
								name="startDate"
								value={base?.startDate}
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>

						<label class="flex flex-col text-sm">
							<span class="font-medium text-neutral-600">Fecha fin</span>
							<input
								type="date"
								name="endDate"
								value={base?.endDate}
								class="mt-1 rounded-md bg-neutral-100 px-3 py-2 text-base"
							/>
						</label>
					</section>
				</div> -->

				<label
					class="group flex cursor-pointer items-center justify-between gap-4 rounded-xl border border-neutral-200 bg-white p-4 shadow-sm transition-all hover:border-blue-300"
				>
					<div class="flex flex-col">
						<span class="font-bold text-neutral-800 group-hover:text-blue-600">
							Plan Tarifario
						</span>
						<span class="text-xs text-neutral-600 md:text-sm">
							Estado actual: {ratePlan?.isActive ? "Activo" : "Inactivo"}
						</span>
					</div>

					<div class="relative h-7 w-12 flex-shrink-0">
						<input
							type="checkbox"
							name="isActive"
							checked={ratePlan?.isActive}
							class="peer sr-only"
						/>

						<span
							class="absolute inset-0 rounded-full bg-neutral-200 transition-all duration-300 peer-checked:bg-gradient-to-r peer-checked:from-blue-700 peer-checked:to-cyan-500"
						></span>

						<span
							class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white shadow-lg transition-all duration-300 peer-checked:translate-x-5 peer-checked:scale-110"
						></span>
					</div>
				</label>

				<footer class="flex items-center justify-between pt-16">
					<button
						id="deleteBtn"
						type="button"
						class="text-sm text-red-600 hover:underline md:text-base"
					>
						Eliminar plan
					</button>

					<button
						type="submit"
						class="h-10 w-40 rounded-xl bg-blue-600 px-4 py-1 font-medium text-white shadow-md transition-colors duration-200 hover:bg-blue-700"
					>
						Guardar cambios
					</button>
				</footer>
			</form>
		</article>
	</section>
</DashboardLayout>

<script type="module">
	document.addEventListener("DOMContentLoaded", () => {
		const root = document.getElementById("pricePreview")
		if (!root) return

		const els = {
			type: document.getElementById("rateType"),
			value: document.getElementById("priceValue"),
			newPrice: document.getElementById("newPrice"),
			newCurrency: document.getElementById("newCurrency"),
			percentIcon: document.getElementById("percentIcon"),
			helper: document.getElementById("priceHelper"),
		}

		const state = {
			basePrice: Number(root.dataset.basePrice || 0),
			currency: root.dataset.currency,
		}

		function applyUX() {
			const t = els.type.value
			els.percentIcon.classList.add("hidden")

			switch (t) {
				case "package":
					els.value.parentElement.classList.add("hidden")
					els.helper.textContent = "Este plan no modifica el precio."
					break
				case "override":
					els.value.parentElement.classList.remove("hidden")
					els.helper.textContent = "Este valor reemplaza el precio base."
					break
				case "percentage_discount":
					els.value.parentElement.classList.remove("hidden")
					els.percentIcon.classList.remove("hidden")
					els.helper.textContent = "Descuento porcentual aplicado."
					break
				case "percentage_markup":
					els.value.parentElement.classList.remove("hidden")
					els.percentIcon.classList.remove("hidden")
					els.helper.textContent = "Aumento porcentual aplicado."
					break
				default:
					els.value.parentElement.classList.remove("hidden")
					els.helper.textContent = "Suma o resta al precio base."
			}
		}

		function clamp(value, min, max) {
			return Math.min(Math.max(value, min), max)
		}
		function calculate() {
			let price = state.basePrice
			let value = Number(els.value.value || 0)

			switch (els.type.value) {
				case "override":
					if (value > 0) price = value
					break
				case "percentage_discount":
					value = clamp(value, 0, 100)
					els.value.value = value
					price -= price * (value / 100)
					break
				case "percentage_discount":
					value = clamp(value, 0, 100)
					els.value.value = value
					price -= price * (value / 100)
					break
				case "percentage_markup":
					const markupVal = Math.max(0, value)
					price += price * (markupVal / 100)
					break
				case "fixed_adjustment":
					price += value
					break
			}

			price = Math.max(0, price)

			els.newPrice.textContent = price.toFixed(2)
			els.newCurrency.textContent = state.currency
		}

		els.type.addEventListener("change", () => {
			applyUX()
			calculate()
		})
		els.value.addEventListener("input", calculate)

		applyUX()
		calculate()
	})
</script>

<script
	type="module"
	define:vars={{
		PRODUCT_ID: id,
		VARIANT_ID: variantId,
		VARIANT_TYPE: variant.entityType,
		RATE_PLAN_ID: ratePlanId,
	}}
>
	const form = document.getElementById("editForm")
	const deleteBtn = document.getElementById("deleteBtn")
	const errorBanner = document.getElementById("errorBanner")
	const errorMsg = document.getElementById("errorMsg")

	function showError(msg) {
		errorMsg.textContent = msg
		errorBanner.classList.remove("hidden")
		window.scrollTo({ top: 0, behavior: "smooth" })
	}

	deleteBtn.addEventListener("click", async () => {
		if (!confirm("¿Eliminar este plan tarifario? Esta acción no se puede deshacer.")) return

		const res = await fetch(`/api/rateplans/delete?id=${RATE_PLAN_ID}`, { method: "DELETE" })
		if (!res.ok) {
			showError("No se pudo eliminar el plan")
			return
		}
		window.location.href = `/products/${PRODUCT_ID}/rate-plans/${VARIANT_ID}`
	})

	form.addEventListener("submit", async (e) => {
		e.preventDefault()
		const fd = new FormData(form)
		// const validDays = fd.getAll("validDays").map(Number)

		const body = {
			id: RATE_PLAN_ID,
			variantId: VARIANT_ID,
			name: fd.get("name"),
			description: fd.get("description") || null,
			type: fd.get("type"),
			value: Number(fd.get("value")),
			refundable: fd.get("refundable") === "on",
			cancellationPolicyId: fd.get("cancellationPolicyId") || null,
			paymentType: fd.get("paymentType"),
			minNights: Number(fd.get("minNights")),
			maxNights: fd.get("maxNights") ? Number(fd.get("maxNights")) : null,
			minAdvanceDays: Number(fd.get("minAdvanceDays")),
			maxAdvanceDays: fd.get("maxAdvanceDays") ? Number(fd.get("maxAdvanceDays")) : null,
			isActive: fd.get("isActive") === "on",
		}

		// if (body.startDate && body.endDate) {
		// 	const start = new Date(body.startDate)
		// 	const end = new Date(body.endDate)

		// 	if (start > end) {
		// 		showError("La fecha de inicio no puede ser posterior a la fecha de fin")
		// 		return
		// 	}
		// }

		const res = await fetch("/api/rateplans/update", {
			method: "PUT",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify(body),
		})

		if (!res.ok) {
			const { error } = await res.json()
			showError(error || "Error al actualizar")
			return
		}

		if (VARIANT_TYPE === "hotel_room") {
			window.location.href = `/products/${PRODUCT_ID}/rate-plans/${VARIANT_ID}`
		}
	})
</script>
