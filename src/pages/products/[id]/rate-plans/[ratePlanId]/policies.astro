---
import PolicyCard from "@/components/policy/PolicyCard.astro"
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireProvider } from "@/lib/auth/requireProvider"
import { getProductById } from "@/modules/catalog/public"
import {
	PolicyValidationError,
	replacePolicyAssignmentCapa6,
	resolveEffectivePolicies,
} from "@/modules/policies/public"
import { getRatePlanOwnerContext } from "@/modules/pricing/application/use-cases/get-rateplan-owner-context"
import { RatePlanOwnerContextRepository } from "@/modules/pricing/infrastructure/repositories/RatePlanOwnerContextRepository"
import { z } from "zod"

const productId = String(Astro.params.id ?? "").trim()
const ratePlanId = String(Astro.params.ratePlanId ?? "").trim()
if (!productId || !ratePlanId) return Astro.redirect("/dashboard")
const saved = Astro.url.searchParams.get("saved") === "1"

let providerId: string | null = null
try {
	const res = await requireProvider(Astro.request)
	providerId = res.providerId
} catch (e: any) {
	if (e instanceof Response && e.status === 401) return Astro.redirect("/SignInPage")
	if (e instanceof Response && e.status === 403) return Astro.redirect("/provider")
	throw e
}

// Ownership: product must belong to provider.
const product = await getProductById(productId)
if (!product || !product.providerId || product.providerId !== providerId) {
	return new Response("Not found", { status: 404 })
}

// Basic consistency: rate plan must exist and belong to this product via its variant.
const ratePlanCtxRepo = new RatePlanOwnerContextRepository()
const ratePlanCtx = await getRatePlanOwnerContext({ repo: ratePlanCtxRepo }, { ratePlanId })
if (!ratePlanCtx || ratePlanCtx.productId !== productId) {
	return new Response("Not found", { status: 404 })
}

let error: string | null = null
let success: string | null = null

if (Astro.request.method === "POST") {
	try {
		const form = await Astro.request.formData()
		const policyId = String(form.get("policyId") ?? "").trim()
		const category = String(form.get("category") ?? "").trim()
		if (!policyId) {
			error = category ? `Select a policy for ${category}` : "Select a policy"
		} else {
			await replacePolicyAssignmentCapa6({
				policyId,
				scope: "rate_plan",
				scopeId: ratePlanId,
				channel: null,
			})
			return Astro.redirect(`${Astro.url.pathname}?saved=1`)
		}
	} catch (e: any) {
		if (e instanceof z.ZodError) {
			error = "Validation error"
		} else if (e instanceof PolicyValidationError) {
			error = "Validation error"
		} else {
			error = String(e?.message || e)
		}
	}
}

const policiesRes = await fetch(new URL("/api/policies/list-active", Astro.url), {
	headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
})
const allPolicies = policiesRes.ok ? ((await policiesRes.json()) as any[]) : []

const categories = ["Cancellation", "Payment", "CheckIn", "NoShow"] as const
const CATEGORY_LABELS: Record<(typeof categories)[number], string> = {
	Cancellation: "Cancellation policy",
	Payment: "Payment policy",
	CheckIn: "Check-in / Check-out",
	NoShow: "No-show (guest does not arrive)",
}
const policiesByCategory: Record<string, any[]> = {}
for (const c of categories) policiesByCategory[c] = []
for (const p of allPolicies) {
	const c = String(p.category ?? "")
	if (!policiesByCategory[c]) continue
	policiesByCategory[c].push(p)
}

const resolved = await resolveEffectivePolicies({
	productId,
	variantId: ratePlanCtx.variantId,
	ratePlanId,
})
const resolvedByCategory: Record<string, any> = {}
for (const p of resolved.policies ?? []) resolvedByCategory[String(p.category)] = p
---

<DashboardLayout>
	<main class="space-y-4 p-6">
		<header class="flex items-center justify-between">
			<h1 class="text-xl font-semibold">Rate plan policies</h1>
			<nav class="space-x-3">
				<a class="underline" href={`/products/${productId}`}>Product</a>
				<a class="underline" href={`/products/${productId}/rate-plans`}>Rate plans</a>
			</nav>
		</header>

		{
			error && (
				<div class="border p-3">
					<strong>Error:</strong> {error}
				</div>
			)
		}
		{
			success && (
				<div class="border p-3">
					<strong>OK:</strong> {success}
				</div>
			)
		}
		{
			saved && (
				<div class="border p-3">
					<strong>OK:</strong> Policy saved.
				</div>
			)
		}

		<section class="space-y-2">
			<p class="text-sm">
				Per category, the rate plan can override a policy inherited from Variant/Product/Global.
			</p>

			{
				!policiesRes.ok ? (
					<p>Failed to load policies.</p>
				) : (
					<div class="space-y-6">
						{categories.map((cat) => {
							const r = resolvedByCategory[cat] ?? null
							const source = String(r?.resolvedFromScope ?? "global") as any
							const state = !r ? "missing" : source === "rate_plan" ? "override" : "inherited"
							const options = policiesByCategory[cat] ?? []
							const selected = state === "override" ? String(r?.policy?.id ?? "") : ""

							return (
								<section class="space-y-2">
									<PolicyCard
										category={CATEGORY_LABELS[cat]}
										description={String(r?.policy?.description ?? "")}
										version={Number(r?.policy?.version ?? 0)}
										source={source}
										state={state}
									/>

									{options.length === 0 ? (
										<p class="text-sm">
											No policies available for {cat}.{" "}
											<a class="underline" href="/provider/policies/new">
												Create policy
											</a>
										</p>
									) : (
										<form method="POST" class="space-y-2">
											<input type="hidden" name="category" value={cat} />
											<label class="block text-sm">Select policy</label>
											<select name="policyId" class="w-full border p-2">
												<option value="">Select…</option>
												{options.map((p) => (
													<option value={p.id} selected={String(p.id) === selected}>
														{p.description} (v{p.version})
													</option>
												))}
											</select>

											<button
												type="submit"
												class="border px-4 py-2"
												disabled={options.length === 0}
											>
												{state === "override"
													? "Change policy"
													: state === "inherited"
														? "Override policy"
														: "Assign policy"}
											</button>
										</form>
									)}

									<p class="text-xs text-neutral-600">
										Tip: editing a policy creates a new version in the same group; assignments stay
										the same.
									</p>
								</section>
							)
						})}
					</div>
				)
			}
		</section>

		<section class="space-y-2">
			<h2 class="font-semibold">Verify</h2>
			<p class="text-sm">
				View product page (policies tab):{" "}
				<a class="underline" href={`/hotels/${productId}`}>/hotels/{productId}</a>
			</p>
		</section>
	</main>
</DashboardLayout>
