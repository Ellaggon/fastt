---
import PolicyCancellationHistory from "@/components/policy/PolicyCancellationHistory.astro"
import PolicyCancellationModal from "@/components/policy/PolicyCancellationModal.astro"
import DashboardLayout from "@/layouts/DashboardLayout.astro"

let { id: scopeId } = Astro.params
let scope = "product"
---

<DashboardLayout>
	<section class="h-full w-full pt-6 md:pt-20">
		<article
			class="mx-auto w-[98%] space-y-8 rounded-3xl border border-neutral-300 bg-neutral-200 p-8 text-neutral-800 shadow-lg sm:p-10 md:w-[80%] md:max-w-3xl lg:p-20"
		>
			<h1 class="mb-2 text-2xl font-semibold uppercase">Políticas de Cancelación</h1>

			<div class="flex justify-end">
				<button
					data-open-modal="cancellation"
					id="btnCreate"
					class="rounded-xl bg-blue-600 px-4 py-2 text-white"
				>
					Nueva Política
				</button>
			</div>

			<div id="policyList" class="mt-6 space-y-4">Cargando...</div>
		</article>
		<PolicyCancellationModal {scope} {scopeId} />
		<PolicyCancellationHistory />
	</section>
</DashboardLayout>

<script type="module" define:vars={{ scope, scopeId }}>
	import { openModal } from "/src/lib/utils/modal-manager"
	const list = document.getElementById("policyList")

	async function loadPolicies() {
		const res = await fetch(
			`/api/policies/assigned?scope=${scope}&scopeId=${scopeId}&category=Cancellation`
		)

		const policies = await res.json()

		if (!policies.length) {
			list.innerHTML = "No hay políticas."
			return
		}

		list.innerHTML = policies.map(renderCard).join("")
		attachActions()
	}

	function renderCard(p) {
		return `
			<div class="border rounded-xl p-4 bg-white flex justify-between">
				<div>
					<p class="text-base text-neutral-600">${p.description}</p>

					<p class="text-xs font-semibold ${p.status === "active" ? "text-green-600" : "text-yellow-600"}">
						${p.status}
					</p>

					<div class="flex gap-3 mt-2">
						${
							p.status === "draft"
								? `
								<button data-id="${p.id}" class="activateBtn bg-blue-600 text-white px-3 py-1 rounded text-xs">
									Activar
								</button>
								<button data-id="${p.id}" class="deleteBtn bg-red-600 text-white px-3 py-1 rounded text-xs">
									Eliminar
								</button>
							`
								: ""
						}

						<button data-group="${p.groupId}" data-open-modal="history" class="historyBtn text-blue-600 text-xs ${p.status === "active" ? "block" : "hidden"}">
							Historial
						</button>
					</div>
				</div>
					<button data-id="${p.id}" class="editBtn text-blue-600 text-xs ${p.status === "active" ? "block" : "hidden"}">
						Editar	
					</button>
			</div>
		`
	}

	function attachActions() {
		document.querySelectorAll(".activateBtn").forEach((btn) => {
			btn.onclick = async () => {
				await fetch("/api/policies/activate", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ policyId: btn.dataset.id }),
				})
				loadPolicies()
			}
		})

		document.querySelectorAll(".deleteBtn").forEach((btn) => {
			btn.onclick = async () => {
				await fetch("/api/policies/delete", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ policyId: btn.dataset.id }),
				})
				loadPolicies()
			}
		})

		document.querySelectorAll(".historyBtn").forEach((btn) => {
			btn.onclick = async () => {
				const res = await fetch(`/api/policies/history?groupId=${btn.dataset.group}`)
				const versions = await res.json()
				window.openHistoryModal(versions)
			}
		})
		document.querySelectorAll(".editBtn").forEach((btn) => {
			btn.onclick = async () => {
				const res = await fetch(`/api/policies/${btn.dataset.id}`)
				const policy = await res.json()

				const modal = document.querySelector('[data-modal="cancellation"]')
				modal.dataset.editPolicy = JSON.stringify(policy)
				openModal("cancellation")
			}
		})
	}

	window.addEventListener("cancellation:created", loadPolicies)

	loadPolicies()
</script>
