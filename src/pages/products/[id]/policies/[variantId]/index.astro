---
import PolicyManager from "@/components/policy/PolicyManager.astro"
import DashboardLayout from "@/layouts/DashboardLayout.astro"

const { id: productId, variantId } = Astro.params
if (!productId || !variantId) return Astro.redirect("/dashboard")
---

<DashboardLayout>
	<PolicyManager
		title="Políticas del Variant"
		scope="variant"
		scopeId={variantId}
		resolveParams={{ productId, variantId }}
	/>
</DashboardLayout>
