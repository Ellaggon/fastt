---
import Layout from "@/layouts/Layout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")
---

<Layout title="Provider V2 - Register">
	<main
		class="mx-auto mt-20 w-10/12 max-w-2xl rounded-2xl border border-neutral-300 bg-neutral-200 p-8"
	>
		<h1 class="mb-2 text-2xl font-semibold">Provider V2: Register</h1>
		<p class="mb-6 text-xs text-neutral-600">Crea un provider (v2) sin afectar el flujo legacy.</p>

		<form id="providerV2Register" class="grid gap-4">
			<label class="text-xs">
				Company Name (required)
				<input class="mt-1 w-full rounded border p-2" name="companyName" required />
			</label>

			<label class="text-xs">
				Legal Name (required)
				<input class="mt-1 w-full rounded border p-2" name="legalName" required minlength="2" />
			</label>

			<label class="text-xs">
				Display Name (required)
				<input class="mt-1 w-full rounded border p-2" name="displayName" required minlength="2" />
			</label>

			<label class="text-xs">
				Contact Name
				<input class="mt-1 w-full rounded border p-2" name="contactName" />
			</label>

			<label class="text-xs">
				Contact Email
				<input class="mt-1 w-full rounded border p-2" type="email" name="contactEmail" />
			</label>

			<label class="text-xs">
				Phone
				<input class="mt-1 w-full rounded border p-2" name="phone" />
			</label>

			<label class="text-xs">
				Type
				<select class="mt-1 w-full rounded border p-2" name="type">
					<option value="">(optional)</option>
					<option value="Hotel">Hotel</option>
					<option value="Tour Operator">Tour Operator</option>
					<option value="Transport">Transport</option>
				</select>
			</label>

			<button class="rounded bg-blue-600 p-2 text-white" type="submit">Register</button>
		</form>

		<pre id="out" class="mt-6 whitespace-pre-wrap rounded bg-neutral-900 p-3 text-xs text-white">
		</pre>

		<p class="mt-4 text-sm">
			<a class="text-blue-700 underline" href="/provider-v2/profile">Next: Profile</a>
		</p>
	</main>

	<script type="module">
		const form = document.getElementById("providerV2Register")
		const out = document.getElementById("out")

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			out.textContent = ""
			const legalName = form.querySelector('input[name="legalName"]')
			const displayName = form.querySelector('input[name="displayName"]')
			if (!legalName?.value?.trim() || !displayName?.value?.trim()) {
				out.textContent = "Required field"
				form.reportValidity()
				return
			}
			const fd = new FormData(form)
			try {
				const res = await fetch("/api/provider-v2/register", { method: "POST", body: fd })
				const txt = await res.text()
				out.textContent = `status=${res.status}\n${txt}`
			} catch (err) {
				out.textContent = `network error: ${String(err)}`
			}
		})
	</script>
</Layout>
