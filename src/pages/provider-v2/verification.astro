---
import Layout from "@/layouts/Layout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")
---

<Layout title="Provider V2 - Verification">
	<main
		class="mx-auto mt-20 w-10/12 max-w-2xl rounded-2xl border border-neutral-300 bg-neutral-200 p-8"
	>
		<h1 class="mb-2 text-2xl font-semibold">Provider V2: Verification</h1>
		<p class="mb-6 text-xs text-neutral-600">Modo simple/admin: cambia estado de verificación.</p>

		<form id="providerV2Verification" class="grid gap-4">
			<label class="text-xs">
				Status
				<select class="mt-1 w-full rounded border p-2" name="status" required>
					<option value="pending">pending</option>
					<option value="approved">approved</option>
					<option value="rejected">rejected</option>
				</select>
			</label>

			<label class="text-xs">
				Reason (optional)
				<input class="mt-1 w-full rounded border p-2" name="reason" />
			</label>

			<label class="text-xs">
				Reviewed By (optional)
				<input class="mt-1 w-full rounded border p-2" name="reviewedBy" />
			</label>

			<label class="text-xs">
				Metadata JSON (optional)
				<textarea class="mt-1 w-full rounded border p-2" name="metadataJson" rows="6"></textarea>
			</label>

			<button class="rounded bg-blue-600 p-2 text-white" type="submit">Update Verification</button>
		</form>

		<pre id="out" class="mt-6 whitespace-pre-wrap rounded bg-neutral-900 p-3 text-xs text-white">
		</pre>
	</main>

	<script type="module">
		const form = document.getElementById("providerV2Verification")
		const out = document.getElementById("out")

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			out.textContent = ""
			const fd = new FormData(form)
			try {
				const res = await fetch("/api/provider-v2/verification", { method: "POST", body: fd })
				const txt = await res.text()
				out.textContent = `status=${res.status}\n${txt}`
			} catch (err) {
				out.textContent = `network error: ${String(err)}`
			}
		})
	</script>
</Layout>
