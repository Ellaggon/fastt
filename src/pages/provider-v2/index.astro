---
import Layout from "@/layouts/Layout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")
---

<Layout title="Provider V2">
	<main
		class="mx-auto mt-20 w-10/12 max-w-2xl rounded-2xl border border-neutral-300 bg-neutral-200 p-8"
	>
		<h1 class="mb-4 text-2xl font-semibold">Provider V2 (Parallel)</h1>
		<p class="mb-6 text-sm text-neutral-600">
			Flujo v2 incremental. No reemplaza el formulario legacy.
		</p>

		<ul class="list-disc pl-5 text-sm">
			<li><a class="text-blue-700 underline" href="/provider-v2/register">1) Register</a></li>
			<li><a class="text-blue-700 underline" href="/provider-v2/profile">2) Profile</a></li>
			<li>
				<a class="text-blue-700 underline" href="/provider-v2/verification">3) Verification</a>
			</li>
		</ul>
	</main>
</Layout>
