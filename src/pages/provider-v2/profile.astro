---
import Layout from "@/layouts/Layout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")
---

<Layout title="Provider V2 - Profile">
	<main
		class="mx-auto mt-20 w-10/12 max-w-2xl rounded-2xl border border-neutral-300 bg-neutral-200 p-8"
	>
		<h1 class="mb-2 text-2xl font-semibold">Provider V2: Profile</h1>
		<p class="mb-6 text-xs text-neutral-600">Configura profile operacional.</p>

		<form id="providerV2Profile" class="grid gap-4">
			<label class="text-xs">
				Timezone (required)
				<input
					class="mt-1 w-full rounded border p-2"
					name="timezone"
					value="America/Santiago"
					required
				/>
			</label>

			<label class="text-xs">
				Default Currency (3-letter)
				<input class="mt-1 w-full rounded border p-2" name="defaultCurrency" value="USD" required />
			</label>

			<label class="text-xs">
				Support Email
				<input class="mt-1 w-full rounded border p-2" type="email" name="supportEmail" />
			</label>

			<label class="text-xs">
				Support Phone
				<input class="mt-1 w-full rounded border p-2" name="supportPhone" />
			</label>

			<button class="rounded bg-blue-600 p-2 text-white" type="submit">Save Profile</button>
		</form>

		<pre id="out" class="mt-6 whitespace-pre-wrap rounded bg-neutral-900 p-3 text-xs text-white">
		</pre>

		<p class="mt-4 text-sm">
			<a class="text-blue-700 underline" href="/provider-v2/verification">Next: Verification</a>
		</p>
	</main>

	<script type="module">
		const form = document.getElementById("providerV2Profile")
		const out = document.getElementById("out")

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			out.textContent = ""
			const timezone = form.querySelector('input[name="timezone"]')
			const defaultCurrency = form.querySelector('input[name="defaultCurrency"]')
			const supportEmail = form.querySelector('input[name="supportEmail"]')
			if (!timezone?.value?.trim() || !defaultCurrency?.value?.trim()) {
				out.textContent = "Required field"
				form.reportValidity()
				return
			}
			if (supportEmail?.value && !supportEmail.checkValidity()) {
				out.textContent = "Invalid email"
				supportEmail.reportValidity()
				return
			}
			const fd = new FormData(form)
			try {
				const res = await fetch("/api/provider-v2/profile", { method: "POST", body: fd })
				const txt = await res.text()
				out.textContent = `status=${res.status}\n${txt}`
			} catch (err) {
				out.textContent = `network error: ${String(err)}`
			}
		})
	</script>
</Layout>
