---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { and, db, eq, Product, sql, Variant } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const rows = await db
	.select({
		productId: Product.id,
		productName: Product.name,
		productType: Product.productType,
		variantId: Variant.id,
		variantName: Variant.name,
		variantKind: Variant.kind,
		variantActive: Variant.isActive,
	})
	.from(Product)
	.leftJoin(Variant, eq(Variant.productId, Product.id))
	.where(and(eq(Product.providerId, providerId), sql`lower(${Product.productType}) = 'hotel'`))

const byProduct = new Map<
	string,
	{
		id: string
		name: string
		type: string
		rooms: Array<{ id: string; name: string; kind: string; active: boolean }>
	}
>()

for (const row of rows) {
	if (!isHotelProductType(row.productType)) continue
	const productId = String(row.productId)
	const entry = byProduct.get(productId) ?? {
		id: productId,
		name: String(row.productName ?? "Alojamiento"),
		type: String(row.productType ?? "Hotel"),
		rooms: [],
	}
	if (row.variantId) {
		entry.rooms.push({
			id: String(row.variantId),
			name: String(row.variantName ?? "Habitación"),
			kind: String(row.variantKind ?? "hotel_room"),
			active: Boolean(row.variantActive ?? true),
		})
	}
	byProduct.set(productId, entry)
}

const products = Array.from(byProduct.values())
if (products.length === 1) return Astro.redirect(routes.productRoomsForProduct(products[0].id))

const totalRooms = products.reduce((sum, product) => sum + product.rooms.length, 0)
const activeRooms = products.reduce(
	(sum, product) => sum + product.rooms.filter((room) => room.active).length,
	0
)
---

<WorkspaceLayout title="Catálogo · Alojamientos · Habitaciones">
	<section class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-sm font-medium text-slate-400">Catálogo · Alojamientos</p>
				<h1 class="text-3xl font-semibold text-slate-100">Habitaciones por alojamiento</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Elige un alojamiento para administrar sus habitaciones. Tours y paquetes no aparecen en
					esta superficie. Si solo tienes un alojamiento, esta sección abre directamente sus
					habitaciones.
				</p>
			</div>
			<Button href={routes.productList()} data-astro-prefetch variant="secondary">
				Ver catálogo
			</Button>
		</header>

		<div class="flex flex-wrap gap-2 text-sm text-slate-300">
			<span class="rounded-full border border-slate-700 bg-slate-900 px-3 py-1">
				{products.length} alojamientos
			</span>
			<span class="rounded-full border border-slate-700 bg-slate-900 px-3 py-1">
				{totalRooms} habitaciones
			</span>
			<span class="rounded-full border border-slate-700 bg-slate-900 px-3 py-1">
				{activeRooms} activas
			</span>
		</div>

		<Section
			title="Habitaciones por alojamiento"
			description="Cada alojamiento mantiene sus propias habitaciones, capacidad y configuración física."
		>
			{
				products.length === 0 ? (
					<Card class="space-y-4 bg-slate-100">
						<h2 class="text-xl font-semibold text-slate-900">Aún no tienes alojamientos</h2>
						<p class="text-sm text-slate-600">Crea un alojamiento antes de agregar habitaciones.</p>
						<div class="flex justify-end">
							<Button
								href="/product/create?type=Hotel"
								data-astro-prefetch
								className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
							>
								Crear alojamiento
							</Button>
						</div>
					</Card>
				) : (
					<div class="space-y-4">
						{products.map((product) => (
							<Card class="space-y-4 bg-slate-100">
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div class="space-y-1">
										<h2 class="text-xl font-semibold text-slate-900">{product.name}</h2>
										<p class="text-sm text-slate-600">
											{product.rooms.length} habitaciones configuradas ·{" "}
											{product.rooms.filter((room) => room.active).length} activas
										</p>
									</div>
									<div class="flex flex-wrap gap-2">
										<Button href={routes.productRoomsForProduct(product.id)} data-astro-prefetch>
											Abrir habitaciones
										</Button>
										<Button
											href={`${routes.productVariants(product.id)}/new`}
											data-astro-prefetch
											variant="secondary"
										>
											Agregar habitación
										</Button>
									</div>
								</div>

								{product.rooms.length === 0 ? (
									<div class="rounded-lg border border-dashed border-slate-300 bg-white p-4 text-sm text-slate-600">
										Este alojamiento todavía no tiene habitaciones.
									</div>
								) : (
									<div class="grid gap-3 md:grid-cols-2">
										{product.rooms.map((room) => (
											<a
												href={routes.variantDetail(product.id, room.id)}
												data-astro-prefetch
												class="rounded-lg border border-slate-200 bg-white p-4 transition hover:-translate-y-0.5 hover:shadow-sm"
											>
												<div class="flex items-start justify-between gap-3">
													<div>
														<p class="font-semibold text-slate-900">{room.name}</p>
														<p class="mt-1 text-sm text-slate-600">
															{room.kind === "hotel_room" ? "Habitación" : room.kind}
														</p>
													</div>
													<Badge variant={room.active ? "success" : "neutral"}>
														{room.active ? "Activa" : "Inactiva"}
													</Badge>
												</div>
											</a>
										))}
									</div>
								)}
							</Card>
						))}
					</div>
				)
			}
		</Section>
	</section>
</WorkspaceLayout>
