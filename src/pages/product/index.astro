---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import {
	getProductVerticalEntry,
	listActiveProductVerticalEntries,
	normalizeProductTypeValue,
} from "@/lib/catalog/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { db, eq, inArray, Product, ProductStatus } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const activeVerticals = listActiveProductVerticalEntries()
const requestedType = String(Astro.url.searchParams.get("type") ?? "").trim()
const requestedProductType = normalizeProductTypeValue(requestedType)
const selectedVertical =
	activeVerticals.find((vertical) => vertical.productType === requestedProductType) ?? null

const allProducts = await db
	.select({
		id: Product.id,
		name: Product.name,
		productType: Product.productType,
	})
	.from(Product)
	.where(eq(Product.providerId, providerId))

const products = selectedVertical
	? allProducts.filter(
			(product) => normalizeProductTypeValue(product.productType) === selectedVertical.productType
		)
	: allProducts
const productIds = products.map((product) => product.id)
const statuses = productIds.length
	? await db
			.select({
				productId: ProductStatus.productId,
				state: ProductStatus.state,
			})
			.from(ProductStatus)
			.where(inArray(ProductStatus.productId, productIds))
	: []

const statusMap = new Map(
	statuses.map((status) => [status.productId, String(status.state ?? "draft")])
)

const totalProducts = products.length
const publishedProducts = statuses.filter(
	(status) => String(status.state ?? "").toLowerCase() === "published"
).length
const readyProducts = statuses.filter(
	(status) => String(status.state ?? "").toLowerCase() === "ready"
).length
const draftProducts = Math.max(0, totalProducts - publishedProducts - readyProducts)
const catalogTitle = selectedVertical ? selectedVertical.labels.workspacePlural : "Catálogo"
const catalogDescription = selectedVertical
	? selectedVertical.readiness.publishSummary
	: "Revisa contenido, fotos, ubicación, condiciones y vista previa antes de publicar. Hoteles, tours y paquetes comparten catálogo, pero cada tipo mantiene su propio modelo operativo."
const createHref = selectedVertical
	? selectedVertical.routes.workspaceCreateHref
	: "/product/create"
const emptyTitle = selectedVertical
	? `Aún no tienes ${selectedVertical.labels.plural}`
	: "Aún no tienes ofertas"
const emptyDescription = selectedVertical
	? `Crea tu primer ${selectedVertical.labels.singular} para preparar contenido, operación y publicación.`
	: "Crea tu primera oferta para preparar contenido, operación y publicación."
const sectionDescription = selectedVertical
	? `Accede a cada ${selectedVertical.labels.singular} para revisar contenido, fotos, ubicación, detalles y vista previa.`
	: "Accede a cada oferta para revisar contenido, fotos, ubicación, detalles y vista previa."
const verticalCounts = new Map<string, number>()
for (const product of allProducts) {
	const vertical = getProductVerticalEntry(product.productType)
	verticalCounts.set(vertical.vertical, (verticalCounts.get(vertical.vertical) ?? 0) + 1)
}

const getStatusMeta = (rawState: string | undefined) => {
	const state = String(rawState ?? "draft")
		.trim()
		.toLowerCase()
	if (state === "published") return { label: "Publicado", variant: "success" as const }
	if (state === "ready") return { label: "Listo", variant: "info" as const }
	return { label: "Borrador", variant: "warning" as const }
}
---

<WorkspaceLayout
	title={selectedVertical
		? `Catálogo · ${selectedVertical.labels.workspacePlural}`
		: "Catálogo · Ofertas"}
>
	<section class="space-y-8">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">{catalogTitle}</h1>
			<p class="max-w-3xl text-sm leading-6 text-slate-400">
				{catalogDescription}
			</p>
		</header>

		<nav class="flex flex-wrap gap-2" aria-label="Filtros de catálogo">
			<a
				href={routes.productList()}
				class={`inline-flex h-10 items-center rounded-lg border px-4 text-sm font-medium transition ${
					selectedVertical
						? "border-slate-700 bg-slate-950 text-slate-300 hover:bg-slate-900"
						: "border-blue-600 bg-blue-600 text-white"
				}`}
			>
				Todo el catálogo
			</a>
			{
				activeVerticals.map((vertical) => {
					const isActive = selectedVertical?.vertical === vertical.vertical
					const count = verticalCounts.get(vertical.vertical) ?? 0
					return (
						<a
							href={vertical.routes.workspaceFilteredHref}
							class={`inline-flex h-10 items-center rounded-lg border px-4 text-sm font-medium transition ${
								isActive
									? "border-blue-600 bg-blue-600 text-white"
									: "border-slate-700 bg-slate-950 text-slate-300 hover:bg-slate-900"
							}`}
							aria-current={isActive ? "page" : undefined}
						>
							{vertical.labels.workspacePlural}
							<span class="ml-2 rounded-full bg-white/10 px-2 py-0.5 text-xs">{count}</span>
						</a>
					)
				})
			}
		</nav>

		<section class="grid gap-4 md:grid-cols-4">
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Ofertas</p>
				<p class="mt-2 text-2xl font-semibold">{totalProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Ofertas bajo edición de catálogo</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Publicados</p>
				<p class="mt-2 text-2xl font-semibold">{publishedProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Presentación pública activa</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Listos</p>
				<p class="mt-2 text-2xl font-semibold">{readyProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Contenido preparado para operación</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Borradores</p>
				<p class="mt-2 text-2xl font-semibold">{draftProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Requiere readiness editorial</p>
			</Card>
		</section>

		<Section
			title={selectedVertical ? `Lista de ${selectedVertical.labels.plural}` : "Lista de ofertas"}
			description={sectionDescription}
		>
			{
				products.length === 0 ? (
					<Card class="space-y-4 bg-slate-100">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">{emptyTitle}</h2>
							<p class="text-sm text-slate-600">{emptyDescription}</p>
						</div>
						<div class="flex justify-end">
							<Button
								href={createHref}
								data-astro-prefetch
								className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
							>
								{selectedVertical ? `Crear ${selectedVertical.labels.singular}` : "Crear oferta"}
							</Button>
						</div>
					</Card>
				) : (
					<div class="space-y-4">
						{products.map((product) => {
							const status = getStatusMeta(statusMap.get(product.id))
							const vertical = getProductVerticalEntry(product.productType)
							return (
								<Card class="space-y-4 bg-slate-100">
									<div class="flex flex-wrap items-start justify-between gap-4">
										<div class="space-y-1">
											<p class="text-lg font-semibold text-slate-900">{product.name}</p>
											<p class="text-sm text-slate-600">
												Tipo: {vertical.labels.workspaceSingular}
											</p>
											<p class="text-sm text-slate-500">{vertical.readiness.publishSummary}</p>
										</div>
										<div class="flex flex-wrap items-center justify-end gap-3">
											<Badge variant={status.variant}>{status.label}</Badge>
											<Button
												href={routes.productPreview(product.id)}
												data-astro-prefetch
												variant="secondary"
											>
												Vista previa
											</Button>
											<Button
												href={routes.productDetail(product.id)}
												data-astro-prefetch
												className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
											>
												Editar {vertical.labels.singular}
											</Button>
										</div>
									</div>
								</Card>
							)
						})}
					</div>
				)
			}
		</Section>

		<Section
			title="Flujo de publicación"
			description="El catálogo concentra presentación y vista previa; cada vertical agrega sus propios bloques operativos."
		>
			<Card class="flex flex-wrap items-center justify-between gap-4 bg-slate-100">
				<p class="text-sm text-slate-600">
					El catálogo prepara la presentación vendible: contenido, fotos, ubicación, detalles,
					condiciones y vista previa antes de publicar.
				</p>
				<div class="flex flex-wrap gap-2">
					<Button href="/provider/house-rules" data-astro-prefetch variant="secondary">
						Reglas para huéspedes
					</Button>
					<Button
						href={createHref}
						data-astro-prefetch
						className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
					>
						{selectedVertical ? `Crear ${selectedVertical.labels.singular}` : "Crear oferta"}
					</Button>
				</div>
			</Card>
		</Section>
	</section>
</WorkspaceLayout>
