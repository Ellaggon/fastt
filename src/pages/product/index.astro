---
import { normalizeProductTypeForStorage } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"

const requestedType = String(Astro.url.searchParams.get("type") ?? "").trim()
const requestedStorageType = normalizeProductTypeForStorage(requestedType)
const targetByType = {
	Hotel: routes.catalogAccommodations(),
	Tour: routes.catalogTours(),
	Package: routes.catalogPackages(),
	Limousine: routes.catalogLimousines(),
} as const

return Astro.redirect(
	requestedStorageType ? targetByType[requestedStorageType] : routes.catalogAccommodations()
)
---
