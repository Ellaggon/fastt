---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import {
	getProductVerticalDefinition,
	normalizeProductTypeForStorage,
	PRODUCT_VERTICAL_OPTIONS,
	productTypeLabel,
} from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { and, db, eq, inArray, Product, ProductStatus, sql } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const requestedType = String(Astro.url.searchParams.get("type") ?? "").trim()
const requestedStorageType = normalizeProductTypeForStorage(requestedType)
const activeVertical = getProductVerticalDefinition(requestedStorageType)
const pageTitle = activeVertical ? activeVertical.labels.plural : "Alojamientos"
const pageDescription = activeVertical
	? `Prepara tus ${activeVertical.labels.plural.toLowerCase()} con fotos, descripción, ubicación y vista previa antes de publicar.`
	: "Prepara tus alojamientos con la información que verá el huésped antes de reservar."

const products = await db
	.select({
		id: Product.id,
		name: Product.name,
		productType: Product.productType,
	})
	.from(Product)
	.where(
		requestedStorageType
			? and(
					eq(Product.providerId, providerId),
					sql`lower(${Product.productType}) = ${requestedStorageType.toLowerCase()}`
				)
			: eq(Product.providerId, providerId)
	)

const productIds = products.map((product) => product.id)
const statuses = productIds.length
	? await db
			.select({
				productId: ProductStatus.productId,
				state: ProductStatus.state,
			})
			.from(ProductStatus)
			.where(inArray(ProductStatus.productId, productIds))
	: []

const statusMap = new Map(
	statuses.map((status) => [status.productId, String(status.state ?? "draft")])
)

const totalProducts = products.length
const publishedProducts = statuses.filter(
	(status) => String(status.state ?? "").toLowerCase() === "published"
).length
const readyProducts = statuses.filter(
	(status) => String(status.state ?? "").toLowerCase() === "ready"
).length
const draftProducts = Math.max(0, totalProducts - publishedProducts - readyProducts)

const getStatusMeta = (rawState: string | undefined) => {
	const state = String(rawState ?? "draft")
		.trim()
		.toLowerCase()
	if (state === "published") return { label: "Publicado", variant: "success" as const }
	if (state === "ready") return { label: "Listo", variant: "info" as const }
	return { label: "Borrador", variant: "warning" as const }
}
---

<WorkspaceLayout title={pageTitle}>
	<section class="space-y-6">
		<header class="space-y-2">
			<p class="text-sm font-medium text-slate-400">Alojamientos</p>
			<h1 class="text-3xl font-semibold text-slate-100">{pageTitle}</h1>
			<p class="max-w-3xl text-sm leading-6 text-slate-400">{pageDescription}</p>
			<nav class="flex flex-wrap gap-2 pt-2" aria-label="Filtros de alojamientos">
				<a
					href="/product"
					class={`fastt-button inline-flex h-8 items-center justify-center rounded-full border px-3 text-sm font-semibold transition ${!requestedStorageType ? "border-slate-100 bg-white text-slate-950" : "border-slate-700 bg-slate-900 text-slate-300 hover:bg-slate-800"}`}
				>
					Todo
				</a>
				{
					PRODUCT_VERTICAL_OPTIONS.map((vertical) => (
						<a
							href={`/product?type=${encodeURIComponent(vertical.storageType)}`}
							class={`fastt-button inline-flex h-8 items-center justify-center rounded-full border px-3 text-sm font-semibold transition ${
								requestedStorageType === vertical.storageType
									? "border-slate-100 bg-white text-slate-950"
									: "border-slate-700 bg-slate-900 text-slate-300 hover:bg-slate-800"
							}`}
						>
							{vertical.labels.plural}
						</a>
					))
				}
			</nav>
		</header>

		<section class="grid gap-3 md:grid-cols-4">
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">{pageTitle}</p>
				<p class="mt-2 text-2xl font-semibold">{totalProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Fichas en preparación</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Publicados</p>
				<p class="mt-2 text-2xl font-semibold">{publishedProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Visibles para huéspedes</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Listos</p>
				<p class="mt-2 text-2xl font-semibold">{readyProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Preparados para revisar</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Borradores</p>
				<p class="mt-2 text-2xl font-semibold">{draftProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Faltan datos visibles</p>
			</Card>
		</section>

		<Section
			title={`Tus ${activeVertical ? activeVertical.labels.plural.toLowerCase() : "alojamientos"}`}
			description="Abre cada ficha para revisar fotos, descripción, ubicación, habitaciones, reglas y vista previa."
		>
			{
				products.length === 0 ? (
					<Card class="space-y-4 bg-slate-100">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Aún no tienes alojamientos</h2>
							<p class="text-sm text-slate-600">
								Crea la primera ficha para agregar fotos, descripción, ubicación y vista previa.
							</p>
						</div>
						<div class="flex justify-end">
							<Button
								href={activeVertical ? activeVertical.providerRoutes.create : "/product/create"}
								data-astro-prefetch
							>
								{activeVertical ? activeVertical.labels.createCta : "Crear alojamiento"}
							</Button>
						</div>
					</Card>
				) : (
					<div class="space-y-4">
						{products.map((product) => {
							const status = getStatusMeta(statusMap.get(product.id))
							return (
								<Card class="space-y-4 bg-slate-100">
									<div class="flex flex-wrap items-start justify-between gap-4">
										<div class="space-y-1">
											<p class="text-lg font-semibold text-slate-900">{product.name}</p>
											<p class="text-sm text-slate-600">
												Tipo: {productTypeLabel(product.productType, "Oferta")}
											</p>
											<p class="text-sm text-slate-500">
												Fotos, descripción, ubicación y vista previa antes de publicar.
											</p>
										</div>
										<div class="flex flex-wrap items-center justify-end gap-3">
											<Badge variant={status.variant}>{status.label}</Badge>
											<Button
												href={routes.productPreview(product.id)}
												data-astro-prefetch
												variant="secondary"
											>
												Vista previa
											</Button>
											<Button href={routes.productDetail(product.id)} data-astro-prefetch>
												Editar {productTypeLabel(product.productType, "oferta").toLowerCase()}
											</Button>
										</div>
									</div>
								</Card>
							)
						})}
					</div>
				)
			}
		</Section>

		<Section
			title="Preparación para publicar"
			description="La ficha concentra lo que verá el huésped. Tarifas, calendario y condiciones viven en Habitaciones y tarifas."
		>
			<Card class="flex flex-wrap items-center justify-between gap-4 bg-slate-100">
				<p class="text-sm text-slate-600">
					Empieza por una ficha clara. Después conecta habitaciones, tarifas, calendario y
					condiciones sin mezclar contenido con operación comercial.
				</p>
				<div class="flex flex-wrap gap-2">
					<Button href="/provider/house-rules" data-astro-prefetch variant="secondary">
						Configurar reglas
					</Button>
					<Button href="/product/create" data-astro-prefetch> Crear alojamiento </Button>
				</div>
			</Card>
		</Section>
	</section>
</WorkspaceLayout>
