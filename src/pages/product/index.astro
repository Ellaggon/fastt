---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { routes } from "@/lib/routes"
import { db, eq, inArray, Product, ProductStatus } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const products = await db
	.select({
		id: Product.id,
		name: Product.name,
		productType: Product.productType,
	})
	.from(Product)
	.where(eq(Product.providerId, providerId))

const productIds = products.map((product) => product.id)
const statuses = productIds.length
	? await db
			.select({
				productId: ProductStatus.productId,
				state: ProductStatus.state,
			})
			.from(ProductStatus)
			.where(inArray(ProductStatus.productId, productIds))
	: []

const statusMap = new Map(
	statuses.map((status) => [status.productId, String(status.state ?? "draft")])
)

const totalProducts = products.length
const publishedProducts = statuses.filter(
	(status) => String(status.state ?? "").toLowerCase() === "published"
).length
const readyProducts = statuses.filter(
	(status) => String(status.state ?? "").toLowerCase() === "ready"
).length
const draftProducts = Math.max(0, totalProducts - publishedProducts - readyProducts)

const getStatusMeta = (rawState: string | undefined) => {
	const state = String(rawState ?? "draft")
		.trim()
		.toLowerCase()
	if (state === "published") return { label: "Publicado", variant: "success" as const }
	if (state === "ready") return { label: "Listo", variant: "info" as const }
	return { label: "Borrador", variant: "warning" as const }
}
---

<WorkspaceLayout title="Property Content · Catalog Readiness">
	<section class="space-y-8">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">Catalog worklist</h1>
			<p class="max-w-3xl text-sm leading-6 text-slate-400">
				Revisa contenido, fotos, House Rules, Booking Policies y la vista huésped antes de publicar.
				Las señales comerciales y físicas se mantienen como contexto, no como ownership editorial.
			</p>
		</header>

		<section class="grid gap-4 md:grid-cols-4">
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Catalog items</p>
				<p class="mt-2 text-2xl font-semibold">{totalProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Productos bajo ownership editorial</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Published</p>
				<p class="mt-2 text-2xl font-semibold">{publishedProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Presentación pública activa</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Ready</p>
				<p class="mt-2 text-2xl font-semibold">{readyProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Contenido preparado para operación</p>
			</Card>
			<Card className="border-slate-800 bg-slate-950 text-slate-100">
				<p class="text-xs uppercase tracking-wide text-slate-500">Draft</p>
				<p class="mt-2 text-2xl font-semibold">{draftProducts}</p>
				<p class="mt-1 text-xs text-slate-400">Requiere readiness editorial</p>
			</Card>
		</section>

		<Section
			title="Catalog worklist"
			description="Accede a cada producto para revisar su contenido, media, ubicación, metadata y contexto de sellability."
		>
			{
				products.length === 0 ? (
					<Card class="space-y-4 bg-slate-100">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Aún no tienes productos</h2>
							<p class="text-sm text-slate-600">
								Crea tu primer producto para iniciar readiness editorial y presentación comercial.
							</p>
						</div>
						<div class="flex justify-end">
							<Button
								href="/product/create"
								data-astro-prefetch
								className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
							>
								Crear producto
							</Button>
						</div>
					</Card>
				) : (
					<div class="space-y-4">
						{products.map((product) => {
							const status = getStatusMeta(statusMap.get(product.id))
							return (
								<Card class="space-y-4 bg-slate-100">
									<div class="flex flex-wrap items-start justify-between gap-4">
										<div class="space-y-1">
											<p class="text-lg font-semibold text-slate-900">{product.name}</p>
											<p class="text-sm text-slate-600">
												Tipo: {String(product.productType ?? "No definido")}
											</p>
											<p class="text-sm text-slate-500">
												Review combines content, photos, booking terms and House Rules into one
												guest-facing pre-publish check.
											</p>
										</div>
										<div class="flex flex-wrap items-center justify-end gap-3">
											<Badge variant={status.variant}>{status.label}</Badge>
											<Button
												href={routes.productPreview(product.id)}
												data-astro-prefetch
												variant="secondary"
											>
												Review listing
											</Button>
											<Button
												href={routes.productDetail(product.id)}
												data-astro-prefetch
												className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
											>
												Abrir readiness
											</Button>
										</div>
									</div>
								</Card>
							)
						})}
					</div>
				)
			}
		</Section>

		<Section
			title="Editorial workflow"
			description="El alta crea identidad de catálogo; House Rules prepara expectativas de estancia, mientras pricing, inventario y reservas se gobiernan en sus dominios operacionales."
		>
			<Card class="flex flex-wrap items-center justify-between gap-4 bg-slate-100">
				<p class="text-sm text-slate-600">
					Property Content prepara la presentación vendible: contenido, House Rules, media,
					ubicación, metadata y revisión guest-facing antes de publicar.
				</p>
				<div class="flex flex-wrap gap-2">
					<Button href="/provider/house-rules" data-astro-prefetch variant="secondary">
						Configurar House Rules
					</Button>
					<Button
						href="/product/create"
						data-astro-prefetch
						className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
					>
						Crear producto
					</Button>
				</div>
			</Card>
		</Section>
	</section>
</WorkspaceLayout>
