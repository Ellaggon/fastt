---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import Textarea from "@/components/ui/Textarea.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProductVerticalDefinition } from "@/lib/productVerticalRegistry"
import { getProductById } from "@/modules/catalog/public"
import { db, eq, Hotel, Limousine, Package, Tour } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product/create")
const flow = Astro.url.searchParams.get("flow") === "create" ? "create" : "edit"

const product = await getProductById(productId)
if (!product) return Astro.redirect("/product/create")

const pt = String(product.productType || "")
	.trim()
	.toLowerCase()
const vertical = getProductVerticalDefinition(product.productType)
const verticalLabel = vertical?.labels.singular.toLowerCase() ?? "oferta"
const detailTitle = vertical?.labels.detailTitle ?? "Detalles de la oferta"
const subtypeHeading = pt === "hotel" ? "Detalles del alojamiento" : `Detalles del ${verticalLabel}`

function listToText(value: unknown, key = "description") {
	if (!Array.isArray(value)) return ""
	return value
		.map((item) => {
			if (typeof item === "string") return item
			if (item && typeof item === "object") return String((item as any)[key] ?? "").trim()
			return ""
		})
		.filter(Boolean)
		.join("\n")
}

function fieldFromObject(value: unknown, key: string) {
	if (!value || typeof value !== "object") return ""
	return String((value as any)[key] ?? "")
}

const hotelSubtype =
	pt === "hotel"
		? await db
				.select({
					stars: Hotel.stars,
					phone: Hotel.phone,
					email: Hotel.email,
					website: Hotel.website,
				})
				.from(Hotel)
				.where(eq(Hotel.productId, productId))
				.get()
		: null

const tourSubtype =
	pt === "tour"
		? await db
				.select({
					duration: Tour.duration,
					difficultyLevel: Tour.difficultyLevel,
					meetingPointJson: Tour.meetingPointJson,
					itineraryJson: Tour.itineraryJson,
					safetyJson: Tour.safetyJson,
					guideJson: Tour.guideJson,
				})
				.from(Tour)
				.where(eq(Tour.productId, productId))
				.get()
		: null

const packageSubtype =
	pt === "package"
		? await db
				.select({
					days: Package.days,
					nights: Package.nights,
					itineraryJson: Package.itineraryJson,
					includesJson: Package.includesJson,
					excludesJson: Package.excludesJson,
				})
				.from(Package)
				.where(eq(Package.productId, productId))
				.get()
		: null

const limousineSubtype =
	pt === "limousine"
		? await db
				.select({
					vehicleProfileJson: Limousine.vehicleProfileJson,
					pickupJson: Limousine.pickupJson,
					dropoffJson: Limousine.dropoffJson,
					passengerCapacity: Limousine.passengerCapacity,
					luggageCapacity: Limousine.luggageCapacity,
				})
				.from(Limousine)
				.where(eq(Limousine.productId, productId))
				.get()
		: null
---

<WorkspaceLayout title={`Alojamientos · ${detailTitle}`}>
	<section class="space-y-8">
		<section class="space-y-4">
			<header class="space-y-1">
				<h1 class="text-3xl font-semibold text-slate-100">{detailTitle}</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Completa atributos editoriales y de categoría que ayudan a presentar y descubrir el
					{verticalLabel}.
				</p>
			</header>

			<Card class="rounded-lg border-slate-200 bg-slate-100 shadow-none">
				<form
					id="subtypeForm"
					method="POST"
					action="/api/product/subtype"
					class="max-w-3xl space-y-6"
				>
					<Input type="hidden" name="productId" value={productId} />
					<Input type="hidden" name="flow" value={flow} />
					<div class="space-y-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">{subtypeHeading}</h2>
							<p class="text-sm font-medium text-slate-500">Detalles específicos</p>
							<p class="text-sm text-slate-600">
								Completa los campos propios de este tipo de oferta. La ubicación vive en la sección
								Ubicación y el contenido editorial vive en Contenido.
							</p>
						</div>

						{
							pt === "hotel" ? (
								<div class="space-y-4">
									<FormField label="Estrellas" htmlFor="stars">
										<Input
											id="stars"
											name="stars"
											value={hotelSubtype?.stars != null ? String(hotelSubtype.stars) : ""}
											placeholder="1-5"
										/>
									</FormField>
									<FormField label="Teléfono" htmlFor="phone">
										<Input
											id="phone"
											name="phone"
											value={hotelSubtype?.phone ?? ""}
											placeholder="Opcional"
										/>
									</FormField>
									<FormField label="Correo" htmlFor="email">
										<Input
											id="email"
											name="email"
											value={hotelSubtype?.email ?? ""}
											placeholder="Opcional"
										/>
									</FormField>
									<FormField label="Sitio web" htmlFor="website">
										<Input
											id="website"
											name="website"
											value={hotelSubtype?.website ?? ""}
											placeholder="Opcional"
										/>
									</FormField>
								</div>
							) : null
						}

						{
							pt === "tour" ? (
								<div class="space-y-4">
									<FormField label="Duración" htmlFor="duration">
										<Input
											id="duration"
											name="duration"
											value={tourSubtype?.duration ?? ""}
											placeholder="Opcional"
										/>
									</FormField>
									<FormField label="Nivel de dificultad" htmlFor="difficultyLevel">
										<Input
											id="difficultyLevel"
											name="difficultyLevel"
											value={tourSubtype?.difficultyLevel ?? ""}
											placeholder="Opcional"
										/>
									</FormField>
									<FormField label="Idiomas guía (separados por coma)" htmlFor="guideLanguages">
										<Input
											id="guideLanguages"
											name="guideLanguages"
											value={fieldFromObject(tourSubtype?.guideJson, "languages")}
											placeholder="es,en"
										/>
									</FormField>
									<FormField label="Tipo de guía" htmlFor="guideType">
										<Input
											id="guideType"
											name="guideType"
											value={fieldFromObject(tourSubtype?.guideJson, "guideType")}
											placeholder="Guía local, conductor guía, anfitrión..."
										/>
									</FormField>
									<FormField label="Punto de encuentro" htmlFor="meetingPointAddress">
										<Input
											id="meetingPointAddress"
											name="meetingPointAddress"
											value={fieldFromObject(tourSubtype?.meetingPointJson, "address")}
											placeholder="Dirección o referencia"
										/>
									</FormField>
									<FormField
										label="Instrucciones del punto de encuentro"
										htmlFor="meetingPointInstructions"
									>
										<Textarea
											id="meetingPointInstructions"
											name="meetingPointInstructions"
											value={fieldFromObject(tourSubtype?.meetingPointJson, "instructions")}
											rows="3"
										/>
									</FormField>
									<FormField label="Itinerario del tour" htmlFor="tourItinerary">
										<Textarea
											id="tourItinerary"
											name="tourItinerary"
											value={listToText(tourSubtype?.itineraryJson)}
											rows="5"
											placeholder="Una parada o experiencia por línea"
										/>
									</FormField>
									<FormField label="Requisitos de seguridad" htmlFor="safetyRequirements">
										<Textarea
											id="safetyRequirements"
											name="safetyRequirements"
											value={fieldFromObject(tourSubtype?.safetyJson, "requirements")}
											rows="3"
										/>
									</FormField>
									<FormField label="Advertencias o condiciones físicas" htmlFor="safetyWarnings">
										<Textarea
											id="safetyWarnings"
											name="safetyWarnings"
											value={fieldFromObject(tourSubtype?.safetyJson, "warnings")}
											rows="3"
										/>
									</FormField>
								</div>
							) : null
						}

						{
							pt === "package" ? (
								<div class="space-y-4">
									<FormField label="Itinerario" htmlFor="itinerary">
										<Textarea
											id="itinerary"
											name="itinerary"
											value={listToText(packageSubtype?.itineraryJson)}
											rows="5"
											placeholder="Un día o etapa por línea"
										/>
									</FormField>
									<FormField label="Días" htmlFor="days">
										<Input
											id="days"
											name="days"
											value={packageSubtype?.days != null ? String(packageSubtype.days) : ""}
											placeholder="0 o más"
										/>
									</FormField>
									<FormField label="Noches" htmlFor="nights">
										<Input
											id="nights"
											name="nights"
											value={packageSubtype?.nights != null ? String(packageSubtype.nights) : ""}
											placeholder="0 o más"
										/>
									</FormField>
									<FormField label="Incluye" htmlFor="includes">
										<Textarea
											id="includes"
											name="includes"
											value={listToText(packageSubtype?.includesJson, "")}
											rows="4"
											placeholder="Una inclusión por línea"
										/>
									</FormField>
									<FormField label="No incluye" htmlFor="excludes">
										<Textarea
											id="excludes"
											name="excludes"
											value={listToText(packageSubtype?.excludesJson, "")}
											rows="4"
											placeholder="Una exclusión por línea"
										/>
									</FormField>
								</div>
							) : null
						}

						{
							pt === "limousine" ? (
								<div class="space-y-4">
									<FormField label="Marca" htmlFor="vehicleMake">
										<Input
											id="vehicleMake"
											name="vehicleMake"
											value={fieldFromObject(limousineSubtype?.vehicleProfileJson, "make")}
											placeholder="Mercedes-Benz"
										/>
									</FormField>
									<FormField label="Modelo" htmlFor="vehicleModel">
										<Input
											id="vehicleModel"
											name="vehicleModel"
											value={fieldFromObject(limousineSubtype?.vehicleProfileJson, "model")}
											placeholder="Clase S"
										/>
									</FormField>
									<FormField label="Clase de vehículo" htmlFor="vehicleClass">
										<Input
											id="vehicleClass"
											name="vehicleClass"
											value={fieldFromObject(limousineSubtype?.vehicleProfileJson, "class")}
											placeholder="Ejecutivo, lujo, van premium"
										/>
									</FormField>
									<FormField label="Color" htmlFor="vehicleColor">
										<Input
											id="vehicleColor"
											name="vehicleColor"
											value={fieldFromObject(limousineSubtype?.vehicleProfileJson, "color")}
											placeholder="Negro"
										/>
									</FormField>
									<div class="grid gap-4 md:grid-cols-2">
										<FormField label="Capacidad de pasajeros" htmlFor="passengerCapacity">
											<Input
												id="passengerCapacity"
												name="passengerCapacity"
												value={
													limousineSubtype?.passengerCapacity != null
														? String(limousineSubtype.passengerCapacity)
														: ""
												}
												placeholder="3"
											/>
										</FormField>
										<FormField label="Capacidad de equipaje" htmlFor="luggageCapacity">
											<Input
												id="luggageCapacity"
												name="luggageCapacity"
												value={
													limousineSubtype?.luggageCapacity != null
														? String(limousineSubtype.luggageCapacity)
														: ""
												}
												placeholder="2"
											/>
										</FormField>
									</div>
									<FormField label="Área base de recogida" htmlFor="pickupDefaultArea">
										<Input
											id="pickupDefaultArea"
											name="pickupDefaultArea"
											value={fieldFromObject(limousineSubtype?.pickupJson, "defaultArea")}
											placeholder="Aeropuerto, zona hotelera..."
										/>
									</FormField>
									<FormField label="Instrucciones de recogida" htmlFor="pickupInstructions">
										<Textarea
											id="pickupInstructions"
											name="pickupInstructions"
											value={fieldFromObject(limousineSubtype?.pickupJson, "instructions")}
											rows="3"
										/>
									</FormField>
									<FormField label="Área base de destino" htmlFor="dropoffDefaultArea">
										<Input
											id="dropoffDefaultArea"
											name="dropoffDefaultArea"
											value={fieldFromObject(limousineSubtype?.dropoffJson, "defaultArea")}
											placeholder="Centro, terminal, hotel..."
										/>
									</FormField>
									<FormField label="Instrucciones de dropoff" htmlFor="dropoffInstructions">
										<Textarea
											id="dropoffInstructions"
											name="dropoffInstructions"
											value={fieldFromObject(limousineSubtype?.dropoffJson, "instructions")}
											rows="3"
										/>
									</FormField>
								</div>
							) : null
						}
					</div>

					<div class="space-y-1">
						<p id="stateLabel" class="text-sm text-slate-600">Vacío: sin cambios guardados.</p>
						<p id="stateDetail" class="whitespace-pre-wrap text-sm text-slate-600"></p>
					</div>

					<div class="flex items-center justify-end gap-3">
						<Button href={`/product/${encodeURIComponent(productId)}/images`} variant="secondary">
							Volver
						</Button>
						<Button id="submitBtn" type="submit"> Guardar subtipo </Button>
					</div>
				</form>
			</Card>
		</section>
	</section>

	<script type="module">
		const form = document.getElementById("subtypeForm")
		const stateLabel = document.getElementById("stateLabel")
		const stateDetail = document.getElementById("stateDetail")
		const btn = document.getElementById("submitBtn")

		function setState(state, detail = "") {
			const labels = {
				empty: "Vacío: sin cambios guardados.",
				loading: "Cargando: guardando subtipo...",
				success: "Éxito: subtipo guardado correctamente.",
				error: "Error: no se pudo guardar el subtipo.",
				disabled: "Deshabilitado: esperando respuesta del servidor.",
			}
			stateLabel.textContent = labels[state] || labels.empty
			stateDetail.textContent = detail
		}

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			setState("loading")
			btn.disabled = true
			setState("disabled")

			try {
				const fd = new FormData(form)
				const res = await fetch("/api/product/subtype", { method: "POST", body: fd })
				const txt = await res.text()
				if (!res.ok) {
					btn.disabled = false
					setState("error", `status=${res.status}\n${txt}`)
					return
				}
				const id = String(fd.get("productId") || "")
				setState("success", "Guardado correctamente")
				window.location.href = `/product/${encodeURIComponent(id)}`
			} catch (err) {
				btn.disabled = false
				setState("error", `Error de red: ${String(err)}`)
			}
		})
	</script>
</WorkspaceLayout>
