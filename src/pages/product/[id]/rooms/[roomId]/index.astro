---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import AccommodationContextSwitcher from "@/components/product/AccommodationContextSwitcher.astro"
import GuestRoomPreviewCards from "@/components/productUI/GuestRoomPreviewCards.astro"
import TabsInsidePanel from "@/components/ui/TabsInsidePanel.astro"
import { productRepository, variantManagementRepository } from "@/container"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import { getNextAddRoomStep, resolveAddRoomPlaybookFromUrl } from "@/lib/playbook/add-room"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { Camera, ImagePlus, RefreshCw, Sparkles } from "@lucide/astro"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
const roomId = String(Astro.params.roomId ?? "")

if (!productId) return Astro.redirect("/product/create")
if (!roomId) return Astro.redirect(routes.productRoomsForProduct(productId))

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")
if (!isHotelProductType(owned.productType)) return Astro.redirect(routes.productDetail(productId))

const variant = await variantManagementRepository.getVariantById(roomId)
if (!variant || variant.productId !== productId) {
	return Astro.redirect(routes.productRoomsForProduct(productId))
}
if (
	String(variant.kind ?? "")
		.trim()
		.toLowerCase() !== "hotel_room"
) {
	return Astro.redirect(routes.productRoomsForProduct(productId))
}

const addRoomPlaybook = resolveAddRoomPlaybookFromUrl(Astro.url)
const flow = Astro.url.searchParams.get("flow")
if (!addRoomPlaybook.active && flow === "add-room") {
	const params = new URLSearchParams(Astro.url.searchParams)
	params.set("playbook", "add-room")
	params.set("step", "room-photos")
	return Astro.redirect(`${routes.productRoomDetail(productId, roomId)}?${params.toString()}`)
}

const addRoomCtx = {
	productId,
	variantId: roomId,
	ratePlanId: addRoomPlaybook.ratePlanId || undefined,
}
const activeAddRoomStepId = addRoomPlaybook.stepId ?? "room-photos"
const isRoomPhotosPlaybook = addRoomPlaybook.active && activeAddRoomStepId === "room-photos"
const addRoomContinueHref = addRoomPlaybook.active
	? (getNextAddRoomStep(activeAddRoomStepId, addRoomCtx)?.buildHref(addRoomCtx) ?? null)
	: null
const Layout = addRoomPlaybook.active ? PlaybookLayout : WorkspaceLayout
const layoutProps = addRoomPlaybook.active
	? {
			title: "Contenido del alojamiento · Habitación",
			playbookId: "add-room" as const,
			active: true,
			stepId: activeAddRoomStepId,
			productId,
			variantId: roomId,
			ratePlanId: addRoomPlaybook.ratePlanId,
			isHotel: true,
			continueHref: addRoomContinueHref,
		}
	: { title: "Contenido del alojamiento · Habitación" }

const photosHref = `${routes.productRoomDetail(productId, roomId)}#fotos`
const previewHref = `${routes.productRoomDetail(productId, roomId)}#previsualizacion`
---

<Layout {...layoutProps}>
	<section
		id="roomWorkspaceRoot"
		class="space-y-8 text-slate-100"
		data-product-id={productId}
		data-room-id={roomId}
	>
		<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
			<div class="space-y-2">
				<AccommodationContextSwitcher
					providerId={providerId}
					productId={productId}
					currentName={owned.name}
					target="rooms"
				/>
				<h1 id="roomTitle" class="text-3xl font-semibold text-slate-100">
					{isRoomPhotosPlaybook ? `Fotos de ${variant.name}` : variant.name}
				</h1>
				<p id="roomHeaderDescription" class="max-w-3xl text-sm leading-6 text-slate-400">
					{
						isRoomPhotosPlaybook
							? "Agrega imágenes claras de la cama, el baño y la distribución real. La primera foto será la referencia principal para huéspedes."
							: "Resumen de cómo se muestra, se vende y se opera esta habitación dentro del alojamiento."
					}
				</p>
			</div>
			{
				!isRoomPhotosPlaybook ? (
					<Button
						href={routes.productRoomCalendar(productId, roomId)}
						data-astro-prefetch
						variant="secondary"
					>
						Abrir calendario
					</Button>
				) : null
			}
		</header>

		{
			!isRoomPhotosPlaybook ? (
				<TabsInsidePanel data-room-tabs aria-label="Secciones de habitación">
					<button
						type="button"
						data-room-tab="resumen"
						data-active="true"
						aria-selected="true"
						class:list={["fastt-tabs-inside-panel__item px-4 py-2 whitespace-nowrap"]}
					>
						Resumen
					</button>
					<button
						type="button"
						data-room-tab="fotos"
						data-active="false"
						aria-selected="false"
						class:list={[
							"fastt-tabs-inside-panel__item px-4 py-2 text-slate-300 whitespace-nowrap hover:bg-slate-800 hover:text-white",
						]}
					>
						Fotos
					</button>
					<button
						type="button"
						data-room-tab="previsualizacion"
						data-active="false"
						aria-selected="false"
						class:list={[
							"fastt-tabs-inside-panel__item px-4 py-2 text-slate-300 whitespace-nowrap hover:bg-slate-800 hover:text-white",
						]}
					>
						Previsualización
					</button>
				</TabsInsidePanel>
			) : null
		}

		<div class="space-y-8">
			<section
				data-room-panel="resumen"
				class:list={["space-y-6", isRoomPhotosPlaybook ? "hidden" : ""]}
			>
				<Card class="overflow-hidden p-0">
					<div id="overviewPrimaryStatus" class="border-b border-slate-200 bg-slate-50 p-5 md:p-6">
						<div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
							<div class="flex items-start gap-4">
								<div
									id="overviewPrimaryIcon"
									class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[16px] bg-amber-50 text-amber-800 ring-1 ring-amber-200"
								>
									<Sparkles class="h-5 w-5" />
								</div>
								<div class="space-y-1">
									<p
										id="overviewPrimaryEyebrow"
										class="text-xs font-semibold uppercase tracking-wide text-slate-500"
									>
										Requiere atención
									</p>
									<h2 id="overviewPrimaryTitle" class="text-xl font-semibold text-slate-950">
										Cargando estado de la habitación
									</h2>
									<p id="overviewPrimaryText" class="max-w-3xl text-sm leading-6 text-slate-600">
										Estamos revisando perfil, fotos, tarifa y disponibilidad.
									</p>
									<p id="readinessFeedback" class="text-sm leading-6 text-slate-500"></p>
								</div>
							</div>
							<div class="flex flex-wrap items-center gap-2 lg:justify-end">
								<div id="overviewPrimaryAction"></div>
								<Button id="reevaluateBtn" type="button" variant="secondary" size="sm">
									<RefreshCw class="h-4 w-4" />
									Actualizar estado
								</Button>
							</div>
						</div>
					</div>

					<div class="space-y-6 p-5 md:p-6">
						<div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_300px]">
							<div>
								<div class="flex flex-wrap items-center justify-between gap-3">
									<div>
										<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
											Preparación
										</p>
										<h3 class="mt-1 text-base font-semibold text-slate-950">
											Estado de venta de la habitación
										</h3>
									</div>
								</div>
								<div
									id="overviewChecklist"
									class="mt-4 divide-y divide-slate-100 rounded-[18px] bg-slate-50 ring-1 ring-slate-900/[0.06]"
								>
									{
										["Perfil", "Fotos", "Tarifa", "Disponibilidad"].map((label) => (
											<div class="flex items-center justify-between gap-4 p-4">
												<div>
													<p class="text-sm font-semibold text-slate-950">{label}</p>
													<div class="mt-2 h-3 w-32 animate-pulse rounded bg-slate-200" />
												</div>
												<div class="h-6 w-16 animate-pulse rounded-full bg-slate-200" />
											</div>
										))
									}
								</div>
							</div>

							<aside class="space-y-3">
								<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
									Accesos rápidos
								</p>
								<div class="grid gap-2">
									<Button
										href={routes.productRoomProfile(productId, roomId)}
										data-astro-prefetch
										variant="secondary"
										className="w-full justify-start"
									>
										Editar información
									</Button>
									<Button
										href={photosHref}
										data-astro-prefetch
										variant="secondary"
										className="w-full justify-start"
									>
										Fotos
									</Button>
									<Button
										href={`/rates/plans/manage?variantId=${encodeURIComponent(roomId)}`}
										data-astro-prefetch
										variant="secondary"
										className="w-full justify-start"
									>
										Tarifas
									</Button>
									<Button
										href={routes.productRoomCalendar(productId, roomId)}
										data-astro-prefetch
										variant="secondary"
										className="w-full justify-start"
									>
										Calendario
									</Button>
									<Button
										href={previewHref}
										data-astro-prefetch
										variant="secondary"
										className="w-full justify-start"
									>
										Previsualización
									</Button>
								</div>
							</aside>
						</div>
					</div>
				</Card>
			</section>

			<section
				data-room-panel="fotos"
				class:list={["space-y-6", isRoomPhotosPlaybook ? "" : "hidden"]}
			>
				<Card class="space-y-5">
					<div class="flex flex-wrap items-center justify-between gap-3">
						<div class="space-y-1">
							<p class="flex items-center gap-2 text-sm font-semibold text-slate-950">
								<Camera class="h-4 w-4" />
								Galería de la habitación
							</p>
							<p class="max-w-2xl text-sm leading-6 text-slate-600">
								Muestra cama, baño, vista y distribución real. La primera imagen será la foto
								principal.
							</p>
						</div>
						<div class="flex flex-wrap items-center gap-2">
							<input id="roomImageFiles" type="file" accept="image/*" multiple class="hidden" />
							<Button id="roomImageUploadBtn" type="button" variant="secondary">
								<ImagePlus class="mr-2 h-4 w-4" />
								Subir imágenes
							</Button>
							<Button id="roomImageSaveBtn" type="button">Guardar galería</Button>
						</div>
					</div>
					<div
						id="roomPhotoReadiness"
						class="rounded-[18px] border border-amber-200 bg-amber-50 p-4 text-sm leading-6 text-amber-900"
					>
						Agrega al menos 1 foto. La primera imagen aparecerá en Dónde dormirás.
					</div>
					<p id="roomImageFeedback" class="text-sm text-slate-600"></p>
					<div id="roomImageGrid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{
							Array.from({ length: 3 }).map(() => (
								<div class="min-h-[180px] animate-pulse rounded-[18px] bg-slate-100" />
							))
						}
					</div>
				</Card>
			</section>

			<section data-room-panel="previsualizacion" class="hidden space-y-6">
				<Card class="space-y-6">
					<div class="flex flex-wrap items-start justify-between gap-4">
						<div>
							<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
								Experiencia huésped
							</p>
							<h2 class="mt-1 text-xl font-semibold text-slate-950">
								Así verá el huésped esta habitación
							</h2>
							<p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">
								Revisa la información visible antes de reservar: nombre, fotos, capacidad, camas,
								baño, vista y comodidades.
							</p>
						</div>
						<div class="flex flex-wrap items-center gap-2">
							<Button
								href={routes.productRoomProfile(productId, roomId)}
								data-astro-prefetch
								variant="secondary"
							>
								Editar información
							</Button>
							<Button href={photosHref} data-astro-prefetch variant="secondary">
								Editar fotos
							</Button>
						</div>
					</div>
					<GuestRoomPreviewCards
						previews={[]}
						containerId="workspaceGuestRoomPreviewCards"
						gridClass="grid gap-4"
						cardClass="border-slate-200 bg-white text-slate-800"
						statusLabel="Así lo verá el huésped"
						emptyText="Cargando preview de la habitación..."
					/>
					<div>
						<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
							Detalles visibles
						</p>
						<div id="profileFacts" class="mt-3 grid gap-3 md:grid-cols-2"></div>
					</div>
				</Card>
			</section>
		</div>
	</section>

	<script
		is:inline
		data-astro-rerun
		define:vars={{
			productId,
			roomId,
			addRoomPlaybookActive: addRoomPlaybook.active,
			isRoomPhotosPlaybook,
		}}
	>
		;(function () {
			const previousController = window.__fasttRoomWorkspaceController
			if (previousController && typeof previousController.abort === "function") {
				previousController.abort()
			}
			const roomWorkspaceController = new AbortController()
			const roomWorkspaceSignal = roomWorkspaceController.signal
			window.__fasttRoomWorkspaceController = roomWorkspaceController
			document.addEventListener(
				"astro:before-swap",
				() => {
					roomWorkspaceController.abort()
				},
				{ once: true, signal: roomWorkspaceSignal }
			)

			const shellStart = performance.now()
			const logShellVisible = () => {
				console.debug("shell visible", {
					page: "room-workspace",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				logShellVisible()
			} else {
				document.addEventListener("DOMContentLoaded", logShellVisible, {
					once: true,
					signal: roomWorkspaceSignal,
				})
			}

			if (!productId || !roomId) return

			const feedback = document.getElementById("readinessFeedback")
			const reevaluateBtn = document.getElementById("reevaluateBtn")
			const roomImageFiles = document.getElementById("roomImageFiles")
			const roomImageUploadBtn = document.getElementById("roomImageUploadBtn")
			const roomImageSaveBtn = document.getElementById("roomImageSaveBtn")
			const roomImageFeedback = document.getElementById("roomImageFeedback")
			const roomImageGrid = document.getElementById("roomImageGrid")
			let roomImages = []

			const isCurrentRoomWorkspace = () => {
				const root = document.getElementById("roomWorkspaceRoot")
				return (
					root instanceof HTMLElement &&
					root.dataset.productId === productId &&
					root.dataset.roomId === roomId
				)
			}

			const safeText = (value, fallback = "") => {
				const normalized = String(value ?? "").trim()
				return normalized || fallback
			}

			const setText = (id, value) => {
				const element = document.getElementById(id)
				if (element) element.textContent = String(value)
			}

			const hasPersistableRoomImages = () =>
				Array.isArray(roomImages) && roomImages.some((image) => safeText(image?.url))

			const syncRoomImageSaveState = (options = {}) => {
				const hasImages = hasPersistableRoomImages()
				if (roomImageSaveBtn instanceof HTMLButtonElement) {
					roomImageSaveBtn.disabled = !hasImages
					roomImageSaveBtn.setAttribute("aria-disabled", hasImages ? "false" : "true")
				}
				if (!hasImages && options.showHint && roomImageFeedback) {
					roomImageFeedback.textContent = "Sube al menos una foto antes de guardar la galería."
				}
			}

			const tabButtons = Array.from(document.querySelectorAll("[data-room-tab]"))
			const panels = Array.from(document.querySelectorAll("[data-room-panel]"))
			const tabIds = new Set(
				tabButtons.map((button) => String(button.getAttribute("data-room-tab")))
			)
			const normalizeTabId = (value) => {
				const normalized = String(value ?? "")
					.trim()
					.replace(/^#/, "")
					.toLowerCase()
				if (normalized === "fotos") return "fotos"
				return tabIds.has(normalized) ? normalized : "resumen"
			}
			const showTab = (id, options = {}) => {
				const targetId = isRoomPhotosPlaybook ? "fotos" : normalizeTabId(id)
				for (const button of tabButtons) {
					const active = button.getAttribute("data-room-tab") === targetId
					button.setAttribute("aria-selected", active ? "true" : "false")
					button.setAttribute("data-active", active ? "true" : "false")
				}
				for (const panel of panels) {
					panel.classList.toggle("hidden", panel.getAttribute("data-room-panel") !== targetId)
				}
				if (!options.skipHash && window.location.hash !== `#${targetId}`) {
					window.history.replaceState(null, "", `#${targetId}`)
				}
			}
			const isSameRoomHashLink = (link) => {
				try {
					const url = new URL(link.href, window.location.href)
					const hashTabId = String(url.hash ?? "")
						.replace(/^#/, "")
						.toLowerCase()
					return (
						url.origin === window.location.origin &&
						url.pathname === window.location.pathname &&
						tabIds.has(hashTabId)
					)
				} catch {
					return false
				}
			}
			for (const button of tabButtons) {
				button.addEventListener(
					"click",
					() => showTab(String(button.getAttribute("data-room-tab"))),
					{ signal: roomWorkspaceSignal }
				)
			}
			document.addEventListener(
				"click",
				(event) => {
					const link = event.target instanceof Element ? event.target.closest("a[href]") : null
					if (!(link instanceof HTMLAnchorElement) || !isSameRoomHashLink(link)) return
					event.preventDefault()
					showTab(link.hash)
				},
				{ signal: roomWorkspaceSignal }
			)
			showTab(window.location.hash || (isRoomPhotosPlaybook ? "fotos" : "resumen"), {
				skipHash: true,
			})
			if (isRoomPhotosPlaybook && window.location.hash !== "#fotos") {
				window.history.replaceState(null, "", "#fotos")
			}
			window.addEventListener(
				"hashchange",
				() => {
					showTab(window.location.hash, { skipHash: true })
					if (isRoomPhotosPlaybook && window.location.hash !== "#fotos") {
						window.history.replaceState(null, "", "#fotos")
					}
				},
				{ signal: roomWorkspaceSignal }
			)

			const toneClasses = (complete) =>
				complete
					? "bg-emerald-50 text-emerald-800 ring-emerald-200"
					: "bg-amber-50 text-amber-900 ring-amber-200"

			const makeSmallButton = (href, label, variant = "secondary") => {
				const link = document.createElement("a")
				link.href = href
				link.textContent = label
				link.setAttribute("data-astro-prefetch", "")
				link.className =
					variant === "primary"
						? "fastt-button inline-flex h-9 items-center justify-center rounded px-3 text-sm font-semibold bg-slate-950 text-white hover:bg-slate-800"
						: "fastt-button inline-flex h-9 items-center justify-center rounded border border-slate-200 bg-white px-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-slate-950"
				return link
			}

			const factCard = (label, value, hint) => {
				const card = document.createElement("article")
				card.className = "rounded-[18px] bg-slate-50 p-4 ring-1 ring-slate-900/[0.06]"
				const title = document.createElement("p")
				title.className = "text-xs font-semibold uppercase tracking-wide text-slate-500"
				title.textContent = label
				const body = document.createElement("p")
				body.className = "mt-2 text-sm font-semibold text-slate-950"
				body.textContent = value
				const meta = document.createElement("p")
				meta.className = "mt-1 text-sm leading-5 text-slate-500"
				meta.textContent = hint
				card.append(title, body, meta)
				return card
			}

			const concisePricingSummary = (payload) => {
				const raw = safeText(payload?.summary?.pricing, "Sin tarifa")
				const lower = raw.toLowerCase()
				if (lower.includes("precios efectivos pendientes") || lower.includes("faltan precios")) {
					return "Precio base creado, falta completar precios efectivos."
				}
				return raw
			}

			const renderOverviewChecklist = (payload) => {
				const container = document.getElementById("overviewChecklist")
				if (!container) return
				const blocks = payload?.blocks ?? {}
				const items = [
					{
						label: "Perfil",
						complete: Boolean(blocks.profile?.complete && blocks.capacity?.complete),
						summary: safeText(payload?.summary?.capacity, "Capacidad pendiente"),
						href: `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(roomId)}/profile`,
					},
					{
						label: "Fotos",
						complete: Boolean(blocks.photos?.complete),
						summary: `${Number(blocks.photos?.count ?? 0)} foto(s)`,
						href: `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(roomId)}#fotos`,
					},
					{
						label: "Tarifa",
						complete: Boolean(blocks.pricing?.complete),
						summary: concisePricingSummary(payload),
						href: `/rates/plans/manage?variantId=${encodeURIComponent(roomId)}`,
					},
					{
						label: "Disponibilidad",
						complete: Boolean(blocks.inventory?.complete),
						summary: safeText(payload?.summary?.inventory, "Sin disponibilidad"),
						href: `/rates/calendar?variantId=${encodeURIComponent(roomId)}&focus=availability`,
					},
				]
				container.innerHTML = ""
				for (const item of items) {
					const row = document.createElement("a")
					row.href = item.href
					row.setAttribute("data-astro-prefetch", "")
					row.className =
						"flex items-center justify-between gap-4 p-4 text-sm transition hover:bg-white"
					const copy = document.createElement("div")
					copy.className = "min-w-0"
					const label = document.createElement("p")
					label.className = "font-semibold text-slate-950"
					label.textContent = item.label
					const summary = document.createElement("p")
					summary.className = "mt-1 line-clamp-2 text-sm leading-5 text-slate-500"
					summary.textContent = item.summary
					copy.append(label, summary)
					const state = document.createElement("span")
					state.className = `inline-flex shrink-0 items-center rounded-full px-2 py-0.5 text-xs font-semibold ring-1 ${toneClasses(item.complete)}`
					state.textContent = item.complete ? "Listo" : "Pendiente"
					row.append(copy, state)
					container.appendChild(row)
				}
			}

			const renderProfileFacts = (payload) => {
				const container = document.getElementById("profileFacts")
				if (!container) return
				const preview = payload?.guestPreview ?? {}
				container.innerHTML = ""
				container.append(
					factCard(
						"Ocupación",
						safeText(preview.occupancySummary, "Capacidad por confirmar"),
						"Rango visible antes de reservar."
					),
					factCard(
						"Descanso",
						safeText(preview.sleepSummary, "Camas por confirmar"),
						"Se muestra en Dónde dormirás."
					),
					factCard(
						"Baño y espacio",
						safeText(preview.bathroomSummary, "Baño por confirmar"),
						safeText(preview.sizeSummary || preview.viewSummary, "Completa tamaño, vista o balcón.")
					),
					factCard(
						"Comodidades",
						`${Array.isArray(preview.amenityLabels) ? preview.amenityLabels.length : 0} seleccionadas`,
						"Servicios propios de esta habitación."
					)
				)
			}

			const getNextAction = (payload) => {
				const blocks = payload?.blocks ?? {}
				if (!blocks.profile?.complete || !blocks.capacity?.complete) {
					return {
						eyebrow: "Requiere atención",
						title: "Completa la información de la habitación",
						text: "Define capacidad, camas, baño y detalles físicos para que el huésped entienda qué está reservando.",
						href: `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(roomId)}/profile`,
						label: "Editar información",
					}
				}
				if (!blocks.photos?.complete) {
					return {
						eyebrow: "Requiere atención",
						title: "Agrega una foto clara de la habitación",
						text: "La primera imagen será la referencia visual principal en la experiencia del huésped.",
						href: `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(roomId)}#fotos`,
						label: "Editar fotos",
					}
				}
				if (!blocks.pricing?.complete) {
					return {
						eyebrow: "Requiere atención",
						title: "Falta completar precios para vender esta habitación",
						text: "Tienes una tarifa comercial creada, pero todavía faltan precios efectivos para los próximos días.",
						href: `/rates/plans/manage?variantId=${encodeURIComponent(roomId)}`,
						label: "Abrir tarifas",
					}
				}
				if (!blocks.inventory?.complete) {
					return {
						eyebrow: "Requiere atención",
						title: "Abre fechas disponibles en el calendario",
						text: "La habitación necesita al menos un rango disponible para poder recibir reservas.",
						href: `/rates/calendar?variantId=${encodeURIComponent(roomId)}&focus=availability`,
						label: "Abrir calendario",
					}
				}
				return {
					eyebrow: "Lista para venderse",
					title: "La habitación está preparada para recibir reservas",
					text: "La habitación está lista para venderse con confianza.",
					href: `/rates/calendar?variantId=${encodeURIComponent(roomId)}&focus=availability`,
					label: "Ver calendario",
					complete: true,
				}
			}

			const renderNextAction = (payload) => {
				const action = getNextAction(payload)
				setText("overviewPrimaryEyebrow", action.eyebrow)
				setText("overviewPrimaryTitle", action.title)
				setText("overviewPrimaryText", action.text)
				const icon = document.getElementById("overviewPrimaryIcon")
				if (icon) {
					icon.className = action.complete
						? "flex h-11 w-11 shrink-0 items-center justify-center rounded-[16px] bg-emerald-50 text-emerald-800 ring-1 ring-emerald-200"
						: "flex h-11 w-11 shrink-0 items-center justify-center rounded-[16px] bg-amber-50 text-amber-800 ring-1 ring-amber-200"
				}
				const slot = document.getElementById("overviewPrimaryAction")
				if (!slot) return
				slot.innerHTML = ""
				slot.appendChild(
					makeSmallButton(action.href, action.label, action.complete ? "secondary" : "primary")
				)
			}

			const renderRoomImages = () => {
				syncRoomImageSaveState()
				if (!roomImageGrid) return
				roomImageGrid.innerHTML = ""
				if (!Array.isArray(roomImages) || roomImages.length === 0) {
					const empty = document.createElement("div")
					empty.className = "fastt-empty-state col-span-full p-6 text-sm text-slate-600"
					empty.textContent =
						"Aún no hay fotos. Agrega al menos una imagen clara de la cama y el baño."
					roomImageGrid.appendChild(empty)
					return
				}
				roomImages.forEach((image, index) => {
					const card = document.createElement("article")
					card.className = "space-y-3 rounded-[20px] bg-slate-50 p-3 ring-1 ring-slate-900/[0.06]"
					const preview = document.createElement("img")
					preview.src = String(image.url)
					preview.alt = `Foto de habitación ${index + 1}`
					preview.className = "h-40 w-full rounded-[16px] object-cover"
					const meta = document.createElement("div")
					meta.className = "flex flex-wrap items-center gap-2"
					const order = document.createElement("span")
					order.className =
						"inline-flex rounded-full bg-white px-2 py-0.5 text-xs font-medium text-slate-700 ring-1 ring-slate-200"
					order.textContent = index === 0 ? "Principal" : `Foto ${index + 1}`
					meta.appendChild(order)
					if (index === 0) {
						const guestPlacement = document.createElement("span")
						guestPlacement.className =
							"inline-flex rounded-full bg-sky-50 px-2 py-0.5 text-xs font-medium text-sky-800 ring-1 ring-sky-200"
						guestPlacement.textContent = "Visible en Dónde dormirás"
						meta.appendChild(guestPlacement)
					}
					const actions = document.createElement("div")
					actions.className = "grid grid-cols-3 gap-2"
					const makeButton = (label, disabled, onClick, tone = "neutral") => {
						const button = document.createElement("button")
						button.type = "button"
						button.disabled = disabled
						button.className =
							tone === "danger"
								? "fastt-button inline-flex h-8 items-center justify-center rounded bg-red-50 px-2 text-xs font-semibold text-red-700 ring-1 ring-red-200 disabled:opacity-40"
								: "fastt-button inline-flex h-8 items-center justify-center rounded bg-white px-2 text-xs font-semibold text-slate-700 ring-1 ring-slate-200 disabled:opacity-40"
						button.textContent = label
						button.addEventListener("click", onClick)
						return button
					}
					actions.append(
						makeButton("Arriba", index === 0, () => {
							const next = roomImages.slice()
							const temp = next[index - 1]
							next[index - 1] = next[index]
							next[index] = temp
							roomImages = next
							renderRoomImages()
						}),
						makeButton("Abajo", index === roomImages.length - 1, () => {
							const next = roomImages.slice()
							const temp = next[index + 1]
							next[index + 1] = next[index]
							next[index] = temp
							roomImages = next
							renderRoomImages()
						}),
						makeButton(
							"Eliminar",
							false,
							() => {
								roomImages = roomImages.filter((_, idx) => idx !== index)
								renderRoomImages()
							},
							"danger"
						)
					)
					card.append(preview, meta, actions)
					roomImageGrid.appendChild(card)
				})
			}

			const renderPhotoReadiness = (payload) => {
				const container = document.getElementById("roomPhotoReadiness")
				if (!container) return
				const photos = payload?.blocks?.photos
				const count = Number(photos?.count ?? 0)
				const complete = Boolean(photos?.complete)
				container.className = complete
					? "rounded-[18px] bg-emerald-50 p-4 text-sm leading-6 text-emerald-900 ring-1 ring-emerald-200"
					: "rounded-[18px] bg-amber-50 p-4 text-sm leading-6 text-amber-900 ring-1 ring-amber-200"
				container.textContent = complete
					? `${count} foto(s) listas. La primera imagen aparecerá en Dónde dormirás.`
					: "Agrega al menos 1 foto. La primera imagen aparecerá en Dónde dormirás y es obligatoria para publicar."
			}

			const toGuestRoomPreviewCard = (payload) => {
				const preview = payload?.guestPreview ?? {}
				const gallery = Array.isArray(preview.gallery) ? preview.gallery : []
				const imageUrl = safeText(preview.coverUrl, gallery[0]?.url ?? "")
				return {
					variantId: safeText(payload?.variant?.id, roomId),
					roomName: safeText(preview.roomName, payload?.variant?.name ?? "Habitación"),
					roomTypeName: safeText(preview.roomTypeLabel, "Habitación"),
					imageUrl: imageUrl || "https://placehold.co/1200x800?text=Habitacion",
					gallery,
					sleepSummary: safeText(preview.sleepSummary, "Camas por confirmar"),
					sleepAreas: Array.isArray(preview.sleepAreas) ? preview.sleepAreas : [],
					bathroomSummary: safeText(preview.bathroomSummary, "Baño por confirmar"),
					occupancySummary: safeText(preview.occupancySummary, "Capacidad por confirmar"),
					sizeSummary: safeText(preview.sizeSummary, ""),
					viewSummary: safeText(preview.viewSummary, ""),
					amenityLabels: Array.isArray(preview.amenityLabels) ? preview.amenityLabels : [],
					amenityGroups: Array.isArray(preview.amenityGroups) ? preview.amenityGroups : [],
					guestFacingNotes: safeText(preview.guestFacingNotes, ""),
					hasBalcony: Boolean(preview.hasBalcony),
				}
			}

			const renderGuestPreview = (payload) => {
				const renderer = window.renderGuestRoomPreviewCards
				if (typeof renderer === "function") {
					renderer("workspaceGuestRoomPreviewCards", [toGuestRoomPreviewCard(payload)], {
						cardClass: "border-slate-200 bg-white text-slate-800",
						statusLabel: "Así lo verá el huésped",
						emptyText: "Completa perfil y fotos para ver la tarjeta pública de la habitación.",
					})
				}
			}

			const hydrate = (payload) => {
				const roomName = safeText(payload?.variant?.name, "Habitación")
				setText("roomTitle", isRoomPhotosPlaybook ? `Fotos de ${roomName}` : roomName)
				setText(
					"roomHeaderDescription",
					isRoomPhotosPlaybook
						? "Agrega imágenes claras de la cama, el baño y la distribución real. La primera foto será la referencia principal para huéspedes."
						: "Resumen de cómo se muestra, se vende y se opera esta habitación dentro del alojamiento."
				)
				roomImages = Array.isArray(payload?.variant?.images) ? payload.variant.images.slice() : []
				renderOverviewChecklist(payload)
				renderProfileFacts(payload)
				renderNextAction(payload)
				renderRoomImages()
				renderPhotoReadiness(payload)
				renderGuestPreview(payload)
			}

			roomImageUploadBtn?.addEventListener(
				"click",
				() => {
					if (roomImageFiles instanceof HTMLInputElement) roomImageFiles.click()
				},
				{ signal: roomWorkspaceSignal }
			)

			roomImageFiles?.addEventListener(
				"change",
				async (event) => {
					const input = event.currentTarget
					if (!(input instanceof HTMLInputElement)) return
					const files = Array.from(input.files ?? [])
					if (files.length === 0) return
					if (roomImageSaveBtn instanceof HTMLButtonElement) roomImageSaveBtn.disabled = true
					if (roomImageFeedback) roomImageFeedback.textContent = "Subiendo imágenes..."
					try {
						for (const file of files) {
							const initData = new FormData()
							initData.set("productId", productId)
							initData.set("file", file)
							const initResponse = await fetch("/api/uploads/init", {
								method: "POST",
								body: initData,
							})
							const initPayload = await initResponse.json().catch(() => ({}))
							if (
								!initResponse.ok ||
								!initPayload?.imageId ||
								!initPayload?.objectKey ||
								!initPayload?.signedUrl
							) {
								throw new Error(String(initPayload?.error ?? "upload_init_failed"))
							}
							const uploadResponse = await fetch(String(initPayload.signedUrl), {
								method: "PUT",
								headers: { "Content-Type": file.type || "application/octet-stream" },
								body: file,
							})
							if (!uploadResponse.ok) throw new Error(`upload_failed_${uploadResponse.status}`)
							const completeData = new FormData()
							completeData.set("productId", productId)
							completeData.set("imageId", String(initPayload.imageId))
							completeData.set("objectKey", String(initPayload.objectKey))
							completeData.set("entityType", "variant")
							completeData.set("entityId", roomId)
							const completeResponse = await fetch("/api/uploads/complete", {
								method: "POST",
								body: completeData,
							})
							const completePayload = await completeResponse.json().catch(() => ({}))
							if (!completeResponse.ok) {
								throw new Error(String(completePayload?.error ?? "upload_complete_failed"))
							}
							roomImages.push({
								id: String(initPayload.imageId),
								url: String(initPayload.publicUrl),
								objectKey: String(initPayload.objectKey),
								order: roomImages.length,
								isPrimary: roomImages.length === 0,
							})
						}
						renderRoomImages()
						if (roomImageFeedback) {
							roomImageFeedback.textContent =
								"Imágenes cargadas y vinculadas. Guarda la galería para confirmar el orden."
						}
					} catch (error) {
						if (roomImageFeedback)
							roomImageFeedback.textContent = `Error al subir imágenes: ${String(error)}`
					} finally {
						input.value = ""
						syncRoomImageSaveState()
					}
				},
				{ signal: roomWorkspaceSignal }
			)

			roomImageSaveBtn?.addEventListener(
				"click",
				async () => {
					if (!hasPersistableRoomImages()) {
						syncRoomImageSaveState({ showHint: true })
						return
					}
					if (roomImageSaveBtn instanceof HTMLButtonElement) roomImageSaveBtn.disabled = true
					if (roomImageFeedback) roomImageFeedback.textContent = "Guardando galería..."
					try {
						const formData = new FormData()
						formData.set("variantId", roomId)
						for (const image of roomImages) {
							formData.append("imageUrl", String(image.url))
							const objectKey =
								image?.objectKey ??
								(() => {
									try {
										return new URL(String(image.url)).pathname.replace(/^\/+/, "")
									} catch {
										return ""
									}
								})()
							formData.append("imageObjectKey", String(objectKey ?? ""))
						}
						const response = await fetch("/api/variant/images", { method: "POST", body: formData })
						const payload = await response.json().catch(() => ({}))
						if (!response.ok) {
							if (roomImageFeedback) {
								roomImageFeedback.textContent = `No se pudo guardar: ${String(payload?.error ?? response.status)}`
							}
							return
						}
						roomImages = Array.isArray(payload?.images) ? payload.images.slice() : roomImages
						renderRoomImages()
						await loadRoom()
						if (roomImageFeedback) roomImageFeedback.textContent = "Galería guardada correctamente."
						if (addRoomPlaybookActive && roomImages.length > 0) {
							const params = new URLSearchParams({
								playbook: "add-room",
								step: "create-rate",
								flow: "add-room",
								variantId: roomId,
							})
							window.location.href = `/rates/plans/manage?${params.toString()}`
							return
						}
					} catch (error) {
						if (roomImageFeedback) roomImageFeedback.textContent = `Error de red: ${String(error)}`
					} finally {
						syncRoomImageSaveState()
					}
				},
				{ signal: roomWorkspaceSignal }
			)

			const loadRoom = async () => {
				if (!isCurrentRoomWorkspace()) return null
				const hydrationStart = performance.now()
				try {
					const response = await fetch(
						`/api/internal/room-summary?productId=${encodeURIComponent(productId)}&variantId=${encodeURIComponent(roomId)}`,
						{ headers: { accept: "application/json" } }
					)
					if (!response.ok) throw new Error(`room_summary_${response.status}`)
					const payload = await response.json()
					hydrate(payload)
					console.debug("data hydrated", {
						page: "room-workspace",
						durationMs: Number((performance.now() - hydrationStart).toFixed(1)),
					})
					return payload
				} catch (error) {
					if (feedback) feedback.textContent = `No se pudo cargar la habitación: ${String(error)}`
					return null
				}
			}

			const evaluateReadiness = async () => {
				if (reevaluateBtn instanceof HTMLButtonElement) reevaluateBtn.disabled = true
				if (feedback) feedback.textContent = "Evaluando habitación..."
				try {
					const form = new FormData()
					form.set("variantId", String(roomId || ""))
					const res = await fetch("/api/variant/evaluate", { method: "POST", body: form })
					if (res.status === 401) {
						window.location.href = "/SignInPage"
						return
					}
					if (!res.ok) {
						const txt = await res.text()
						if (feedback) feedback.textContent = txt || "No se pudo evaluar en este momento."
						return
					}
					await loadRoom()
					if (feedback) feedback.textContent = "Revisión actualizada correctamente."
				} catch (error) {
					if (feedback) feedback.textContent = `Error de red: ${String(error)}`
				} finally {
					if (reevaluateBtn instanceof HTMLButtonElement) reevaluateBtn.disabled = false
				}
			}

			reevaluateBtn?.addEventListener("click", evaluateReadiness, { signal: roomWorkspaceSignal })
			const refreshRoomWorkspace = () => {
				if (!isCurrentRoomWorkspace()) return
				showTab(window.location.hash || (isRoomPhotosPlaybook ? "fotos" : "resumen"), {
					skipHash: true,
				})
				void loadRoom()
			}
			window.addEventListener(
				"pageshow",
				(event) => {
					if (event.persisted) refreshRoomWorkspace()
				},
				{ signal: roomWorkspaceSignal }
			)
			refreshRoomWorkspace()
		})()
	</script>
</Layout>
