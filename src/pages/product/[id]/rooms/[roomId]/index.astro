---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import GuestRoomPreviewCards from "@/components/productUI/GuestRoomPreviewCards.astro"
import Section from "@/components/ui/Section.astro"
import { productRepository } from "@/container"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import {
	ArrowLeft,
	BedDouble,
	CalendarDays,
	Camera,
	ClipboardCheck,
	CircleCheck,
	DoorOpen,
	Eye,
	Hotel,
	ImagePlus,
	RefreshCw,
	Sparkles,
} from "@lucide/astro"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
const roomId = String(Astro.params.roomId ?? "")

if (!productId) return Astro.redirect("/product/create")
if (!roomId) return Astro.redirect(routes.productRoomsForProduct(productId))

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")
if (!isHotelProductType(owned.productType)) return Astro.redirect(routes.productDetail(productId))

const tabs = [
	{ id: "perfil", label: "Perfil", icon: DoorOpen },
	{ id: "fotos", label: "Fotos", icon: Camera },
	{ id: "preview", label: "Preview huésped", icon: Eye },
	{ id: "disponibilidad", label: "Disponibilidad", icon: CalendarDays },
	{ id: "publicacion", label: "Publicación", icon: ClipboardCheck },
]
---

<WorkspaceLayout title="Contenido del alojamiento · Habitación">
	<section class="space-y-8">
		<header class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-950/80 shadow-sm">
			<div class="grid gap-0 lg:grid-cols-[1fr_340px]">
				<div class="space-y-5 p-5 md:p-6">
					<a
						href={routes.productRoomsForProduct(productId)}
						data-astro-prefetch
						class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-slate-100"
					>
						<ArrowLeft class="h-4 w-4" />
						Volver a habitaciones
					</a>
					<div class="space-y-2">
						<p class="flex items-center gap-2 text-sm font-medium text-slate-400">
							<Hotel class="h-4 w-4" />
							Alojamiento · Habitación
						</p>
						<h1 id="roomTitle" class="text-3xl font-semibold text-slate-100">
							Cargando habitación...
						</h1>
						<p class="max-w-3xl text-sm leading-6 text-slate-400">
							Administra la ficha como la verá el huésped: perfil, fotos, preview, disponibilidad y
							publicación en un solo workspace.
						</p>
					</div>
					<div class="flex flex-wrap items-center gap-2">
						<Badge id="roomStatusBadge" variant="neutral">Cargando...</Badge>
						<Button id="evaluateHeaderBtn" type="button">
							<RefreshCw class="mr-2 h-4 w-4" />
							Actualizar publicación
						</Button>
						<Button
							href={routes.productRoomProfile(productId, roomId)}
							data-astro-prefetch
							variant="secondary"
						>
							Editar perfil
						</Button>
					</div>
				</div>
				<aside
					class="border-t border-slate-800 bg-slate-900/80 p-5 lg:border-l lg:border-t-0 md:p-6"
				>
					<p class="flex items-center gap-2 text-sm font-semibold text-slate-100">
						<Sparkles class="h-4 w-4 text-slate-300" />
						Readiness de habitación
					</p>
					<div class="mt-4 h-2 w-full overflow-hidden rounded-full bg-slate-700">
						<div id="roomProgressBar" class="h-full w-0 bg-slate-50"></div>
					</div>
					<div class="mt-4 grid grid-cols-3 gap-2 text-sm">
						<div class="rounded-lg border border-slate-700 p-3">
							<p class="text-xs text-slate-400">Listo</p>
							<p id="roomProgressCompleted" class="mt-1 text-lg font-semibold text-white">—/4</p>
						</div>
						<div class="rounded-lg border border-slate-700 p-3">
							<p class="text-xs text-slate-400">Pendiente</p>
							<p id="roomProgressPending" class="mt-1 text-lg font-semibold text-white">—</p>
						</div>
						<div class="rounded-lg border border-slate-700 p-3">
							<p class="text-xs text-slate-400">Progreso</p>
							<p id="roomProgressPercent" class="mt-1 text-lg font-semibold text-white">—%</p>
						</div>
					</div>
				</aside>
			</div>
		</header>

		<nav
			class="sticky top-0 z-10 overflow-x-auto rounded-2xl border border-slate-800 bg-slate-950/95 p-2 shadow-sm"
			aria-label="Secciones de habitación"
		>
			<div class="flex min-w-max gap-2">
				{
					tabs.map((tab, index) => {
						const Icon = tab.icon
						return (
							<button
								type="button"
								data-room-tab={tab.id}
								aria-selected={index === 0 ? "true" : "false"}
								class={`inline-flex h-11 items-center gap-2 rounded-xl px-4 text-sm font-medium transition ${
									index === 0
										? "bg-white text-slate-950"
										: "text-slate-300 hover:bg-slate-800 hover:text-white"
								}`}
							>
								<Icon class="h-4 w-4" />
								{tab.label}
							</button>
						)
					})
				}
			</div>
		</nav>

		<div class="space-y-8">
			<section data-room-panel="perfil" class="space-y-6">
				<div class="grid gap-6 lg:grid-cols-[1fr_360px]">
					<Section
						title="Perfil para huéspedes"
						description="La información esencial que ayuda a decidir si esta habitación es adecuada."
					>
						<div id="profileCards" class="grid gap-4 md:grid-cols-2">
							{
								Array.from({ length: 4 }).map(() => (
									<Card class="min-h-[140px] space-y-3 bg-slate-100">
										<div class="h-4 w-24 animate-pulse rounded bg-slate-200" />
										<div class="h-5 w-40 animate-pulse rounded bg-slate-200" />
										<div class="h-4 w-full animate-pulse rounded bg-slate-200" />
									</Card>
								))
							}
						</div>
					</Section>
					<Card class="h-fit space-y-4 bg-slate-100">
						<div class="flex items-center gap-3">
							<div
								class="flex h-11 w-11 items-center justify-center rounded-xl bg-slate-100 text-slate-800"
							>
								<BedDouble class="h-5 w-5" />
							</div>
							<div>
								<h2 class="font-semibold text-slate-900">Siguiente edición</h2>
								<p class="text-sm text-slate-600">Actualiza camas, baño, ocupación y notas.</p>
							</div>
						</div>
						<Button
							href={routes.productRoomProfile(productId, roomId)}
							data-astro-prefetch
							className="w-full"
						>
							Editar perfil completo
						</Button>
					</Card>
				</div>
			</section>

			<section data-room-panel="fotos" class="hidden space-y-6">
				<Section
					title="Photo tour de la habitación"
					description="La foto principal es obligatoria: aparecerá en Dónde dormirás y define la confianza visual del huésped."
				>
					<Card class="space-y-5 bg-slate-100">
						<div class="flex flex-wrap items-center justify-between gap-3">
							<p class="flex items-center gap-2 text-sm text-slate-600">
								<Camera class="h-4 w-4" />
								Muestra cama, baño, vista y distribución real. La primera imagen será la foto principal.
							</p>
							<div class="flex flex-wrap items-center gap-2">
								<input id="roomImageFiles" type="file" accept="image/*" multiple class="hidden" />
								<Button id="roomImageUploadBtn" type="button" variant="secondary">
									<ImagePlus class="mr-2 h-4 w-4" />
									Subir imágenes
								</Button>
								<Button id="roomImageSaveBtn" type="button"> Guardar galería </Button>
							</div>
						</div>
						<div
							id="roomPhotoReadiness"
							class="rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm leading-6 text-amber-900"
						>
							Agrega al menos 1 foto. La primera imagen aparecerá en Dónde dormirás.
						</div>
						<p id="roomImageFeedback" class="text-sm text-slate-600"></p>
						<div id="roomImageGrid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
							{
								Array.from({ length: 3 }).map(() => (
									<div class="min-h-[180px] animate-pulse rounded-xl border border-slate-200 bg-white" />
								))
							}
						</div>
					</Card>
				</Section>
			</section>

			<section data-room-panel="preview" class="hidden space-y-6">
				<Section
					title="Así lo verá el huésped"
					description="Misma tarjeta visible para huéspedes que se usa en el detalle público del alojamiento."
				>
					<GuestRoomPreviewCards
						previews={[]}
						containerId="workspaceGuestRoomPreviewCards"
						gridClass="grid gap-4"
						cardClass="border-slate-200 bg-white text-slate-800"
						statusLabel="Así lo verá el huésped"
						emptyText="Cargando preview de la habitación..."
					/>
				</Section>
			</section>

			<section data-room-panel="disponibilidad" class="hidden space-y-6">
				<Section
					title="Disponibilidad y cupos"
					description="Handoff operativo: cupos físicos y cobertura diaria para esta habitación."
				>
					<div class="grid gap-4 lg:grid-cols-[1fr_320px]">
						<div id="availabilitySummaryCards" class="grid gap-4 md:grid-cols-2"></div>
						<Card class="h-fit space-y-4 bg-slate-100">
							<h2 class="text-lg font-semibold text-slate-900">Operación diaria</h2>
							<p class="text-sm leading-6 text-slate-600">
								La edición de cupos vive en disponibilidad. Esta ficha solo resume si la habitación
								está preparada para publicarse.
							</p>
							<Button
								href={routes.productRoomInventory(productId, roomId)}
								data-astro-prefetch
								className="w-full"
							>
								Editar disponibilidad y cupos
							</Button>
							<Button
								href={routes.productRoomAvailability(productId, roomId)}
								data-astro-prefetch
								variant="secondary"
								className="w-full"
							>
								Ver consulta de venta
							</Button>
						</Card>
					</div>
				</Section>
			</section>

			<section data-room-panel="publicacion" class="hidden space-y-6">
				<Section
					title="Publicación"
					description="Separa lo que completa la ficha huésped de lo que deja la habitación lista para vender."
				>
					<div class="grid gap-6 lg:grid-cols-[1fr_360px]">
						<Card class="space-y-5 bg-slate-100">
							<div class="flex flex-wrap items-start justify-between gap-3">
								<div>
									<h2 class="flex items-center gap-2 text-xl font-semibold text-slate-900">
										<ClipboardCheck class="h-5 w-5" />
										Estado de publicación
									</h2>
									<p id="readinessStateText" class="mt-1 text-sm text-slate-600">
										Estado actual: Cargando...
									</p>
								</div>
								<Badge id="readinessStateBadge" variant="neutral">Cargando</Badge>
							</div>

							<div class="grid gap-4 xl:grid-cols-2">
								<div class="rounded-2xl border border-slate-200 bg-white p-4">
									<div class="flex items-start justify-between gap-3">
										<div>
											<p class="text-sm font-semibold text-slate-950">Ficha huésped completa</p>
											<p class="mt-1 text-xs leading-5 text-slate-500">
												Perfil, camas, baño, fotos y comodidades. Es lo que construye confianza en
												el listing.
											</p>
										</div>
										<Badge id="guestReadinessBadge" variant="neutral">Cargando</Badge>
									</div>
									<div id="guestReadinessList" class="mt-4 space-y-3">
										<p class="text-sm text-slate-500">Cargando ficha huésped...</p>
									</div>
								</div>
								<div class="rounded-2xl border border-slate-200 bg-white p-4">
									<div class="flex items-start justify-between gap-3">
										<div>
											<p class="text-sm font-semibold text-slate-950">Lista para vender</p>
											<p class="mt-1 text-xs leading-5 text-slate-500">
												Tarifas, disponibilidad y condiciones viven en sus dominios. Habitaciones
												solo muestra si el traspaso está claro.
											</p>
										</div>
										<Badge id="sellReadinessBadge" variant="neutral">Cargando</Badge>
									</div>
									<div id="sellReadinessList" class="mt-4 space-y-3">
										<p class="text-sm text-slate-500">Cargando readiness comercial...</p>
									</div>
								</div>
							</div>

							<div class="rounded-2xl border border-slate-200 bg-white p-4">
								<div class="grid gap-4 md:grid-cols-2">
									<div class="space-y-2">
										<p class="text-sm font-semibold text-slate-900">Bloqueos de publicación</p>
										<ul
											id="blockingErrorsList"
											class="list-disc space-y-1 pl-5 text-sm text-slate-700"
										>
											<li class="list-none text-slate-500">Cargando validaciones...</li>
										</ul>
									</div>
									<div class="space-y-2">
										<p class="text-sm font-semibold text-slate-900">Mejoras recomendadas</p>
										<ul
											id="nonBlockingErrorsList"
											class="list-disc space-y-1 pl-5 text-sm text-slate-700"
										>
											<li class="list-none text-slate-500">Cargando validaciones...</li>
										</ul>
									</div>
								</div>
							</div>

							<p id="readinessFeedback" class="text-sm text-slate-600"></p>

							<div class="flex justify-end">
								<Button id="reevaluateBtn" type="button">
									<RefreshCw class="mr-2 h-4 w-4" />
									Actualizar revisión
								</Button>
							</div>
						</Card>
						<Card class="h-fit space-y-4 bg-white">
							<div class="flex items-center gap-3">
								<div
									class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-800"
								>
									<CircleCheck class="h-5 w-5" />
								</div>
								<div>
									<h2 class="font-semibold text-slate-900">Publicación con confianza</h2>
									<p class="text-sm text-slate-600">
										Habitaciones se encarga de la experiencia de estancia. Tarifas, disponibilidad y
										condiciones conservan la responsabilidad comercial.
									</p>
								</div>
							</div>
						</Card>
					</div>
				</Section>
			</section>
		</div>
	</section>

	<script is:inline define:vars={{ productId, roomId }}>
		;(function () {
			const shellStart = performance.now()
			const logShellVisible = () => {
				console.debug("shell visible", {
					page: "room-workspace",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				logShellVisible()
			} else {
				document.addEventListener("DOMContentLoaded", logShellVisible, { once: true })
			}

			if (!productId || !roomId) return

			const feedback = document.getElementById("readinessFeedback")
			const reevaluateBtn = document.getElementById("reevaluateBtn")
			const evaluateHeaderBtn = document.getElementById("evaluateHeaderBtn")
			const roomImageFiles = document.getElementById("roomImageFiles")
			const roomImageUploadBtn = document.getElementById("roomImageUploadBtn")
			const roomImageSaveBtn = document.getElementById("roomImageSaveBtn")
			const roomImageFeedback = document.getElementById("roomImageFeedback")
			const roomImageGrid = document.getElementById("roomImageGrid")
			let roomImages = []

			const safeText = (value, fallback = "") => {
				const normalized = String(value ?? "").trim()
				return normalized || fallback
			}

			const setText = (id, value) => {
				const element = document.getElementById(id)
				if (element) element.textContent = String(value)
			}

			const tabButtons = Array.from(document.querySelectorAll("[data-room-tab]"))
			const panels = Array.from(document.querySelectorAll("[data-room-panel]"))
			const tabIds = new Set(
				tabButtons.map((button) => String(button.getAttribute("data-room-tab")))
			)
			const normalizeTabId = (value) => {
				const normalized = String(value ?? "")
					.trim()
					.replace(/^#/, "")
					.toLowerCase()
				return tabIds.has(normalized) ? normalized : "perfil"
			}
			const showTab = (id, options = {}) => {
				const targetId = normalizeTabId(id)
				for (const button of tabButtons) {
					const active = button.getAttribute("data-room-tab") === targetId
					button.setAttribute("aria-selected", active ? "true" : "false")
					button.className = `inline-flex h-11 items-center gap-2 rounded-xl px-4 text-sm font-medium transition ${
						active
							? "bg-white text-slate-950"
							: "text-slate-300 hover:bg-slate-800 hover:text-white"
					}`
				}
				for (const panel of panels) {
					panel.classList.toggle("hidden", panel.getAttribute("data-room-panel") !== targetId)
				}
				if (!options.skipHash && window.location.hash !== `#${targetId}`) {
					window.history.replaceState(null, "", `#${targetId}`)
				}
			}
			for (const button of tabButtons) {
				button.addEventListener("click", () =>
					showTab(String(button.getAttribute("data-room-tab")))
				)
			}
			showTab(window.location.hash || "perfil", { skipHash: true })
			window.addEventListener("hashchange", () => showTab(window.location.hash, { skipHash: true }))

			const statusClass = (tone) => {
				if (tone === "success") return "border-green-200 bg-green-100 text-green-800"
				if (tone === "info") return "border-sky-200 bg-sky-50 text-sky-800"
				return "border-orange-200 bg-orange-100 text-orange-800"
			}

			const metricCard = (label, value, icon, tone = "neutral") => {
				const article = document.createElement("article")
				const toneClass =
					tone === "ok"
						? "border-emerald-200 bg-emerald-50"
						: tone === "warn"
							? "border-amber-200 bg-amber-50"
							: "border-slate-200 bg-white"
				article.className = `fastt-soft-box p-5 ${toneClass}`
				const title = document.createElement("p")
				title.className = "text-xs font-semibold uppercase tracking-wide text-slate-500"
				title.textContent = label
				const body = document.createElement("p")
				body.className = "mt-2 text-base font-semibold text-slate-950"
				body.textContent = value
				const hint = document.createElement("p")
				hint.className = "mt-2 text-sm text-slate-600"
				hint.textContent = icon
				article.append(title, body, hint)
				return article
			}

			const renderProfileCards = (payload) => {
				const container = document.getElementById("profileCards")
				if (!container) return
				container.innerHTML = ""
				const preview = payload?.guestPreview ?? {}
				container.append(
					metricCard(
						"Ocupación",
						safeText(preview.occupancySummary, "Capacidad por confirmar"),
						String(payload?.summary?.capacity ?? "Define límites de ocupación."),
						payload?.blocks?.capacity?.complete ? "ok" : "warn"
					),
					metricCard(
						"Camas",
						safeText(preview.sleepSummary, "Camas por confirmar"),
						"Se mostrará en la sección Dónde dormirás.",
						payload?.blocks?.profile?.complete ? "ok" : "warn"
					),
					metricCard(
						"Baño",
						safeText(preview.bathroomSummary, "Baño por confirmar"),
						safeText(preview.sizeSummary || preview.viewSummary, "Completa detalles físicos."),
						payload?.blocks?.profile?.complete ? "ok" : "warn"
					),
					metricCard(
						"Comodidades",
						`${Array.isArray(preview.amenityLabels) ? preview.amenityLabels.length : 0} seleccionadas`,
						"Propias de esta habitación.",
						Array.isArray(preview.amenityLabels) && preview.amenityLabels.length > 0 ? "ok" : "warn"
					)
				)
			}

			const getErrorAction = (code) => {
				const value = String(code || "")
					.trim()
					.toLowerCase()
				if (value === "missing_capacity" || value === "missing_subtype") {
					return {
						href: `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(roomId)}/profile`,
						label: "Completar perfil",
					}
				}
				if (
					value === "pricing_missing" ||
					value === "no_default_rate_plan" ||
					value === "effective_pricing_missing" ||
					value === "pricing_invalid"
				) {
					return { href: "/rates/plans/manage", label: "Abrir tarifas" }
				}
				if (value === "inventory_missing") {
					return {
						href: `/rates/calendar?variantId=${encodeURIComponent(roomId)}&focus=availability`,
						label: "Editar disponibilidad",
					}
				}
				if (value === "missing_room_photo") {
					return {
						href: `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(roomId)}#fotos`,
						label: "Agregar fotos",
					}
				}
				return null
			}

			const renderReadinessSplit = (payload) => {
				const renderColumn = (column, listId, badgeId) => {
					const list = document.getElementById(listId)
					const badge = document.getElementById(badgeId)
					const complete = Boolean(column?.complete)
					const completedItems = Number(column?.completedItems ?? 0)
					const totalItems = Number(column?.totalItems ?? 0)
					if (badge) {
						badge.textContent = complete
							? "Completa"
							: `${completedItems}/${Math.max(totalItems, 0)} listo(s)`
						badge.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${complete ? statusClass("success") : statusClass("warning")}`
					}
					if (!list) return
					list.innerHTML = ""
					const items = Array.isArray(column?.items) ? column.items : []
					if (items.length === 0) {
						const empty = document.createElement("p")
						empty.className = "text-sm text-slate-500"
						empty.textContent = "Sin validaciones disponibles."
						list.appendChild(empty)
						return
					}
					for (const item of items) {
						const row = document.createElement("article")
						row.className = `rounded-xl border p-3 ${item?.complete ? "border-emerald-200 bg-emerald-50" : "border-amber-200 bg-amber-50"}`
						const header = document.createElement("div")
						header.className = "flex items-start justify-between gap-3"
						const text = document.createElement("div")
						const label = document.createElement("p")
						label.className = "text-sm font-semibold text-slate-950"
						label.textContent = safeText(item?.label, "Sección")
						const summary = document.createElement("p")
						summary.className = "mt-1 text-xs leading-5 text-slate-600"
						summary.textContent = safeText(item?.summary, "Pendiente")
						text.append(label, summary)
						const state = document.createElement("span")
						state.className = `shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium ${item?.complete ? "border-emerald-200 bg-white text-emerald-800" : "border-amber-200 bg-white text-amber-800"}`
						state.textContent = item?.externalOwner
							? "Otro dominio"
							: item?.complete
								? "Listo"
								: "Pendiente"
						header.append(text, state)
						row.appendChild(header)
						const href = safeText(item?.actionHref)
						const actionLabel = safeText(item?.actionLabel)
						if (href && actionLabel && (!item?.complete || item?.externalOwner)) {
							const link = document.createElement("a")
							link.href = href
							link.textContent = actionLabel
							link.className =
								"mt-3 inline-flex text-xs font-semibold text-slate-950 underline hover:text-slate-700"
							link.setAttribute("data-astro-prefetch", "")
							row.appendChild(link)
						}
						list.appendChild(row)
					}
				}
				renderColumn(payload?.readinessSplit?.guest, "guestReadinessList", "guestReadinessBadge")
				renderColumn(payload?.readinessSplit?.sell, "sellReadinessList", "sellReadinessBadge")
			}

			const renderErrors = (container, items, emptyText) => {
				if (!container) return
				container.innerHTML = ""
				if (!Array.isArray(items) || items.length === 0) {
					const li = document.createElement("li")
					li.className = "list-none text-slate-500"
					li.textContent = emptyText
					container.appendChild(li)
					return
				}
				for (const item of items) {
					const li = document.createElement("li")
					const code = String(item?.code || "")
					const message = safeText(item?.message, code || "Pendiente")
					const action = getErrorAction(code)
					li.className = "space-x-2"
					const text = document.createElement("span")
					text.textContent = message
					li.appendChild(text)
					if (action) {
						const link = document.createElement("a")
						link.href = action.href
						link.textContent = action.label
						link.className = "text-slate-950 underline hover:text-slate-700"
						link.setAttribute("data-astro-prefetch", "")
						li.appendChild(link)
					}
					container.appendChild(li)
				}
			}

			const renderRoomImages = () => {
				if (!roomImageGrid) return
				roomImageGrid.innerHTML = ""
				if (!Array.isArray(roomImages) || roomImages.length === 0) {
					const empty = document.createElement("div")
					empty.className = "fastt-empty-state col-span-full p-6 text-sm text-slate-600"
					empty.textContent =
						"Aún no hay fotos. Agrega al menos una imagen clara de la cama y el baño. Esta imagen aparecerá en Dónde dormirás."
					roomImageGrid.appendChild(empty)
					return
				}
				roomImages.forEach((image, index) => {
					const card = document.createElement("article")
					card.className = "space-y-3 rounded-xl border border-slate-200 bg-white p-3"
					const preview = document.createElement("img")
					preview.src = String(image.url)
					preview.alt = `Foto de habitación ${index + 1}`
					preview.className = "h-36 w-full rounded-lg object-cover"
					const meta = document.createElement("div")
					meta.className = "flex flex-wrap items-center gap-2"
					const order = document.createElement("span")
					order.className =
						"inline-flex rounded-full border border-slate-200 bg-slate-100 px-2 py-0.5 text-xs text-slate-700"
					order.textContent = index === 0 ? "Principal" : `Foto ${index + 1}`
					meta.appendChild(order)
					if (index === 0) {
						const guestPlacement = document.createElement("span")
						guestPlacement.className =
							"inline-flex rounded-full border border-sky-200 bg-sky-50 px-2 py-0.5 text-xs font-medium text-sky-800"
						guestPlacement.textContent = "Esta imagen aparecerá en Dónde dormirás"
						meta.appendChild(guestPlacement)
					}
					const actions = document.createElement("div")
					actions.className = "grid grid-cols-3 gap-2"
					const makeButton = (label, disabled, onClick, tone = "neutral") => {
						const button = document.createElement("button")
						button.type = "button"
						button.disabled = disabled
						button.className =
							tone === "danger"
								? "fastt-button inline-flex h-8 items-center justify-center rounded border border-red-200 bg-red-50 px-2 text-xs text-red-700 disabled:opacity-40"
								: "fastt-button inline-flex h-8 items-center justify-center rounded border border-slate-300 bg-white px-2 text-xs text-slate-700 disabled:opacity-40"
						button.textContent = label
						button.addEventListener("click", onClick)
						return button
					}
					actions.append(
						makeButton("Arriba", index === 0, () => {
							const next = roomImages.slice()
							const temp = next[index - 1]
							next[index - 1] = next[index]
							next[index] = temp
							roomImages = next
							renderRoomImages()
						}),
						makeButton("Abajo", index === roomImages.length - 1, () => {
							const next = roomImages.slice()
							const temp = next[index + 1]
							next[index + 1] = next[index]
							next[index] = temp
							roomImages = next
							renderRoomImages()
						}),
						makeButton(
							"Eliminar",
							false,
							() => {
								roomImages = roomImages.filter((_, idx) => idx !== index)
								renderRoomImages()
							},
							"danger"
						)
					)
					card.append(preview, meta, actions)
					roomImageGrid.appendChild(card)
				})
			}

			const renderPhotoReadiness = (payload) => {
				const container = document.getElementById("roomPhotoReadiness")
				if (!container) return
				const photos = payload?.blocks?.photos
				const count = Number(photos?.count ?? 0)
				const complete = Boolean(photos?.complete)
				container.className = complete
					? "fastt-notice rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm leading-6 text-emerald-900"
					: "fastt-notice rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm leading-6 text-amber-900"
				container.textContent = complete
					? `${count} foto(s) listas. La primera imagen aparecerá en Dónde dormirás.`
					: "Agrega al menos 1 foto. La primera imagen aparecerá en Dónde dormirás y es obligatoria para publicar."
			}

			const toGuestRoomPreviewCard = (payload) => {
				const preview = payload?.guestPreview ?? {}
				const gallery = Array.isArray(preview.gallery) ? preview.gallery : []
				const imageUrl = safeText(preview.coverUrl, gallery[0]?.url ?? "")
				return {
					variantId: safeText(payload?.variant?.id, roomId),
					roomName: safeText(preview.roomName, payload?.variant?.name ?? "Habitación"),
					roomTypeName: safeText(preview.roomTypeLabel, "Habitación"),
					imageUrl: imageUrl || "https://placehold.co/1200x800?text=Habitacion",
					gallery,
					sleepSummary: safeText(preview.sleepSummary, "Camas por confirmar"),
					sleepAreas: Array.isArray(preview.sleepAreas) ? preview.sleepAreas : [],
					bathroomSummary: safeText(preview.bathroomSummary, "Baño por confirmar"),
					occupancySummary: safeText(preview.occupancySummary, "Capacidad por confirmar"),
					sizeSummary: safeText(preview.sizeSummary, ""),
					viewSummary: safeText(preview.viewSummary, ""),
					amenityLabels: Array.isArray(preview.amenityLabels) ? preview.amenityLabels : [],
					amenityGroups: Array.isArray(preview.amenityGroups) ? preview.amenityGroups : [],
					guestFacingNotes: safeText(preview.guestFacingNotes, ""),
					hasBalcony: Boolean(preview.hasBalcony),
				}
			}

			const renderGuestPreview = (payload) => {
				const renderer = window.renderGuestRoomPreviewCards
				if (typeof renderer === "function") {
					renderer("workspaceGuestRoomPreviewCards", [toGuestRoomPreviewCard(payload)], {
						cardClass: "border-slate-200 bg-white text-slate-800",
						statusLabel: "Así lo verá el huésped",
						emptyText: "Completa perfil y fotos para ver la tarjeta pública de la habitación.",
					})
				}
			}

			const renderAvailability = (payload) => {
				const container = document.getElementById("availabilitySummaryCards")
				if (!container) return
				container.innerHTML = ""
				container.append(
					metricCard(
						"Cobertura diaria",
						String(payload?.summary?.inventory ?? "Sin disponibilidad"),
						"Se gestiona desde disponibilidad y cupos.",
						payload?.blocks?.inventory?.complete ? "ok" : "warn"
					),
					metricCard(
						"Tarifas",
						String(payload?.summary?.pricing ?? "Sin tarifas"),
						"Las tarifas viven en Habitaciones y tarifas.",
						payload?.blocks?.pricing?.complete ? "ok" : "warn"
					)
				)
			}

			const hydrate = (payload) => {
				setText("roomTitle", safeText(payload?.variant?.name, "Habitación"))
				const statusBadge = document.getElementById("roomStatusBadge")
				if (statusBadge) {
					statusBadge.textContent = safeText(payload?.variant?.statusLabel, "Borrador")
					statusBadge.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${statusClass(payload?.variant?.statusVariant)}`
				}

				const percent = Number(payload?.progress?.progressPercent ?? 0)
				const progressBar = document.getElementById("roomProgressBar")
				if (progressBar) progressBar.style.width = `${Math.max(0, Math.min(100, percent))}%`
				setText(
					"roomProgressCompleted",
					`${Number(payload?.progress?.completedBlocks ?? 0)}/${Number(payload?.progress?.totalBlocks ?? 3)}`
				)
				setText("roomProgressPending", Number(payload?.progress?.pendingBlocks ?? 0))
				setText("roomProgressPercent", `${percent}%`)

				roomImages = Array.isArray(payload?.variant?.images) ? payload.variant.images.slice() : []
				renderProfileCards(payload)
				renderRoomImages()
				renderPhotoReadiness(payload)
				renderGuestPreview(payload)
				renderAvailability(payload)
				renderReadinessSplit(payload)

				setText(
					"readinessStateText",
					`Estado actual: ${safeText(payload?.readiness?.stateLabel, "Borrador")}`
				)
				const readinessBadge = document.getElementById("readinessStateBadge")
				if (readinessBadge) {
					readinessBadge.textContent = safeText(payload?.readiness?.stateLabel, "Borrador")
					readinessBadge.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${statusClass(payload?.readiness?.stateVariant)}`
				}
				renderErrors(
					document.getElementById("blockingErrorsList"),
					payload?.readiness?.blockingErrors ?? [],
					"Sin bloqueantes."
				)
				renderErrors(
					document.getElementById("nonBlockingErrorsList"),
					payload?.readiness?.nonBlockingErrors ?? [],
					"Sin pendientes adicionales."
				)
			}

			roomImageUploadBtn?.addEventListener("click", () => {
				if (roomImageFiles instanceof HTMLInputElement) roomImageFiles.click()
			})

			roomImageFiles?.addEventListener("change", async (event) => {
				const input = event.currentTarget
				if (!(input instanceof HTMLInputElement)) return
				const files = Array.from(input.files ?? [])
				if (files.length === 0) return
				if (roomImageFeedback) roomImageFeedback.textContent = "Subiendo imágenes..."
				try {
					const signData = new FormData()
					files.forEach((file) => signData.append("file", file))
					signData.set("prefix", "rooms")
					const signResponse = await fetch("/api/upload/create-signed", {
						method: "POST",
						body: signData,
					})
					const signPayload = await signResponse.json().catch(() => ({}))
					if (!signResponse.ok || !Array.isArray(signPayload?.urls)) {
						if (roomImageFeedback)
							roomImageFeedback.textContent = "No se pudieron preparar las cargas."
						return
					}
					for (const [index, file] of files.entries()) {
						const target = signPayload.urls[index]
						if (!target?.signedUrl || !target?.publicUrl || !target?.key) continue
						const uploadResponse = await fetch(String(target.signedUrl), {
							method: "PUT",
							headers: { "Content-Type": file.type || "application/octet-stream" },
							body: file,
						})
						if (!uploadResponse.ok) throw new Error(`upload_failed_${uploadResponse.status}`)
						roomImages.push({
							id: `local-${crypto.randomUUID()}`,
							url: String(target.publicUrl),
							objectKey: String(target.key),
							order: roomImages.length,
							isPrimary: roomImages.length === 0,
						})
					}
					renderRoomImages()
					if (roomImageFeedback) {
						roomImageFeedback.textContent = "Imágenes cargadas. Guarda la galería para persistir."
					}
				} catch (error) {
					if (roomImageFeedback)
						roomImageFeedback.textContent = `Error al subir imágenes: ${String(error)}`
				} finally {
					input.value = ""
				}
			})

			roomImageSaveBtn?.addEventListener("click", async () => {
				if (roomImageSaveBtn instanceof HTMLButtonElement) roomImageSaveBtn.disabled = true
				if (roomImageFeedback) roomImageFeedback.textContent = "Guardando galería..."
				try {
					const formData = new FormData()
					formData.set("variantId", roomId)
					for (const image of roomImages) {
						formData.append("imageUrl", String(image.url))
						const objectKey =
							image?.objectKey ??
							(() => {
								try {
									return new URL(String(image.url)).pathname.replace(/^\/+/, "")
								} catch {
									return ""
								}
							})()
						formData.append("imageObjectKey", String(objectKey ?? ""))
					}
					const response = await fetch("/api/variant/images", { method: "POST", body: formData })
					const payload = await response.json().catch(() => ({}))
					if (!response.ok) {
						if (roomImageFeedback) {
							roomImageFeedback.textContent = `No se pudo guardar: ${String(payload?.error ?? response.status)}`
						}
						return
					}
					roomImages = Array.isArray(payload?.images) ? payload.images.slice() : roomImages
					renderRoomImages()
					await loadRoom()
					if (roomImageFeedback) roomImageFeedback.textContent = "Galería guardada correctamente."
				} catch (error) {
					if (roomImageFeedback) roomImageFeedback.textContent = `Error de red: ${String(error)}`
				} finally {
					if (roomImageSaveBtn instanceof HTMLButtonElement) roomImageSaveBtn.disabled = false
				}
			})

			const loadRoom = async () => {
				const hydrationStart = performance.now()
				try {
					const response = await fetch(
						`/api/internal/room-summary?productId=${encodeURIComponent(productId)}&variantId=${encodeURIComponent(roomId)}`,
						{ headers: { accept: "application/json" } }
					)
					if (!response.ok) throw new Error(`room_summary_${response.status}`)
					const payload = await response.json()
					hydrate(payload)
					console.debug("data hydrated", {
						page: "room-workspace",
						durationMs: Number((performance.now() - hydrationStart).toFixed(1)),
					})
					return payload
				} catch (error) {
					if (feedback)
						feedback.textContent = `No se pudo cargar la ficha de habitación: ${String(error)}`
					return null
				}
			}

			const setBusy = (isBusy) => {
				if (reevaluateBtn) reevaluateBtn.disabled = isBusy
				if (evaluateHeaderBtn) evaluateHeaderBtn.disabled = isBusy
			}

			const evaluateReadiness = async () => {
				setBusy(true)
				if (feedback) feedback.textContent = "Evaluando publicación..."
				try {
					const form = new FormData()
					form.set("variantId", String(roomId || ""))
					const res = await fetch("/api/variant/evaluate", { method: "POST", body: form })
					if (res.status === 401) {
						window.location.href = "/SignInPage"
						return
					}
					if (!res.ok) {
						const txt = await res.text()
						if (feedback) feedback.textContent = txt || "No se pudo evaluar en este momento."
						return
					}
					await loadRoom()
					if (feedback) feedback.textContent = "Revisión actualizada correctamente."
				} catch (error) {
					if (feedback) feedback.textContent = `Error de red: ${String(error)}`
				} finally {
					setBusy(false)
				}
			}

			evaluateHeaderBtn?.addEventListener("click", evaluateReadiness)
			reevaluateBtn?.addEventListener("click", evaluateReadiness)
			void loadRoom()
		})()
	</script>
</WorkspaceLayout>
