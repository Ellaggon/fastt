---
const productId = String(Astro.params.id ?? "").trim()
const variantId = String(Astro.params.roomId ?? "").trim()

const target = new URL("/rates/calendar", Astro.url)
target.search = Astro.url.search
if (variantId) target.searchParams.set("variantId", variantId)
target.searchParams.set("focus", "availability")
if (productId) target.searchParams.set("sourceProductId", productId)

return Astro.redirect(target.toString(), 308)
---
