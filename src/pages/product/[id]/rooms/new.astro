---
import RoomProfileEditor from "@/components/rooms/RoomProfileEditor.astro"
import { productRepository } from "@/container"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { buildAddRoomHref } from "@/lib/playbook/add-room"
import { buildPlaybookHref } from "@/lib/playbook/launch-accommodation"
import { resolvePlaybookFromUrl } from "@/lib/playbook/resolve-playbook"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { getProductAggregate } from "@/modules/catalog/public"
import { Hotel } from "@lucide/astro"
import { AmenityRoom, asc, db, RoomType } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product/create")

const playbook = resolvePlaybookFromUrl(Astro.url, { isHotel: true })
const flow = Astro.url.searchParams.get("flow")

if (!playbook.active && flow === "create") {
	return Astro.redirect(buildPlaybookHref(routes.productRoomNew(productId), "room-profile"))
}
if (!playbook.active && flow === "add-room") {
	return Astro.redirect(buildAddRoomHref(routes.productRoomNew(productId), "create-room"))
}

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")
if (!isHotelProductType(owned.productType)) return Astro.redirect(routes.productDetail(productId))

const product = await getProductAggregate(productId)
if (!product) return Astro.redirect("/product/create")

const [roomTypes, amenities] = await Promise.all([
	db
		.select({ id: RoomType.id, name: RoomType.name, maxOccupancy: RoomType.maxOccupancy })
		.from(RoomType)
		.orderBy(asc(RoomType.name))
		.all(),
	db
		.select({ id: AmenityRoom.id, name: AmenityRoom.name, category: AmenityRoom.category })
		.from(AmenityRoom)
		.orderBy(asc(AmenityRoom.category), asc(AmenityRoom.name))
		.all(),
])

const playbookId = playbook.playbookId
const isAddRoom = playbookId === "add-room"
const stepId = isAddRoom ? (playbook.stepId ?? "create-room") : (playbook.stepId ?? "room-profile")
const roomEditorPlaybookId =
	playbookId === "launch" || playbookId === "add-room" ? playbookId : null
---

<PlaybookLayout
	title="Contenido del alojamiento · Nueva habitación"
	playbookId={playbookId}
	active={playbook.active}
	stepId={stepId}
	productId={productId}
	isHotel={true}
>
	<section class="space-y-5 text-slate-100">
		<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
			<div class="space-y-1.5">
				<p
					class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400"
				>
					<Hotel class="h-4 w-4" />
					{product.displayName} · Nueva habitación
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Crea una habitación para huéspedes</h1>
				<p class="max-w-2xl text-sm leading-6 text-slate-300">
					{
						isAddRoom
							? "Define el espacio físico de la nueva habitación. Después completarás fotos, tarifa y disponibilidad."
							: "Empieza con la experiencia física: camas, baño, capacidad, vista, comodidades y notas. Las tarifas y la disponibilidad se completan después."
					}
				</p>
			</div>
		</header>

		<RoomProfileEditor
			productId={productId}
			mode="create"
			roomTypes={roomTypes}
			amenities={amenities}
			playbookId={playbook.active ? roomEditorPlaybookId : null}
			showIntro={false}
		/>
	</section>
</PlaybookLayout>
