---
import RoomProfileEditor from "@/components/rooms/RoomProfileEditor.astro"
import Section from "@/components/ui/Section.astro"
import { productRepository } from "@/container"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { getProductAggregate } from "@/modules/catalog/public"
import { AmenityRoom, asc, db, RoomType } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product/create")

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")
if (!isHotelProductType(owned.productType)) return Astro.redirect(routes.productDetail(productId))

const product = await getProductAggregate(productId)
if (!product) return Astro.redirect("/product/create")

const [roomTypes, amenities] = await Promise.all([
	db
		.select({ id: RoomType.id, name: RoomType.name, maxOccupancy: RoomType.maxOccupancy })
		.from(RoomType)
		.orderBy(asc(RoomType.name))
		.all(),
	db
		.select({ id: AmenityRoom.id, name: AmenityRoom.name, category: AmenityRoom.category })
		.from(AmenityRoom)
		.orderBy(asc(AmenityRoom.category), asc(AmenityRoom.name))
		.all(),
])
---

<WorkspaceLayout title="Contenido del alojamiento · Nueva habitación">
	<section class="space-y-8 text-neutral-100">
		<header class="space-y-3">
			<h1 class="text-3xl font-semibold text-slate-100">Nueva habitación</h1>
			<p class="text-sm text-slate-400">
				Crea una ficha completa para huéspedes. Pricing, promociones, inventario diario y
				restricciones se configuran después en sus superficies operativas.
			</p>
			<p class="text-sm text-slate-300">Alojamiento: {product.displayName}</p>
		</header>

		<Section
			title="Ficha OTA de habitación"
			description="Un solo formulario para identidad, capacidad, tipo, camas, baños y comodidades de habitación."
		>
			<RoomProfileEditor
				productId={productId}
				mode="create"
				roomTypes={roomTypes}
				amenities={amenities}
			/>
		</Section>
	</section>
</WorkspaceLayout>
