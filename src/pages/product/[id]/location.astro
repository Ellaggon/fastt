---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import { buildCompleteToPublishHref } from "@/lib/playbook/complete-to-publish"
import { buildPlaybookHref } from "@/lib/playbook/launch-accommodation"
import { resolvePlaybookFromUrl } from "@/lib/playbook/resolve-playbook"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getProductVerticalEntry } from "@/lib/catalog/productVerticalRegistry"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProductFullAggregate } from "@/modules/catalog/public"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product/create")
const flow = Astro.url.searchParams.get("flow")
if (!resolvePlaybookFromUrl(Astro.url).active && flow === "create") {
	return Astro.redirect(buildPlaybookHref(`/product/${productId}/location`, "location"))
}
if (!resolvePlaybookFromUrl(Astro.url).active && flow === "complete") {
	return Astro.redirect(buildCompleteToPublishHref(`/product/${productId}/location`, "location"))
}

const product = await getProductFullAggregate(productId, providerId)
if (!product) return Astro.redirect("/product/create")

const vertical = getProductVerticalEntry(product.productType)
const isHotel = vertical.vertical === "hotel"
const playbook = resolvePlaybookFromUrl(Astro.url, { isHotel })
const existingLocation = product.location

const initialLat = typeof existingLocation?.lat === "number" ? existingLocation.lat : -16.495905
const initialLng = typeof existingLocation?.lng === "number" ? existingLocation.lng : -68.133623
---

<PlaybookLayout
	title="Alojamientos · Ubicación"
	playbookId={playbook.playbookId}
	active={playbook.active}
	stepId={playbook.stepId ?? "location"}
	productId={productId}
	isHotel={isHotel}
>
	<section class="space-y-8">
		<section class="space-y-4">
			<header class="space-y-1">
				<h1 class="text-3xl font-semibold text-slate-100">Ubicación</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Define ubicación, coordenadas y contexto geográfico de {vertical.labels.singular}.
				</p>
			</header>

			<Card class="rounded-lg border-slate-200 bg-slate-100 shadow-none">
				<form
					id="locationForm"
					method="POST"
					action="/api/product/location"
					class="max-w-3xl space-y-6"
				>
					<Input type="hidden" name="productId" value={productId} />
					<Input
						type="hidden"
						name="flow"
						value={flow === "create" ? "create" : flow === "complete" ? "complete" : "edit"}
					/>
					{
						playbook.active && playbook.playbookId ? (
							<Input type="hidden" name="playbook" value={playbook.playbookId} />
						) : null
					}
					<Input id="lat" type="hidden" name="lat" value={String(initialLat)} />
					<Input id="lng" type="hidden" name="lng" value={String(initialLng)} />

					<div class="space-y-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Metadata geográfica</h2>
							<p class="text-sm text-slate-600">Selecciona el punto en el mapa y guarda.</p>
						</div>

						<FormField label="Dirección (opcional)" htmlFor="address">
							<Input
								id="address"
								name="address"
								value={existingLocation?.address ?? ""}
								placeholder="Av. Ejemplo 123"
							/>
						</FormField>

						<FormField
							label="Ubicación de la oferta"
							htmlFor="map"
							required
							description="Haz clic en el mapa para seleccionar la ubicación"
						>
							<div id="map" class="h-72 w-full overflow-hidden rounded-lg border border-slate-300">
							</div>
							<p id="coordsText" class="mt-2 text-sm text-slate-600"></p>
						</FormField>
					</div>

					<div class="space-y-1">
						<p id="stateLabel" class="text-sm text-slate-600">Vacío: sin cambios guardados.</p>
						<p id="stateDetail" class="whitespace-pre-wrap text-sm text-slate-600"></p>
					</div>

					<div class="flex items-center justify-end gap-3">
						<Button
							href={playbook.active && playbook.playbookId === "launch"
								? buildPlaybookHref(`/product/${productId}/content`, "content")
								: playbook.active && playbook.playbookId === "complete-to-publish"
									? buildCompleteToPublishHref(`/product/${productId}/preview`, "preview")
									: `/product/${encodeURIComponent(productId)}/content`}
							variant="secondary"
						>
							Volver
						</Button>
						<Button id="submitBtn" type="submit">
							{playbook.active ? "Guardar y continuar" : "Guardar ubicación"}
						</Button>
					</div>
				</form>
			</Card>
		</section>
	</section>

	<script
		src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
		integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
		crossorigin=""></script>
	<script type="module" define:vars={{ initialLat, initialLng }}>
		import { resolvePlaybookRedirectAfterSave } from "@/lib/playbook/playbook-nav.ts"

		const form = document.getElementById("locationForm")
		const btn = document.getElementById("submitBtn")
		const stateLabel = document.getElementById("stateLabel")
		const stateDetail = document.getElementById("stateDetail")
		const latInput = document.getElementById("lat")
		const lngInput = document.getElementById("lng")
		const coordsText = document.getElementById("coordsText")

		function setState(state, detail = "") {
			const labels = {
				empty: "Vacío: sin cambios guardados.",
				loading: "Cargando: guardando ubicación...",
				success: "Éxito: ubicación guardada correctamente.",
				error: "Error: no se pudo guardar la ubicación.",
				disabled: "Deshabilitado: esperando respuesta del servidor.",
			}
			stateLabel.textContent = labels[state] || labels.empty
			stateDetail.textContent = detail
		}

		function updateCoords(lat, lng) {
			latInput.value = String(lat)
			lngInput.value = String(lng)
			coordsText.textContent = `Coordenadas seleccionadas: ${Number(lat).toFixed(6)}, ${Number(lng).toFixed(6)}`
		}

		const map = window.L.map("map").setView([Number(initialLat), Number(initialLng)], 12)
		window.L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
			maxZoom: 19,
			attribution: "&copy; OpenStreetMap",
		}).addTo(map)

		const marker = window.L.marker([Number(initialLat), Number(initialLng)], {
			draggable: true,
		}).addTo(map)
		updateCoords(initialLat, initialLng)

		map.on("click", (event) => {
			const { lat, lng } = event.latlng
			marker.setLatLng([lat, lng])
			updateCoords(lat, lng)
		})

		marker.on("dragend", () => {
			const { lat, lng } = marker.getLatLng()
			updateCoords(lat, lng)
		})

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			setState("loading")
			btn.disabled = true
			setState("disabled")

			try {
				const fd = new FormData(form)
				const res = await fetch("/api/product/location", { method: "POST", body: fd })
				const txt = await res.text()

				if (!res.ok) {
					btn.disabled = false
					setState("error", `status=${res.status}\n${txt}`)
					return
				}

				setState("success", "Guardado correctamente")
				const targetProductId = String(fd.get("productId") || "")
				window.location.href = resolvePlaybookRedirectAfterSave(fd, {
					productId: targetProductId,
					launchPath: `/product/${encodeURIComponent(targetProductId)}/images`,
					launchStep: "images",
				})
			} catch (err) {
				btn.disabled = false
				setState("error", `Error de red: ${String(err)}`)
			}
		})
	</script>
</PlaybookLayout>
