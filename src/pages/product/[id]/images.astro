---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProductVerticalEntry } from "@/lib/catalog/productVerticalRegistry"
import { buildCompleteToPublishHref } from "@/lib/playbook/complete-to-publish"
import { buildPlaybookHref } from "@/lib/playbook/launch-accommodation"
import { resolvePlaybookFromUrl } from "@/lib/playbook/resolve-playbook"
import { routes } from "@/lib/routes"
import { getProductFullAggregate } from "@/modules/catalog/public"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect(routes.providerSettingsProfile())

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product/create")
const flow = Astro.url.searchParams.get("flow")
if (!resolvePlaybookFromUrl(Astro.url).active && flow === "create") {
	return Astro.redirect(buildPlaybookHref(`/product/${productId}/images`, "images"))
}
if (!resolvePlaybookFromUrl(Astro.url).active && flow === "complete") {
	return Astro.redirect(buildCompleteToPublishHref(`/product/${productId}/images`, "photos"))
}

const product = await getProductFullAggregate(productId, providerId)
if (!product) return Astro.redirect("/product/create")

const vertical = getProductVerticalEntry(product.productType)
const isHotel = vertical.vertical === "hotel"
const playbook = resolvePlaybookFromUrl(Astro.url, { isHotel })
const existingImages = product.images || []
---

<PlaybookLayout
	title="Alojamientos · Fotos"
	playbookId={playbook.playbookId}
	active={playbook.active}
	stepId={playbook.stepId ?? "images"}
	productId={productId}
	isHotel={isHotel}
>
	<section class="space-y-8">
		<section class="space-y-4">
			<header class="space-y-1">
				<h1 class="text-3xl font-semibold text-slate-100">Fotos</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-400">
					Gestiona la galería visible de {vertical.labels.singular} y su cobertura visual mínima.
				</p>
			</header>

			<Card class="rounded-lg border-slate-200 bg-slate-100 shadow-none">
				<form
					id="imagesForm"
					method="POST"
					action="/api/product/images"
					class="max-w-3xl space-y-6"
				>
					<Input type="hidden" name="productId" value={productId} />
					<Input
						type="hidden"
						name="flow"
						value={flow === "create" ? "create" : flow === "complete" ? "complete" : "edit"}
					/>
					{
						playbook.active && playbook.playbookId ? (
							<Input type="hidden" name="playbook" value={playbook.playbookId} />
						) : null
					}
					<div class="space-y-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">
								{vertical.vertical === "hotel" ? "Galería del alojamiento" : "Galería de la oferta"}
							</h2>
							<p class="text-sm text-slate-600">
								Arrastra imágenes aquí o haz clic para seleccionarlas.
							</p>
						</div>

						<FormField label="Carga de imágenes" htmlFor="files" required>
							<Input
								id="files"
								type="file"
								name="files"
								accept="image/*"
								multiple
								required
								className="hidden"
							/>
							<div
								id="dropzone"
								class="fastt-empty-state cursor-pointer rounded-xl border-2 border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-600 transition"
							>
								<p class="font-medium text-slate-700">Suelta imágenes aquí</p>
								<p class="mt-1 text-slate-500">o haz clic para abrir el selector</p>
							</div>
						</FormField>

						<div class="space-y-2">
							<p class="text-sm font-medium text-slate-700">Vista previa</p>
							<div id="previewGrid" class="grid grid-cols-2 gap-4 sm:grid-cols-3"></div>
						</div>
					</div>

					<div class="space-y-1">
						<p id="stateLabel" class="text-sm text-slate-600">
							Vacío: selecciona imágenes para continuar.
						</p>
						<p id="stateDetail" class="whitespace-pre-wrap text-sm text-slate-600"></p>
					</div>

					<div class="flex items-center justify-end gap-3">
						<Button
							href={playbook.active && playbook.playbookId === "launch"
								? buildPlaybookHref(`/product/${productId}/location`, "location")
								: playbook.active && playbook.playbookId === "complete-to-publish"
									? buildCompleteToPublishHref(`/product/${productId}/preview`, "preview")
									: `/product/${encodeURIComponent(productId)}/location`}
							variant="secondary"
						>
							Volver
						</Button>
						<Button
							id="submitBtn"
							type="submit"
							className={playbook.active ? "fastt-playbook-cta" : ""}
						>
							{playbook.active ? "Guardar y continuar" : "Subir y asociar"}
						</Button>
					</div>
				</form>
			</Card>
		</section>
	</section>

	<script
		id="existingImagesData"
		type="application/json"
		set:html={JSON.stringify(existingImages)}
	/>
	<script src="/src/lib/forms/productImagesHandler.ts"></script>
</PlaybookLayout>
