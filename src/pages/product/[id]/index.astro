---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import { productRepository } from "@/container"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { routes } from "@/lib/routes"
import { db, eq, ProductStatus } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product/create")

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")

const statusRow = await db
	.select({ state: ProductStatus.state })
	.from(ProductStatus)
	.where(eq(ProductStatus.productId, productId))
	.get()

const status = String(statusRow?.state || "draft")
	.trim()
	.toLowerCase()
const statusBadgeVariant =
	status === "published" ? "success" : status === "ready" ? "info" : "warning"
const statusLabel = status === "published" ? "Publicado" : status === "ready" ? "Listo" : "Borrador"
---

<WorkspaceLayout title="Ficha del alojamiento">
	<section class="space-y-6">
		<header class="overflow-hidden rounded-xl border border-slate-800 bg-slate-950 shadow-sm">
			<div class="grid gap-0 lg:grid-cols-[280px_1fr]">
				<div
					id="productHeroMedia"
					class="flex min-h-[220px] items-center justify-center bg-slate-900 text-sm font-semibold text-slate-500 lg:min-h-full"
				>
					Fotos del alojamiento
				</div>
				<div class="space-y-5 p-5 sm:p-6">
					<div class="flex flex-wrap items-center gap-2">
						<Badge variant={statusBadgeVariant}>{statusLabel}</Badge>
						<span
							id="productReadyChip"
							class="rounded-full border border-slate-700 bg-slate-900 px-3 py-1 text-xs font-semibold text-slate-200"
						>
							Cargando estado...
						</span>
					</div>
					<div class="space-y-2">
						<h1 class="text-2xl font-semibold tracking-tight text-slate-50 sm:text-3xl">
							{owned.name}
						</h1>
						<p id="productHeaderMeta" class="text-sm text-slate-300">
							Cargando ubicación y tipo de alojamiento...
						</p>
						<p id="productHeaderSummary" class="max-w-3xl text-sm leading-6 text-slate-400">
							Prepara fotos, descripción, ubicación, habitaciones y reglas antes de publicar.
						</p>
					</div>
					<div class="flex flex-wrap gap-2">
						<Button href={routes.productPreview(productId)} data-astro-prefetch>Vista previa</Button
						>
						<Button
							href={`/product/${encodeURIComponent(productId)}/subtype`}
							data-astro-prefetch
							variant="secondary"
						>
							Editar detalles
						</Button>
					</div>
				</div>
			</div>
		</header>

		<Section
			title="Ficha del alojamiento"
			description="Edita los bloques que verá el huésped antes de reservar."
			className="space-y-4"
		>
			<div class="grid gap-4 lg:grid-cols-2">
				<Card class="bg-white">
					<div class="space-y-4">
						<div class="flex items-start justify-between gap-4">
							<div class="space-y-1">
								<p class="text-sm font-semibold text-slate-950">Fotos</p>
								<p id="summaryImagesCount" class="text-sm text-slate-600">Cargando fotos...</p>
							</div>
							<Badge id="blockBadge-images" variant="warning" class="whitespace-nowrap">
								Cargando...
							</Badge>
						</div>
						<div id="summaryImageGrid" class="grid min-h-[74px] grid-cols-3 gap-2">
							<div class="h-16 w-full animate-pulse rounded-md bg-slate-200"></div>
							<div class="h-16 w-full animate-pulse rounded-md bg-slate-200"></div>
							<div class="h-16 w-full animate-pulse rounded-md bg-slate-200"></div>
						</div>
						<div class="flex justify-end">
							<Button
								href={`/product/${encodeURIComponent(productId)}/images`}
								data-astro-prefetch
								variant="secondary"
							>
								Gestionar fotos
							</Button>
						</div>
					</div>
				</Card>

				<Card class="bg-white">
					<div class="flex h-full flex-col justify-between gap-4">
						<div class="space-y-3">
							<div class="flex items-start justify-between gap-4">
								<div class="space-y-1">
									<p class="text-sm font-semibold text-slate-950">Descripción</p>
									<p id="summaryDescription" class="text-sm leading-6 text-slate-600">
										Cargando descripción...
									</p>
								</div>
								<Badge id="blockBadge-content" variant="warning" class="whitespace-nowrap">
									Cargando...
								</Badge>
							</div>
							<p id="summaryHighlights" class="text-sm text-slate-500">Destacados: —</p>
						</div>
						<div class="flex justify-end">
							<Button
								href={`/product/${encodeURIComponent(productId)}/content`}
								data-astro-prefetch
								variant="secondary"
							>
								Editar descripción
							</Button>
						</div>
					</div>
				</Card>

				<Card class="bg-white">
					<div class="flex h-full flex-col justify-between gap-4">
						<div class="space-y-3">
							<div class="flex items-start justify-between gap-4">
								<div class="space-y-1">
									<p class="text-sm font-semibold text-slate-950">Ubicación</p>
									<p id="summaryAddress" class="text-sm leading-6 text-slate-600">
										Cargando dirección...
									</p>
								</div>
								<Badge id="blockBadge-location" variant="warning" class="whitespace-nowrap">
									Cargando...
								</Badge>
							</div>
							<p id="summaryCoordinates" class="text-sm text-slate-500">Coordenadas: —</p>
						</div>
						<div class="flex justify-end">
							<Button
								href={`/product/${encodeURIComponent(productId)}/location`}
								data-astro-prefetch
								variant="secondary"
							>
								Editar ubicación
							</Button>
						</div>
					</div>
				</Card>

				<Card class="bg-white">
					<div class="flex h-full flex-col justify-between gap-4">
						<div class="space-y-3">
							<div class="flex items-start justify-between gap-4">
								<div class="space-y-1">
									<p class="text-sm font-semibold text-slate-950">Habitaciones</p>
									<p id="summaryRooms" class="text-sm leading-6 text-slate-600">
										Cargando habitaciones...
									</p>
								</div>
								<Badge id="blockBadge-variants" variant="warning" class="whitespace-nowrap">
									Cargando...
								</Badge>
							</div>
							<p class="text-sm text-slate-500">
								Define capacidad y habitaciones vendibles para este alojamiento.
							</p>
						</div>
						<div class="flex justify-end">
							<Button
								href={routes.productRoomsForProduct(productId)}
								data-astro-prefetch
								variant="secondary"
							>
								Abrir habitaciones
							</Button>
						</div>
					</div>
				</Card>

				<Card class="bg-white">
					<div class="flex h-full flex-col justify-between gap-4">
						<div class="space-y-3">
							<div class="flex items-start justify-between gap-4">
								<div class="space-y-1">
									<p class="text-sm font-semibold text-slate-950">Reglas de la casa</p>
									<p id="summaryHouseRules" class="text-sm leading-6 text-slate-600">
										Cargando reglas...
									</p>
								</div>
								<Badge id="blockBadge-houseRules" variant="warning" class="whitespace-nowrap">
									Cargando...
								</Badge>
							</div>
							<p class="text-sm text-slate-500">
								Estas reglas pertenecen a este alojamiento y aparecerán en la vista previa.
							</p>
						</div>
						<div class="flex flex-wrap justify-end gap-2">
							<Button
								href={`${routes.providerHouseRules()}?productId=${encodeURIComponent(productId)}`}
								data-astro-prefetch
								variant="secondary"
							>
								Editar reglas
							</Button>
							<Button
								href={routes.productPreview(productId)}
								data-astro-prefetch
								variant="secondary"
							>
								Vista previa
							</Button>
						</div>
					</div>
				</Card>

				<Card class="bg-white">
					<div class="flex h-full flex-col justify-between gap-4">
						<div class="space-y-3">
							<div class="flex items-start justify-between gap-4">
								<div class="space-y-1">
									<p class="text-sm font-semibold text-slate-950">Tipo y características</p>
									<p id="summaryProductType" class="text-sm leading-6 text-slate-600">
										Cargando tipo...
									</p>
								</div>
								<Badge id="blockBadge-subtype" variant="warning" class="whitespace-nowrap">
									Cargando...
								</Badge>
							</div>
							<p id="summarySubtype" class="text-sm text-slate-500">Características: —</p>
						</div>
						<div class="flex justify-end">
							<Button
								href={`/product/${encodeURIComponent(productId)}/subtype`}
								data-astro-prefetch
								variant="secondary"
							>
								Editar características
							</Button>
						</div>
					</div>
				</Card>

				<Card class="border-blue-100 bg-blue-50 lg:col-span-2">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<div class="space-y-1">
							<p class="text-sm font-semibold text-blue-950">Vista previa</p>
							<p class="max-w-2xl text-sm leading-6 text-blue-900">
								Revisa fotos, descripción, habitaciones y reglas como las verá el huésped.
							</p>
						</div>
						<Button href={routes.productPreview(productId)} data-astro-prefetch>
							Abrir vista previa
						</Button>
					</div>
				</Card>
			</div>
		</Section>

		<details class="rounded-xl border border-slate-800 bg-slate-950 p-4 text-slate-200">
			<summary class="cursor-pointer text-sm font-semibold text-slate-100">Detalle interno</summary>
			<div class="mt-4 space-y-4">
				<div class="space-y-2">
					<div class="h-2 w-full overflow-hidden rounded-full bg-slate-800">
						<div id="productProgressBar" class="h-full bg-[#1E3A8A]" style="width: 0%"></div>
					</div>
					<p id="productProgressText" class="text-sm text-slate-300">Cargando estado interno...</p>
					<p id="productMissingStepsText" class="text-sm text-slate-400">
						Cargando señales internas...
					</p>
				</div>
				<div
					id="internalChecks"
					class="grid gap-2 text-xs text-slate-400 sm:grid-cols-2 lg:grid-cols-3"
				>
					<span>Descripción: cargando</span>
					<span>Fotos: cargando</span>
					<span>Ubicación: cargando</span>
					<span>Habitaciones: cargando</span>
					<span>Reglas: cargando</span>
					<span>Características: cargando</span>
				</div>
				<p class="text-xs text-slate-500">ID interno: {productId}</p>
			</div>
		</details>
	</section>
	<script is:inline define:vars={{ productId }}>
		;(function () {
			const shellStart = performance.now()
			const logShellVisible = () => {
				console.debug("shell visible", {
					page: "product-surface",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				logShellVisible()
			} else {
				document.addEventListener("DOMContentLoaded", logShellVisible, { once: true })
			}

			const setBadgeState = (key, complete) => {
				const badge = document.getElementById(`blockBadge-${key}`)
				if (!badge) return
				badge.textContent = complete ? "Listo" : "Falta"
				badge.classList.remove("bg-amber-100", "text-amber-800", "bg-green-100", "text-green-800")
				if (complete) {
					badge.classList.add("bg-green-100", "text-green-800")
				} else {
					badge.classList.add("bg-amber-100", "text-amber-800")
				}
			}

			const setText = (id, value) => {
				const element = document.getElementById(id)
				if (element) element.textContent = value
			}

			const yesNo = (value) => (value ? "listo" : "pendiente")

			if (!productId) return

			const hydrationStart = performance.now()
			fetch(`/api/internal/product-summary?productId=${encodeURIComponent(productId)}`, {
				headers: { accept: "application/json" },
			})
				.then(async (response) => {
					if (!response.ok) throw new Error(`summary_${response.status}`)
					return await response.json()
				})
				.then((payload) => {
					const missingStepsText = document.getElementById("productMissingStepsText")
					const progressBar = document.getElementById("productProgressBar")
					const progressText = document.getElementById("productProgressText")
					const readyChip = document.getElementById("productReadyChip")
					const headerMeta = document.getElementById("productHeaderMeta")
					const headerSummary = document.getElementById("productHeaderSummary")

					const missing = Number(payload?.progress?.missingSteps ?? 0)
					const completed = Number(payload?.progress?.completedSteps ?? 0)
					const total = Number(payload?.progress?.totalSteps ?? 0)
					const percent = Number(payload?.progress?.progressPercent ?? 0)
					const address = String(payload?.location?.address || "Ubicación pendiente")
					const productType = String(payload?.productType || "Tipo por definir")
					const subtypeSummary = String(payload?.subtype?.summary || "Características pendientes")
					const hasVariants = Boolean(payload?.checks?.hasVariants)
					const hasHouseRules = Boolean(payload?.checks?.hasHouseRules)

					if (missingStepsText) {
						missingStepsText.textContent =
							missing === 0
								? "La ficha está lista para revisión final."
								: `Faltan ${missing} puntos para completar la ficha.`
					}
					if (progressBar) progressBar.style.width = `${Math.max(0, Math.min(100, percent))}%`
					if (progressText)
						progressText.textContent = `${completed} de ${total} puntos internos listos.`
					if (readyChip) {
						readyChip.textContent =
							missing === 0 ? "Listo para publicar" : `Faltan ${missing} pasos`
						readyChip.classList.toggle("border-green-700", missing === 0)
						readyChip.classList.toggle("text-green-200", missing === 0)
					}
					if (headerMeta) headerMeta.textContent = `${address} · ${productType}`
					if (headerSummary) {
						headerSummary.textContent =
							missing === 0
								? "La ficha tiene la información principal lista. Revisa la vista previa antes de publicar."
								: "Completa los bloques pendientes para que el alojamiento se entienda bien antes de reservar."
					}

					setBadgeState("content", Boolean(payload?.checks?.hasContent))
					setBadgeState("houseRules", hasHouseRules)
					setBadgeState("location", Boolean(payload?.checks?.hasLocation))
					setBadgeState("images", Boolean(payload?.checks?.hasImages))
					setBadgeState("subtype", Boolean(payload?.checks?.hasSubtype))
					setBadgeState("variants", hasVariants)

					const summaryDescription = document.getElementById("summaryDescription")
					const summaryHighlights = document.getElementById("summaryHighlights")
					const summaryAddress = document.getElementById("summaryAddress")
					const summaryCoordinates = document.getElementById("summaryCoordinates")
					const summaryImagesCount = document.getElementById("summaryImagesCount")
					const summaryProductType = document.getElementById("summaryProductType")
					const summarySubtype = document.getElementById("summarySubtype")
					const summaryImageGrid = document.getElementById("summaryImageGrid")
					const productHeroMedia = document.getElementById("productHeroMedia")

					if (summaryDescription)
						summaryDescription.textContent = String(payload?.content?.descriptionPreview ?? "")
					if (summaryHighlights)
						summaryHighlights.textContent = `Destacados: ${Number(payload?.content?.highlightsCount ?? 0)}`
					if (summaryAddress) summaryAddress.textContent = address
					if (summaryCoordinates)
						summaryCoordinates.textContent = String(payload?.location?.coordinates ?? "")
					if (summaryImagesCount)
						summaryImagesCount.textContent = `${Number(payload?.images?.count ?? 0)} fotos cargadas`
					if (summaryProductType) summaryProductType.textContent = productType
					if (summarySubtype) summarySubtype.textContent = subtypeSummary
					setText(
						"summaryRooms",
						hasVariants
							? `${Number(payload?.variants?.count ?? 0)} habitaciones configuradas${
									Array.isArray(payload?.variants?.names) && payload.variants.names.length > 0
										? `: ${payload.variants.names.join(", ")}`
										: "."
								}`
							: "Agrega habitaciones para que este alojamiento pueda venderse correctamente."
					)
					setText(
						"summaryHouseRules",
						hasHouseRules
							? "Reglas principales listas para este alojamiento."
							: "Agrega las reglas principales para que el huésped sepa qué esperar."
					)

					if (summaryImageGrid) {
						summaryImageGrid.innerHTML = ""
						const previews = Array.isArray(payload?.images?.previews) ? payload.images.previews : []
						if (previews.length === 0) {
							const empty = document.createElement("p")
							empty.className = "col-span-3 text-sm text-slate-500"
							empty.textContent = "Sin imágenes cargadas."
							summaryImageGrid.appendChild(empty)
						} else {
							for (const item of previews) {
								const img = document.createElement("img")
								img.src = String(item.url)
								img.alt = "Vista previa"
								img.className = "h-16 w-full rounded-md border border-slate-200 object-cover"
								summaryImageGrid.appendChild(img)
							}
						}
					}

					if (productHeroMedia) {
						const coverImage = payload?.images?.cover?.url ? String(payload.images.cover.url) : ""
						if (coverImage) {
							productHeroMedia.textContent = ""
							const heroImage = document.createElement("img")
							heroImage.src = coverImage
							heroImage.alt = "Foto principal del alojamiento"
							heroImage.className = "h-full min-h-[220px] w-full object-cover"
							productHeroMedia.appendChild(heroImage)
						}
					}

					const checks = [
						["Descripción", Boolean(payload?.checks?.hasContent)],
						["Fotos", Boolean(payload?.checks?.hasImages)],
						["Ubicación", Boolean(payload?.checks?.hasLocation)],
						["Habitaciones", hasVariants],
						["Reglas", hasHouseRules],
						["Características", Boolean(payload?.checks?.hasSubtype)],
					]
					const internalChecks = document.getElementById("internalChecks")
					if (internalChecks) {
						internalChecks.innerHTML = ""
						for (const [label, value] of checks) {
							const item = document.createElement("span")
							item.textContent = `${label}: ${yesNo(value)}`
							internalChecks.appendChild(item)
						}
					}

					console.debug("data hydrated", {
						page: "product-surface",
						durationMs: Number((performance.now() - hydrationStart).toFixed(1)),
					})
				})
				.catch(() => {
					const progressText = document.getElementById("productProgressText")
					if (progressText)
						progressText.textContent = "No se pudo cargar el progreso en este momento."
					;["content", "houseRules", "location", "images", "subtype", "variants"].forEach((key) =>
						setBadgeState(key, false)
					)
				})
		})()
	</script>
</WorkspaceLayout>
