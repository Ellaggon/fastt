---
import { variantManagementRepository } from "@/container"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { routes } from "@/lib/routes"

const variantId = String(Astro.params.variantId ?? "")
const defaultPlan = await variantManagementRepository.getDefaultRatePlanWithRules(variantId)
const target = defaultPlan ? routes.ratePlanPricing(defaultPlan.ratePlanId) : routes.ratePlansHub()
return Astro.redirect(target, 307)
---

<WorkspaceLayout title="Redirecting pricing..." />
