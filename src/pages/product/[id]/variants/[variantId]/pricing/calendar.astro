---
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { resolveRatePlanIdFromLegacyInput } from "@/lib/pricing/legacy-rateplan-adapter"
import { routes } from "@/lib/routes"

const variantId = String(Astro.params.variantId ?? "")
const resolved = await resolveRatePlanIdFromLegacyInput({ variantId })
const target = resolved.ratePlanId
	? routes.ratePlanPricing(resolved.ratePlanId)
	: routes.ratePlansHub()
return Astro.redirect(target, 307)
---

<WorkspaceLayout title="Redirecting pricing..." />
