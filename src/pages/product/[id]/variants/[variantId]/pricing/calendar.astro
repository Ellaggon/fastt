---
import PricingCalendar from "@/components/pricing/PricingCalendar.astro"
import PricingSubnav from "@/components/pricing/PricingSubnav.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { loadVariantPricingData } from "@/lib/pricing/loadVariantPricingData"

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
const loaded = await loadVariantPricingData({
	request: Astro.request,
	productId,
	variantId,
})
if ("redirectTo" in loaded) return Astro.redirect(loaded.redirectTo)
const pathname = Astro.url.pathname
---

<WorkspaceLayout title="Producto · Pricing · Calendario">
	<section class="space-y-8 text-neutral-100">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">Calendario de precios</h1>
			<p class="text-sm text-slate-400">
				Consulta precio diario, reglas aplicadas y crea ajustes manuales por fecha.
			</p>
		</header>
		<PricingSubnav productId={productId} variantId={variantId} pathname={pathname} />
		<PricingCalendar />
	</section>

	<script
		type="module"
		define:vars={{
			productId,
			variantId,
			initialCurrency: loaded.initialCurrency,
			activeRulesForUi: loaded.activeRulesForUi,
		}}
	>
		const calendarSkeleton = document.getElementById("pricingCalendarSkeleton")
		const calendarContent = document.getElementById("pricingCalendarContent")
		const calendarRows = document.getElementById("pricingCalendarRows")
		const calendarLatency = document.getElementById("pricingCalendarLatency")
		const calendarCoverageHint = document.getElementById("pricingCalendarCoverageHint")
		const calendarRepairBtn = document.getElementById("pricingCalendarRepairBtn")
		const calendarInspector = document.getElementById("pricingCalendarInspector")
		const calendarInspectorTitle = document.getElementById("pricingCalendarInspectorTitle")
		const calendarInspectorBody = document.getElementById("pricingCalendarInspectorBody")
		const calendarInspectorBase = document.getElementById("pricingCalendarInspectorBase")
		const calendarInspectorFinal = document.getElementById("pricingCalendarInspectorFinal")
		const calendarInspectorSellable = document.getElementById("pricingCalendarInspectorSellable")
		const calendarInspectorBreakdown = document.getElementById("pricingCalendarInspectorBreakdown")
		const calendarInspectorAdvancedLink = document.getElementById(
			"pricingCalendarInspectorAdvancedLink"
		)
		const calendarOverrideInput = document.getElementById("pricingCalendarOverrideInput")
		const calendarOverrideBtn = document.getElementById("pricingCalendarOverrideBtn")
		const calendarPromoInput = document.getElementById("pricingCalendarPromoInput")
		const calendarPromoBtn = document.getElementById("pricingCalendarPromoBtn")
		const calendarSeasonInput = document.getElementById("pricingCalendarSeasonInput")
		const calendarSeasonBtn = document.getElementById("pricingCalendarSeasonBtn")
		const calendarOverrideFeedback = document.getElementById("pricingCalendarOverrideFeedback")
		const activeRules = Array.isArray(activeRulesForUi) ? activeRulesForUi : []
		let selectedInspectorDate = ""
		let selectedRange = []
		let cachedDays = []
		let missingPricingDates = []
		let minPrice = null
		let maxPrice = null
		const usedCurrency = String(initialCurrency || "USD")

		const parseDateOnly = (value) => new Date(`${String(value)}T00:00:00.000Z`)
		const getApplicableRulesForDate = (dateString) => {
			const date = parseDateOnly(dateString)
			if (Number.isNaN(date.getTime())) return []
			return activeRules.filter((rule) => {
				const from = rule?.dateFrom ? parseDateOnly(rule.dateFrom) : null
				if (from && !Number.isNaN(from.getTime()) && date < from) return false
				const to = rule?.dateTo ? parseDateOnly(rule.dateTo) : null
				if (to && !Number.isNaN(to.getTime()) && date > to) return false
				const days = Array.isArray(rule?.dayOfWeek) ? rule.dayOfWeek : []
				if (days.length > 0 && !days.includes(date.getUTCDay())) return false
				return true
			})
		}
		const toDateOnly = (date) => {
			const yyyy = date.getUTCFullYear()
			const mm = String(date.getUTCMonth() + 1).padStart(2, "0")
			const dd = String(date.getUTCDate()).padStart(2, "0")
			return `${yyyy}-${mm}-${dd}`
		}
		const today = new Date()
		today.setUTCHours(0, 0, 0, 0)
		const rangeEnd = new Date(today)
		rangeEnd.setUTCDate(today.getUTCDate() + 29)
		const fromDate = toDateOnly(today)
		const toDate = toDateOnly(rangeEnd)
		const getSelectedRange = () => {
			if (!selectedRange.length) return null
			const sorted = [...selectedRange].sort()
			return { from: sorted[0], to: sorted[sorted.length - 1] }
		}
		const getExclusiveToDate = (isoDate) => {
			const date = parseDateOnly(isoDate)
			date.setUTCDate(date.getUTCDate() + 1)
			return toDateOnly(date)
		}
		const classifyRule = (rule) => {
			const type = String(rule?.type ?? "").toLowerCase()
			if (type === "fixed_override") return "override"
			if (type.includes("discount")) return "promotion"
			if (type.includes("markup") || type.includes("adjustment")) return "season"
			return "rule"
		}
		const formatMoney = (value) =>
			value == null ? "—" : `${usedCurrency} ${Number(value).toFixed(2)}`
		const getStatusLabel = (day) => {
			if (day?.sellable) return "Vendible"
			if (day?.price == null) return "Sin pricing"
			if (Number(day?.capacity ?? 0) <= 0) return "Sin inventario"
			if (day?.closed) return "Cerrado"
			return "No vendible"
		}
		const updateRangeUi = () => {
			const range = getSelectedRange()
			if (!range) {
				if (calendarInspectorBody) {
					calendarInspectorBody.textContent =
						"Haz click en un día para ver su explicación de pricing."
				}
				return
			}
			if (calendarInspectorBody) {
				calendarInspectorBody.textContent = `Rango seleccionado: ${range.from} → ${range.to} (${selectedRange.length} día(s)).`
			}
		}
		const heatClass = (price) => {
			if (price == null || minPrice == null || maxPrice == null)
				return "bg-slate-100 text-slate-600"
			if (maxPrice <= minPrice) return "bg-blue-100 text-blue-700"
			const ratio = (Number(price) - minPrice) / (maxPrice - minPrice)
			if (ratio >= 0.75) return "bg-red-100 text-red-700"
			if (ratio >= 0.5) return "bg-amber-100 text-amber-700"
			if (ratio >= 0.25) return "bg-blue-100 text-blue-700"
			return "bg-green-100 text-green-700"
		}
		const setFeedback = (message) => {
			if (calendarOverrideFeedback) calendarOverrideFeedback.textContent = message
		}
		const createIndicator = (label, className) => {
			const span = document.createElement("span")
			span.className = className
			span.textContent = label
			return span
		}
		const findDay = (date) => cachedDays.find((day) => String(day?.date) === String(date))
		const setAdvancedLink = (type, range) => {
			if (!(calendarInspectorAdvancedLink instanceof HTMLAnchorElement)) return
			const params = new URLSearchParams()
			if (range?.from) params.set("from", range.from)
			if (range?.to) params.set("to", range.to)
			let path = "seasons"
			if (type === "promotion") path = "promotions"
			if (type === "override") path = "overrides"
			calendarInspectorAdvancedLink.href = `/product/${encodeURIComponent(productId)}/variants/${encodeURIComponent(variantId)}/pricing/${path}?${params.toString()}`
		}
		const renderBreakdown = (payload) => {
			if (!calendarInspectorBreakdown) return
			calendarInspectorBreakdown.innerHTML = ""
			const breakdown = Array.isArray(payload?.breakdown) ? payload.breakdown : []
			if (!breakdown.length) {
				const row = document.createElement("tr")
				row.className = "border-t border-slate-200"
				row.innerHTML =
					'<td class="px-2 py-2 text-slate-500" colspan="4">Sin reglas aplicadas para este día.</td>'
				calendarInspectorBreakdown.appendChild(row)
				return
			}
			for (const item of breakdown) {
				const row = document.createElement("tr")
				row.className = "border-t border-slate-200"
				const ruleText = `${String(item?.type ?? "regla")} (valor ${Number(item?.value ?? 0)}, prioridad ${Number(item?.priority ?? 10)})`
				const delta = Number(item?.delta ?? 0)
				row.innerHTML = `
					<td class="px-2 py-1 text-slate-700">${ruleText}</td>
					<td class="px-2 py-1 text-slate-700">${formatMoney(item?.before)}</td>
					<td class="px-2 py-1 text-slate-700">${formatMoney(item?.after)}</td>
					<td class="px-2 py-1 ${delta < 0 ? "text-green-700" : "text-slate-700"}">${delta > 0 ? "+" : ""}${delta.toFixed(2)}</td>
				`
				calendarInspectorBreakdown.appendChild(row)
			}
		}
		const hydrateInspector = async (date) => {
			if (!date) return
			const day = findDay(date)
			if (!day) return
			selectedInspectorDate = String(date)
			calendarInspector?.classList.remove("hidden")
			if (calendarInspectorTitle) {
				calendarInspectorTitle.textContent = `Inspector de pricing · ${selectedInspectorDate}`
			}
			updateRangeUi()
			if (calendarOverrideInput instanceof HTMLInputElement) {
				calendarOverrideInput.value = day?.price == null ? "" : String(day.price)
			}
			if (calendarInspectorSellable) {
				calendarInspectorSellable.textContent = getStatusLabel(day)
			}
			if (calendarInspectorFinal) {
				calendarInspectorFinal.textContent = formatMoney(day?.price)
			}
			setFeedback("Cargando explicación de pricing...")
			try {
				const qs = new URLSearchParams({
					variantId: String(variantId),
					date: selectedInspectorDate,
					currency: usedCurrency,
				})
				const response = await fetch(`/api/internal/pricing-day-inspector?${qs.toString()}`, {
					headers: { accept: "application/json" },
				})
				const payload = await response.json().catch(() => ({}))
				if (!response.ok) {
					setFeedback(
						`No se pudo cargar el inspector: ${String(payload?.error ?? response.status)}`
					)
					return
				}
				if (calendarInspectorBase) {
					calendarInspectorBase.textContent = formatMoney(payload?.basePrice)
				}
				if (calendarInspectorFinal) {
					const finalFromEffective = payload?.finalPrice
					calendarInspectorFinal.textContent =
						finalFromEffective == null
							? "Sin pricing materializado"
							: formatMoney(finalFromEffective)
				}
				renderBreakdown(payload)
				setAdvancedLink("season", getSelectedRange())
				setFeedback("Explicación lista. Puedes aplicar acciones rápidas desde aquí.")
			} catch (error) {
				setFeedback(`Error de red: ${String(error)}`)
			}
		}
		const renderRows = () => {
			if (!calendarRows) return
			calendarRows.innerHTML = ""
			for (const day of cachedDays) {
				const date = String(day?.date ?? "—")
				const isSelected = selectedRange.includes(date)
				const applicableRules = getApplicableRulesForDate(date)
				const indicators = []
				if (day?.price == null) {
					indicators.push(
						createIndicator(
							"Gap",
							"inline-flex items-center rounded-full border border-red-200 bg-red-100 px-2 py-0.5 text-[11px] text-red-700"
						)
					)
				}
				const hasOverride = applicableRules.some((rule) => classifyRule(rule) === "override")
				const hasPromotion = applicableRules.some((rule) => classifyRule(rule) === "promotion")
				const hasSeason = applicableRules.some((rule) => classifyRule(rule) === "season")
				if (hasOverride)
					indicators.push(
						createIndicator(
							"Ajuste manual",
							"inline-flex items-center rounded-full border border-amber-200 bg-amber-100 px-2 py-0.5 text-[11px] text-amber-700"
						)
					)
				if (hasPromotion)
					indicators.push(
						createIndicator(
							"Promoción",
							"inline-flex items-center rounded-full border border-fuchsia-200 bg-fuchsia-100 px-2 py-0.5 text-[11px] text-fuchsia-700"
						)
					)
				if (hasSeason)
					indicators.push(
						createIndicator(
							"Temporada",
							"inline-flex items-center rounded-full border border-blue-200 bg-blue-100 px-2 py-0.5 text-[11px] text-blue-700"
						)
					)
				if (!indicators.length) {
					indicators.push(
						createIndicator(
							"Normal",
							"inline-flex items-center rounded-full border border-green-200 bg-green-100 px-2 py-0.5 text-[11px] text-green-700"
						)
					)
				}

				const row = document.createElement("tr")
				row.className = `border-t border-slate-200 cursor-pointer ${isSelected ? "bg-blue-50" : "bg-white"}`
				row.dataset.date = date

				const dateCell = document.createElement("td")
				dateCell.className = "px-3 py-2 text-slate-900"
				dateCell.textContent = date

				const priceCell = document.createElement("td")
				priceCell.className = "px-3 py-2 text-slate-700"
				priceCell.textContent = formatMoney(day?.price)

				const heatCell = document.createElement("td")
				heatCell.className = "px-3 py-2"
				const heatSpan = document.createElement("span")
				heatSpan.className = `inline-flex min-w-[72px] items-center justify-center rounded-full px-2 py-1 text-xs font-medium ${heatClass(day?.price)}`
				heatSpan.textContent = day?.price == null ? "Sin precio" : "Nivel"
				heatCell.appendChild(heatSpan)

				const capacityCell = document.createElement("td")
				capacityCell.className = "px-3 py-2 text-slate-700"
				capacityCell.textContent = Number.isFinite(Number(day?.capacity))
					? String(day.capacity)
					: "—"

				const statusCell = document.createElement("td")
				statusCell.className = "px-3 py-2"
				const status = document.createElement("span")
				status.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
					day?.sellable
						? "border-green-200 bg-green-100 text-green-800"
						: "border-amber-200 bg-amber-100 text-amber-800"
				}`
				status.textContent = getStatusLabel(day)
				statusCell.appendChild(status)

				const indicatorsCell = document.createElement("td")
				indicatorsCell.className = "px-3 py-2"
				const indicatorWrap = document.createElement("div")
				indicatorWrap.className = "flex flex-wrap gap-1"
				for (const item of indicators) indicatorWrap.appendChild(item)
				indicatorsCell.appendChild(indicatorWrap)

				row.appendChild(dateCell)
				row.appendChild(priceCell)
				row.appendChild(heatCell)
				row.appendChild(capacityCell)
				row.appendChild(statusCell)
				row.appendChild(indicatorsCell)

				row.addEventListener("click", async (event) => {
					const withShift = event.shiftKey
					if (!selectedRange.length || !withShift) {
						selectedRange = [date]
					} else {
						const previous = selectedRange[0]
						const min = previous <= date ? previous : date
						const max = previous <= date ? date : previous
						selectedRange = cachedDays
							.map((item) => String(item?.date ?? ""))
							.filter((dayDate) => dayDate >= min && dayDate <= max)
					}
					renderRows()
					await hydrateInspector(date)
				})

				calendarRows.appendChild(row)
			}
		}
		const runRuleCreation = async ({ type, value, priority }) => {
			const range = getSelectedRange()
			const dayForRange =
				range ??
				(selectedInspectorDate ? { from: selectedInspectorDate, to: selectedInspectorDate } : null)
			if (!dayForRange) {
				setFeedback("Selecciona al menos un día en el calendario.")
				return false
			}
			const parsedValue = Number(value)
			if (!Number.isFinite(parsedValue) || parsedValue < 0) {
				setFeedback("Ingresa un valor válido.")
				return false
			}
			const formData = new FormData()
			formData.set("variantId", String(variantId))
			formData.set("type", type)
			formData.set("value", String(parsedValue))
			formData.set("priority", String(priority))
			formData.set("dateFrom", dayForRange.from)
			formData.set("dateTo", dayForRange.to)
			const response = await fetch("/api/pricing/rule", { method: "POST", body: formData })
			const payload = await response.json().catch(() => ({}))
			if (!response.ok) {
				setFeedback(`No se pudo crear la regla: ${String(payload?.error ?? response.status)}`)
				return false
			}
			return true
		}

		const loadCalendar = async () => {
			const started = performance.now()
			const qs = new URLSearchParams({
				variantId: String(variantId),
				from: fromDate,
				to: toDate,
				occupancy: "1",
				currency: usedCurrency,
			})
			try {
				const response = await fetch(`/api/internal/availability-summary?${qs.toString()}`, {
					headers: { accept: "application/json" },
				})
				if (!response.ok) throw new Error(`availability_${response.status}`)
				const payload = await response.json()
				cachedDays = Array.isArray(payload?.days) ? payload.days : []
				selectedRange = []
				missingPricingDates = Array.isArray(payload?.missingPricingDates)
					? payload.missingPricingDates
					: []
				const pricedValues = cachedDays
					.map((day) => (day?.price == null ? null : Number(day.price)))
					.filter((value) => Number.isFinite(value))
				minPrice = pricedValues.length ? Math.min(...pricedValues) : null
				maxPrice = pricedValues.length ? Math.max(...pricedValues) : null
				renderRows()
				if (missingPricingDates.length > 0) {
					if (calendarCoverageHint) {
						calendarCoverageHint.classList.remove("hidden")
						calendarCoverageHint.textContent = `Faltan precios materializados para ${missingPricingDates.length} día(s).`
					}
					calendarRepairBtn?.classList.remove("hidden")
				} else {
					if (calendarCoverageHint) {
						calendarCoverageHint.classList.add("hidden")
						calendarCoverageHint.textContent = ""
					}
					calendarRepairBtn?.classList.add("hidden")
				}
				calendarSkeleton?.classList.add("hidden")
				calendarContent?.classList.remove("hidden")
				const durationMs = Number((performance.now() - started).toFixed(1))
				if (calendarLatency) calendarLatency.textContent = `Latencia: ${durationMs}ms`
				console.debug("pricing_calendar_loaded", { variantId, durationMs })
			} catch {
				if (calendarRows) {
					calendarRows.innerHTML =
						'<tr class="border-t border-slate-200"><td colspan="6" class="px-3 py-4 text-sm text-slate-600">No se pudo cargar el calendario de precios.</td></tr>'
				}
				calendarSkeleton?.classList.add("hidden")
				calendarContent?.classList.remove("hidden")
			}
		}

		calendarOverrideBtn?.addEventListener("click", async () => {
			if (!(calendarOverrideInput instanceof HTMLInputElement)) return
			const overrideValue = Number(calendarOverrideInput.value)
			calendarOverrideBtn.disabled = true
			setFeedback("Creando ajuste manual...")
			try {
				const ok = await runRuleCreation({
					type: "fixed_override",
					value: overrideValue,
					priority: 0,
				})
				if (!ok) return
				setFeedback("Ajuste manual creado correctamente. Recargando calendario...")
				await loadCalendar()
			} catch (error) {
				setFeedback(`Error de red: ${String(error)}`)
			} finally {
				calendarOverrideBtn.disabled = false
			}
		})
		calendarPromoBtn?.addEventListener("click", async () => {
			if (!(calendarPromoInput instanceof HTMLInputElement)) return
			calendarPromoBtn.disabled = true
			setFeedback("Aplicando promoción...")
			try {
				const ok = await runRuleCreation({
					type: "percentage_discount",
					value: Number(calendarPromoInput.value),
					priority: 10,
				})
				if (!ok) return
				setAdvancedLink("promotion", getSelectedRange())
				setFeedback("Promoción aplicada correctamente.")
				await loadCalendar()
			} catch (error) {
				setFeedback(`Error de red: ${String(error)}`)
			} finally {
				calendarPromoBtn.disabled = false
			}
		})
		calendarSeasonBtn?.addEventListener("click", async () => {
			if (!(calendarSeasonInput instanceof HTMLInputElement)) return
			calendarSeasonBtn.disabled = true
			setFeedback("Aplicando temporada...")
			try {
				const ok = await runRuleCreation({
					type: "percentage_markup",
					value: Number(calendarSeasonInput.value),
					priority: 10,
				})
				if (!ok) return
				setAdvancedLink("season", getSelectedRange())
				setFeedback("Temporada aplicada correctamente.")
				await loadCalendar()
			} catch (error) {
				setFeedback(`Error de red: ${String(error)}`)
			} finally {
				calendarSeasonBtn.disabled = false
			}
		})
		calendarRepairBtn?.addEventListener("click", async () => {
			if (!missingPricingDates.length) return
			calendarRepairBtn.setAttribute("disabled", "true")
			setFeedback("Reparando cobertura de pricing...")
			const sorted = [...missingPricingDates].sort()
			const from = sorted[0]
			const toExclusive = getExclusiveToDate(sorted[sorted.length - 1])
			try {
				const response = await fetch("/api/pricing/generate-effective", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({
						variantId,
						from,
						to: toExclusive,
					}),
				})
				const payload = await response.json().catch(() => ({}))
				if (!response.ok) {
					setFeedback(`No se pudo reparar cobertura: ${String(payload?.error ?? response.status)}`)
					return
				}
				setFeedback(`Cobertura reparada (${Number(payload?.daysGenerated ?? 0)} día(s)).`)
				await loadCalendar()
			} catch (error) {
				setFeedback(`Error de red: ${String(error)}`)
			} finally {
				calendarRepairBtn.removeAttribute("disabled")
			}
		})

		void loadCalendar()
	</script>
</WorkspaceLayout>
