---
import PricingRules from "@/components/pricing/PricingRules.astro"
import PricingSubnav from "@/components/pricing/PricingSubnav.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { loadVariantPricingData } from "@/lib/pricing/loadVariantPricingData"

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
const loaded = await loadVariantPricingData({
	request: Astro.request,
	productId,
	variantId,
})
if ("redirectTo" in loaded) return Astro.redirect(loaded.redirectTo)
const pathname = Astro.url.pathname
---

<WorkspaceLayout title="Producto · Pricing · Ajustes">
	<section class="space-y-8 text-neutral-100">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">Ajustes manuales</h1>
			<p class="text-sm text-slate-400">
				Define precios fijos por fecha para ajustes comerciales puntuales.
			</p>
		</header>
		<PricingSubnav productId={productId} variantId={variantId} pathname={pathname} />
		<PricingRules variantId={variantId} rules={loaded.activeRulesForUi} mode="overrides" />
	</section>
</WorkspaceLayout>
