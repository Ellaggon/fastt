---
import PricingHeader from "@/components/pricing/PricingHeader.astro"
import PricingSubnav from "@/components/pricing/PricingSubnav.astro"
import RatePlansSection from "@/components/pricing/RatePlansSection.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { loadVariantPricingData } from "@/lib/pricing/loadVariantPricingData"

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
const loaded = await loadVariantPricingData({
	request: Astro.request,
	productId,
	variantId,
})
if ("redirectTo" in loaded) return Astro.redirect(loaded.redirectTo)
const pathname = Astro.url.pathname
---

<WorkspaceLayout title="Producto · Pricing · Rate plans">
	<section class="space-y-8 text-neutral-100">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">Rate plans</h1>
			<p class="text-sm text-slate-400">
				Define tarifa base y plan por defecto para esta variante.
			</p>
		</header>
		<PricingSubnav productId={productId} variantId={variantId} pathname={pathname} />
		<PricingHeader
			variantName={loaded.variant.name}
			currency={loaded.initialCurrency}
			basePrice={loaded.initialBasePrice || "No configurada"}
			defaultRatePlanLabel={loaded.defaultPlanLabel}
			coverageStart={loaded.effectivePricingStart}
			coverageEnd={loaded.effectivePricingEnd}
			coverageDays={loaded.effectivePricingDays}
		/>
		<RatePlansSection
			ratePlans={loaded.ratePlans}
			initialCurrency={loaded.initialCurrency}
			hasDefaultPlan={Boolean(loaded.defaultRatePlanId)}
			initialBasePrice={loaded.initialBasePrice}
			variantId={variantId}
			productId={productId}
		/>
	</section>

	<script type="module" define:vars={{ productId, variantId }}>
		const form = document.getElementById("pricingForm")
		const submitBtn = document.getElementById("submitBtn")
		const feedback = document.getElementById("pricingFeedback")
		const ratePlanForm = document.getElementById("ratePlanForm")
		const ratePlanSubmitBtn = document.getElementById("ratePlanSubmitBtn")
		const ratePlanFeedback = document.getElementById("ratePlanFeedback")
		const ratePlanDefault = document.getElementById("ratePlanDefault")

		function setState(state, detail = "") {
			const labels = {
				loading: "Guardando...",
				success: "Guardado correctamente.",
				error: "No se pudo guardar el precio base.",
			}
			if (feedback) feedback.textContent = `${labels[state] ?? ""}${detail ? `\n${detail}` : ""}`
		}

		form?.addEventListener("submit", async (event) => {
			event.preventDefault()
			if (!(submitBtn instanceof HTMLButtonElement)) return
			submitBtn.disabled = true
			setState("loading")
			try {
				const formData = new FormData(form)
				const response = await fetch("/api/pricing/base-rate", { method: "POST", body: formData })
				if (response.status === 401) {
					window.location.href = "/SignInPage"
					return
				}
				const payload = await response.json().catch(() => ({}))
				if (!response.ok) {
					submitBtn.disabled = false
					setState("error", String(payload?.error ?? response.status))
					return
				}
				setState("success")
				window.location.reload()
			} catch (error) {
				submitBtn.disabled = false
				setState("error", `Error de red: ${String(error)}`)
			}
		})

		ratePlanForm?.addEventListener("submit", async (event) => {
			event.preventDefault()
			if (!(ratePlanSubmitBtn instanceof HTMLButtonElement)) return
			ratePlanSubmitBtn.disabled = true
			if (ratePlanFeedback) ratePlanFeedback.textContent = "Guardando..."
			try {
				const name = String(document.getElementById("ratePlanName")?.value ?? "").trim()
				const markAsDefault =
					ratePlanDefault instanceof HTMLInputElement ? Boolean(ratePlanDefault.checked) : false
				const response = await fetch("/api/rateplans/create", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({
						variantId,
						name,
						description: null,
						paymentType: "prepaid",
						refundable: false,
						isActive: true,
						isDefault: markAsDefault,
						type: "package",
					}),
				})
				const payload = await response.json().catch(() => ({}))
				if (!response.ok) {
					if (ratePlanFeedback) {
						ratePlanFeedback.textContent = `No se pudo crear el rate plan: ${String(payload?.error ?? response.status)}`
					}
					ratePlanSubmitBtn.disabled = false
					return
				}
				if (ratePlanFeedback) ratePlanFeedback.textContent = "Rate plan creado correctamente."
				window.location.reload()
			} catch (error) {
				if (ratePlanFeedback) ratePlanFeedback.textContent = `Error de red: ${String(error)}`
				ratePlanSubmitBtn.disabled = false
			}
		})
	</script>
</WorkspaceLayout>
