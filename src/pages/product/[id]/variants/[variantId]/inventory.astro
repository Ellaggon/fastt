---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import FormSection from "@/components/ui/FormSection.astro"
import Input from "@/components/ui/Input.astro"
import Section from "@/components/ui/Section.astro"
import {
	productRepository,
	variantInventoryConfigRepository,
	variantManagementRepository,
} from "@/container"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { asc, count, DailyInventory, db, eq } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
if (!productId) return Astro.redirect("/product/create")
if (!variantId) return Astro.redirect(`/product/${encodeURIComponent(productId)}/variants`)

const variant = await variantManagementRepository.getVariantById(variantId)
if (!variant || variant.productId !== productId) {
	return Astro.redirect(`/product/${encodeURIComponent(productId)}/variants`)
}

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")

const inventoryConfig = await variantInventoryConfigRepository.getByVariantId(variantId)

const initialTotalUnits =
	inventoryConfig?.defaultTotalUnits != null ? String(inventoryConfig.defaultTotalUnits) : ""
const initialHorizonDays =
	inventoryConfig?.horizonDays != null ? String(inventoryConfig.horizonDays) : "365"

const dailyInventoryPreview = await db
	.select({
		date: DailyInventory.date,
		totalInventory: DailyInventory.totalInventory,
		reservedCount: DailyInventory.reservedCount,
		stopSell: DailyInventory.stopSell,
	})
	.from(DailyInventory)
	.where(eq(DailyInventory.variantId, variantId))
	.orderBy(asc(DailyInventory.date))
	.limit(14)

const dailyInventoryCount = await db
	.select({ value: count() })
	.from(DailyInventory)
	.where(eq(DailyInventory.variantId, variantId))
	.get()
---

<WorkspaceLayout title="Producto · Editar inventario">
	<section class="space-y-8 text-neutral-100">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">Editar inventario</h1>
			<p class="text-sm text-slate-400">
				Configura el inventario por defecto y el horizonte de días.
			</p>
		</header>

		<Section
			title="Inventario base"
			description="Estos valores se usan como configuración inicial."
		>
			<Card class="bg-slate-100">
				<form id="inventoryForm" class="mx-auto max-w-3xl space-y-6">
					<Input type="hidden" name="variantId" value={variantId} />
					<FormSection title="Parámetros de inventario">
						<FormField label="Unidades totales" htmlFor="totalUnits" required>
							<Input
								id="totalUnits"
								name="totalUnits"
								type="number"
								min="0"
								step="1"
								value={initialTotalUnits}
								required
							/>
						</FormField>
						<FormField label="Horizonte (días)" htmlFor="horizonDays">
							<Input
								id="horizonDays"
								name="horizonDays"
								type="number"
								min="1"
								max="3650"
								step="1"
								value={initialHorizonDays}
							/>
						</FormField>
					</FormSection>

					<p id="inventoryFeedback" class="whitespace-pre-wrap text-sm text-slate-600"></p>

					<div class="flex items-center justify-between gap-3">
						<a
							href={`/product/${encodeURIComponent(productId)}/variants/${encodeURIComponent(variantId)}`}
							class="inline-flex h-10 items-center justify-center rounded-lg border border-neutral-300 bg-neutral-100 px-4 text-sm font-medium text-neutral-900 hover:bg-neutral-200"
						>
							Volver
						</a>
						<Button
							id="submitBtn"
							type="submit"
							className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
						>
							Guardar cambios
						</Button>
					</div>
				</form>
			</Card>
		</Section>

		<Section title="Inventario diario" description="Estado generado para disponibilidad.">
			<Card class="space-y-6 bg-slate-100">
				<div class="grid gap-3 md:grid-cols-2">
					<div class="rounded-lg border border-slate-200 bg-white p-4">
						<p class="text-xs text-slate-500">Días generados</p>
						<p class="text-sm font-semibold text-slate-900">
							{Number(dailyInventoryCount?.value ?? 0)}
						</p>
					</div>
					<div class="rounded-lg border border-slate-200 bg-white p-4">
						<p class="text-xs text-slate-500">Estado</p>
						<p class="text-sm font-semibold text-slate-900">
							{
								Number(dailyInventoryCount?.value ?? 0) > 0
									? "Inventario diario disponible"
									: "Inventario diario no generado"
							}
						</p>
					</div>
				</div>

				<div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
					<table class="min-w-full divide-y divide-slate-200 text-sm">
						<thead>
							<tr class="text-left text-slate-700">
								<th class="px-3 py-2">Fecha</th>
								<th class="px-3 py-2">Total</th>
								<th class="px-3 py-2">Reservado</th>
								<th class="px-3 py-2">Stop sell</th>
							</tr>
						</thead>
						<tbody>
							{
								dailyInventoryPreview.length > 0 ? (
									dailyInventoryPreview.map((row) => (
										<tr class="border-t border-slate-200">
											<td class="px-3 py-2 text-slate-900">{row.date}</td>
											<td class="px-3 py-2 text-slate-700">{row.totalInventory}</td>
											<td class="px-3 py-2 text-slate-700">{row.reservedCount}</td>
											<td class="px-3 py-2 text-slate-700">{row.stopSell ? "Sí" : "No"}</td>
										</tr>
									))
								) : (
									<tr>
										<td class="px-3 py-3 text-slate-500" colspan="4">
											Sin inventario disponible
										</td>
									</tr>
								)
							}
						</tbody>
					</table>
				</div>
			</Card>
		</Section>
	</section>

	<script type="module" define:vars={{ productId, variantId }}>
		const form = document.getElementById("inventoryForm")
		const submitBtn = document.getElementById("submitBtn")
		const feedback = document.getElementById("inventoryFeedback")

		function setState(state, detail = "") {
			const labels = {
				loading: "Guardando y generando inventario diario...",
				success: "Inventario diario generado correctamente.",
				error: "No se pudo guardar el inventario.",
			}
			if (feedback) feedback.textContent = `${labels[state] ?? ""}${detail ? `\n${detail}` : ""}`
		}

		form?.addEventListener("submit", async (event) => {
			event.preventDefault()
			if (!submitBtn) return
			submitBtn.disabled = true
			setState("loading")

			try {
				const formData = new FormData(form)
				if (!formData.get("horizonDays")) formData.set("horizonDays", "365")
				const response = await fetch("/api/inventory/set-default", {
					method: "POST",
					body: formData,
				})

				if (response.status === 401) {
					window.location.href = "/SignInPage"
					return
				}

				let payload = null
				try {
					payload = await response.json()
				} catch {
					payload = null
				}

				if (!response.ok) {
					submitBtn.disabled = false
					const message =
						payload?.error === "validation_error" && Array.isArray(payload?.details)
							? payload.details
									.map((item) => String(item?.message || ""))
									.filter(Boolean)
									.join("\n") || "Error de validación"
							: String(payload?.error || `status=${response.status}`)
					setState("error", message)
					return
				}

				setState("success")
				window.location.href = `/product/${encodeURIComponent(productId)}/variants/${encodeURIComponent(variantId)}`
			} catch (error) {
				submitBtn.disabled = false
				setState("error", `Error de red: ${String(error)}`)
			}
		})
	</script>
</WorkspaceLayout>
