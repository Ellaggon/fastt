---
const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")

if (!productId) return Astro.redirect("/product")
if (!variantId) return Astro.redirect(`/product/${encodeURIComponent(productId)}/rooms`)

return Astro.redirect(
	`/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(variantId)}/profile`
)
---
