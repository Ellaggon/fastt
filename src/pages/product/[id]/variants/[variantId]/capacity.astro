---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import FormSection from "@/components/ui/FormSection.astro"
import Input from "@/components/ui/Input.astro"
import Section from "@/components/ui/Section.astro"
import { productRepository, variantManagementRepository } from "@/container"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
if (!productId) return Astro.redirect("/product/create")
if (!variantId) return Astro.redirect(`/product/${encodeURIComponent(productId)}/variants`)

const variant = await variantManagementRepository.getVariantById(variantId)
if (!variant || variant.productId !== productId) {
	return Astro.redirect(`/product/${encodeURIComponent(productId)}/variants`)
}

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")

const capacity = await variantManagementRepository.getCapacity(variantId)

const initialMin = capacity?.minOccupancy != null ? String(capacity.minOccupancy) : ""
const initialMax = capacity?.maxOccupancy != null ? String(capacity.maxOccupancy) : ""
const initialMaxAdults = capacity?.maxAdults != null ? String(capacity.maxAdults) : ""
const initialMaxChildren = capacity?.maxChildren != null ? String(capacity.maxChildren) : ""
---

<WorkspaceLayout title="Producto · Editar capacidad">
	<section class="space-y-8 text-neutral-100">
		<header class="space-y-2">
			<h1 class="text-3xl font-semibold text-slate-100">Editar capacidad</h1>
			<p class="text-sm text-slate-400">Actualiza los límites de ocupación de la variante.</p>
		</header>

		<Section title="Capacidad" description="Define mínimos y máximos de ocupación.">
			<Card class="bg-slate-100">
				<form id="capacityForm" class="mx-auto max-w-3xl space-y-6">
					<Input type="hidden" name="variantId" value={variantId} />
					<FormSection title="Límites de ocupación">
						<FormField label="Huéspedes mínimos" htmlFor="minOccupancy" required>
							<Input
								id="minOccupancy"
								name="minOccupancy"
								type="number"
								min="0"
								step="1"
								value={initialMin}
								required
							/>
						</FormField>
						<FormField label="Huéspedes máximos" htmlFor="maxOccupancy" required>
							<Input
								id="maxOccupancy"
								name="maxOccupancy"
								type="number"
								min="0"
								step="1"
								value={initialMax}
								required
							/>
						</FormField>
						<FormField label="Máximo adultos" htmlFor="maxAdults">
							<Input
								id="maxAdults"
								name="maxAdults"
								type="number"
								min="0"
								step="1"
								value={initialMaxAdults}
							/>
						</FormField>
						<FormField label="Máximo niños" htmlFor="maxChildren">
							<Input
								id="maxChildren"
								name="maxChildren"
								type="number"
								min="0"
								step="1"
								value={initialMaxChildren}
							/>
						</FormField>
					</FormSection>

					<p id="capacityFeedback" class="whitespace-pre-wrap text-sm text-slate-600"></p>

					<div class="flex items-center justify-between gap-3">
						<a
							href={`/product/${encodeURIComponent(productId)}/variants/${encodeURIComponent(variantId)}`}
							class="inline-flex h-10 items-center justify-center rounded-lg border border-neutral-300 bg-neutral-100 px-4 text-sm font-medium text-neutral-900 hover:bg-neutral-200"
						>
							Volver
						</a>
						<Button
							id="submitBtn"
							type="submit"
							className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
						>
							Guardar cambios
						</Button>
					</div>
				</form>
			</Card>
		</Section>
	</section>

	<script type="module" define:vars={{ productId, variantId }}>
		const form = document.getElementById("capacityForm")
		const submitBtn = document.getElementById("submitBtn")
		const feedback = document.getElementById("capacityFeedback")

		function setState(state, detail = "") {
			const labels = {
				loading: "Guardando...",
				success: "Guardado correctamente.",
				error: "No se pudo guardar la capacidad.",
			}
			if (feedback) feedback.textContent = `${labels[state] ?? ""}${detail ? `\n${detail}` : ""}`
		}

		form?.addEventListener("submit", async (event) => {
			event.preventDefault()
			if (!submitBtn) return
			submitBtn.disabled = true
			setState("loading")

			try {
				const formData = new FormData(form)
				const response = await fetch("/api/variant/capacity", { method: "POST", body: formData })

				if (response.status === 401) {
					window.location.href = "/SignInPage"
					return
				}

				let payload = null
				try {
					payload = await response.json()
				} catch {
					payload = null
				}

				if (!response.ok) {
					submitBtn.disabled = false
					const message =
						payload?.error === "validation_error" && Array.isArray(payload?.details)
							? payload.details
									.map((item) => String(item?.message || ""))
									.filter(Boolean)
									.join("\n") || "Error de validación"
							: String(payload?.error || `status=${response.status}`)
					setState("error", message)
					return
				}

				setState("success")
				window.location.href = `/product/${encodeURIComponent(productId)}/variants/${encodeURIComponent(variantId)}`
			} catch (error) {
				submitBtn.disabled = false
				setState("error", `Error de red: ${String(error)}`)
			}
		})
	</script>
</WorkspaceLayout>
