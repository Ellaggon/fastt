---
import { routes } from "@/lib/routes"

const productId = String(Astro.params.id ?? "").trim()
const variantId = String(Astro.params.variantId ?? "").trim()
if (!productId) return Astro.redirect(routes.productList())
if (!variantId) return Astro.redirect(routes.productRoomsForProduct(productId))

return Astro.redirect(routes.productRoomCapacity(productId, variantId))
---
