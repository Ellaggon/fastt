---
import Layout from "@/layouts/Layout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
if (!productId) return Astro.redirect("/product/create")
if (!variantId) return Astro.redirect(`/product/${encodeURIComponent(productId)}/variants`)
---

<Layout title="Product - Variant Review">
	<main style="max-width: 640px; margin: 40px auto; padding: 0 16px;">
		<h1>Variant: Review</h1>
		<p>
			Product: <code>{productId}</code>
		</p>
		<p>
			Variant: <code>{variantId}</code>
		</p>

		<button id="evalBtn" type="button">Evaluate readiness</button>
		<pre id="out" style="white-space: pre-wrap; margin-top: 16px;"></pre>

		<p style="margin-top: 16px;">
			<a href={`/product/${encodeURIComponent(productId)}/variants`}>Back to Rooms list</a>
		</p>
	</main>

	<script type="module">
		const out = document.getElementById("out")
		const btn = document.getElementById("evalBtn")
		const productId = String(document.getElementById("productId")?.textContent || "").trim()
		const variantId = String(document.getElementById("variantId")?.textContent || "").trim()

		function render(state, validationErrors) {
			const errs = Array.isArray(validationErrors) ? validationErrors : []
			out.textContent =
				`state=${String(state || "unknown")}\n` +
				(errs.length
					? `validationErrors:\n- ${errs.map((e) => e?.code || e).join("\n- ")}\n`
					: "validationErrors: []\n")
		}

		async function run() {
			out.textContent = ""
			btn.disabled = true
			try {
				if (!variantId) {
					out.textContent = "Missing variantId"
					return
				}
				const fd = new FormData()
				fd.set("variantId", variantId)
				const res = await fetch("/api/variant/evaluate", { method: "POST", body: fd })

				if (res.status === 401) {
					window.location.href = "/SignInPage"
					return
				}
				if (res.status === 404) {
					out.textContent = "Variant not found"
					return
				}

				if (!res.ok) {
					out.textContent =
						res.status >= 500 ? "Something went wrong. Try again." : "Request failed."
					return
				}

				const json = await res.json()
				render(json?.state, json?.validationErrors)
			} catch (err) {
				out.textContent = `Network error: ${String(err)}`
			} finally {
				btn.disabled = false
			}
		}

		btn?.addEventListener("click", run)
		run()
	</script>
</Layout>
<span id="productId" style="display:none">{productId}</span>
<span id="variantId" style="display:none">{variantId}</span>
