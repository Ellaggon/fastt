---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import FormSection from "@/components/ui/FormSection.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import Layout from "@/layouts/Layout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
if (!productId) return Astro.redirect("/product/create")
if (!variantId) return Astro.redirect(`/product/${encodeURIComponent(productId)}/variants`)
---

<Layout title="Product - Variant Pricing">
	<main class="mx-auto max-w-4xl space-y-6 px-6 py-10 text-neutral-100">
		<Card class="space-y-2 bg-white text-slate-900">
			<h1 class="text-2xl font-semibold">Pricing</h1>
			<p class="text-sm text-slate-600">
				Producto: <code>{productId}</code> | Unidad: <code>{variantId}</code>
			</p>
		</Card>

		<form id="baseRateForm" class="space-y-6">
			<Input type="hidden" name="variantId" value={variantId} />
			<FormSection title="Base rate">
				<FormField label="Currency" htmlFor="currency" required>
					<Select id="currency" name="currency" required>
						<option value="USD">USD</option>
						<option value="BOB">BOB</option>
					</Select>
				</FormField>
				<FormField label="Base price" htmlFor="basePrice" required>
					<Input id="basePrice" name="basePrice" type="number" min="0" step="1" required />
					<div id="err-baseRate" class="text-sm text-red-600"></div>
				</FormField>
			</FormSection>
			<div class="flex justify-end">
				<Button
					id="saveBaseRateBtn"
					type="submit"
					className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
				>
					Save base rate
				</Button>
			</div>
		</form>

		<div id="baseRateOk" class="text-sm text-emerald-400"></div>

		<Card class="space-y-4 bg-white text-slate-900">
			<h2 class="text-lg font-semibold">Pricing rules</h2>
			<div id="rulesState" class="text-sm text-slate-600">Loading rules…</div>

			<ul id="rulesList"></ul>

			<form id="addRuleForm" class="space-y-4">
				<Input type="hidden" name="variantId" value={variantId} />
				<FormField label="Type" htmlFor="type" required>
					<Select id="type" name="type" required>
						<option value="percentage">percentage</option>
						<option value="fixed">fixed</option>
					</Select>
				</FormField>
				<FormField label="Value" htmlFor="value" required>
					<Input id="value" name="value" type="number" step="1" required />
					<div id="err-rule" class="text-sm text-red-600"></div>
				</FormField>
				<div class="flex justify-end">
					<Button
						id="addRuleBtn"
						type="submit"
						className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
					>
						Add rule
					</Button>
				</div>
			</form>

			<div id="rulesErr" class="text-sm text-red-600"></div>
		</Card>

		<Card class="space-y-4 bg-white text-slate-900">
			<h2 class="text-lg font-semibold">Preview</h2>
			<p>
				<Button id="previewBtn" type="button" variant="secondary">Preview price</Button>
			</p>
			<div id="previewBox" class="rounded-lg border border-slate-200 p-3">
				<div>Base price: <strong id="previewBase">—</strong></div>
				<div>Final price: <strong id="previewFinal">—</strong></div>
				<div class="text-xs text-slate-600">
					(Computed using the current engine and default rate plan if present.)
				</div>
			</div>
			<div id="previewErr" class="text-sm text-red-600"></div>
		</Card>

		<p class="text-sm text-neutral-300">
			<a href={`/product/${encodeURIComponent(productId)}/variants`}>Back to Rooms list</a>
		</p>
	</main>

	<script type="module">
		const form = document.getElementById("baseRateForm")
		const saveBtn = document.getElementById("saveBaseRateBtn")
		const errBaseRate = document.getElementById("err-baseRate")
		const baseRateOk = document.getElementById("baseRateOk")

		const previewBtn = document.getElementById("previewBtn")
		const previewBase = document.getElementById("previewBase")
		const previewFinal = document.getElementById("previewFinal")
		const previewErr = document.getElementById("previewErr")

		const rulesState = document.getElementById("rulesState")
		const rulesList = document.getElementById("rulesList")
		const addRuleForm = document.getElementById("addRuleForm")
		const addRuleBtn = document.getElementById("addRuleBtn")
		const errRule = document.getElementById("err-rule")
		const rulesErr = document.getElementById("rulesErr")

		function setDisabled(isDisabled) {
			if (saveBtn) saveBtn.disabled = isDisabled
			if (previewBtn) previewBtn.disabled = isDisabled
			if (addRuleBtn) addRuleBtn.disabled = isDisabled
		}

		function clearMessages() {
			if (errBaseRate) errBaseRate.textContent = ""
			if (baseRateOk) baseRateOk.textContent = ""
			if (previewErr) previewErr.textContent = ""
			if (errRule) errRule.textContent = ""
			if (rulesErr) rulesErr.textContent = ""
		}

		async function callPreview(variantId) {
			const fd = new FormData()
			fd.set("variantId", variantId)

			const res = await fetch("/api/pricing/preview", { method: "POST", body: fd })
			if (res.status === 401) {
				window.location.href = "/SignInPage"
				return null
			}
			if (res.status === 404) {
				if (previewErr) previewErr.textContent = "Not found"
				return null
			}
			let payload = null
			try {
				payload = await res.json()
			} catch {
				payload = null
			}
			if (!res.ok) {
				if (previewErr)
					previewErr.textContent = payload?.error ? String(payload.error) : "Preview failed"
				return null
			}
			return payload
		}

		async function refreshPreviewAndPrefill() {
			clearMessages()
			const fd = new FormData(form)
			const variantId = String(fd.get("variantId") || "").trim()
			if (!variantId) return

			const payload = await callPreview(variantId)
			if (!payload) return

			if (previewBase)
				previewBase.textContent = `${payload.basePrice} ${payload.currency || ""}`.trim()
			if (previewFinal)
				previewFinal.textContent = `${payload.finalPrice} ${payload.currency || ""}`.trim()

			// Prefill base-rate form from preview response.
			const currencySel = form?.querySelector("select[name='currency']")
			const basePriceInput = form?.querySelector("input[name='basePrice']")
			if (currencySel && payload.currency) currencySel.value = String(payload.currency)
			if (basePriceInput && typeof payload.basePrice === "number")
				basePriceInput.value = String(payload.basePrice)
		}

		async function loadRules() {
			const fd = new FormData(form)
			const variantId = String(fd.get("variantId") || "").trim()
			if (!variantId) return

			if (rulesState) rulesState.textContent = "Loading rules…"
			if (rulesErr) rulesErr.textContent = ""
			if (rulesList) rulesList.innerHTML = ""

			const res = await fetch(`/api/pricing/rules?variantId=${encodeURIComponent(variantId)}`, {
				method: "GET",
			})
			if (res.status === 401) {
				window.location.href = "/SignInPage"
				return
			}
			if (res.status === 404) {
				if (rulesErr) rulesErr.textContent = "Not found"
				if (rulesState) rulesState.textContent = ""
				return
			}
			let payload = null
			try {
				payload = await res.json()
			} catch {
				payload = null
			}
			if (!res.ok) {
				if (rulesErr)
					rulesErr.textContent = payload?.error ? String(payload.error) : "Failed to load rules"
				if (rulesState) rulesState.textContent = ""
				return
			}

			const rules = Array.isArray(payload?.rules) ? payload.rules : []
			if (!rules.length) {
				if (rulesState) rulesState.textContent = "No pricing rules yet."
				return
			}

			if (rulesState) rulesState.textContent = ""
			for (const r of rules) {
				const li = document.createElement("li")
				const type = String(r?.type || "")
				const value = String(r?.value ?? "")
				const id = String(r?.id || "")
				li.textContent = `${type}: ${value} `

				const del = document.createElement("button")
				del.type = "button"
				del.textContent = "Delete"
				del.addEventListener("click", async () => {
					clearMessages()
					setDisabled(true)
					try {
						const req = new FormData()
						req.set("ruleId", id)
						const resp = await fetch("/api/pricing/rule-delete", { method: "POST", body: req })
						if (resp.status === 401) {
							window.location.href = "/SignInPage"
							return
						}
						if (!resp.ok) {
							let p = null
							try {
								p = await resp.json()
							} catch {
								p = null
							}
							if (rulesErr) rulesErr.textContent = p?.error ? String(p.error) : "Delete failed"
							return
						}
						await loadRules()
						await refreshPreviewAndPrefill()
					} finally {
						setDisabled(false)
					}
				})
				li.appendChild(del)

				rulesList?.appendChild(li)
			}
		}

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			clearMessages()
			setDisabled(true)
			try {
				const fd = new FormData(form)
				const variantId = String(fd.get("variantId") || "").trim()
				const currency = String(fd.get("currency") || "").trim()
				const basePriceRaw = String(fd.get("basePrice") || "").trim()
				const basePrice = Number(basePriceRaw)

				if (
					!variantId ||
					!currency ||
					basePriceRaw.length === 0 ||
					Number.isNaN(basePrice) ||
					basePrice < 0
				) {
					if (errBaseRate) errBaseRate.textContent = "Please enter a valid base price."
					return
				}

				const req = new FormData()
				req.set("variantId", variantId)
				req.set("currency", currency)
				req.set("basePrice", String(basePrice))

				const res = await fetch("/api/pricing/base-rate", { method: "POST", body: req })
				if (res.status === 401) {
					window.location.href = "/SignInPage"
					return
				}
				let payload = null
				try {
					payload = await res.json()
				} catch {
					payload = null
				}
				if (!res.ok) {
					if (res.status === 400 && payload?.error === "validation_error") {
						if (errBaseRate) errBaseRate.textContent = "Validation error. Check inputs."
						return
					}
					if (errBaseRate)
						errBaseRate.textContent = payload?.error ? String(payload.error) : "Save failed"
					return
				}

				if (baseRateOk) baseRateOk.textContent = "Saved."
				await refreshPreviewAndPrefill()
			} finally {
				setDisabled(false)
			}
		})

		previewBtn?.addEventListener("click", async () => {
			clearMessages()
			setDisabled(true)
			try {
				await refreshPreviewAndPrefill()
			} finally {
				setDisabled(false)
			}
		})

		addRuleForm?.addEventListener("submit", async (e) => {
			e.preventDefault()
			clearMessages()
			setDisabled(true)
			try {
				const fd = new FormData(addRuleForm)
				const variantId = String(fd.get("variantId") || "").trim()
				const type = String(fd.get("type") || "").trim()
				const valueRaw = String(fd.get("value") || "").trim()
				const value = Number(valueRaw)

				if (!variantId || !type || valueRaw.length === 0 || Number.isNaN(value)) {
					if (errRule) errRule.textContent = "Please enter a valid value."
					return
				}

				const req = new FormData()
				req.set("variantId", variantId)
				req.set("type", type)
				req.set("value", String(value))

				const res = await fetch("/api/pricing/rule", { method: "POST", body: req })
				if (res.status === 401) {
					window.location.href = "/SignInPage"
					return
				}
				let payload = null
				try {
					payload = await res.json()
				} catch {
					payload = null
				}
				if (!res.ok) {
					if (res.status === 400 && payload?.error === "validation_error") {
						if (errRule) errRule.textContent = "Validation error."
						return
					}
					if (errRule)
						errRule.textContent = payload?.error ? String(payload.error) : "Add rule failed"
					return
				}

				// Reset value input for convenience.
				const valInput = addRuleForm.querySelector("input[name='value']")
				if (valInput) valInput.value = ""

				await loadRules()
				await refreshPreviewAndPrefill()
			} finally {
				setDisabled(false)
			}
		})

		// Initial preview on load (best effort).
		refreshPreviewAndPrefill()
		loadRules()
	</script>
</Layout>
