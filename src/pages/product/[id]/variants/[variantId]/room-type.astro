---
import { routes } from "@/lib/routes"

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")

if (!productId) return Astro.redirect("/product/create")
if (!variantId) return Astro.redirect(routes.productRoomsForProduct(productId))

return Astro.redirect(routes.productRoomSubtype(productId, variantId))
---
