---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import { productRepository } from "@/container"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import {
	buildAddRoomEntryHref,
	buildAddRoomHref,
	resolveAddRoomPlaybookFromUrl,
} from "@/lib/playbook/add-room"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { BedDouble, Camera, DoorOpen, Hotel, ListChecks, Plus, Users } from "@lucide/astro"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "").trim()
if (!productId) return Astro.redirect(routes.productList())

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect(routes.productList())
if (!isHotelProductType(owned.productType)) return Astro.redirect(routes.productDetail(productId))

const addRoomPlaybook = resolveAddRoomPlaybookFromUrl(Astro.url)
const flow = Astro.url.searchParams.get("flow")
if (!addRoomPlaybook.active && flow === "add-room") {
	return Astro.redirect(buildAddRoomHref(routes.productRoomsForProduct(productId), "confirmation"))
}
const highlightVariantId = String(Astro.url.searchParams.get("variantId") ?? "").trim()
const addRoomEntryHref = buildAddRoomEntryHref(productId)
const addRoomNewRoomHref = buildAddRoomHref(routes.productRoomNew(productId), "create-room")
const Layout = addRoomPlaybook.active ? PlaybookLayout : WorkspaceLayout
const layoutProps = addRoomPlaybook.active
	? {
			title: `Habitaciones · ${owned.name}`,
			playbookId: "add-room" as const,
			active: true,
			stepId: addRoomPlaybook.stepId ?? "confirmation",
			productId,
			variantId: highlightVariantId,
			isHotel: true,
		}
	: { title: `Habitaciones · ${owned.name}` }
---

<Layout {...layoutProps}>
	<section class="space-y-8">
		<header
			class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-950/80 p-5 shadow-sm md:p-6"
		>
			<div class="flex flex-wrap items-start justify-between gap-4">
				<div class="max-w-3xl space-y-2">
					<p class="flex items-center gap-2 text-sm font-medium text-slate-400">
						<Hotel class="h-4 w-4" />
						Alojamiento · Habitaciones
					</p>
					<h1 class="text-3xl font-semibold text-slate-100">
						Experiencia de descanso de {owned.name}
					</h1>
					<p class="text-sm leading-6 text-slate-400">
						Crea habitaciones claras para huéspedes. La habitación es lo físico; las tarifas definen
						cómo se vende y el calendario cuándo está disponible.
					</p>
				</div>
				<div class="flex flex-wrap gap-2">
					<Button href={routes.productDetail(productId)} data-astro-prefetch variant="secondary">
						Volver a la ficha
					</Button>
					<Button href={addRoomNewRoomHref} data-astro-prefetch>
						<Plus class="mr-2 h-4 w-4" />
						Nueva habitación
					</Button>
					<Button href={addRoomEntryHref} data-astro-prefetch variant="secondary">
						Guía paso a paso
					</Button>
				</div>
			</div>
		</header>

		<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4" aria-label="Resumen de habitaciones">
			<Card class="bg-slate-100 p-4">
				<p
					class="flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-slate-500"
				>
					<DoorOpen class="h-4 w-4" />
					Habitaciones
				</p>
				<p id="roomsTotal" class="mt-2 text-2xl font-semibold text-slate-950">—</p>
			</Card>
			<Card class="bg-slate-100 p-4">
				<p
					class="flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-slate-500"
				>
					<Users class="h-4 w-4" />
					Capacidad lista
				</p>
				<p id="roomsWithCapacity" class="mt-2 text-2xl font-semibold text-slate-950">—</p>
			</Card>
			<Card class="bg-slate-100 p-4">
				<p
					class="flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-slate-500"
				>
					<Camera class="h-4 w-4" />
					Con fotos
				</p>
				<p id="roomsWithPhotos" class="mt-2 text-2xl font-semibold text-slate-950">—</p>
			</Card>
			<Card class="bg-slate-100 p-4">
				<p
					class="flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-slate-500"
				>
					<ListChecks class="h-4 w-4" />
					Listas para vender
				</p>
				<p id="roomsWithTariffs" class="mt-2 text-2xl font-semibold text-slate-950">—</p>
			</Card>
		</div>

		<Section
			title="Habitaciones"
			description="Una card por habitación, con foco en lo que entiende el huésped y el próximo paso operativo."
		>
			<div id="roomsEmptyState" class="hidden">
				<Card class="overflow-hidden bg-white p-0">
					<div class="grid gap-0 md:grid-cols-[1fr_0.8fr]">
						<div class="space-y-5 p-6">
							<div
								class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-slate-100 text-slate-800"
							>
								<BedDouble class="h-6 w-6" />
							</div>
							<div class="space-y-2">
								<h2 class="text-xl font-semibold text-slate-900">
									Crea la primera habitación del alojamiento
								</h2>
								<p class="text-sm leading-6 text-slate-600">
									Empieza con una ficha simple: nombre, capacidad, camas, baño y una foto. Luego
									podrás completar disponibilidad y tarifas.
								</p>
							</div>
							<div class="grid gap-2 text-sm text-slate-700 sm:grid-cols-3">
								<span class="rounded-lg bg-slate-50 px-3 py-2">Camas y baño</span>
								<span class="rounded-lg bg-slate-50 px-3 py-2">Fotos reales</span>
								<span class="rounded-lg bg-slate-50 px-3 py-2">Lista para vender</span>
							</div>
							<div class="flex flex-wrap gap-2">
								<Button href={addRoomEntryHref} data-astro-prefetch>
									<Plus class="mr-2 h-4 w-4" />
									Preparar mi primera habitación
								</Button>
								<Button
									href={routes.productRoomNew(productId)}
									data-astro-prefetch
									variant="secondary"
								>
									Solo crear habitación
								</Button>
								<Button
									href={routes.productDetail(productId)}
									data-astro-prefetch
									variant="secondary"
								>
									Volver a la ficha
								</Button>
							</div>
						</div>
						<div class="flex min-h-[260px] items-center justify-center bg-slate-100 p-6">
							<div class="max-w-xs rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
								<div class="h-36 rounded-xl bg-slate-200"></div>
								<div class="mt-4 space-y-2">
									<div class="h-4 w-32 rounded bg-slate-200"></div>
									<div class="h-3 w-48 rounded bg-slate-100"></div>
									<div class="flex gap-2">
										<span class="h-7 w-20 rounded-full bg-slate-100"></span>
										<span class="h-7 w-24 rounded-full bg-slate-100"></span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</Card>
			</div>

			<div id="roomsSkeleton" class="grid gap-4 lg:grid-cols-2">
				{
					Array.from({ length: 2 }).map(() => (
						<Card class="overflow-hidden bg-slate-100 p-0">
							<div class="grid min-h-[280px] gap-0 md:grid-cols-[180px_1fr]">
								<div class="animate-pulse bg-slate-200" />
								<div class="space-y-4 p-5">
									<div class="h-5 w-40 animate-pulse rounded bg-slate-200" />
									<div class="h-4 w-28 animate-pulse rounded bg-slate-200" />
									<div class="grid gap-3 sm:grid-cols-2">
										<div class="h-20 animate-pulse rounded-lg bg-slate-200" />
										<div class="h-20 animate-pulse rounded-lg bg-slate-200" />
										<div class="h-20 animate-pulse rounded-lg bg-slate-200" />
										<div class="h-20 animate-pulse rounded-lg bg-slate-200" />
									</div>
								</div>
							</div>
						</Card>
					))
				}
			</div>

			<div id="roomsList" class="hidden grid gap-4 lg:grid-cols-2"></div>
		</Section>
	</section>

	<script
		is:inline
		define:vars={{ productId, highlightVariantId, addRoomPlaybookActive: addRoomPlaybook.active }}
	>
		;(function () {
			if (!productId) return

			const text = (value, fallback) => {
				const normalized = String(value ?? "").trim()
				return normalized || fallback
			}

			const setText = (id, value) => {
				const element = document.getElementById(id)
				if (element) element.textContent = String(value)
			}

			const statusClass = (tone) => {
				if (tone === "ok") return "border-emerald-200 bg-emerald-50 text-emerald-800"
				if (tone === "warn") return "border-amber-200 bg-amber-50 text-amber-800"
				return "border-slate-200 bg-white text-slate-700"
			}

			const pill = (label, tone) => {
				const element = document.createElement("span")
				element.className = `inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-xs font-medium ${statusClass(tone)}`
				element.textContent = label
				return element
			}

			const metric = (label, value, tone) => {
				const wrapper = document.createElement("div")
				wrapper.className = `rounded-lg border p-3 ${statusClass(tone)}`
				const title = document.createElement("p")
				title.className = "text-xs font-medium uppercase tracking-wide opacity-70"
				title.textContent = label
				const body = document.createElement("p")
				body.className = "mt-1 text-sm font-semibold"
				body.textContent = value
				wrapper.append(title, body)
				return wrapper
			}

			const action = (href, label, primary) => {
				const link = document.createElement("a")
				link.href = href
				link.setAttribute("data-astro-prefetch", "")
				link.className = primary
					? "fastt-button inline-flex h-10 items-center justify-center rounded-lg border border-slate-950 bg-slate-950 px-4 text-sm font-medium text-white hover:bg-slate-800"
					: "fastt-button inline-flex h-10 items-center justify-center rounded-lg border border-slate-300 bg-white px-4 text-sm font-medium text-slate-700 hover:bg-slate-50"
				link.textContent = label
				return link
			}

			const roomCard = (room) => {
				const card = document.createElement("article")
				const isHighlighted =
					highlightVariantId && String(room?.id ?? "") === String(highlightVariantId)
				card.className = `fastt-row-card overflow-hidden bg-white transition hover:-translate-y-0.5 hover:shadow-md${
					isHighlighted ? " ring-2 ring-emerald-400 ring-offset-2 ring-offset-slate-950" : ""
				}`

				const layout = document.createElement("div")
				layout.className = "grid min-h-[280px] gap-0 md:grid-cols-[180px_1fr]"

				const imageSlot = document.createElement("div")
				imageSlot.className = "min-h-[180px] bg-slate-200 md:min-h-full"
				const coverUrl = text(room?.photos?.coverUrl, "")
				if (coverUrl) {
					const image = document.createElement("img")
					image.src = coverUrl
					image.alt = `Foto de ${text(room?.name, "habitación")}`
					image.loading = "lazy"
					image.className = "h-full min-h-[180px] w-full object-cover md:min-h-full"
					imageSlot.append(image)
				} else {
					imageSlot.classList.add("flex", "items-center", "justify-center")
					const placeholder = document.createElement("span")
					placeholder.className = "px-4 text-center text-sm font-medium text-slate-500"
					placeholder.textContent = "Agrega una foto para mostrar esta habitación"
					imageSlot.append(placeholder)
				}

				const body = document.createElement("div")
				body.className = "space-y-5 p-5"

				const top = document.createElement("div")
				top.className = "flex flex-wrap items-start justify-between gap-3"
				const titleBlock = document.createElement("div")
				titleBlock.className = "min-w-0 space-y-1"
				const name = document.createElement("h2")
				name.className = "text-xl font-semibold text-slate-950"
				name.textContent = text(room?.name, "Habitación")
				const type = document.createElement("p")
				type.className = "text-sm text-slate-600"
				type.textContent = text(room?.type?.label, text(room?.kindLabel, "Habitación"))
				titleBlock.append(name, type)
				const active = String(room?.status ?? "").toLowerCase() !== "archived"
				top.append(titleBlock, pill(active ? "Visible" : "Pausada", active ? "ok" : "neutral"))

				const grid = document.createElement("div")
				grid.className = "grid gap-3 sm:grid-cols-2"
				const photosCount = Number(room?.photos?.count ?? 0)
				const tariffCount = Number(room?.tariffs?.count ?? 0)
				const isComplete = Boolean(room?.states?.isComplete)
				const resumeParams = (step, extra = {}) => {
					const params = new URLSearchParams({
						playbook: "add-room",
						step,
						flow: "add-room",
						...extra,
					})
					return params.toString()
				}
				const resumeHref = (() => {
					const variantId = String(room?.id ?? "")
					const ratePlanId = String(room?.tariffs?.defaultId ?? "")
					if (!variantId) return "#"
					if (!room?.states?.capacityComplete) {
						return `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(variantId)}?${resumeParams("create-room")}`
					}
					if (photosCount <= 0) {
						return `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(variantId)}?${resumeParams("room-photos")}#fotos`
					}
					if (tariffCount <= 0) {
						return `/rates/plans/manage?${resumeParams("create-rate", { variantId, openDialog: "1" })}`
					}
					if (!room?.states?.inventoryComplete) {
						const params = new URLSearchParams(
							resumeParams("availability", { variantId, focus: "availability" })
						)
						if (ratePlanId) params.set("ratePlanId", ratePlanId)
						return `/rates/calendar?${params.toString()}`
					}
					return `/product/${encodeURIComponent(productId)}/rooms?${resumeParams("confirmation", { variantId })}`
				})()
				grid.append(
					metric(
						"Capacidad",
						text(room?.capacity?.label, "Capacidad pendiente"),
						room?.states?.capacityComplete ? "ok" : "warn"
					),
					metric(
						"Fotos",
						photosCount > 0 ? `${photosCount} foto${photosCount === 1 ? "" : "s"}` : "Pendientes",
						photosCount > 0 ? "ok" : "warn"
					),
					metric(
						"Disponibilidad",
						text(room?.inventory?.label, "Fechas pendientes"),
						room?.states?.inventoryComplete ? "ok" : "warn"
					),
					metric(
						"Tarifas",
						tariffCount > 0 ? `${tariffCount} tarifa${tariffCount === 1 ? "" : "s"}` : "Pendientes",
						tariffCount > 0 ? "ok" : "warn"
					)
				)

				const tariffNames = Array.isArray(room?.tariffs?.names) ? room.tariffs.names : []
				const tariffSummary = document.createElement("p")
				tariffSummary.className = "text-sm text-slate-600"
				tariffSummary.textContent =
					tariffNames.length > 0
						? `Se vende con: ${tariffNames.slice(0, 3).join(", ")}${tariffNames.length > 3 ? "..." : ""}`
						: "Agrega una tarifa para definir cómo se vende esta habitación."

				const actions = document.createElement("div")
				actions.className = "flex flex-wrap gap-2"
				actions.append(
					action(text(room?.actions?.detailHref, "#"), "Editar habitación", true),
					action(text(room?.actions?.tariffsHref, "/rates/plans/manage"), "Tarifas", false),
					action(text(room?.actions?.calendarHref, "#"), "Calendario", false),
					action(text(room?.actions?.conditionsHref, "/rates/plans/manage"), "Condiciones", false)
				)

				const nextStep = document.createElement("div")
				nextStep.className =
					"rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700"
				const missing = []
				if (!room?.states?.capacityComplete) missing.push("perfil")
				if (photosCount <= 0) missing.push("fotos")
				if (tariffCount <= 0) missing.push("tarifas")
				if (!room?.states?.inventoryComplete) missing.push("calendario")

				if (isHighlighted && addRoomPlaybookActive) {
					const success = document.createElement("p")
					success.className = "font-semibold text-emerald-800"
					success.textContent = isComplete
						? "Habitación lista para vender."
						: "Habitación creada. Revisa el siguiente paso si aún falta algo."
					nextStep.append(success)
				} else if (tariffCount <= 0) {
					const warn = document.createElement("p")
					warn.textContent =
						"Esta habitación aún no se puede vender. Siguiente paso: crear una tarifa."
					const ctaRow = document.createElement("div")
					ctaRow.className = "mt-3 flex flex-wrap gap-2"
					ctaRow.append(
						action(
							`/rates/plans/manage?${resumeParams("create-rate", { variantId: String(room?.id ?? ""), openDialog: "1" })}`,
							"Crear tarifa",
							true
						),
						action(resumeHref, "Guía paso a paso", false)
					)
					nextStep.append(warn, ctaRow)
				} else if (missing.length > 0) {
					const warn = document.createElement("p")
					warn.textContent = `Siguiente paso recomendado: completar ${missing[0]}.`
					const ctaRow = document.createElement("div")
					ctaRow.className = "mt-3 flex flex-wrap gap-2"
					ctaRow.append(action(resumeHref, "Retomar configuración", true))
					nextStep.append(warn, ctaRow)
				} else {
					nextStep.textContent = "Lista para mostrarse con confianza en la ficha pública."
				}

				body.append(top, grid, tariffSummary, actions, nextStep)
				layout.append(imageSlot, body)
				card.append(layout)
				return card
			}

			fetch(`/api/internal/rooms-summary?productId=${encodeURIComponent(productId)}`, {
				headers: { accept: "application/json" },
			})
				.then(async (response) => {
					if (!response.ok) throw new Error(`rooms_summary_${response.status}`)
					return await response.json()
				})
				.then((payload) => {
					const rooms = Array.isArray(payload?.variants) ? payload.variants : []
					const list = document.getElementById("roomsList")
					const skeleton = document.getElementById("roomsSkeleton")
					const empty = document.getElementById("roomsEmptyState")

					setText("roomsTotal", rooms.length)
					setText(
						"roomsWithCapacity",
						rooms.filter((room) => Boolean(room?.states?.capacityComplete)).length
					)
					setText(
						"roomsWithPhotos",
						rooms.filter((room) => Number(room?.photos?.count ?? 0) > 0).length
					)
					setText(
						"roomsWithTariffs",
						rooms.filter((room) => Number(room?.tariffs?.count ?? 0) > 0).length
					)

					if (list) {
						list.innerHTML = ""
						for (const room of rooms) list.append(roomCard(room))
					}

					skeleton?.classList.add("hidden")
					if (rooms.length > 0) {
						list?.classList.remove("hidden")
						empty?.classList.add("hidden")
					} else {
						list?.classList.add("hidden")
						empty?.classList.remove("hidden")
					}
				})
				.catch(() => {
					const skeleton = document.getElementById("roomsSkeleton")
					if (skeleton) {
						skeleton.innerHTML =
							'<article class="rounded-xl border border-slate-200 bg-slate-100 p-5 text-sm text-slate-600">No se pudo cargar la ficha de habitaciones.</article>'
					}
				})
		})()
	</script>
</Layout>
