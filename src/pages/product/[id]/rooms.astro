---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import AccommodationContextSwitcher from "@/components/product/AccommodationContextSwitcher.astro"
import { productRepository } from "@/container"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import {
	buildAddRoomEntryHref,
	buildAddRoomHref,
	resolveAddRoomPlaybookFromUrl,
} from "@/lib/playbook/add-room"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"
import { BadgeCheck, BedDouble, CalendarDays, Hotel, Plus } from "@lucide/astro"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "").trim()
if (!productId) return Astro.redirect(routes.productList())

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect(routes.productList())
if (!isHotelProductType(owned.productType)) return Astro.redirect(routes.productDetail(productId))

const addRoomPlaybook = resolveAddRoomPlaybookFromUrl(Astro.url)
const flow = Astro.url.searchParams.get("flow")
if (!addRoomPlaybook.active && flow === "add-room") {
	return Astro.redirect(buildAddRoomHref(routes.productRoomsForProduct(productId), "confirmation"))
}
const highlightVariantId = String(Astro.url.searchParams.get("variantId") ?? "").trim()
const isAddRoomConfirmation =
	addRoomPlaybook.active && (addRoomPlaybook.stepId ?? "confirmation") === "confirmation"
const addRoomEntryHref = buildAddRoomEntryHref(productId)
const addRoomNewRoomHref = buildAddRoomHref(routes.productRoomNew(productId), "create-room")
const cleanRoomsHref = routes.productRoomsForProduct(productId)
const cleanRoomHref = highlightVariantId
	? routes.productRoomDetail(productId, highlightVariantId)
	: cleanRoomsHref
const cleanCalendarHref = highlightVariantId
	? `${routes.calendar()}?variantId=${encodeURIComponent(highlightVariantId)}&focus=availability`
	: routes.calendar()
const Layout = addRoomPlaybook.active ? PlaybookLayout : WorkspaceLayout
const layoutProps = addRoomPlaybook.active
	? {
			title: `Habitaciones · ${owned.name}`,
			playbookId: "add-room" as const,
			active: true,
			stepId: addRoomPlaybook.stepId ?? "confirmation",
			productId,
			variantId: highlightVariantId,
			isHotel: true,
			hideFooter: isAddRoomConfirmation,
		}
	: { title: `Habitaciones · ${owned.name}` }
---

<Layout {...layoutProps}>
	<section class="space-y-8" data-rooms-summary-page data-product-id={productId}>
		{
			isAddRoomConfirmation ? (
				<section class="fastt-card overflow-hidden border bg-white text-slate-900">
					<div class="grid gap-0 lg:grid-cols-[minmax(0,1fr)_320px]">
						<div class="space-y-6 p-5 md:p-6">
							<div class="space-y-3">
								<p class="flex items-center gap-2 text-sm font-medium text-slate-500">
									<Hotel class="h-4 w-4" />
									{owned.name} · Nueva habitación
								</p>
								<div class="space-y-2">
									<h1
										id="confirmationTitle"
										class="text-2xl font-semibold text-slate-950 md:text-3xl"
									>
										Habitación lista para vender
									</h1>
									<p
										id="confirmationDescription"
										class="max-w-2xl text-sm leading-6 text-slate-600"
									>
										La habitación ya tiene perfil, fotos, tarifa, condiciones y disponibilidad
										inicial. Ahora puedes revisarla o volver al listado operativo.
									</p>
								</div>
							</div>

							<div
								class="grid overflow-hidden rounded-[var(--fastt-radius-card)] border border-slate-200 bg-slate-50 sm:grid-cols-2 xl:grid-cols-5"
								aria-label="Resumen del alta de habitación"
							>
								<div class="border-b border-slate-200 p-3 sm:border-r xl:border-b-0">
									<p class="text-xs font-medium text-slate-500">Perfil</p>
									<p
										id="confirmationProfileStatus"
										class="mt-1 text-sm font-semibold text-slate-950"
									>
										Listo
									</p>
								</div>
								<div class="border-b border-slate-200 p-3 xl:border-r xl:border-b-0">
									<p class="text-xs font-medium text-slate-500">Fotos</p>
									<p
										id="confirmationPhotosStatus"
										class="mt-1 text-sm font-semibold text-slate-950"
									>
										Listo
									</p>
								</div>
								<div class="border-b border-slate-200 p-3 sm:border-r xl:border-b-0">
									<p class="text-xs font-medium text-slate-500">Tarifa</p>
									<p id="confirmationRateStatus" class="mt-1 text-sm font-semibold text-slate-950">
										Listo
									</p>
								</div>
								<div class="border-b border-slate-200 p-3 xl:border-r xl:border-b-0">
									<p class="text-xs font-medium text-slate-500">Condiciones</p>
									<p class="mt-1 text-sm font-semibold text-slate-950">Listas</p>
								</div>
								<div class="p-3">
									<p class="text-xs font-medium text-slate-500">Disponibilidad</p>
									<p
										id="confirmationAvailabilityStatus"
										class="mt-1 text-sm font-semibold text-slate-950"
									>
										Inicial abierta
									</p>
								</div>
							</div>
						</div>

						<aside class="border-t border-slate-200 bg-slate-50 p-5 md:p-6 lg:border-t-0 lg:border-l">
							<div class="flex h-full flex-col justify-between gap-6">
								<div class="space-y-4">
									<div class="inline-flex h-11 w-11 items-center justify-center rounded-[var(--fastt-radius-card)] bg-slate-950 text-white">
										<BadgeCheck class="h-5 w-5" />
									</div>
									<div>
										<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
											Siguiente uso natural
										</p>
										<p class="mt-2 text-sm leading-6 text-slate-700">
											Revisa cómo quedó la habitación o vuelve al listado para operar habitaciones,
											tarifas y calendario sin el asistente.
										</p>
									</div>
								</div>
								<div class="flex flex-col gap-2">
									<Button href={cleanRoomHref} className="fastt-playbook-cta">
										Ver habitación
									</Button>
									<Button href={cleanRoomsHref} variant="secondary">
										Ver todas las habitaciones
									</Button>
									<Button href={cleanCalendarHref} variant="ghost">
										<CalendarDays class="h-4 w-4" />
										Abrir calendario
									</Button>
								</div>
							</div>
						</aside>
					</div>
				</section>
			) : (
				<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
					<div class="space-y-1.5">
						<AccommodationContextSwitcher
							providerId={providerId}
							productId={productId}
							currentName={owned.name}
							target="rooms"
						/>
						<h1 class="text-3xl font-semibold text-slate-100">Habitaciones</h1>
						<p class="max-w-2xl text-sm leading-6 text-slate-300">
							Experiencia de descanso de {owned.name}. Gestiona los espacios físicos que verá el
							huésped. Tarifas, condiciones y calendario viven en sus herramientas operativas.
						</p>
					</div>
					<div class="flex flex-wrap gap-2">
						<Button href={addRoomNewRoomHref} data-astro-prefetch>
							<Plus class="mr-2 h-4 w-4" />
							Nueva habitación
						</Button>
						<Button href={routes.productDetail(productId)} data-astro-prefetch variant="secondary">
							Ficha del alojamiento
						</Button>
					</div>
				</header>
			)
		}

		<section class="space-y-4">
			<div class="mb-4 flex flex-wrap items-center justify-between gap-3">
				<nav class="rooms-status-tabs max-w-full" aria-label="Filtrar habitaciones">
					<button
						type="button"
						class:list={["rooms-status-tab px-3 py-2 text-sm font-semibold whitespace-nowrap"]}
						data-room-filter="attention"
						data-active="true"
						aria-pressed="true"
					>
						Requieren atención <span id="roomsTabAttention" class="ml-1 text-xs opacity-70">—</span>
					</button>
					<button
						type="button"
						class:list={["rooms-status-tab px-3 py-2 text-sm font-semibold whitespace-nowrap"]}
						data-room-filter="ready"
						data-active="false"
						aria-pressed="false"
					>
						Vendibles <span id="roomsTabReady" class="ml-1 text-xs opacity-70">—</span>
					</button>
					<button
						type="button"
						class:list={["rooms-status-tab px-3 py-2 text-sm font-semibold whitespace-nowrap"]}
						data-room-filter="no-rate"
						data-active="false"
						aria-pressed="false"
					>
						Sin tarifa <span id="roomsTabNoRate" class="ml-1 text-xs opacity-70">—</span>
					</button>
					<button
						type="button"
						class:list={["rooms-status-tab px-3 py-2 text-sm font-semibold whitespace-nowrap"]}
						data-room-filter="no-availability"
						data-active="false"
						aria-pressed="false"
					>
						Sin disponibilidad <span id="roomsTabNoAvailability" class="ml-1 text-xs opacity-70"
							>—</span
						>
					</button>
					<button
						type="button"
						class:list={["rooms-status-tab px-3 py-2 text-sm font-semibold whitespace-nowrap"]}
						data-room-filter="all"
						data-active="false"
						aria-pressed="false"
					>
						Todas <span id="roomsTabAll" class="ml-1 text-xs opacity-70">—</span>
					</button>
				</nav>
				<p class="text-xs text-slate-400">Evaluación: mínimo 30 noches con disponibilidad</p>
			</div>

			<div id="roomsFilteredEmpty" class="hidden">
				<Card class="bg-white p-5 text-sm text-slate-600">
					<p class="font-semibold text-slate-950">No hay habitaciones en esta vista.</p>
					<p class="mt-1">Cambia el filtro o crea una nueva habitación.</p>
				</Card>
			</div>

			<div id="roomsEmptyState" class="hidden">
				<Card class="overflow-hidden bg-white p-0">
					<div class="grid gap-0 md:grid-cols-[1fr_0.8fr]">
						<div class="space-y-5 p-6">
							<div
								class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-slate-100 text-slate-800"
							>
								<BedDouble class="h-6 w-6" />
							</div>
							<div class="space-y-2">
								<h2 class="text-xl font-semibold text-slate-900">
									Crea la primera habitación del alojamiento
								</h2>
								<p class="text-sm leading-6 text-slate-600">
									Empieza con una ficha simple: nombre, capacidad, camas, baño y una foto. Luego
									podrás completar disponibilidad y tarifas.
								</p>
							</div>
							<div class="grid gap-2 text-sm text-slate-700 sm:grid-cols-3">
								<span class="rounded-lg bg-slate-50 px-3 py-2">Camas y baño</span>
								<span class="rounded-lg bg-slate-50 px-3 py-2">Fotos reales</span>
								<span class="rounded-lg bg-slate-50 px-3 py-2">Lista para vender</span>
							</div>
							<div class="flex flex-wrap gap-2">
								<Button href={addRoomEntryHref} data-astro-prefetch>
									<Plus class="mr-2 h-4 w-4" />
									Preparar mi primera habitación
								</Button>
								<Button
									href={routes.productRoomNew(productId)}
									data-astro-prefetch
									variant="secondary"
								>
									Solo crear habitación
								</Button>
								<Button
									href={routes.productDetail(productId)}
									data-astro-prefetch
									variant="secondary"
								>
									Volver a la ficha
								</Button>
							</div>
						</div>
						<div class="flex min-h-[260px] items-center justify-center bg-slate-100 p-6">
							<div class="max-w-xs rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
								<div class="h-36 rounded-xl bg-slate-200"></div>
								<div class="mt-4 space-y-2">
									<div class="h-4 w-32 rounded bg-slate-200"></div>
									<div class="h-3 w-48 rounded bg-slate-100"></div>
									<div class="flex gap-2">
										<span class="h-7 w-20 rounded-full bg-slate-100"></span>
										<span class="h-7 w-24 rounded-full bg-slate-100"></span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</Card>
			</div>

			<div id="roomsSkeleton" class="grid gap-5 lg:grid-cols-2">
				{
					Array.from({ length: 2 }).map(() => (
						<Card class="overflow-hidden rounded-4xl border-0 bg-white p-0 shadow-sm">
							<div class="grid min-h-[280px] gap-0 md:grid-cols-[180px_1fr]">
								<div class="animate-pulse bg-slate-100" />
								<div class="space-y-4 p-5">
									<div class="h-5 w-40 animate-pulse rounded bg-slate-200/80" />
									<div class="h-4 w-28 animate-pulse rounded bg-slate-100" />
									<div class="grid overflow-hidden rounded-[var(--fastt-radius-card)] border border-slate-100 bg-white sm:grid-cols-2">
										<div class="h-14 animate-pulse border-b border-slate-100 bg-slate-50" />
										<div class="h-14 animate-pulse border-b border-slate-100 bg-slate-50" />
										<div class="h-14 animate-pulse border-b border-slate-100 bg-slate-50" />
										<div class="h-14 animate-pulse bg-slate-50" />
									</div>
								</div>
							</div>
						</Card>
					))
				}
			</div>

			<div id="roomsList" class="hidden grid gap-5 lg:grid-cols-2"></div>
		</section>
	</section>

	<style is:global>
		.room-card-shell {
			transform: translateY(0);
			transition: transform 180ms ease;
		}

		.room-card-shell:hover {
			transform: translateY(-4px);
		}

		.room-card-image {
			border-radius: 2rem 2rem 0 0;
		}

		.room-card-image-media {
			border-radius: inherit;
			transition:
				filter 200ms ease,
				transform 200ms ease;
		}

		.room-card-shell:hover .room-card-image-media {
			filter: brightness(1.04) saturate(1.04);
			transform: scale(1.018);
		}

		.rooms-status-tabs {
			display: flex;
			gap: 0.25rem;
			overflow-x: auto;
			border: 0;
			border-radius: var(--fastt-radius-pill);
			background: rgb(0 0 0);
			padding: 0.25rem;
			box-shadow: none;
		}

		.rooms-status-tab,
		.rooms-status-tab[data-active="false"] {
			flex-shrink: 0;
			border: 0;
			border-radius: var(--fastt-radius-pill);
			background: rgb(0 0 0);
			color: rgb(203 213 225);
			box-shadow: none;
			outline: 0;
			transition:
				background-color var(--fastt-motion-fast) ease,
				color var(--fastt-motion-fast) ease,
				box-shadow var(--fastt-motion-fast) ease;
		}

		.rooms-status-tab:hover {
			background: rgb(0 0 0);
			color: rgb(248 250 252);
		}

		.rooms-status-tab[data-active="true"] {
			background: rgb(248 250 252);
			color: rgb(15 23 42);
			box-shadow: 0 6px 18px rgb(0 0 0 / 18%);
			border: 0;
			outline: 0;
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
		}

		.room-card-body {
			border-radius: 0 0 2rem 2rem;
		}

		@media (min-width: 768px) {
			.room-card-image {
				border-top-left-radius: 2rem;
				border-top-right-radius: 0;
				border-bottom-right-radius: 0;
				border-bottom-left-radius: 2rem;
			}

			.room-card-body {
				border-top-left-radius: 0;
				border-top-right-radius: 2rem;
				border-bottom-right-radius: 2rem;
				border-bottom-left-radius: 0;
			}
		}
	</style>

	<script
		is:inline
		data-astro-rerun
		define:vars={{
			productId,
			highlightVariantId,
			addRoomPlaybookActive: addRoomPlaybook.active,
			isAddRoomConfirmation,
		}}
	>
		;(function () {
			if (!productId) return
			let activeRoomFilter = "attention"

			const text = (value, fallback) => {
				const normalized = String(value ?? "").trim()
				return normalized || fallback
			}

			const setText = (id, value) => {
				const element = document.getElementById(id)
				if (element) element.textContent = String(value)
			}

			const updateConfirmation = (rooms) => {
				if (!isAddRoomConfirmation || !highlightVariantId) return
				const room = rooms.find((item) => String(item?.id ?? "") === String(highlightVariantId))
				if (!room) return

				const roomName = text(room?.name, "Habitación")
				const photosCount = Number(room?.photos?.count ?? 0)
				const tariffCount = Number(room?.tariffs?.count ?? 0)
				const inventoryLabel = text(room?.inventory?.label, "Disponibilidad inicial abierta")
				const isComplete = Boolean(room?.states?.isComplete)

				setText(
					"confirmationTitle",
					isComplete ? `${roomName} lista para vender` : `${roomName} casi lista`
				)
				setText(
					"confirmationDescription",
					isComplete
						? `${roomName} ya tiene perfil, fotos, tarifa, condiciones y disponibilidad inicial. Ahora puedes revisarla o volver al listado operativo.`
						: `${roomName} ya avanzó en el asistente. Revisa los puntos pendientes antes de dejarla como vendible.`
				)
				setText("confirmationProfileStatus", room?.states?.capacityComplete ? "Listo" : "Pendiente")
				setText(
					"confirmationPhotosStatus",
					photosCount > 0 ? `${photosCount} foto${photosCount === 1 ? "" : "s"}` : "Pendientes"
				)
				setText(
					"confirmationRateStatus",
					tariffCount > 0 ? `${tariffCount} tarifa${tariffCount === 1 ? "" : "s"}` : "Pendiente"
				)
				setText("confirmationAvailabilityStatus", inventoryLabel)
			}

			const statusClass = (tone) => {
				if (tone === "ok") return "bg-emerald-50 text-emerald-800"
				if (tone === "warn") return "bg-amber-50 text-amber-800"
				return "bg-slate-50 text-slate-700"
			}

			const pill = (label, tone) => {
				const element = document.createElement("span")
				element.className = `inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-medium ${statusClass(tone)}`
				element.textContent = label
				return element
			}

			const checklistItem = (label, value, complete) => {
				const wrapper = document.createElement("div")
				wrapper.className =
					"flex min-w-0 items-center justify-between gap-3 bg-slate-50 px-3.5 py-3"
				const copy = document.createElement("div")
				copy.className = "min-w-0"
				const title = document.createElement("p")
				title.className = "text-[11px] font-semibold tracking-wide text-slate-500 uppercase"
				title.textContent = label
				const body = document.createElement("p")
				body.className = "mt-1 truncate text-sm font-medium text-slate-900"
				body.textContent = value
				copy.append(title, body)
				if (complete) {
					const check = document.createElement("span")
					check.className =
						"inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-600 text-[11px] font-semibold text-white"
					check.textContent = "✓"
					wrapper.append(copy, check)
				} else {
					const pending = document.createElement("span")
					pending.className =
						"inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-slate-200"
					wrapper.append(copy, pending)
				}
				return wrapper
			}

			const compactAvailabilityLabel = (room) => {
				const days = Number(room?.inventory?.days ?? 0)
				if (days > 0) return `${days} noche${days === 1 ? "" : "s"}`
				return "Pendiente"
			}

			const action = (href, label, primary) => {
				const link = document.createElement("a")
				link.href = href
				link.setAttribute("data-astro-prefetch", "")
				link.className = primary
					? "fastt-button inline-flex h-10 max-w-full items-center justify-center rounded-[var(--fastt-radius-control)] border border-slate-950 bg-slate-950 px-4 text-sm font-semibold whitespace-nowrap text-white hover:bg-slate-800"
					: "fastt-button inline-flex h-9 max-w-full items-center justify-center rounded-[var(--fastt-radius-control)] border border-slate-200 bg-white px-3 text-xs font-semibold whitespace-nowrap text-slate-700 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950"
				link.textContent = label
				return link
			}

			const roomState = (room) => {
				const photosCount = Number(room?.photos?.count ?? 0)
				const tariffCount = Number(room?.tariffs?.count ?? 0)
				if (Boolean(room?.states?.isComplete)) return "ready"
				if (tariffCount <= 0) return "no-rate"
				if (!room?.states?.inventoryComplete) return "no-availability"
				if (photosCount <= 0) return "no-photos"
				return "attention"
			}

			const setActiveFilter = (filter) => {
				activeRoomFilter = filter
				for (const button of document.querySelectorAll("[data-room-filter]")) {
					const active = button instanceof HTMLElement && button.dataset.roomFilter === filter
					button.setAttribute("data-active", active ? "true" : "false")
					button.setAttribute("aria-pressed", active ? "true" : "false")
				}
				applyRoomFilter()
			}

			const applyRoomFilter = () => {
				const list = document.getElementById("roomsList")
				const empty = document.getElementById("roomsFilteredEmpty")
				if (!list) return
				const cards = [...list.querySelectorAll("[data-room-state]")]
				if (cards.length === 0) {
					empty?.classList.add("hidden")
					return
				}
				let visible = 0
				for (const card of cards) {
					if (!(card instanceof HTMLElement)) continue
					const states = String(card.dataset.roomState ?? "").split(" ")
					const show =
						activeRoomFilter === "all" ||
						(activeRoomFilter === "attention" && !states.includes("ready")) ||
						states.includes(activeRoomFilter)
					card.classList.toggle("hidden", !show)
					if (show) visible += 1
				}
				empty?.classList.toggle("hidden", visible > 0)
			}

			const bindRoomFilterControls = () => {
				for (const button of document.querySelectorAll("[data-room-filter]")) {
					if (!(button instanceof HTMLElement)) continue
					if (button.dataset.roomFilterBound === "true") continue
					button.dataset.roomFilterBound = "true"
					button.addEventListener("click", () => {
						setActiveFilter(String(button.dataset.roomFilter || "attention"))
					})
				}
			}

			const roomCard = (room) => {
				const card = document.createElement("article")
				const isHighlighted =
					highlightVariantId && String(room?.id ?? "") === String(highlightVariantId)
				const photosCount = Number(room?.photos?.count ?? 0)
				const tariffCount = Number(room?.tariffs?.count ?? 0)
				const isComplete = Boolean(room?.states?.isComplete)
				const state = roomState(room)
				card.dataset.roomState = [
					state,
					isComplete ? "ready" : "attention",
					tariffCount <= 0 ? "no-rate" : "",
					!room?.states?.inventoryComplete ? "no-availability" : "",
					photosCount <= 0 ? "no-photos" : "",
				]
					.filter(Boolean)
					.join(" ")
				card.className =
					"room-card-shell group isolate overflow-visible border-none bg-transparent shadow-none"

				const layout = document.createElement("div")
				layout.className = "grid min-h-[260px] gap-0 md:grid-cols-[168px_minmax(0,1fr)]"

				const imageSlot = document.createElement("div")
				imageSlot.className =
					"room-card-image min-h-[180px] overflow-hidden bg-transparent md:min-h-full"
				const coverUrl = text(room?.photos?.coverUrl, "")
				if (coverUrl) {
					const image = document.createElement("img")
					image.src = coverUrl
					image.alt = `Foto de ${text(room?.name, "habitación")}`
					image.loading = "lazy"
					image.className =
						"room-card-image-media block h-full min-h-[180px] w-full object-cover md:min-h-full"
					imageSlot.append(image)
				} else {
					imageSlot.classList.add("flex", "items-center", "justify-center", "bg-slate-100")
					const placeholder = document.createElement("span")
					placeholder.className = "px-4 text-center text-sm font-medium text-slate-500"
					placeholder.textContent = "Agrega una foto para mostrar esta habitación"
					imageSlot.append(placeholder)
				}

				const body = document.createElement("div")
				body.className = `room-card-body space-y-4 bg-white p-5 shadow-none${
					isHighlighted ? " ring-2 ring-[var(--fastt-color-selection)]" : ""
				}`

				const top = document.createElement("div")
				top.className = "flex flex-wrap items-start justify-between gap-3"
				const titleBlock = document.createElement("div")
				titleBlock.className = "min-w-0 space-y-1"
				const name = document.createElement("h2")
				name.className = "text-xl font-semibold text-slate-950"
				name.textContent = text(room?.name, "Habitación")
				const type = document.createElement("p")
				type.className = "text-sm text-slate-600"
				type.textContent = text(room?.type?.label, text(room?.kindLabel, "Habitación"))
				titleBlock.append(name, type)
				const active = String(room?.status ?? "").toLowerCase() !== "archived"
				const readiness = isComplete
					? pill("Vendible", "ok")
					: state === "no-rate"
						? pill("Sin tarifa", "warn")
						: state === "no-availability"
							? pill("Sin disponibilidad", "warn")
							: pill(active ? "Requiere atención" : "Pausada", active ? "warn" : "neutral")
				top.append(titleBlock, readiness)

				const resumeParams = (step, extra = {}) => {
					const params = new URLSearchParams({
						playbook: "add-room",
						step,
						flow: "add-room",
						...extra,
					})
					return params.toString()
				}
				const resumeHref = (() => {
					const variantId = String(room?.id ?? "")
					if (!variantId) return "#"
					if (!room?.states?.capacityComplete) {
						return `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(variantId)}?${resumeParams("create-room")}`
					}
					if (photosCount <= 0) {
						return `/product/${encodeURIComponent(productId)}/rooms/${encodeURIComponent(variantId)}?${resumeParams("room-photos")}#fotos`
					}
					if (tariffCount <= 0) {
						return `/rates/plans/manage?${resumeParams("create-rate", { variantId, openDialog: "1" })}`
					}
					if (!room?.states?.inventoryComplete) {
						const params = new URLSearchParams(
							resumeParams("availability", { variantId, focus: "availability" })
						)
						return `/rates/calendar?${params.toString()}`
					}
					return `/product/${encodeURIComponent(productId)}/rooms?${resumeParams("confirmation", { variantId })}`
				})()

				const checklist = document.createElement("div")
				checklist.className =
					"grid overflow-hidden rounded-[var(--fastt-radius-card)] bg-slate-50 sm:grid-cols-2"
				checklist.append(
					checklistItem(
						"Perfil",
						text(room?.capacity?.label, "Pendiente"),
						Boolean(room?.states?.capacityComplete)
					),
					checklistItem(
						"Fotos",
						photosCount > 0 ? `${photosCount} foto${photosCount === 1 ? "" : "s"}` : "Pendientes",
						photosCount > 0
					),
					checklistItem(
						"Tarifas",
						tariffCount > 0 ? `${tariffCount} tarifa${tariffCount === 1 ? "" : "s"}` : "Pendientes",
						tariffCount > 0
					),
					checklistItem(
						"Disponibilidad",
						compactAvailabilityLabel(room),
						Boolean(room?.states?.inventoryComplete)
					)
				)

				const tariffNames = Array.isArray(room?.tariffs?.names) ? room.tariffs.names : []
				const tariffSummary = document.createElement("p")
				tariffSummary.className = "text-sm text-slate-600"
				tariffSummary.textContent =
					tariffNames.length > 0
						? `Se vende con: ${tariffNames.slice(0, 3).join(", ")}${tariffNames.length > 3 ? "..." : ""}`
						: "Agrega una tarifa para definir cómo se vende esta habitación."

				const missing = []
				if (!room?.states?.capacityComplete) missing.push("perfil")
				if (photosCount <= 0) missing.push("fotos")
				if (tariffCount <= 0) missing.push("tarifas")
				if (!room?.states?.inventoryComplete) missing.push("calendario")

				let primaryHref = text(room?.actions?.detailHref, "#")
				let primaryLabel = "Ver habitación"
				let nextCopy = "Lista para mostrarse con confianza en la ficha pública."
				if (!room?.states?.capacityComplete) {
					primaryHref = resumeHref
					primaryLabel = "Completar perfil"
					nextCopy = "Siguiente paso recomendado: completar perfil."
				} else if (photosCount <= 0) {
					primaryHref = resumeHref
					primaryLabel = "Agregar fotos"
					nextCopy = "Siguiente paso recomendado: agregar fotos."
				} else if (tariffCount <= 0) {
					primaryHref = resumeHref
					primaryLabel = "Crear tarifa"
					nextCopy = "Siguiente paso recomendado: crear una tarifa."
				} else if (!room?.states?.inventoryComplete) {
					primaryHref = resumeHref
					primaryLabel = "Abrir disponibilidad"
					nextCopy = "Siguiente paso recomendado: abrir disponibilidad."
				}

				const footer = document.createElement("div")
				footer.className = "grid min-w-0 gap-3"
				const nextStep = document.createElement("p")
				nextStep.className = "min-w-0 text-sm leading-6 text-slate-600"
				if (isHighlighted && addRoomPlaybookActive) {
					nextStep.className = "text-sm font-semibold leading-6 text-slate-950"
					nextStep.textContent = isComplete
						? "Habitación lista para vender."
						: "Habitación creada. Revisa el siguiente paso si aún falta algo."
				} else {
					nextStep.textContent = nextCopy
				}

				const actionRow = document.createElement("div")
				actionRow.className = "flex w-full min-w-0 flex-wrap items-center justify-end gap-2"
				actionRow.append(action(primaryHref, primaryLabel, true))
				const more = document.createElement("details")
				more.className = "relative shrink-0"
				const summary = document.createElement("summary")
				summary.className =
					"fastt-button inline-flex h-10 cursor-pointer list-none items-center justify-center rounded-[var(--fastt-radius-control)] border border-slate-200 bg-white px-3 text-sm font-semibold whitespace-nowrap text-slate-700 hover:border-slate-300 hover:bg-slate-50"
				summary.textContent = "Más"
				const menu = document.createElement("div")
				menu.className =
					"fastt-soft-box absolute right-0 z-20 mt-2 w-44 space-y-1 border border-slate-200 bg-white p-1.5 shadow-lg"
				menu.append(
					action(text(room?.actions?.detailHref, "#"), "Editar habitación", false),
					action(text(room?.actions?.tariffsHref, "/rates/plans/manage"), "Tarifas", false),
					action(text(room?.actions?.calendarHref, "#"), "Calendario", false),
					action(text(room?.actions?.conditionsHref, "/rates/plans/manage"), "Condiciones", false),
					action(resumeHref, "Guía paso a paso", false)
				)
				for (const link of menu.querySelectorAll("a")) {
					link.classList.add("w-full", "justify-start")
				}
				more.append(summary, menu)
				actionRow.append(more)
				footer.append(nextStep, actionRow)

				body.append(top, checklist, tariffSummary, footer)
				layout.append(imageSlot, body)
				card.append(layout)
				return card
			}

			const bootRoomsSummaryPage = () => {
				const root = document.querySelector("[data-rooms-summary-page]")
				if (!(root instanceof HTMLElement)) return
				if (root.dataset.productId !== productId) return
				bindRoomFilterControls()
				if (
					root.dataset.roomsSummaryState === "loading" ||
					root.dataset.roomsSummaryState === "ready"
				) {
					return
				}
				root.dataset.roomsSummaryState = "loading"

				fetch(`/api/internal/rooms-summary?productId=${encodeURIComponent(productId)}`, {
					headers: { accept: "application/json" },
				})
					.then(async (response) => {
						if (!response.ok) throw new Error(`rooms_summary_${response.status}`)
						return await response.json()
					})
					.then((payload) => {
						const rooms = Array.isArray(payload?.variants) ? payload.variants : []
						const list = document.getElementById("roomsList")
						const skeleton = document.getElementById("roomsSkeleton")
						const empty = document.getElementById("roomsEmptyState")

						const readyCount = rooms.filter((room) => Boolean(room?.states?.isComplete)).length
						const noRateCount = rooms.filter(
							(room) => Number(room?.tariffs?.count ?? 0) <= 0
						).length
						const noAvailabilityCount = rooms.filter(
							(room) => !room?.states?.inventoryComplete
						).length
						const attentionCount = Math.max(0, rooms.length - readyCount)

						setText("roomsTabAttention", attentionCount)
						setText("roomsTabReady", readyCount)
						setText("roomsTabNoRate", noRateCount)
						setText("roomsTabNoAvailability", noAvailabilityCount)
						setText("roomsTabAll", rooms.length)

						if (list) {
							list.innerHTML = ""
							for (const room of rooms) list.append(roomCard(room))
						}
						updateConfirmation(rooms)
						if (activeRoomFilter === "attention" && attentionCount === 0 && readyCount > 0) {
							setActiveFilter("ready")
						}
						applyRoomFilter()

						skeleton?.classList.add("hidden")
						if (rooms.length > 0) {
							list?.classList.remove("hidden")
							empty?.classList.add("hidden")
						} else {
							list?.classList.add("hidden")
							empty?.classList.remove("hidden")
						}
						root.dataset.roomsSummaryState = "ready"
					})
					.catch(() => {
						root.dataset.roomsSummaryState = "error"
						const skeleton = document.getElementById("roomsSkeleton")
						if (skeleton) {
							skeleton.innerHTML =
								'<article class="rounded-xl border border-slate-200 bg-slate-100 p-5 text-sm text-slate-600">No se pudo cargar la ficha de habitaciones.</article>'
						}
					})
			}

			document.addEventListener("astro:page-load", bootRoomsSummaryPage)
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", bootRoomsSummaryPage, { once: true })
			} else {
				bootRoomsSummaryPage()
			}
		})()
	</script>
</Layout>
