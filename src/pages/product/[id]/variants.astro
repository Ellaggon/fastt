---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import { productRepository } from "@/container"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { isHotelProductType } from "@/lib/productVerticalRegistry"
import { routes } from "@/lib/routes"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product/create")

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect("/product/create")
if (!isHotelProductType(owned.productType)) return Astro.redirect(routes.productDetail(productId))
---

<WorkspaceLayout title="Contenido del alojamiento · Habitaciones">
	<section class="space-y-8">
		<header class="space-y-4">
			<div class="flex flex-wrap items-start justify-between gap-4">
				<div class="space-y-2">
					<h1 class="text-3xl font-semibold text-slate-100">Habitaciones</h1>
					<p class="text-sm text-slate-400">
						Configura habitaciones, capacidad e inventario base. Tarifas, precios y restricciones
						viven en Habitaciones y tarifas.
					</p>
					<p id="productDisplayName" class="text-sm text-slate-300">Alojamiento: {owned.name}</p>
				</div>
				<Badge id="productStatusBadge" variant="neutral">Cargando estado...</Badge>
			</div>
		</header>

		<Section
			title="Estado general"
			description="Resumen de configuración de habitaciones."
			className="space-y-4"
		>
			<Card class="space-y-6 border-slate-700 bg-slate-900 text-white">
				<div
					class="rounded-lg border border-slate-700 bg-slate-950 p-4 text-sm leading-6 text-slate-300"
				>
					<p class="font-semibold text-slate-100">Habitaciones y capacidad</p>
					<p>
						Las habitaciones definen el contexto físico. La cobertura comercial se gestiona desde
						Habitaciones y tarifas.
					</p>
				</div>
				<div class="space-y-4">
					<div class="h-2 w-full overflow-hidden rounded-full bg-slate-700">
						<div id="variantsProgressBar" class="h-full w-0 bg-[#1E3A8A]"></div>
					</div>
					<div class="grid gap-4 text-sm md:grid-cols-3">
						<div class="min-h-[90px] rounded-lg border border-slate-700 p-3">
							<p class="text-slate-300">Total habitaciones</p>
							<p id="variantsTotal" class="text-xl font-semibold text-white">—</p>
						</div>
						<div class="min-h-[90px] rounded-lg border border-slate-700 p-3">
							<p class="text-slate-300">Completas</p>
							<p id="variantsCompleted" class="text-xl font-semibold text-white">—</p>
						</div>
						<div class="min-h-[90px] rounded-lg border border-slate-700 p-3">
							<p class="text-slate-300">Incompletas</p>
							<p id="variantsIncomplete" class="text-xl font-semibold text-white">—</p>
						</div>
					</div>
				</div>
				<div class="flex justify-end">
					<Button
						href={`/product/${encodeURIComponent(productId)}/variants/new`}
						data-astro-prefetch
						className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
					>
						Crear habitación
					</Button>
				</div>
			</Card>
		</Section>

		<Section
			title="Lista de habitaciones"
			description="Configura cada habitación por bloques operativos."
		>
			<div id="variantsEmptyState" class="hidden">
				<Card class="min-h-[220px] space-y-4 bg-slate-100">
					<div class="space-y-1">
						<h2 class="text-xl font-semibold text-slate-900">Aún no hay habitaciones</h2>
						<p class="text-sm text-slate-600">
							Crea la primera habitación para habilitar capacidad, inventario base y tarifas.
						</p>
					</div>
					<div class="flex justify-end">
						<Button
							href={`/product/${encodeURIComponent(productId)}/variants/new`}
							data-astro-prefetch
							className="bg-[#1E3A8A] text-white hover:bg-[#1e40af]"
						>
							Crear habitación
						</Button>
					</div>
				</Card>
			</div>

			<div id="variantsListSkeleton" class="space-y-4">
				{
					Array.from({ length: 3 }).map(() => (
						<Card class="min-h-[158px] space-y-4 bg-slate-100">
							<div class="grid gap-4 lg:grid-cols-[1fr_auto_auto] lg:items-start">
								<div class="space-y-2">
									<div class="h-5 w-44 animate-pulse rounded bg-slate-200" />
									<div class="h-4 w-28 animate-pulse rounded bg-slate-200" />
								</div>
								<div class="flex flex-wrap items-center gap-2">
									<div class="h-6 w-20 animate-pulse rounded-full bg-slate-200" />
									<div class="h-6 w-20 animate-pulse rounded-full bg-slate-200" />
									<div class="h-6 w-20 animate-pulse rounded-full bg-slate-200" />
									<div class="h-6 w-20 animate-pulse rounded-full bg-slate-200" />
								</div>
								<div class="flex flex-col items-stretch gap-2 lg:items-end">
									<div class="h-10 w-48 animate-pulse rounded bg-slate-200" />
									<div class="h-4 w-20 animate-pulse rounded bg-slate-200" />
								</div>
							</div>
						</Card>
					))
				}
			</div>

			<div id="variantsList" class="hidden space-y-4"></div>
		</Section>
	</section>

	<script is:inline define:vars={{ productId }}>
		;(function () {
			const shellStart = performance.now()
			const logShellVisible = () => {
				console.debug("shell visible", {
					page: "variants-surface",
					durationMs: Number((performance.now() - shellStart).toFixed(1)),
				})
			}
			if (document.readyState === "complete" || document.readyState === "interactive") {
				logShellVisible()
			} else {
				document.addEventListener("DOMContentLoaded", logShellVisible, { once: true })
			}

			if (!productId) return

			const badgeClass = (complete) =>
				`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
					complete
						? "bg-green-100 text-green-800 border-green-200"
						: "bg-orange-100 text-orange-800 border-orange-200"
				}`

			const sectionBadge = (label, complete) => {
				const span = document.createElement("span")
				span.className = badgeClass(complete)
				span.textContent = label
				return span
			}

			const hydrationStart = performance.now()
			fetch(`/api/internal/variants-summary?productId=${encodeURIComponent(productId)}`, {
				headers: { accept: "application/json" },
			})
				.then(async (response) => {
					if (!response.ok) throw new Error(`variants_summary_${response.status}`)
					return await response.json()
				})
				.then((payload) => {
					const productDisplayName = document.getElementById("productDisplayName")
					const productStatusBadge = document.getElementById("productStatusBadge")
					const progressBar = document.getElementById("variantsProgressBar")
					const total = document.getElementById("variantsTotal")
					const completed = document.getElementById("variantsCompleted")
					const incomplete = document.getElementById("variantsIncomplete")
					const emptyState = document.getElementById("variantsEmptyState")
					const skeleton = document.getElementById("variantsListSkeleton")
					const list = document.getElementById("variantsList")

					if (productDisplayName)
						productDisplayName.textContent = `Alojamiento: ${String(payload?.product?.displayName ?? "")}`
					if (productStatusBadge) {
						productStatusBadge.textContent = String(payload?.product?.statusLabel ?? "Borrador")
						productStatusBadge.className = `inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${
							payload?.product?.statusVariant === "success"
								? "bg-green-100 text-green-800 border-green-200"
								: payload?.product?.statusVariant === "info"
									? "bg-blue-100 text-blue-800 border-blue-200"
									: "bg-orange-100 text-orange-800 border-orange-200"
						}`
					}
					if (progressBar)
						progressBar.style.width = `${Math.max(0, Math.min(100, Number(payload?.progress?.progressPercent ?? 0)))}%`
					if (total) total.textContent = String(payload?.progress?.totalVariants ?? 0)
					if (completed) completed.textContent = String(payload?.progress?.completedVariants ?? 0)
					if (incomplete)
						incomplete.textContent = String(payload?.progress?.incompleteVariants ?? 0)

					const variants = Array.isArray(payload?.variants) ? payload.variants : []
					if (list) {
						list.innerHTML = ""
						for (const variant of variants) {
							const card = document.createElement("article")
							card.className = "rounded-lg border border-slate-200 bg-slate-100 p-6 space-y-4"

							const wrapper = document.createElement("div")
							wrapper.className = "grid gap-4 lg:grid-cols-[1fr_auto_auto] lg:items-start"

							const left = document.createElement("div")
							left.className = "space-y-1"
							const name = document.createElement("p")
							name.className = "text-lg font-semibold text-slate-900"
							name.textContent = String(variant?.name ?? "Variante")
							const kind = document.createElement("p")
							kind.className = "text-sm text-slate-600"
							kind.textContent = String(variant?.kindLabel ?? "Sin tipo")
							left.append(name, kind)

							const middle = document.createElement("div")
							middle.className = "flex flex-wrap items-center gap-2"
							middle.append(
								sectionBadge("Capacidad", Boolean(variant?.states?.capacityComplete)),
								sectionBadge("Subtipo", Boolean(variant?.states?.subtypeComplete)),
								sectionBadge("Cobertura comercial", Boolean(variant?.states?.pricingComplete)),
								sectionBadge("Inventario", Boolean(variant?.states?.inventoryComplete))
							)

							const right = document.createElement("div")
							right.className = "flex flex-col items-stretch gap-2 lg:items-end"

							const primary = document.createElement("a")
							primary.href = String(variant?.actions?.detailHref ?? "#")
							primary.className =
								"inline-flex h-10 items-center justify-center rounded-lg bg-[#1E3A8A] px-4 text-sm font-medium text-white hover:bg-[#1e40af]"
							primary.textContent = "Continuar configuración"
							primary.setAttribute("data-astro-prefetch", "")

							const secondary = document.createElement("a")
							secondary.href = String(variant?.actions?.detailHref ?? "#")
							secondary.className = "text-sm font-medium text-slate-600 hover:text-slate-900"
							secondary.textContent = "Ver detalle"

							right.append(primary, secondary)
							wrapper.append(left, middle, right)
							card.append(wrapper)
							list.append(card)
						}
					}

					if (skeleton) skeleton.classList.add("hidden")
					if (variants.length > 0) {
						list?.classList.remove("hidden")
						emptyState?.classList.add("hidden")
					} else {
						emptyState?.classList.remove("hidden")
						list?.classList.add("hidden")
					}

					console.debug("data hydrated", {
						page: "variants-surface",
						durationMs: Number((performance.now() - hydrationStart).toFixed(1)),
					})
				})
				.catch(() => {
					const skeleton = document.getElementById("variantsListSkeleton")
					if (skeleton) {
						skeleton.innerHTML =
							'<article class="rounded-lg border border-slate-200 bg-slate-100 p-6"><p class="text-sm text-slate-600">No se pudo cargar el resumen de variantes.</p></article>'
					}
				})
		})()
	</script>
</WorkspaceLayout>
