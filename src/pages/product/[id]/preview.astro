---
import { buildGuestRoomPreviews } from "@/components/productUI/room-section.viewmodel"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import Section from "@/components/ui/Section.astro"
import { productRepository } from "@/container"
import { POLICY_CATEGORY_ORDER } from "@/data/policy/policy-categories"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProductVerticalEntry } from "@/lib/catalog/productVerticalRegistry"
import { routes } from "@/lib/routes"
import {
	getProductFullAggregate,
	getProductVariantsAggregate,
	resolveHotelAmenities,
	resolveHotelType,
} from "@/modules/catalog/public"
import {
	essentialHouseRuleTypes,
	houseRuleGroups,
	houseRuleLabels,
} from "@/modules/house-rules/presentation/houseRulePresentation"
import { buildGuestStayExpectationsSnapshot } from "@/modules/house-rules/public"
import { mapResolvedPoliciesToUI, resolveEffectivePolicies } from "@/modules/policies/public"
import { and, asc, db, Image, inArray } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect(routes.productList())

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect(routes.productList())

const aggregate = await getProductFullAggregate(productId, providerId)
if (!aggregate) return Astro.redirect(routes.productList())

const vertical = getProductVerticalEntry(aggregate.productType)
const isHotel = vertical.vertical === "hotel"
const publicDetailHref = vertical.routes.publicDetailHref(productId)
const requiredPolicyCategories = ["Cancellation", "Payment", "CheckIn", "NoShow"]
const highlights = Array.isArray(aggregate.content.highlights) ? aggregate.content.highlights : []
const description = String(aggregate.content.description ?? "").trim()
const primaryImage = aggregate.images[0]?.url ?? ""
const imagePreviews = aggregate.images.slice(0, 6)
const productFallbackGallery = aggregate.images
	.map((image) => String(image.url ?? "").trim())
	.filter(Boolean)
const packageIncludes =
	aggregate.subtype?.kind === "package" ? String(aggregate.subtype.includes ?? "").trim() : ""
const packageExcludes =
	aggregate.subtype?.kind === "package" ? String(aggregate.subtype.excludes ?? "").trim() : ""
const packageInclusionItems = packageIncludes
	.split(/\r?\n|,/)
	.map((item) => item.trim())
	.filter(Boolean)
const packageExclusionItems = packageExcludes
	.split(/\r?\n|,/)
	.map((item) => item.trim())
	.filter(Boolean)

const guestExpectationsSnapshot = isHotel
	? await buildGuestStayExpectationsSnapshot(productId)
	: null
const houseRules = guestExpectationsSnapshot?.rules ?? []
const houseRuleTypeSet = new Set(houseRules.map((rule: any) => String(rule.type ?? "")))
const missingHouseRules = isHotel
	? essentialHouseRuleTypes.filter((type) => !houseRuleTypeSet.has(type))
	: []
const houseRuleLabelByType = houseRuleLabels as Record<string, string>
const houseRulesByType = houseRules.reduce((acc: Record<string, any[]>, rule: any) => {
	const type = String(rule.type ?? "Other")
	if (!acc[type]) acc[type] = []
	acc[type].push(rule)
	return acc
}, {})

let guestRoomPreviews: ReturnType<typeof buildGuestRoomPreviews> = []
if (isHotel) {
	const variantsAggregate = await getProductVariantsAggregate(productId, providerId)
	const roomVariants = variantsAggregate?.variants ?? []
	const roomVariantIds = roomVariants
		.map((variant: any) => String(variant.id ?? "").trim())
		.filter(Boolean)
	const [roomProfiles, roomAmenities, variantImageRows] = roomVariantIds.length
		? await Promise.all([
				resolveHotelType(roomVariantIds),
				resolveHotelAmenities(roomVariantIds),
				db
					.select({
						id: Image.id,
						entityId: Image.entityId,
						url: Image.url,
						order: Image.order,
						isPrimary: Image.isPrimary,
					})
					.from(Image)
					.where(
						and(
							inArray(Image.entityType, ["variant", "Variant"]),
							inArray(Image.entityId, roomVariantIds)
						)
					)
					.orderBy(asc(Image.order), asc(Image.id))
					.all(),
			])
		: [[], [], []]
	const imagesByVariant = new Map<string, any[]>()
	for (const image of variantImageRows) {
		const variantId = String(image.entityId ?? "")
		if (!imagesByVariant.has(variantId)) imagesByVariant.set(variantId, [])
		imagesByVariant.get(variantId)?.push({
			id: String(image.id),
			url: String(image.url),
			order: Number(image.order ?? 0),
			isPrimary: Boolean(image.isPrimary),
		})
	}

	guestRoomPreviews = buildGuestRoomPreviews({
		offers: roomVariants.map((variant: any) => ({
			variantId: variant.id,
			variant: {
				id: variant.id,
				name: variant.name,
				maxOccupancy: variant.capacity?.maxOccupancy ?? null,
			},
			variantImages: imagesByVariant.get(String(variant.id)) ?? [],
		})),
		hotelRoom: roomProfiles,
		amenities: roomAmenities,
		productFallbackImage: primaryImage || "https://placehold.co/1200x800?text=Habitacion",
		productFallbackGallery,
	})
}

let mappedPolicies: any[] = []
let policyResolutionError: string | null = null
try {
	const resolvedPolicies = await resolveEffectivePolicies({
		productId,
		channel: "web",
		requiredCategories: requiredPolicyCategories,
		onMissingCategory: "return_null",
		featureContext: {
			request: Astro.request,
			query: Astro.url.searchParams,
		},
	})
	mappedPolicies = mapResolvedPoliciesToUI(resolvedPolicies) as any[]
} catch (error) {
	policyResolutionError = error instanceof Error ? error.message : "Could not resolve policies"
}

const policyCategorySet = new Set(
	mappedPolicies.map((policy: any) => String(policy.category ?? ""))
)
const missingPolicies = requiredPolicyCategories.filter(
	(category) => !policyCategorySet.has(category)
)

const checks = [
	{
		key: "content",
		label: "Contenido visible para huéspedes",
		complete: Boolean(description && highlights.length),
		href: `/product/${encodeURIComponent(productId)}/content`,
		cta: "Editar contenido",
		detail:
			description && highlights.length
				? "Descripción y destacados listos."
				: "Agrega descripción y al menos un destacado.",
	},
	{
		key: "photos",
		label: "Fotos",
		complete: aggregate.images.length > 0,
		href: `/product/${encodeURIComponent(productId)}/images`,
		cta: "Editar fotos",
		detail: aggregate.images.length
			? `${aggregate.images.length} fotos disponibles.`
			: "Agrega al menos una foto.",
	},
	{
		key: "location",
		label: "Ubicación",
		complete: aggregate.location.lat !== null && aggregate.location.lng !== null,
		href: `/product/${encodeURIComponent(productId)}/location`,
		cta: "Editar ubicación",
		detail:
			aggregate.location.lat !== null && aggregate.location.lng !== null
				? "Coordenadas configuradas."
				: "Agrega coordenadas antes de publicar.",
	},
	...(isHotel
		? [
				{
					key: "house-rules",
					label: "Reglas para huéspedes",
					complete: missingHouseRules.length === 0,
					href: routes.providerHouseRules(),
					cta: "Revisar reglas",
					detail: missingHouseRules.length
						? `Faltan: ${missingHouseRules.map((type) => houseRuleLabels[type] ?? type).join(", ")}.`
						: "Reglas principales listas.",
				},
			]
		: []),
	...(vertical.vertical === "package"
		? [
				{
					key: "package-inclusions",
					label: "Incluye / No incluye",
					complete: packageInclusionItems.length > 0,
					href: `/product/${encodeURIComponent(productId)}/subtype`,
					cta: "Editar inclusiones",
					detail: packageInclusionItems.length
						? `${packageInclusionItems.length} inclusiones visibles.`
						: "Agrega qué incluye el paquete antes de publicar.",
				},
			]
		: []),
	{
		key: "booking-policies",
		label: "Condiciones de reserva",
		complete: missingPolicies.length === 0 && !policyResolutionError,
		href: routes.providerPolicies(),
		cta: "Revisar condiciones",
		detail: policyResolutionError
			? "No se pudieron resolver las condiciones."
			: missingPolicies.length
				? `Faltan: ${missingPolicies.map((category) => POLICY_CATEGORY_ORDER[category as keyof typeof POLICY_CATEGORY_ORDER] ?? category).join(", ")}.`
				: "Condiciones principales visibles.",
	},
]

const completedChecks = checks.filter((check) => check.complete).length
const readyToPublish = completedChecks === checks.length
const readinessPercent = Math.round((completedChecks / checks.length) * 100)
---

<WorkspaceLayout title="Catálogo · Vista previa">
	<section class="space-y-8">
		<header class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
					Catálogo · Revisión antes de publicar
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">Vista previa</h1>
				<p class="max-w-3xl text-sm leading-6 text-slate-300">
					Confirma qué entenderán los viajeros antes de reservar: fotos, contenido, condiciones
					{isHotel ? " y reglas de la casa" : ""}. Esta revisión no cambia precios, inventario ni
					venta.
				</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				<Button href={routes.productDetail(productId)} variant="secondary"
					>Volver a {vertical.labels.singular}</Button
				>
				{
					publicDetailHref ? (
						<Button href={publicDetailHref} variant="secondary">
							Abrir página pública
						</Button>
					) : null
				}
			</div>
		</header>

		<section class="grid gap-4 lg:grid-cols-[0.8fr_1.2fr]">
			<Card className="space-y-4 border-slate-800 bg-slate-950 text-slate-100">
				<div class="flex items-start justify-between gap-3">
					<div>
						<p class="text-sm font-semibold">Estado de publicación</p>
						<p class="mt-1 text-sm text-slate-400">
							{completedChecks} de {checks.length} bloques principales listos.
						</p>
					</div>
					<Badge variant={readyToPublish ? "success" : "warning"}>
						{readyToPublish ? "Listo para publicar" : `${readinessPercent}% listo`}
					</Badge>
				</div>
				<div class="h-2 overflow-hidden rounded-full bg-slate-800">
					<div class="h-full bg-blue-600" style={`width: ${readinessPercent}%`}></div>
				</div>
				<p class="text-sm text-slate-300">
					{
						readyToPublish
							? "El viajero puede ver una ficha coherente con contenido y condiciones claras."
							: "Revisa lo pendiente antes de publicar."
					}
				</p>
			</Card>

			<Card className="space-y-3 bg-white text-slate-800">
				<div class="flex flex-wrap items-start justify-between gap-3">
					<div>
						<p class="text-sm font-semibold text-slate-900">Antes de publicar</p>
						<p class="mt-1 text-sm text-slate-600">
							Una revisión simple para que la ficha sea clara para el huésped.
						</p>
					</div>
					{
						isHotel ? (
							<Button href={routes.providerHouseRules()} variant="secondary" size="sm">
								Reglas para huéspedes
							</Button>
						) : null
					}
				</div>
				<div class="grid gap-3 md:grid-cols-2">
					{
						checks.map((check) => (
							<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
								<div class="flex items-start justify-between gap-3">
									<div>
										<p class="text-sm font-semibold text-slate-900">{check.label}</p>
										<p class="mt-1 text-xs leading-5 text-slate-600">{check.detail}</p>
									</div>
									<Badge variant={check.complete ? "success" : "warning"}>
										{check.complete ? "Listo" : "Revisar"}
									</Badge>
								</div>
								<div class="mt-3">
									<Button href={check.href} variant="secondary" size="sm">
										{check.cta}
									</Button>
								</div>
							</div>
						))
					}
				</div>
			</Card>
		</section>

		<Section
			title="Vista previa"
			description="Cómo se lee la ficha con contenido, fotos y condiciones visibles para viajeros."
		>
			<Card className="overflow-hidden bg-white p-0 text-slate-800">
				{
					primaryImage ? (
						<img src={primaryImage} alt={aggregate.displayName} class="h-72 w-full object-cover" />
					) : (
						<div class="flex h-72 items-center justify-center bg-slate-100 text-sm text-slate-500">
							Agrega fotos para dar una primera impresión clara.
						</div>
					)
				}
				<div class="space-y-6 p-5">
					<div class="flex flex-wrap items-start justify-between gap-4">
						<div>
							<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
								{vertical.labels.workspaceSingular}
							</p>
							<h2 class="mt-1 text-2xl font-semibold text-slate-950">{aggregate.displayName}</h2>
							<p class="mt-1 text-sm text-slate-500">
								{aggregate.location.address || "Ubicación pendiente"}
							</p>
						</div>
						<Badge variant={readyToPublish ? "success" : "warning"}>
							{readyToPublish ? "Lista para huéspedes" : "Borrador"}
						</Badge>
					</div>

					{
						imagePreviews.length > 1 ? (
							<div class="grid grid-cols-3 gap-2 md:grid-cols-6">
								{imagePreviews.map((image) => (
									<img src={image.url} alt="Listing preview" class="h-20 rounded-md object-cover" />
								))}
							</div>
						) : null
					}

					<div class="grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
						<div class="space-y-4">
							<div>
								<p class="text-sm font-semibold text-slate-900">Sobre esta oferta</p>
								<p class="mt-2 text-sm leading-6 text-slate-700">
									{
										description ||
											"Agrega una descripción clara para que el viajero entienda la oferta."
									}
								</p>
							</div>
							<div>
								<p class="text-sm font-semibold text-slate-900">Destacados</p>
								{
									highlights.length ? (
										<ul class="mt-2 grid gap-2 text-sm text-slate-700 md:grid-cols-2">
											{highlights.map((item) => (
												<li class="rounded-md bg-slate-50 px-3 py-2">{String(item)}</li>
											))}
										</ul>
									) : (
										<p class="mt-2 text-sm text-slate-500">
											Agrega al menos un destacado visible para viajeros.
										</p>
									)
								}
							</div>
						</div>

						<div class="space-y-4 rounded-lg border border-slate-200 bg-slate-50 p-4">
							<p class="text-sm font-semibold text-slate-900">Confianza de reserva</p>
							<p class="text-sm leading-6 text-slate-600">
								Los viajeros deben entender cancelación, pagos, no-show y check-in antes de
								reservar.
							</p>
							<div class="flex flex-wrap gap-2">
								{
									requiredPolicyCategories.map((category) => (
										<Badge variant={policyCategorySet.has(category) ? "success" : "neutral"}>
											{POLICY_CATEGORY_ORDER[category as keyof typeof POLICY_CATEGORY_ORDER] ??
												category}
										</Badge>
									))
								}
							</div>
						</div>
					</div>
				</div>
			</Card>
		</Section>

		{
			isHotel ? (
				<Section
					title="Dónde dormirán los huéspedes"
					description="Vista de habitaciones, camas, baño, fotos y comodidades como aparecerán en la ficha pública."
				>
					{guestRoomPreviews.length ? (
						<div class="grid gap-4 lg:grid-cols-2">
							{guestRoomPreviews.map((preview) => (
								<Card className="overflow-hidden bg-white p-0 text-slate-800">
									<img
										src={preview.imageUrl}
										alt={preview.roomName}
										class="h-56 w-full object-cover"
									/>
									<div class="space-y-5 p-5">
										<div>
											<p class="text-xs font-semibold tracking-wide text-slate-500 uppercase">
												{preview.roomTypeName || "Habitación"}
											</p>
											<h3 class="mt-1 text-lg font-semibold text-slate-950">{preview.roomName}</h3>
											<p class="mt-1 text-sm text-slate-500">
												{[preview.sizeSummary, preview.viewSummary].filter(Boolean).join(" · ") ||
													"Detalle de habitación"}
											</p>
										</div>

										<div class="grid gap-3 text-sm leading-6 text-slate-700">
											<div>
												<p class="font-semibold text-slate-900">Dónde dormirás</p>
												{preview.sleepAreas.length ? (
													<div class="mt-2 grid gap-2">
														{preview.sleepAreas.map((area) => (
															<p class="rounded-lg bg-slate-50 px-3 py-2">
																<span class="font-medium text-slate-900">{area.label}:</span>{" "}
																{area.summary}
															</p>
														))}
													</div>
												) : (
													<p class="mt-1 text-slate-500">Camas por confirmar.</p>
												)}
											</div>
											<div class="grid gap-2 sm:grid-cols-2">
												<p class="rounded-lg bg-slate-50 px-3 py-2">
													<span class="font-medium text-slate-900">Baño:</span>{" "}
													{preview.bathroomSummary}
												</p>
												<p class="rounded-lg bg-slate-50 px-3 py-2">
													<span class="font-medium text-slate-900">Capacidad:</span>{" "}
													{preview.occupancySummary}
												</p>
											</div>
										</div>

										{preview.amenityLabels.length ? (
											<div>
												<p class="text-sm font-semibold text-slate-900">Comodidades visibles</p>
												<div class="mt-2 flex flex-wrap gap-2">
													{preview.amenityLabels.slice(0, 8).map((label) => (
														<span class="rounded-full bg-slate-50 px-3 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200">
															{label}
														</span>
													))}
													{preview.amenityLabels.length > 8 ? (
														<span class="rounded-full bg-slate-50 px-3 py-1 text-xs font-medium text-slate-500 ring-1 ring-slate-200">
															+{preview.amenityLabels.length - 8}
														</span>
													) : null}
												</div>
											</div>
										) : null}

										{preview.guestFacingNotes ? (
											<div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
												<p class="text-sm font-semibold text-slate-900">Notas para huéspedes</p>
												<p class="mt-1 text-sm leading-6 text-slate-600">
													{preview.guestFacingNotes}
												</p>
											</div>
										) : null}
									</div>
								</Card>
							))}
						</div>
					) : (
						<Card className="border-amber-200 bg-amber-50 text-amber-950">
							<p class="text-sm font-semibold">Aún no hay habitaciones listas para preview.</p>
							<p class="mt-1 text-sm leading-6">
								Completa la ficha de habitación con camas, baño, capacidad, fotos y notas para que
								el huésped pueda entender dónde dormirá.
							</p>
							<div class="mt-4">
								<Button
									href={`/product/${encodeURIComponent(productId)}/rooms`}
									variant="secondary"
									size="sm"
								>
									Editar habitaciones
								</Button>
							</div>
						</Card>
					)}
				</Section>
			) : null
		}

		{
			vertical.vertical === "package" ? (
				<Section
					title="Incluye / No incluye"
					description="Estas listas pertenecen al paquete. No son destacados editoriales."
				>
					<div class="grid gap-4 md:grid-cols-2">
						<Card className="bg-white text-slate-800">
							<p class="text-sm font-semibold text-slate-900">Incluye</p>
							{packageInclusionItems.length ? (
								<ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
									{packageInclusionItems.map((item) => (
										<li class="rounded-md bg-slate-50 px-3 py-2">{item}</li>
									))}
								</ul>
							) : (
								<p class="mt-2 text-sm text-slate-500">
									Agrega inclusiones visibles antes de publicar.
								</p>
							)}
						</Card>
						<Card className="bg-white text-slate-800">
							<p class="text-sm font-semibold text-slate-900">No incluye</p>
							{packageExclusionItems.length ? (
								<ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
									{packageExclusionItems.map((item) => (
										<li class="rounded-md bg-slate-50 px-3 py-2">{item}</li>
									))}
								</ul>
							) : (
								<p class="mt-2 text-sm text-slate-500">
									Las exclusiones son opcionales, pero ayudan a evitar dudas antes de reservar.
								</p>
							)}
						</Card>
					</div>
				</Section>
			) : null
		}

		<Section
			title="Condiciones que verá el huésped"
			description="Las condiciones de reserva viven en Condiciones. Esta vista solo confirma cómo se leen."
		>
			<div class="grid gap-4 md:grid-cols-2">
				{
					policyResolutionError ? (
						<Card className="border-red-200 bg-red-50 text-red-900">
							<p class="font-semibold">No se pudieron resolver las condiciones.</p>
							<p class="mt-1 text-sm">{policyResolutionError}</p>
						</Card>
					) : mappedPolicies.length ? (
						mappedPolicies.map((policy: any) => {
							const category = String(policy.category ?? "")
							return (
								<Card className="bg-white text-slate-800">
									<div class="flex items-start justify-between gap-3">
										<div>
											<p class="text-sm font-semibold text-slate-900">
												{POLICY_CATEGORY_ORDER[category as keyof typeof POLICY_CATEGORY_ORDER] ??
													category}
											</p>
											<p class="mt-1 text-sm leading-6 text-slate-600">
												{String(policy.description ?? "Sin detalle visible.")}
											</p>
										</div>
										<Badge variant="info">v{Number(policy.version ?? 0)}</Badge>
									</div>
								</Card>
							)
						})
					) : (
						<Card className="bg-white text-slate-700">
							<p class="font-semibold text-slate-900">Aún no hay condiciones visibles.</p>
							<p class="mt-1 text-sm">Agrega condiciones antes de publicar.</p>
						</Card>
					)
				}
			</div>
		</Section>

		{
			isHotel ? (
				<Section
					title="Reglas para huéspedes"
					description="Explican comportamiento y operación de estadía. No son precios, restricciones ni penalidades de cancelación."
				>
					<Card className="space-y-5 bg-white text-slate-800">
						{houseRules.length ? (
							<div class="grid gap-4 lg:grid-cols-2">
								{houseRuleGroups.map((group) => {
									const items = group.types.flatMap((type) => houseRulesByType[type] ?? [])
									if (!items.length) return null
									return (
										<div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
											<p class="text-sm font-semibold text-slate-900">{group.label}</p>
											<p class="mt-1 text-xs text-slate-500">{group.description}</p>
											<ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
												{items.map((rule: any) => {
													const type = String(rule.type ?? "Other")
													return (
														<li>
															<span class="font-medium text-slate-900">
																{houseRuleLabelByType[type] ?? "Otra regla"}:
															</span>{" "}
															{rule.summary}
														</li>
													)
												})}
											</ul>
										</div>
									)
								})}
							</div>
						) : (
							<div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-5">
								<p class="text-sm font-semibold text-slate-900">
									Aún no hay reglas para huéspedes.
								</p>
								<p class="mt-1 text-sm text-slate-600">
									Agrega reglas para que el huésped entienda comportamiento, llegada y salida.
								</p>
							</div>
						)}
					</Card>
				</Section>
			) : null
		}
	</section>
</WorkspaceLayout>
