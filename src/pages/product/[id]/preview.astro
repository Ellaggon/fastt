---
import GuestRoomPreviewCards from "@/components/productUI/GuestRoomPreviewCards.astro"
import { buildGuestRoomPreviews } from "@/components/productUI/room-section.viewmodel"
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import ProgressBar from "@/components/ui/ProgressBar.astro"
import { productRepository } from "@/container"
import { POLICY_CATEGORY_ORDER } from "@/data/policy/policy-categories"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import {
	buildCompleteToPublishHref,
	buildCompleteToPublishResumeHref,
	resolveCompleteToPublishPlaybookFromUrl,
} from "@/lib/playbook/complete-to-publish"
import { loadCompleteToPublishState } from "@/lib/playbook/evaluate-complete-to-publish-progress"
import {
	buildPlaybookHref,
	resolveLaunchPlaybookFromUrl,
} from "@/lib/playbook/launch-accommodation"
import { resolvePlaybookFromUrl } from "@/lib/playbook/resolve-playbook"
import { resolveReservationConditionsHref } from "@/lib/product-preview/resolveReservationConditionsHref"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProductVerticalEntry } from "@/lib/catalog/productVerticalRegistry"
import { routes } from "@/lib/routes"
import {
	getProductFullAggregate,
	getProductVariantsAggregate,
	resolveHotelAmenities,
	resolveHotelType,
} from "@/modules/catalog/public"
import { ArrowRight, BedDouble, CircleCheck, Hotel, ShieldCheck } from "@lucide/astro"
import {
	houseRuleGroups,
	houseRuleLabels,
} from "@/modules/house-rules/presentation/houseRulePresentation"
import { buildGuestStayExpectationsSnapshot } from "@/modules/house-rules/public"
import { mapResolvedPoliciesToUI, resolveEffectivePolicies } from "@/modules/policies/public"
import { and, asc, db, eq, Image, inArray, ProductStatus } from "astro:db"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect(routes.productList())

const owned = await productRepository.ensureProductOwnedByProvider(productId, providerId)
if (!owned) return Astro.redirect(routes.productList())

const aggregate = await getProductFullAggregate(productId, providerId)
if (!aggregate) return Astro.redirect(routes.productList())

const vertical = getProductVerticalEntry(aggregate.productType)
const isHotel = vertical.vertical === "hotel"
const publicDetailHref = vertical.routes.publicDetailHref(productId)

const statusRow = await db
	.select({ state: ProductStatus.state })
	.from(ProductStatus)
	.where(eq(ProductStatus.productId, productId))
	.get()
const productStatus = String(statusRow?.state ?? "draft")
	.trim()
	.toLowerCase()
const isPublished = productStatus === "published"

const publishState = await loadCompleteToPublishState({
	productId,
	providerId,
	request: Astro.request,
	url: Astro.url,
})
if (!publishState) return Astro.redirect(routes.productList())

const checks = publishState.checks
const completedChecks = publishState.completedChecks
const readyToPublish = publishState.readyToPublish && !isPublished
const readinessPercent = publishState.readinessPercent
const blockerLabels = publishState.blockers
	.filter((check) => check.sectionKey !== "preview")
	.map((check) => check.label)

const playbook = resolvePlaybookFromUrl(Astro.url, { isHotel })
const launchPlaybook = resolveLaunchPlaybookFromUrl(Astro.url)
const completePlaybook = resolveCompleteToPublishPlaybookFromUrl(Astro.url)
const flow = Astro.url.searchParams.get("flow")

if (!playbook.active && flow === "create") {
	return Astro.redirect(buildPlaybookHref(routes.productPreview(productId), "preview"))
}
if (!playbook.active && flow === "complete") {
	return Astro.redirect(buildCompleteToPublishHref(routes.productPreview(productId), "preview"))
}

const playbookId = playbook.active ? playbook.playbookId : null
const stepId =
	playbookId === "complete-to-publish"
		? (completePlaybook.stepId ?? "preview")
		: playbookId === "launch"
			? (launchPlaybook.stepId ?? "preview")
			: "preview"

function checkHref(check: (typeof checks)[number]) {
	if (playbookId === "complete-to-publish") {
		return buildCompleteToPublishHref(check.href, check.sectionKey)
	}
	return check.href
}

const completePreparationHref = buildCompleteToPublishResumeHref(productId, checks)
const description = String(aggregate.content.description ?? "").trim()
const highlights = Array.isArray(aggregate.content.highlights) ? aggregate.content.highlights : []
const primaryImage = aggregate.images[0]?.url ?? ""
const imagePreviews = aggregate.images.slice(0, 6)
const productFallbackGallery = aggregate.images
	.map((image) => String(image.url ?? "").trim())
	.filter(Boolean)
const packageIncludes =
	aggregate.subtype?.kind === "package" ? String(aggregate.subtype.includes ?? "").trim() : ""
const packageExcludes =
	aggregate.subtype?.kind === "package" ? String(aggregate.subtype.excludes ?? "").trim() : ""
const packageInclusionItems = packageIncludes
	.split(/\r?\n|,/)
	.map((item) => item.trim())
	.filter(Boolean)
const packageExclusionItems = packageExcludes
	.split(/\r?\n|,/)
	.map((item) => item.trim())
	.filter(Boolean)

const guestExpectationsSnapshot = isHotel
	? await buildGuestStayExpectationsSnapshot(productId)
	: null
const houseRules = guestExpectationsSnapshot?.rules ?? []
const houseRuleLabelByType = houseRuleLabels as Record<string, string>
const houseRulesByType = houseRules.reduce((acc: Record<string, any[]>, rule: any) => {
	const type = String(rule.type ?? "Other")
	if (!acc[type]) acc[type] = []
	acc[type].push(rule)
	return acc
}, {})

let guestRoomPreviews: ReturnType<typeof buildGuestRoomPreviews> = []
let conditionsHref = routes.rates()
if (isHotel) {
	const variantsAggregate = await getProductVariantsAggregate(productId, providerId)
	const roomVariants = variantsAggregate?.variants ?? []
	const roomVariantIds = roomVariants
		.map((variant: any) => String(variant.id ?? "").trim())
		.filter(Boolean)
	const [roomProfiles, roomAmenities, variantImageRows] = roomVariantIds.length
		? await Promise.all([
				resolveHotelType(roomVariantIds),
				resolveHotelAmenities(roomVariantIds),
				db
					.select({
						id: Image.id,
						entityId: Image.entityId,
						url: Image.url,
						order: Image.order,
						isPrimary: Image.isPrimary,
					})
					.from(Image)
					.where(
						and(
							inArray(Image.entityType, ["variant", "Variant"]),
							inArray(Image.entityId, roomVariantIds)
						)
					)
					.orderBy(asc(Image.order), asc(Image.id))
					.all(),
			])
		: [[], [], []]
	const imagesByVariant = new Map<string, any[]>()
	for (const image of variantImageRows) {
		const variantId = String(image.entityId ?? "")
		if (!imagesByVariant.has(variantId)) imagesByVariant.set(variantId, [])
		imagesByVariant.get(variantId)?.push({
			id: String(image.id),
			url: String(image.url),
			order: Number(image.order ?? 0),
			isPrimary: Boolean(image.isPrimary),
		})
	}

	guestRoomPreviews = buildGuestRoomPreviews({
		offers: roomVariants.map((variant: any) => ({
			variantId: variant.id,
			variant: {
				id: variant.id,
				name: variant.name,
				maxOccupancy: variant.capacity?.maxOccupancy ?? null,
			},
			variantImages: imagesByVariant.get(String(variant.id)) ?? [],
		})),
		hotelRoom: roomProfiles,
		amenities: roomAmenities,
		productFallbackImage: primaryImage || "https://placehold.co/1200x800?text=Habitacion",
		productFallbackGallery,
	})

	conditionsHref = await resolveReservationConditionsHref({ productId, variantIds: roomVariantIds })
}

const requiredPolicyCategories = ["Cancellation", "Payment", "CheckIn", "NoShow"]
let policyCategorySet = new Set<string>()
let mappedPolicies: any[] = []
let policyResolutionError: string | null = null
try {
	const resolvedPolicies = await resolveEffectivePolicies({
		productId,
		channel: "web",
		requiredCategories: requiredPolicyCategories,
		onMissingCategory: "return_null",
		featureContext: {
			request: Astro.request,
			query: Astro.url.searchParams,
		},
	})
	policyCategorySet = new Set(
		resolvedPolicies.policies.map((policy) => String(policy.category ?? ""))
	)
	mappedPolicies = mapResolvedPoliciesToUI(resolvedPolicies) as any[]
} catch (error) {
	policyResolutionError =
		error instanceof Error ? error.message : "No se pudieron resolver las condiciones"
	mappedPolicies = []
}
---

<PlaybookLayout
	title="Alojamientos · Vista previa"
	playbookId={playbookId}
	active={playbook.active}
	stepId={stepId}
	productId={productId}
	isHotel={isHotel}
	hideFooter={playbookId === "complete-to-publish" && stepId === "preview"}
>
	<section class="space-y-7">
		<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
			<div class="max-w-3xl space-y-1.5">
				<p
					class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400"
				>
					<Hotel class="h-4 w-4" aria-hidden="true" />
					{vertical.labels.workspaceSingular}
				</p>
				<h1 class="text-3xl font-semibold tracking-tight text-slate-100">
					Vista previa de {aggregate.displayName}
				</h1>
				<p class="max-w-2xl text-sm leading-6 text-slate-400">
					Revisa cómo se verá la ficha pública antes de publicarla. Confirma fotos, habitaciones,
					condiciones y reglas para huéspedes.
				</p>
			</div>
			<div class="flex flex-wrap items-center justify-end gap-2">
				<Button href={routes.productDetail(productId)} variant="secondary"> Volver a ficha </Button>
				{
					isPublished && publicDetailHref ? (
						<Button href={publicDetailHref} variant="secondary">
							Abrir página pública
						</Button>
					) : null
				}
			</div>
		</header>

		<Card className="bg-white">
			<div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-start">
				<div class="space-y-4">
					<div class="flex flex-wrap items-start justify-between gap-3">
						<div class="space-y-1">
							<p class="text-sm font-semibold text-slate-950">Antes de publicar</p>
							<p class="text-sm leading-6 text-slate-600">
								{completedChecks} de {checks.length} bloques principales listos.
							</p>
						</div>
						<Badge variant={isPublished ? "success" : readyToPublish ? "success" : "warning"}>
							{
								isPublished
									? "Publicado"
									: readyToPublish
										? "Listo para publicar"
										: `${readinessPercent}% listo`
							}
						</Badge>
					</div>
					<ProgressBar value={readinessPercent} />
					<p class="text-sm leading-6 text-slate-600">
						{
							isPublished
								? "El alojamiento ya está publicado. Usa esta revisión para detectar ajustes de contenido."
								: readyToPublish
									? "La ficha está completa para huéspedes. Publica cuando estés listo."
									: blockerLabels.length
										? `Faltan ${blockerLabels.length} paso${blockerLabels.length === 1 ? "" : "s"}: ${blockerLabels.slice(0, 3).join(", ")}${blockerLabels.length > 3 ? "..." : ""}.`
										: "Revisa lo pendiente antes de publicar."
						}
					</p>
					{
						!readyToPublish && !isPublished ? (
							<div class="grid gap-2 pt-1 md:grid-cols-2">
								{checks
									.filter((check) => !check.complete)
									.slice(0, 4)
									.map((check) => (
										<a
											href={checkHref(check)}
											class="fastt-soft-box flex items-start justify-between gap-3 bg-slate-50 px-3 py-2 text-sm ring-1 ring-slate-200 transition hover:bg-white"
										>
											<span>
												<span class="font-semibold text-slate-950">{check.label}</span>
												<span class="mt-0.5 block text-xs leading-5 text-slate-500">
													{check.detail}
												</span>
											</span>
											<Badge variant="warning">Revisar</Badge>
										</a>
									))}
							</div>
						) : (
							<div class="flex items-center gap-2 text-sm font-medium text-emerald-700">
								<CircleCheck class="h-4 w-4" aria-hidden="true" />
								Todo lo obligatorio está listo.
							</div>
						)
					}
				</div>
				<div class="flex flex-wrap gap-2 lg:justify-end">
					{
						isPublished ? (
							<Button href={routes.productDetail(productId)}>Ir a ficha</Button>
						) : readyToPublish ? (
							<Button class="publish-product-button" type="button">
								Publicar alojamiento
							</Button>
						) : (
							<Button href={completePreparationHref}>
								Completar preparación
								<ArrowRight class="h-4 w-4" aria-hidden="true" />
							</Button>
						)
					}
				</div>
			</div>
			<p id="publishFeedback" class="mt-4 hidden text-sm text-slate-500"></p>
		</Card>

		<section class="space-y-4">
			<header class="space-y-1">
				<h2 class="text-lg font-semibold text-slate-100">Ficha pública</h2>
				<p class="text-sm leading-6 text-slate-400">
					Así se leerá el contenido principal para el huésped.
				</p>
			</header>
			<Card className="overflow-hidden bg-white p-0 text-slate-800">
				{
					primaryImage ? (
						<img src={primaryImage} alt={aggregate.displayName} class="h-80 w-full object-cover" />
					) : (
						<div class="flex h-80 items-center justify-center bg-slate-100 text-sm text-slate-500">
							Agrega fotos para dar una primera impresión clara.
						</div>
					)
				}
				<div class="space-y-6 p-5 md:p-6">
					<div class="flex flex-wrap items-start justify-between gap-4">
						<div class="space-y-1">
							<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
								{vertical.labels.workspaceSingular}
							</p>
							<h2 class="text-2xl font-semibold text-slate-950">{aggregate.displayName}</h2>
							<p class="text-sm text-slate-500">
								{aggregate.location.address || "Ubicación pendiente"}
							</p>
						</div>
						<Badge variant={readyToPublish || isPublished ? "success" : "warning"}>
							{readyToPublish || isPublished ? "Lista para huéspedes" : "Borrador"}
						</Badge>
					</div>

					{
						imagePreviews.length > 1 ? (
							<div class="grid grid-cols-3 gap-2 md:grid-cols-6">
								{imagePreviews.map((image) => (
									<img src={image.url} alt="Vista previa" class="h-20 rounded-lg object-cover" />
								))}
							</div>
						) : null
					}

					<div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
						<div class="space-y-5">
							<div>
								<p class="text-sm font-semibold text-slate-900">Sobre este alojamiento</p>
								<p class="mt-2 text-sm leading-7 text-slate-700">
									{
										description ||
											"Agrega una descripción clara para que el huésped entienda el alojamiento."
									}
								</p>
							</div>
							<div>
								<p class="text-sm font-semibold text-slate-900">Destacados</p>
								{
									highlights.length ? (
										<ul class="mt-3 flex flex-wrap gap-2 text-sm text-slate-700">
											{highlights.map((item) => (
												<li class="rounded-full bg-slate-100 px-3 py-1.5">{String(item)}</li>
											))}
										</ul>
									) : (
										<p class="mt-2 text-sm text-slate-500">
											Agrega al menos un destacado visible para huéspedes.
										</p>
									)
								}
							</div>
						</div>

						<div class="space-y-3 rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200">
							<p class="flex items-center gap-2 text-sm font-semibold text-slate-900">
								<ShieldCheck class="h-4 w-4 text-slate-500" aria-hidden="true" />
								Confianza de reserva
							</p>
							<p class="text-sm leading-6 text-slate-600">
								El huésped debe entender cancelación, pagos, no presentación e ingreso antes de
								reservar.
							</p>
							<div class="flex flex-wrap gap-2">
								{
									requiredPolicyCategories.map((category) => (
										<Badge variant={policyCategorySet.has(category) ? "success" : "neutral"}>
											{POLICY_CATEGORY_ORDER[category as keyof typeof POLICY_CATEGORY_ORDER] ??
												category}
										</Badge>
									))
								}
							</div>
						</div>
					</div>
				</div>
			</Card>
		</section>

		{
			isHotel ? (
				<section class="space-y-4">
					<header class="flex flex-wrap items-end justify-between gap-3">
						<div class="space-y-1">
							<h2 class="text-lg font-semibold text-slate-100">Dónde dormirán los huéspedes</h2>
							<p class="text-sm leading-6 text-slate-400">
								Habitaciones que el huésped podrá revisar antes de reservar.
							</p>
						</div>
						<Button
							href={`/product/${encodeURIComponent(productId)}/rooms`}
							variant="secondary"
							size="sm"
						>
							<BedDouble class="h-4 w-4" aria-hidden="true" />
							Editar habitaciones
						</Button>
					</header>
					{guestRoomPreviews.length ? (
						<GuestRoomPreviewCards
							previews={guestRoomPreviews}
							cardClass="fastt-row-card bg-white text-slate-900 ring-1 ring-slate-200/70"
							gridClass="grid gap-4 lg:grid-cols-2"
						/>
					) : (
						<Card className="border-amber-200 bg-amber-50 text-amber-950">
							<p class="text-sm font-semibold">Aún no hay habitaciones listas para preview.</p>
							<p class="mt-1 text-sm leading-6">
								Completa camas, baño, capacidad, fotos y notas para que el huésped entienda dónde
								dormirá.
							</p>
						</Card>
					)}
				</section>
			) : null
		}

		{
			vertical.vertical === "package" ? (
				<section class="space-y-4">
					<header class="space-y-1">
						<h2 class="text-lg font-semibold text-slate-100">Incluye / No incluye</h2>
						<p class="text-sm leading-6 text-slate-400">
							Listas visibles del paquete antes de publicar.
						</p>
					</header>
					<div class="grid gap-4 md:grid-cols-2">
						<Card className="bg-white text-slate-800">
							<p class="text-sm font-semibold text-slate-900">Incluye</p>
							{packageInclusionItems.length ? (
								<ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
									{packageInclusionItems.map((item) => (
										<li class="rounded-md bg-slate-50 px-3 py-2">{item}</li>
									))}
								</ul>
							) : (
								<p class="mt-2 text-sm text-slate-500">
									Agrega inclusiones visibles antes de publicar.
								</p>
							)}
						</Card>
						<Card className="bg-white text-slate-800">
							<p class="text-sm font-semibold text-slate-900">No incluye</p>
							{packageExclusionItems.length ? (
								<ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
									{packageExclusionItems.map((item) => (
										<li class="rounded-md bg-slate-50 px-3 py-2">{item}</li>
									))}
								</ul>
							) : (
								<p class="mt-2 text-sm text-slate-500">
									Las exclusiones ayudan a evitar dudas antes de reservar.
								</p>
							)}
						</Card>
					</div>
				</section>
			) : null
		}

		<section class="space-y-4">
			<header class="flex flex-wrap items-end justify-between gap-3">
				<div class="space-y-1">
					<h2 class="text-lg font-semibold text-slate-100">Condiciones que verá el huésped</h2>
					<p class="text-sm leading-6 text-slate-400">
						Resumen visible de cancelación, pago, no presentación y llegada.
					</p>
				</div>
				{
					isHotel ? (
						<Button href={conditionsHref} variant="secondary" size="sm">
							Editar condiciones
						</Button>
					) : null
				}
			</header>
			<div class="grid gap-3 md:grid-cols-2">
				{
					policyResolutionError ? (
						<Card className="border-red-200 bg-red-50 text-red-900">
							<p class="font-semibold">No se pudieron resolver las condiciones.</p>
							<p class="mt-1 text-sm">{policyResolutionError}</p>
						</Card>
					) : mappedPolicies.length ? (
						mappedPolicies.map((policy: any) => {
							const category = String(policy.category ?? "")
							return (
								<Card className="bg-white text-slate-800">
									<p class="text-sm font-semibold text-slate-900">
										{POLICY_CATEGORY_ORDER[category as keyof typeof POLICY_CATEGORY_ORDER] ??
											category}
									</p>
									<p class="mt-2 text-sm leading-6 text-slate-600">
										{String(policy.description ?? "Sin detalle visible.")}
									</p>
								</Card>
							)
						})
					) : (
						<Card className="bg-white text-slate-700">
							<p class="font-semibold text-slate-900">Aún no hay condiciones visibles.</p>
							<p class="mt-1 text-sm">Agrega condiciones antes de publicar.</p>
						</Card>
					)
				}
			</div>
		</section>

		{
			isHotel ? (
				<section class="space-y-4">
					<header class="flex flex-wrap items-end justify-between gap-3">
						<div class="space-y-1">
							<h2 class="text-lg font-semibold text-slate-100">Reglas para huéspedes</h2>
							<p class="text-sm leading-6 text-slate-400">
								Comportamiento, llegada y operación de estadía que el huésped verá antes de
								reservar.
							</p>
						</div>
						<Button href={routes.providerHouseRules()} variant="secondary" size="sm">
							Editar reglas
						</Button>
					</header>
					<Card className="bg-white text-slate-800">
						{houseRules.length ? (
							<div class="grid gap-4 lg:grid-cols-2">
								{houseRuleGroups.map((group) => {
									const items = group.types.flatMap((type) => houseRulesByType[type] ?? [])
									if (!items.length) return null
									return (
										<div class="space-y-2">
											<p class="text-sm font-semibold text-slate-900">{group.label}</p>
											<ul class="space-y-2 text-sm leading-6 text-slate-700">
												{items.map((rule: any) => {
													const type = String(rule.type ?? "Other")
													return (
														<li class="rounded-xl bg-slate-50 px-3 py-2">
															<span class="font-medium text-slate-900">
																{houseRuleLabelByType[type] ?? "Otra regla"}:
															</span>{" "}
															{rule.summary}
														</li>
													)
												})}
											</ul>
										</div>
									)
								})}
							</div>
						) : (
							<div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-5">
								<p class="text-sm font-semibold text-slate-900">
									Aún no hay reglas para huéspedes.
								</p>
								<p class="mt-1 text-sm text-slate-600">
									Agrega reglas para que el huésped entienda comportamiento, llegada y salida.
								</p>
							</div>
						)}
					</Card>
				</section>
			) : null
		}

		<Card className="bg-slate-950 text-slate-100">
			<div class="flex flex-wrap items-center justify-between gap-4">
				<div class="space-y-1">
					<p class="text-sm font-semibold">
						{
							isPublished
								? "Ficha publicada"
								: readyToPublish
									? "Lista para publicar"
									: "Preparación pendiente"
						}
					</p>
					<p class="text-sm leading-6 text-slate-400">
						{
							isPublished
								? "Puedes volver a la ficha para seguir gestionando el alojamiento."
								: readyToPublish
									? "La revisión final está completa para huéspedes."
									: "Completa los pendientes antes de publicar el alojamiento."
						}
					</p>
				</div>
				<div class="flex flex-wrap gap-2">
					<Button href={routes.productDetail(productId)} variant="secondary">
						Volver a ficha
					</Button>
					{
						!isPublished && readyToPublish ? (
							<Button class="publish-product-button" type="button">
								Publicar alojamiento
							</Button>
						) : !isPublished ? (
							<Button href={completePreparationHref}>Completar preparación</Button>
						) : null
					}
				</div>
			</div>
		</Card>
	</section>

	<script is:inline define:vars={{ productId, productDetailHref: routes.productDetail(productId) }}>
		;(function () {
			const publishButtons = Array.from(document.querySelectorAll(".publish-product-button"))
			const feedback = document.getElementById("publishFeedback")
			if (!publishButtons.length || !productId) return

			const setDisabled = (disabled) => {
				for (const button of publishButtons) {
					button.disabled = disabled
				}
			}

			const publish = async () => {
				setDisabled(true)
				if (feedback) {
					feedback.classList.remove("hidden")
					feedback.textContent = "Verificando requisitos y publicando..."
				}

				try {
					const formData = new FormData()
					formData.set("productId", productId)

					const evaluateResponse = await fetch("/api/product/evaluate", {
						method: "POST",
						body: formData,
					})
					const evaluatePayload = await evaluateResponse.json().catch(() => ({}))
					if (!evaluateResponse.ok || evaluatePayload.state !== "ready") {
						const errors = Array.isArray(evaluatePayload.validationErrors)
							? evaluatePayload.validationErrors
									.map((item) => String(item?.message || item?.code || ""))
									.filter(Boolean)
									.join("\n")
							: String(evaluatePayload.error || "No se pudo validar el alojamiento.")
						if (feedback)
							feedback.textContent = errors || "Completa los requisitos antes de publicar."
						setDisabled(false)
						return
					}

					const publishResponse = await fetch("/api/product/publish", {
						method: "POST",
						body: formData,
					})
					const publishPayload = await publishResponse.json().catch(() => ({}))
					if (!publishResponse.ok || !publishPayload.ok) {
						const errors = Array.isArray(publishPayload.validationErrors)
							? publishPayload.validationErrors
									.map((item) => String(item?.message || item?.code || ""))
									.filter(Boolean)
									.join("\n")
							: String(publishPayload.error || "No se pudo publicar el alojamiento.")
						if (feedback) feedback.textContent = errors
						setDisabled(false)
						return
					}

					window.location.href = productDetailHref
				} catch (error) {
					if (feedback) feedback.textContent = `Error de red: ${String(error)}`
					setDisabled(false)
				}
			}

			for (const button of publishButtons) {
				button.addEventListener("click", publish)
			}
		})()
	</script>
</PlaybookLayout>
