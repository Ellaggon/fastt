---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import {
	listActiveProductVerticalEntries,
	normalizeProductTypeValue,
} from "@/lib/catalog/productVerticalRegistry"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const verticalOptions = listActiveProductVerticalEntries()
const requestedType = String(Astro.url.searchParams.get("type") ?? "").trim()
const requestedProductType = normalizeProductTypeValue(requestedType)
---

<WorkspaceLayout title="Catálogo · Crear oferta">
	<section class="space-y-8">
		<section class="space-y-4">
			<header class="space-y-1">
				<h1 class="text-3xl font-semibold text-slate-100">Crear oferta</h1>
				<p class="text-sm text-slate-400">
					Elige el tipo de oferta y crea su identidad mínima. Cada vertical activa sus propios
					bloques de contenido y readiness.
				</p>
			</header>

			<Card class="rounded-lg border-slate-200 bg-slate-100 shadow-none">
				<form
					id="createForm"
					method="POST"
					action="/api/product/create"
					class="max-w-3xl space-y-6"
				>
					<div class="space-y-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Datos base de la oferta</h2>
							<p class="text-sm text-slate-600">
								Solo se piden los campos mínimos obligatorios para crear la ficha inicial.
							</p>
						</div>

						<FormField label="Nombre de la oferta" htmlFor="name" required>
							<Input
								id="name"
								name="name"
								required
								placeholder="Ej: Hotel Central, City Tour Histórico o Paquete Lago Titicaca"
							/>
						</FormField>

						<FormField label="Tipo de oferta" htmlFor="productType" required>
							<Select id="productType" name="productType" required>
								<option value="">Selecciona una opción</option>
								{
									verticalOptions.map((vertical) => (
										<option
											value={vertical.productType ?? ""}
											selected={requestedProductType === vertical.productType}
										>
											{vertical.creation.typeOptionLabel}
										</option>
									))
								}
							</Select>
						</FormField>

						<FormField label="Destino principal (ID)" htmlFor="destinationId" required>
							<Input id="destinationId" name="destinationId" required placeholder="Ej: la-paz" />
						</FormField>
					</div>

					<div class="space-y-1">
						<p id="stateLabel" class="text-sm text-slate-600">
							Vacío: completa el formulario para crear.
						</p>
						<p id="stateDetail" class="whitespace-pre-wrap text-sm text-slate-600"></p>
					</div>

					<div class="flex items-center justify-end gap-3">
						<a
							href="/dashboard"
							class="inline-flex h-10 items-center justify-center rounded-lg border border-neutral-300 bg-neutral-100 px-4 text-sm font-medium text-neutral-900 hover:bg-neutral-200"
						>
							Volver
						</a>
						<Button
							id="submitBtn"
							type="submit"
							className="bg-[#1E3A8A] text-white hover:bg-[#1e40af] disabled:opacity-60"
						>
							Crear oferta
						</Button>
					</div>
				</form>
			</Card>
		</section>
	</section>

	<script type="module">
		const form = document.getElementById("createForm")
		const btn = document.getElementById("submitBtn")
		const btnText = btn?.textContent || "Crear oferta"
		const stateLabel = document.getElementById("stateLabel")
		const stateDetail = document.getElementById("stateDetail")

		function setState(state, detail = "") {
			const labels = {
				empty: "Vacío: completa el formulario para crear.",
				loading: "Cargando: creando oferta...",
				success: "Éxito: oferta creada correctamente.",
				error: "Error: no se pudo crear la oferta.",
				disabled: "Deshabilitado: esperando respuesta del servidor.",
			}
			stateLabel.textContent = labels[state] || labels.empty
			stateDetail.textContent = detail
		}

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			setState("loading")
			btn.disabled = true
			btn.textContent = "Cargando..."
			setState("disabled")

			try {
				const fd = new FormData(form)
				const res = await fetch("/api/product/create", { method: "POST", body: fd })
				const txt = await res.text()

				if (!res.ok) {
					btn.disabled = false
					btn.textContent = btnText
					setState("error", `status=${res.status}\n${txt}`)
					return
				}

				let json = null
				try {
					json = JSON.parse(txt)
				} catch {
					btn.disabled = false
					btn.textContent = btnText
					setState("error", `Respuesta inválida:\n${txt}`)
					return
				}

				if (!json?.id) {
					btn.disabled = false
					btn.textContent = btnText
					setState("error", `Respuesta sin ID:\n${txt}`)
					return
				}

				setState("success", "Guardado correctamente")
				window.location.href = `/product/${json.id}/content?flow=create`
			} catch (err) {
				btn.disabled = false
				btn.textContent = btnText
				setState("error", `Error de red: ${String(err)}`)
			}
		})
	</script>
</WorkspaceLayout>
