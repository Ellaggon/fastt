---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import FormField from "@/components/ui/FormField.astro"
import Input from "@/components/ui/Input.astro"
import Select from "@/components/ui/Select.astro"
import PlaybookLayout from "@/layouts/PlaybookLayout.astro"
import {
	buildPlaybookHref,
	resolveLaunchPlaybookFromUrl,
} from "@/lib/playbook/launch-accommodation"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import {
	getProductVerticalDefinition,
	PRODUCT_VERTICAL_OPTIONS,
} from "@/lib/productVerticalRegistry"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request, user)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const requestedType = String(Astro.url.searchParams.get("type") ?? "").trim()
const requestedVertical = getProductVerticalDefinition(requestedType)
const createCopy = requestedVertical?.createCopy ?? {
	title: "Crear oferta",
	description:
		"Crea la identidad mínima de la oferta para empezar contenido, configuración y publicación.",
	namePlaceholder: "Ej: Hotel Boutique Centro",
}
const selectedProductType = requestedVertical?.storageType ?? ""
const playbook = resolveLaunchPlaybookFromUrl(Astro.url)
if (!playbook.active && Astro.url.searchParams.get("flow") === "create") {
	return Astro.redirect(buildPlaybookHref("/product/create", "create"))
}
---

<PlaybookLayout
	title="Alojamientos · Crear alojamiento"
	active={playbook.active}
	stepId={playbook.stepId ?? "create"}
	isHotel={requestedVertical?.vertical === "hotel"}
>
	<section class="space-y-8">
		<section class="space-y-4">
			<header class="space-y-1">
				<p class="text-sm font-medium text-slate-400">Alojamientos</p>
				<h1 class="text-3xl font-semibold text-slate-100">{createCopy.title}</h1>
				<p class="text-sm text-slate-400">{createCopy.description}</p>
			</header>

			<Card class="rounded-lg border-slate-200 bg-slate-100 shadow-none">
				<form
					id="createForm"
					method="POST"
					action="/api/product/create"
					class="max-w-3xl space-y-6"
				>
					<div class="space-y-4">
						<div class="space-y-1">
							<h2 class="text-xl font-semibold text-slate-900">Datos base de la oferta</h2>
							<p class="text-sm text-slate-600">Solo se piden los campos mínimos obligatorios.</p>
						</div>

						<FormField label="Nombre" htmlFor="name" required>
							<Input id="name" name="name" required placeholder={createCopy.namePlaceholder} />
						</FormField>

						<FormField label="Tipo de oferta" htmlFor="productType" required>
							<Select id="productType" name="productType" required value={selectedProductType}>
								<option value="">Selecciona una opción</option>
								{
									PRODUCT_VERTICAL_OPTIONS.map((vertical) => (
										<option value={vertical.storageType}>{vertical.labels.singular}</option>
									))
								}
							</Select>
						</FormField>

						<FormField label="Destino (ID)" htmlFor="destinationId" required>
							<Input id="destinationId" name="destinationId" required placeholder="Ej: la-paz" />
						</FormField>
					</div>

					<div class="space-y-1">
						<p id="stateLabel" class="text-sm text-slate-600">
							Vacío: completa el formulario para crear.
						</p>
						<p id="stateDetail" class="whitespace-pre-wrap text-sm text-slate-600"></p>
					</div>

					<div class="flex items-center justify-end gap-3">
						<Button href="/dashboard" variant="secondary"> Volver </Button>
						<Button id="submitBtn" type="submit">
							{
								playbook.active
									? "Crear y continuar"
									: (requestedVertical?.labels.createCta ?? "Crear oferta")
							}
						</Button>
					</div>
				</form>
			</Card>
		</section>
	</section>

	<script type="module">
		const form = document.getElementById("createForm")
		const btn = document.getElementById("submitBtn")
		const btnText = btn?.textContent || "Crear producto"
		const stateLabel = document.getElementById("stateLabel")
		const stateDetail = document.getElementById("stateDetail")

		function setState(state, detail = "") {
			const labels = {
				empty: "Vacío: completa el formulario para crear.",
				loading: "Cargando: creando oferta...",
				success: "Éxito: oferta creada correctamente.",
				error: "Error: no se pudo crear la oferta.",
				disabled: "Deshabilitado: esperando respuesta del servidor.",
			}
			stateLabel.textContent = labels[state] || labels.empty
			stateDetail.textContent = detail
		}

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			setState("loading")
			btn.disabled = true
			btn.textContent = "Cargando..."
			setState("disabled")

			try {
				const fd = new FormData(form)
				const res = await fetch("/api/product/create", { method: "POST", body: fd })
				const txt = await res.text()

				if (!res.ok) {
					btn.disabled = false
					btn.textContent = btnText
					setState("error", `status=${res.status}\n${txt}`)
					return
				}

				let json = null
				try {
					json = JSON.parse(txt)
				} catch {
					btn.disabled = false
					btn.textContent = btnText
					setState("error", `Respuesta inválida:\n${txt}`)
					return
				}

				if (!json?.id) {
					btn.disabled = false
					btn.textContent = btnText
					setState("error", `Respuesta sin ID:\n${txt}`)
					return
				}

				setState("success", "Guardado correctamente")
				window.location.href = `/product/${json.id}/content?playbook=launch&step=content&flow=create`
			} catch (err) {
				btn.disabled = false
				btn.textContent = btnText
				setState("error", `Error de red: ${String(err)}`)
			}
		})
	</script>
</PlaybookLayout>
