---
import Breadcrumbs from "@/components/Breadcrumbs.astro"
import SearchLayout from "@/layouts/SearchLayout.astro"
import {
	asc,
	db,
	Destination,
	eq,
	Package,
	Product,
	ProductContent,
	ProductLocation,
	sql,
} from "@/shared/infrastructure/db/compat"

const packages = await db
	.select({
		id: Product.id,
		name: Product.name,
		destinationName: Destination.name,
		description: ProductContent.description,
		address: ProductLocation.address,
		includes: Package.includesJson,
		excludes: Package.excludesJson,
		imageUrl: sql<string>`(
			SELECT url
			FROM Image
			WHERE entityId = ${Product.id}
			ORDER BY isPrimary DESC, "order" ASC
			LIMIT 1
		)`.as("imageUrl"),
		itinerary: Package.itineraryJson,
		days: Package.days,
		nights: Package.nights,
	})
	.from(Product)
	.leftJoin(Destination, eq(Destination.id, Product.destinationId))
	.leftJoin(ProductContent, eq(ProductContent.productId, Product.id))
	.leftJoin(ProductLocation, eq(ProductLocation.productId, Product.id))
	.leftJoin(Package, eq(Package.productId, Product.id))
	.where(sql`lower(${Product.productType}) = 'package'`)
	.groupBy(Product.id)
	.orderBy(asc(Product.name))
	.limit(60)

const breadcrumbsItems = [
	{ name: "Home", href: "/" },
	{ name: "Paquetes", href: "/packages", current: true },
]

function textList(value: unknown): string[] {
	if (Array.isArray(value)) {
		return value
			.map((item) => {
				if (typeof item === "string") return item
				if (item && typeof item === "object") {
					return String(
						(item as any).description ?? (item as any).title ?? (item as any).name ?? ""
					)
				}
				return ""
			})
			.map((item) => item.trim())
			.filter(Boolean)
	}
	return String(value ?? "")
		.split(/\r?\n|,/)
		.map((item) => item.trim())
		.filter(Boolean)
}
---

<SearchLayout title="Paquetes en Bolivia" producType="packages">
	<main class="mx-auto min-h-screen max-w-7xl space-y-8 p-6 lg:p-10">
		<Breadcrumbs items={breadcrumbsItems} />

		<header class="space-y-3">
			<p class="text-sm font-semibold uppercase tracking-wide text-slate-300">Paquetes</p>
			<h1 class="text-4xl font-bold text-gray-100">Paquetes turísticos</h1>
			<p class="max-w-3xl text-base leading-7 text-gray-200">
				Explora experiencias combinadas con recorrido, días, noches e inclusiones visibles antes de
				reservar.
			</p>
		</header>

		<section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
			{
				packages.length ? (
					packages.map((item) => {
						const inclusions = textList(item.includes).slice(0, 3)
						const duration =
							item.days || item.nights
								? `${Number(item.days ?? 0)} días / ${Number(item.nights ?? 0)} noches`
								: "Duración por confirmar"
						return (
							<a
								href={`/packages/${item.id}`}
								class="fastt-row-card group overflow-hidden rounded-[var(--fastt-radius-card)] border border-white/10 bg-white text-slate-900 shadow-sm transition hover:-translate-y-0.5 hover:shadow-xl"
							>
								<img
									src={item.imageUrl || "https://placehold.co/800x500?text=Paquete"}
									alt={item.name}
									class="h-52 w-full object-cover"
								/>
								<div class="space-y-4 p-5">
									<div class="space-y-1">
										<p class="text-xs font-semibold tracking-wide text-slate-700 uppercase">
											{item.destinationName || item.address || "Destino por confirmar"}
										</p>
										<h2 class="text-xl font-semibold text-slate-950 group-hover:text-slate-700">
											{item.name}
										</h2>
										<p class="text-sm text-slate-500">{duration}</p>
									</div>
									<p class="line-clamp-3 text-sm leading-6 text-slate-700">
										{item.description ||
											textList(item.itinerary)[0] ||
											"Itinerario en preparación."}
									</p>
									{inclusions.length ? (
										<ul class="grid gap-2 text-sm text-slate-700">
											{inclusions.map((inclusion) => (
												<li class="rounded-md bg-slate-100 px-3 py-2">{inclusion}</li>
											))}
										</ul>
									) : null}
								</div>
							</a>
						)
					})
				) : (
					<div class="fastt-empty-state rounded-[var(--fastt-radius-card)] border border-dashed border-white/20 bg-white/10 p-8 text-gray-100 md:col-span-2 xl:col-span-3">
						<h2 class="text-xl font-semibold">Aún no hay paquetes publicados.</h2>
						<p class="mt-2 text-sm text-gray-200">
							Los paquetes aparecerán aquí cuando estén listos para viajeros.
						</p>
					</div>
				)
			}
		</section>
	</main>
</SearchLayout>
