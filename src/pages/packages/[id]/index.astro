---
import Breadcrumbs from "@/components/Breadcrumbs.astro"
import Layout from "@/layouts/Layout.astro"
import {
	asc,
	db,
	Destination,
	eq,
	Image,
	Package,
	Product,
	ProductContent,
	ProductLocation,
	sql,
} from "astro:db"

const productId = String(Astro.params.id ?? "").trim()
if (!productId) return Astro.redirect("/packages")

const row = await db
	.select({
		id: Product.id,
		name: Product.name,
		productType: Product.productType,
		destinationName: Destination.name,
		description: ProductContent.description,
		address: ProductLocation.address,
		lat: ProductLocation.lat,
		lng: ProductLocation.lng,
		itinerary: Package.itineraryJson,
		days: Package.days,
		nights: Package.nights,
		includes: Package.includesJson,
		excludes: Package.excludesJson,
	})
	.from(Product)
	.leftJoin(Destination, eq(Destination.id, Product.destinationId))
	.leftJoin(ProductContent, eq(ProductContent.productId, Product.id))
	.leftJoin(ProductLocation, eq(ProductLocation.productId, Product.id))
	.leftJoin(Package, eq(Package.productId, Product.id))
	.where(sql`${Product.id} = ${productId} AND lower(${Product.productType}) = 'package'`)
	.get()

if (!row) return Astro.redirect("/packages")

const images = await db
	.select({
		id: Image.id,
		url: Image.url,
		isPrimary: Image.isPrimary,
		order: Image.order,
	})
	.from(Image)
	.where(eq(Image.entityId, productId))
	.orderBy(asc(Image.order))
	.all()

function textList(value: unknown): string[] {
	if (Array.isArray(value)) {
		return value
			.map((item) => {
				if (typeof item === "string") return item
				if (item && typeof item === "object") {
					return String(
						(item as any).description ?? (item as any).title ?? (item as any).name ?? ""
					)
				}
				return ""
			})
			.map((item) => item.trim())
			.filter(Boolean)
	}
	return String(value ?? "")
		.split(/\r?\n|,/)
		.map((item) => item.trim())
		.filter(Boolean)
}

const inclusions = textList(row.includes)
const exclusions = textList(row.excludes)
const itineraryItems = textList(row.itinerary)
const duration =
	row.days || row.nights
		? `${Number(row.days ?? 0)} días / ${Number(row.nights ?? 0)} noches`
		: "Duración por confirmar"
const primaryImage = images[0]?.url || "https://placehold.co/1200x720?text=Paquete"
const breadcrumbItems = [
	{ name: "Home", href: "/" },
	{ name: "Paquetes", href: "/packages" },
	{ name: row.name, href: `/packages/${productId}`, current: true },
]
---

<Layout title={row.name || "Paquete"}>
	<main class="mx-auto min-h-screen max-w-7xl space-y-10 p-4 lg:p-12">
		<Breadcrumbs items={breadcrumbItems} />

		<section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
			<div class="space-y-4">
				<img
					src={primaryImage}
					alt={row.name}
					class="h-[28rem] w-full rounded-2xl object-cover shadow-lg"
				/>
				{
					images.length > 1 ? (
						<div class="grid grid-cols-3 gap-2 md:grid-cols-6">
							{images.slice(0, 6).map((image) => (
								<img src={image.url} alt={row.name} class="h-24 rounded-lg object-cover" />
							))}
						</div>
					) : null
				}
			</div>

			<aside class="space-y-5 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
				<p class="text-sm font-semibold uppercase tracking-wide text-blue-700">Paquete</p>
				<h1 class="text-4xl font-bold text-gray-950">{row.name}</h1>
				<p class="text-sm text-gray-600">
					{row.destinationName || row.address || "Destino por confirmar"}
				</p>
				<div class="rounded-xl bg-blue-50 p-4 text-blue-950">
					<p class="text-sm font-semibold">Duración</p>
					<p class="mt-1 text-2xl font-semibold">{duration}</p>
				</div>
				<a
					href="/packages"
					class="inline-flex w-full items-center justify-center rounded-lg bg-blue-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-800"
				>
					Ver más paquetes
				</a>
			</aside>
		</section>

		<section class="grid gap-6 lg:grid-cols-[1fr_0.8fr]">
			<div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
				<h2 class="text-2xl font-semibold text-gray-950">Sobre este paquete</h2>
				<p class="mt-4 text-base leading-8 text-gray-700">
					{row.description || "La descripción del paquete está en preparación."}
				</p>
			</div>

			<div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
				<h2 class="text-2xl font-semibold text-gray-950">Incluye</h2>
				{
					inclusions.length ? (
						<ul class="mt-4 grid gap-3 text-sm text-gray-700">
							{inclusions.map((inclusion) => (
								<li class="rounded-lg bg-gray-50 px-4 py-3">{inclusion}</li>
							))}
						</ul>
					) : (
						<p class="mt-4 text-sm text-gray-600">
							Las inclusiones se publicarán cuando el proveedor complete el detalle del paquete.
						</p>
					)
				}
			</div>
		</section>

		<section class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
			<h2 class="text-2xl font-semibold text-gray-950">No incluye</h2>
			{
				exclusions.length ? (
					<ul class="mt-4 grid gap-3 text-sm text-gray-700 md:grid-cols-2">
						{exclusions.map((exclusion) => (
							<li class="rounded-lg bg-gray-50 px-4 py-3">{exclusion}</li>
						))}
					</ul>
				) : (
					<p class="mt-4 text-sm text-gray-600">
						El proveedor todavía no publicó exclusiones específicas.
					</p>
				)
			}
		</section>

		<section class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
			<h2 class="text-2xl font-semibold text-gray-950">Itinerario</h2>
			<p class="mt-4 whitespace-pre-line text-base leading-8 text-gray-700">
				{itineraryItems.length ? itineraryItems.join("\n") : "Itinerario en preparación."}
			</p>
		</section>

		<section class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
			<h2 class="text-2xl font-semibold text-gray-950">Ubicación de referencia</h2>
			<p class="mt-3 text-sm text-gray-700">
				{row.address || row.destinationName || "Ubicación por confirmar"}
			</p>
			<div
				class="mt-4 flex h-64 items-center justify-center rounded-xl bg-gray-100 text-sm text-gray-500"
			>
				Mapa (pendiente)
			</div>
		</section>
	</main>
</Layout>
