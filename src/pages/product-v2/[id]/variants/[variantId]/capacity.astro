---
import Layout from "@/layouts/Layout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
const variantId = String(Astro.params.variantId ?? "")
if (!productId) return Astro.redirect("/product-v2/create")
if (!variantId) return Astro.redirect(`/product-v2/${encodeURIComponent(productId)}/variants`)
---

<Layout title="Product V2 - Variant Capacity">
	<main style="max-width: 640px; margin: 40px auto; padding: 0 16px;">
		<h1>Capacity</h1>
		<p>
			Product: <code>{productId}</code>
		</p>
		<p>
			Variant: <code>{variantId}</code>
		</p>

		<form id="capForm">
			<input type="hidden" name="variantId" value={variantId} />

			<label>
				Min guests *
				<input name="minOccupancy" type="number" min="0" step="1" required />
			</label>
			<div id="err-minOccupancy" style="color: #b00020; font-size: 12px;"></div>
			<br />

			<label>
				Max guests *
				<input name="maxOccupancy" type="number" min="0" step="1" required />
			</label>
			<div id="err-maxOccupancy" style="color: #b00020; font-size: 12px;"></div>
			<br />

			<label>
				Max adults (optional)
				<input name="maxAdults" type="number" min="0" step="1" />
			</label>
			<div id="err-maxAdults" style="color: #b00020; font-size: 12px;"></div>
			<br />

			<label>
				Max children (optional)
				<input name="maxChildren" type="number" min="0" step="1" />
			</label>
			<div id="err-maxChildren" style="color: #b00020; font-size: 12px;"></div>
			<br />

			<button id="submitBtn" type="submit">Save and continue</button>
		</form>

		<div id="generalError" style="margin-top: 12px; color: #b00020;"></div>

		<p style="margin-top: 16px;">
			<a href={`/product-v2/${encodeURIComponent(productId)}/variants`}>Back to Rooms list</a>
		</p>
	</main>

	<script type="module">
		const form = document.getElementById("capForm")
		const btn = document.getElementById("submitBtn")
		const generalError = document.getElementById("generalError")

		const fieldErrIds = ["minOccupancy", "maxOccupancy", "maxAdults", "maxChildren"]
		function clearErrors() {
			generalError.textContent = ""
			for (const f of fieldErrIds) {
				const el = document.getElementById(`err-${f}`)
				if (el) el.textContent = ""
			}
		}

		function setFieldError(field, msg) {
			const el = document.getElementById(`err-${field}`)
			if (el) el.textContent = msg
		}

		function parseIntOrNull(v) {
			const s = String(v ?? "").trim()
			if (!s) return null
			const n = Number(s)
			return Number.isFinite(n) ? Math.trunc(n) : null
		}

		function validate({ minOccupancy, maxOccupancy }) {
			let ok = true

			if (minOccupancy === null) {
				setFieldError("minOccupancy", "Required field")
				ok = false
			} else if (minOccupancy < 0) {
				setFieldError("minOccupancy", "Must be >= 0")
				ok = false
			}

			if (maxOccupancy === null) {
				setFieldError("maxOccupancy", "Required field")
				ok = false
			} else if (maxOccupancy < 0) {
				setFieldError("maxOccupancy", "Must be >= 0")
				ok = false
			}

			if (minOccupancy !== null && maxOccupancy !== null && minOccupancy > maxOccupancy) {
				setFieldError("minOccupancy", "Min cannot exceed Max")
				setFieldError("maxOccupancy", "Max cannot be below Min")
				ok = false
			}

			return ok
		}

		function mapZodIssues(details) {
			if (!Array.isArray(details)) return false
			let mapped = false
			for (const issue of details) {
				const path = Array.isArray(issue?.path) ? issue.path : []
				const field = path.length ? String(path[0]) : ""
				if (!field) continue
				setFieldError(field, issue?.message || "Invalid")
				mapped = true
			}
			return mapped
		}

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			clearErrors()
			btn.disabled = true

			try {
				const fd = new FormData(form)
				const variantId = String(fd.get("variantId") || "").trim()
				const productId = String(document.getElementById("productId")?.textContent || "").trim()

				const minOccupancy = parseIntOrNull(fd.get("minOccupancy"))
				const maxOccupancy = parseIntOrNull(fd.get("maxOccupancy"))
				const maxAdults = parseIntOrNull(fd.get("maxAdults"))
				const maxChildren = parseIntOrNull(fd.get("maxChildren"))

				if (!variantId) {
					generalError.textContent = "Variant not found"
					return
				}
				if (!validate({ minOccupancy, maxOccupancy })) return

				const req = new FormData()
				req.set("variantId", variantId)
				req.set("minOccupancy", String(minOccupancy))
				req.set("maxOccupancy", String(maxOccupancy))
				if (maxAdults !== null) req.set("maxAdults", String(maxAdults))
				if (maxChildren !== null) req.set("maxChildren", String(maxChildren))

				const res = await fetch("/api/variant/capacity", { method: "POST", body: req })

				if (res.status === 401) {
					window.location.href = "/SignInPage"
					return
				}
				if (res.status === 404) {
					generalError.textContent = "Variant not found"
					return
				}

				if (!res.ok) {
					let payload = null
					try {
						payload = await res.json()
					} catch {
						payload = null
					}

					if (res.status === 400 && payload?.error === "validation_error") {
						const mapped = mapZodIssues(payload?.details)
						if (!mapped) generalError.textContent = "Validation error"
						return
					}

					generalError.textContent =
						res.status >= 500 ? "Something went wrong. Try again." : "Request failed."
					return
				}

				// Next step placeholder.
				window.location.href = `/product-v2/${encodeURIComponent(
					productId
				)}/variants/${encodeURIComponent(variantId)}/room-type`
			} catch (err) {
				generalError.textContent = `Network error: ${String(err)}`
			} finally {
				btn.disabled = false
			}
		})
	</script>
</Layout>
<span id="productId" style="display:none">{productId}</span>
