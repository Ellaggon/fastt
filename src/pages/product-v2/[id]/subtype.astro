---
import Layout from "@/layouts/Layout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { getProductById } from "@/modules/catalog/public"

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const providerId = (await getProviderIdFromRequest(Astro.request)) ?? ""
if (!providerId) return Astro.redirect("/provider")

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/product-v2/create")

const product = await getProductById(productId)
if (!product) return Astro.redirect("/product-v2/create")

const pt = String(product.productType || "")
	.trim()
	.toLowerCase()
---

<Layout title="Product V2 - Subtype">
	<main style="max-width: 640px; margin: 40px auto; padding: 0 16px;">
		<h1>Product V2: Subtype</h1>
		<p>Product: <code>{productId}</code> ({product.productType})</p>

		<form id="subtypeForm" method="post" action="/api/product-v2/subtype">
			<input type="hidden" name="productId" value={productId} />

			{
				pt === "hotel" ? (
					<div>
						<h2>Hotel</h2>
						<div>
							<label>
								Stars <input name="stars" placeholder="1-5" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Phone <input name="phone" placeholder="Optional" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Email <input name="email" placeholder="Optional" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Website <input name="website" placeholder="Optional" />
							</label>
							<br />
						</div>
					</div>
				) : null
			}

			{
				pt === "tour" ? (
					<div>
						<h2>Tour</h2>
						<div>
							<label>
								Duration <input name="duration" placeholder="Optional" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Difficulty <input name="difficultyLevel" placeholder="Optional" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Guide languages (comma) <input name="guideLanguages" placeholder="es,en" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Includes <textarea name="includes" rows="3" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Excludes <textarea name="excludes" rows="3" />
							</label>
							<br />
						</div>
					</div>
				) : null
			}

			{
				pt === "package" ? (
					<div>
						<h2>Package</h2>
						<div>
							<label>
								Itinerary <textarea name="itinerary" rows="3" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Days <input name="days" placeholder="0+" />
							</label>
							<br />
						</div>
						<div>
							<label>
								Nights <input name="nights" placeholder="0+" />
							</label>
							<br />
						</div>
					</div>
				) : null
			}

			<button id="submitBtn" type="submit">Save subtype</button>
		</form>

		<pre id="out" style="white-space: pre-wrap; margin-top: 16px;"></pre>
	</main>

	<script type="module">
		const form = document.getElementById("subtypeForm")
		const out = document.getElementById("out")
		const btn = document.getElementById("submitBtn")

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			out.textContent = ""
			btn.disabled = true
			try {
				const fd = new FormData(form)
				const res = await fetch("/api/product-v2/subtype", { method: "POST", body: fd })
				const txt = await res.text()
				if (!res.ok) {
					out.textContent = `status=${res.status}\n${txt}`
					btn.disabled = false
					return
				}
				const productId = String(fd.get("productId") || "")
				window.location.href = `/product-v2/${encodeURIComponent(productId)}/review`
			} catch (err) {
				out.textContent = `network error: ${String(err)}`
				btn.disabled = false
			}
		})
	</script>
</Layout>
