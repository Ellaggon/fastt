---
import PolicyCard from "@/components/policy/PolicyCard.astro"
import BreadcrumProduct from "@/components/productUI/BreadcrumProduct.astro"
import ImageModal from "@/components/productUI/ImageModal.astro"
import MapModal from "@/components/productUI/MapModal.astro"
import RoomModal from "@/components/productUI/RoomModal.astro"
import RoomSection from "@/components/productUI/RoomSection.astro"
import ServiceDetailsModal from "@/components/productUI/ServiceDetailsModal.astro"
import { searchOffers } from "@/container"
import { POLICY_CATEGORY_ORDER, POLICY_UI_GROUPS } from "@/data/policy/policy-categories"
import UILayout from "@/layouts/UILayout.astro"
import {
	resolveHotelAmenities,
	resolveHotelType,
	resolveProductImages,
	resolveProductServices,
	resolveRoomImages,
} from "@/modules/catalog/public"
import { listHouseRulesByProduct } from "@/modules/house-rules/public"
import { mapResolvedPoliciesToUI, resolveEffectivePolicies } from "@/modules/policies/public"
import type { ImageRow } from "@/types/products"
import { db, Destination, eq, Hotel, Product } from "astro:db"

const url = Astro.url
const productId = Astro.params.id
if (!productId) {
	return Astro.redirect("/hotels")
}

function toISODateOnly(d: Date) {
	return d.toISOString().split("T")[0]
}

let hotelProduct: any = null
let hotelSubtype: any = null
let errorMessage: string | null = null

const checkInStr = url.searchParams.get("checkin")
const checkOutStr = url.searchParams.get("checkout")
const adults = Number(url.searchParams.get("adults") ?? 2)
const children = Number(url.searchParams.get("children") ?? 0)

// If required dates are missing/invalid, redirect to safe defaults.
if (!checkInStr || !checkOutStr) {
	const today = new Date()
	const tomorrow = new Date(today)
	tomorrow.setDate(today.getDate() + 1)
	return Astro.redirect(
		`/hotels/${productId}?checkin=${toISODateOnly(today)}&checkout=${toISODateOnly(tomorrow)}&adults=${adults}&children=${children}`
	)
}

const checkIn = new Date(checkInStr)
const checkOut = new Date(checkOutStr)
if (Number.isNaN(checkIn.getTime()) || Number.isNaN(checkOut.getTime()) || checkOut <= checkIn) {
	const today = new Date()
	const tomorrow = new Date(today)
	tomorrow.setDate(today.getDate() + 1)
	return Astro.redirect(
		`/hotels/${productId}?checkin=${toISODateOnly(today)}&checkout=${toISODateOnly(tomorrow)}&adults=${adults}&children=${children}`
	)
}

const offers = await searchOffers({
	productId,
	checkIn,
	checkOut,
	adults,
	children,
})

const searchState = {
	checkIn: toISODateOnly(checkIn),
	checkOut: toISODateOnly(checkOut),
	adults,
	children,
}

const images = await resolveProductImages(productId)
const services = await resolveProductServices(productId)

const houseRules = await listHouseRulesByProduct(String(productId))
const HOUSE_RULE_TYPES = ["Children", "Pets", "Smoking", "ExtraBeds", "Access", "Other"] as const
const houseRulesByType = houseRules.reduce((acc: Record<string, any[]>, r: any) => {
	const t = String(r.type ?? "")
	if (!acc[t]) acc[t] = []
	acc[t].push(r)
	return acc
}, {})

// CAPA 6: resolve policies using the same scope context the user is actually shopping with.
// For rate-plan scoped policies, we need a concrete {variantId, ratePlanId}. Pick the cheapest offer context.
let policyVariantId: string | undefined = undefined
let policyRatePlanId: string | undefined = undefined
let minOfferPrice = Number.POSITIVE_INFINITY
for (const o of offers) {
	for (const rp of o.ratePlans ?? []) {
		const price = Number((rp as any).finalPrice ?? NaN)
		if (!Number.isFinite(price)) continue
		if (price < minOfferPrice) {
			minOfferPrice = price
			policyVariantId = String(o.variantId)
			policyRatePlanId = String((rp as any).ratePlanId)
		}
	}
}

const resolvedPolicies = await resolveEffectivePolicies({
	productId,
	variantId: policyVariantId,
	ratePlanId: policyRatePlanId,
	channel: "web",
})
let policies: any[] = mapResolvedPoliciesToUI(resolvedPolicies) as any[]
if (policies.length === 0) {
	console.warn(
		"[policies] canonical resolver returned 0 policies (no fallback; hotel scope removed)",
		{
			productId,
		}
	)
}

const policiesByCategory = policies.reduce((acc: Record<string, any[]>, p: any) => {
	if (!acc[p.category]) acc[p.category] = []
	acc[p.category].push(p)
	return acc
}, {})

const hotelRoom = await resolveHotelType(offers.map((o) => o.variant.entityId))
const amenities = await resolveHotelAmenities(offers.map((o) => o.variant.entityId))
const roomImages = await resolveRoomImages(offers.map((o) => o.variant.entityId))

try {
	const productResult = await db
		.select()
		.from(Product)
		.leftJoin(Destination, eq(Destination.id, Product.destinationId))
		.where(eq(Product.id, productId))
		.get()

	if (!productResult) {
		errorMessage = "Producto no encontrado."
	} else {
		hotelProduct = { ...productResult.Product, destination: productResult.Destination }
		hotelSubtype = await db.select().from(Hotel).where(eq(Hotel.productId, productId)).get()
	}
} catch (e) {
	console.error("Error al obtener detalles del producto:", e)
	errorMessage = e instanceof Error ? e.message : "Error desconocido"
}
---

<UILayout title={hotelProduct?.name || "Producto"}>
	<main
		class="mx-auto min-h-screen w-[96%] max-w-7xl space-y-7 overflow-x-hidden py-3 md:space-y-20 md:py-7 lg:p-12"
	>
		<BreadcrumProduct productData={hotelProduct} productId={productId} />

		{
			errorMessage ? (
				<div class="flex min-h-[60vh] flex-col items-center justify-center text-center">
					<h1 class="mb-4 text-4xl font-bold text-red-500">{errorMessage}</h1>
					<a
						href="/"
						class="rounded-lg border border-neutral-500 px-6 py-3 transition hover:bg-neutral-800 hover:text-white"
					>
						Volver al inicio
					</a>
				</div>
			) : hotelProduct ? (
				<>
					<section class="space-y-3">
						<div class="relative overflow-hidden rounded-2xl shadow-lg">
							<img
								id="gallery-main-img"
								data-open-modal="images"
								src={images[0]?.url || "https://placehold.co/1200x675?text=Sin+imagen"}
								alt={hotelProduct?.name}
								class="h-96 w-full cursor-pointer object-cover transition-transform duration-700 hover:scale-105"
							/>
						</div>

						{images.length > 1 && (
							<div class="grid grid-cols-3 gap-2 sm:grid-cols-4 md:grid-cols-6" dir="rtl">
								{images.map((img: ImageRow, i: number) => (
									<img
										src={img.url}
										alt={`Imagen ${i + 1}`}
										class="thumb-img h-24 w-full cursor-pointer rounded-lg object-cover hover:opacity-80"
										data-open-modal="images"
										data-index={i}
									/>
								))}
							</div>
						)}
					</section>

					<section class="space-y-3" id="info">
						<article
							class="flex h-auto w-full cursor-pointer flex-row gap-2 border-b border-neutral-700 text-sm text-neutral-400 md:gap-3"
							id="tabs"
						>
							<div class="tab-button active p-2 text-white" data-tab="info">
								<button>Información</button>
							</div>
							<div class="tab-button p-2" data-tab="price">
								<button>Precios</button>
							</div>
							<div class="tab-button p-2" data-tab="map">
								<button>Ubicación</button>
							</div>
							<div class="tab-button p-2" data-tab="policies">
								<button>Políticas</button>
							</div>
						</article>

						<article class="space-y-3 rounded-2xl bg-neutral-100 p-3 py-7 shadow-sm md:p-8">
							<div class="flex gap-1 text-black">
								{Array.from({ length: hotelSubtype?.stars ?? 0 }).map((_, i) => (
									<svg
										xmlns="http://www.w3.org/2000/svg"
										fill="currentColor"
										viewBox="0 0 24 24"
										class="h-5 w-5"
									>
										<path d="M12 .587l3.668 7.568L24 9.748l-6 5.85 1.416 8.252L12 19.771l-7.416 4.079L6 15.598 0 9.748l8.332-1.593z" />
									</svg>
								))}
							</div>
							<h1 class="text-lg text-xl font-semibold text-neutral-900 md:text-4xl md:font-bold">
								{hotelProduct?.name}
							</h1>
							<p class="text-xs text-neutral-500 md:text-sm">
								{hotelSubtype?.address}, {hotelProduct.destination?.name}
							</p>

							<p class="pt-7 text-sm leading-relaxed text-neutral-700 md:text-base">
								{hotelProduct?.description}
							</p>
							<div class="text-end">
								<span class="cursor-pointer text-sm text-blue-600" data-open-modal="services">
									... Más Información
								</span>
							</div>
						</article>

						<article>
							{services.length > 0 && (
								<div class="space-y-3 rounded-2xl bg-neutral-100 p-3 shadow-sm md:p-8" id="map">
									<ul class="grid grid-cols-2 gap-3 md:grid-cols-3 md:py-3 lg:grid-cols-4">
										{services.slice(0, 4).map((service: any) => {
											const Icon = service.icon
											return (
												<li class="flex h-[42px] max-w-56 items-center gap-2 p-2">
													{Icon ? <Icon class="h-5 w-5 shrink-0 text-black" /> : <span>•</span>}
													<span class="text-xs text-black md:text-sm">{service.name}</span>
												</li>
											)
										})}
									</ul>
									<div class="text-end">
										{services.length > 4 && (
											<span class="cursor-pointer text-sm text-blue-600" data-open-modal="services">
												+{services.length - 4} Servicios Más
											</span>
										)}
									</div>
								</div>
							)}
						</article>

						<article class="grid grid-cols-2">
							<button
								data-open-modal="map"
								class="group relative h-40 w-full overflow-hidden rounded-xl bg-neutral-200 shadow"
							>
								<iframe
									class="pointer-events-none h-full w-full grayscale transition group-hover:grayscale-0"
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade"
									src="https://www.google.com/maps?q=-33.4489,-70.6693&z=15&output=embed"
								/>

								<div class="absolute inset-0 flex items-center justify-center bg-black/30 text-sm font-medium text-white opacity-0 transition group-hover:opacity-100">
									Ver mapa
								</div>
							</button>
						</article>
					</section>

					<section class="mx-auto max-w-7xl" id="price">
						<RoomSection
							searchState={searchState}
							productId={productId}
							offers={offers}
							amenities={amenities}
							roomImages={roomImages}
							hotelRoom={hotelRoom}
						/>
					</section>

					<section>
						<article
							class="space-y-9 rounded-2xl bg-neutral-100 p-3 py-6 shadow-sm md:p-8"
							id="policies"
						>
							<h3 class="text-lg text-xl font-semibold text-neutral-900 md:text-4xl md:font-bold">
								Políticas de Alojamiento
							</h3>
							<div class="space-y-8">
								{Object.values(POLICY_UI_GROUPS)
									.flat()
									.map((category) => {
										const group = policiesByCategory[category] ?? []
										const first = group[0] ?? null
										const source = String(first?.resolvedFromScope ?? "global") as any
										const state = first
											? source === "rate_plan"
												? "override"
												: "inherited"
											: "missing"

										return (
											<div class="space-y-3">
												<PolicyCard
													category={POLICY_CATEGORY_ORDER[category] ?? category}
													description={String(first?.description ?? "")}
													version={Number(first?.version ?? 0)}
													source={source}
													state={state}
												/>
											</div>
										)
									})}
							</div>
						</article>
					</section>

					<section>
						<article class="space-y-6 rounded-2xl bg-neutral-100 p-3 py-6 shadow-sm md:p-8">
							<h3 class="text-lg text-xl font-semibold text-neutral-900 md:text-4xl md:font-bold">
								House Rules
							</h3>
							<p class="text-sm text-neutral-700">
								Information provided by the property. House rules are not part of booking policies.
							</p>

							<div class="space-y-6">
								{HOUSE_RULE_TYPES.map((t) => {
									const items = houseRulesByType[t] ?? []
									if (!items.length) return null
									return (
										<div class="space-y-2">
											<h4 class="text-lg font-semibold text-neutral-800">{t}</h4>
											<ul class="list-disc space-y-2 pl-5 text-sm text-neutral-600 md:text-base">
												{items.map((r: any) => (
													<li class="whitespace-pre-line">{String(r.description ?? "")}</li>
												))}
											</ul>
										</div>
									)
								})}
							</div>
						</article>
					</section>
				</>
			) : (
				<p class="text-center text-neutral-500">Cargando...</p>
			)
		}
	</main>

	<ImageModal />
	<ServiceDetailsModal services={services} />
	<MapModal
		latitude={hotelSubtype?.latitude}
		longitude={hotelSubtype?.longitude}
		address={hotelSubtype?.address || ""}
	/>
	<RoomModal
		searchState={searchState}
		productId={productId}
		offers={offers}
		amenities={amenities}
		roomImages={roomImages}
		hotelRoom={hotelRoom}
	/>

	<script>
		const tabs = document.querySelectorAll("#tabs .tab-button") as NodeListOf<HTMLDivElement>

		tabs.forEach((tab) => {
			tab.addEventListener("click", () => {
				tabs.forEach((t) => {
					t.classList.remove("active", "text-white")
					t.classList.add("text-neutral-400")
				})

				tab.classList.add("active", "text-white")
				tab.classList.remove("text-neutral-400")

				const targetId = tab.dataset.tab
				if (!targetId) return
				const section = document.getElementById(targetId)

				if (section) {
					section.scrollIntoView({
						behavior: "smooth",
						block: "start",
					})
				}
			})
		})
	</script>
</UILayout>
