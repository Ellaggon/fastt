---
import Badge from "@/components/ui/Badge.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import InternalAdminLayout from "@/layouts/InternalAdminLayout.astro"
import { requireInternalAdmin } from "@/lib/auth/requireInternalAdmin"
import { listPolicyExceptionRulesUseCase } from "@/container/policy-exceptions.container"
import { resolveRatePlanNameColumn } from "@/lib/rates/ratePlanSchemaCompat"
import { POLICY_EXCEPTION_RULE_TYPES } from "@/modules/policies/public"
import { asc, db, Product, Provider, RatePlan, Variant, eq } from "astro:db"

let isAdmin = false
try {
	await requireInternalAdmin(Astro.request)
	isAdmin = true
} catch (response) {
	if (response instanceof Response && response.status === 401) return Astro.redirect("/SignInPage")
	isAdmin = false
}
const filters = {
	q: String(Astro.url.searchParams.get("q") ?? "")
		.trim()
		.toLowerCase(),
	scope: String(Astro.url.searchParams.get("scope") ?? "all").trim(),
	category: String(Astro.url.searchParams.get("category") ?? "").trim(),
	type: String(Astro.url.searchParams.get("type") ?? "all").trim(),
	status: String(Astro.url.searchParams.get("status") ?? "all").trim(),
}
const rawItems = isAdmin
	? await listPolicyExceptionRulesUseCase({
			scope: filters.scope as any,
			category: filters.category || null,
			type: filters.type as any,
			isActive:
				filters.status === "active"
					? true
					: filters.status === "inactive"
						? false
						: ("all" as const),
			limit: 250,
		})
	: []
const items = filters.q
	? rawItems.filter((item) =>
			[
				item.id,
				item.type,
				item.scope,
				item.scopeId,
				item.category,
				item.reason,
				item.createdBy,
				JSON.stringify(item.action ?? {}),
			]
				.join(" ")
				.toLowerCase()
				.includes(filters.q)
		)
	: rawItems
const scopeRows = await (async () => {
	if (!isAdmin) return []
	const ratePlanName = await resolveRatePlanNameColumn()
	return db
		.select({
			productId: Product.id,
			productName: Product.name,
			providerName: Provider.displayName,
			variantId: Variant.id,
			variantName: Variant.name,
			ratePlanId: RatePlan.id,
			ratePlanName,
		})
		.from(Product)
		.leftJoin(Provider, eq(Provider.id, Product.providerId))
		.leftJoin(Variant, eq(Variant.productId, Product.id))
		.leftJoin(RatePlan, eq(RatePlan.variantId, Variant.id))
		.orderBy(asc(Product.name), asc(Variant.name), asc(ratePlanName))
		.all()
})()
const fmt = new Intl.DateTimeFormat("es-CL", { dateStyle: "short", timeStyle: "short" })
const categories = [
	{ value: "Cancellation", label: "Cancelación" },
	{ value: "Payment", label: "Pago" },
	{ value: "CheckIn", label: "Ingreso / salida" },
	{ value: "NoShow", label: "No presentación" },
]
const scopes = [
	{ value: "global", label: "Global" },
	{ value: "product", label: "Oferta / hotel" },
	{ value: "variant", label: "Habitación / variante" },
	{ value: "rate_plan", label: "Tarifa" },
]
const exceptionTypeLabels: Record<string, string> = {
	major_disruptive_event: "Evento disruptivo mayor",
	rebooking_refund: "Reubicación / reembolso",
	host_cancellation: "Cancelación del proveedor",
	local_law: "Ley local",
	support_manual_override: "Ajuste manual de soporte",
}
const categoryLabels = Object.fromEntries(
	categories.map((category) => [category.value, category.label])
)
const scopeLabels = Object.fromEntries(scopes.map((scope) => [scope.value, scope.label]))
const productOptions = new Map<string, string>()
const variantOptions = new Map<string, string>()
const ratePlanOptions = new Map<string, string>()
for (const row of scopeRows) {
	const provider = String(row.providerName ?? "Proveedor")
	const productId = String(row.productId ?? "")
	const productName = String(row.productName ?? productId)
	if (productId) productOptions.set(productId, `${provider} / ${productName}`)
	const variantId = String(row.variantId ?? "")
	if (variantId)
		variantOptions.set(variantId, `${productName} / ${String(row.variantName ?? variantId)}`)
	const ratePlanId = String(row.ratePlanId ?? "")
	if (ratePlanId) {
		ratePlanOptions.set(
			ratePlanId,
			`${productName} / ${String(row.variantName ?? "Habitación")} / ${String(row.ratePlanName ?? ratePlanId)}`
		)
	}
}

function percent(value: unknown): string | null {
	const n = Number(value)
	return Number.isFinite(n) ? `${n}%` : null
}

function money(value: unknown): string | null {
	const n = Number(value)
	return Number.isFinite(n) ? `${n}` : null
}

function basisLabel(value: unknown): string {
	const labels: Record<string, string> = {
		platform_absorbs: "la plataforma absorbe el ajuste",
		provider_absorbs: "el proveedor absorbe el ajuste",
		total_booking: "reserva completa",
		room_rate: "tarifa base",
		first_night: "primera noche",
		deposit: "depósito",
		none: "sin base de reembolso",
	}
	return labels[String(value ?? "").trim()] ?? String(value ?? "sin definir")
}

function effectiveWindow(item: any): string {
	const from = item.effectiveFrom ? fmt.format(new Date(item.effectiveFrom)) : "desde ahora"
	const to = item.effectiveTo ? fmt.format(new Date(item.effectiveTo)) : "sin fecha de cierre"
	return `${from} → ${to}`
}

function impactCopy(item: any) {
	const action = item.action ?? {}
	const refund = percent(action.refundOverridePercent)
	const payout = percent(action.payoutOverridePercent)
	const rebookingAmount = money(action.rebookingCreditAmount)
	const rebookingPercent = percent(action.rebookingCreditPercent)
	const hostFeeAmount = money(action.hostCancellationFeeAmount)
	const hostFeePercent = percent(action.hostCancellationFeePercent)
	const noShowWaived = action.waiveNoShowCharge === true
	return {
		before: "Antes: cálculo estándar de condiciones vigentes, sin excepción aplicada.",
		after:
			[
				refund ? `Después: reembolso forzado ${refund}` : null,
				payout ? `Después: payout ajustado ${payout}` : null,
				noShowWaived ? "Después: cargo no-show eximido" : null,
				hostFeeAmount || hostFeePercent ? "Después: cargo al proveedor por cancelación" : null,
				rebookingAmount || rebookingPercent ? "Después: crédito de reubicación aplicado" : null,
			]
				.filter(Boolean)
				.join(" · ") || "Después: se mantiene cálculo estándar, pero queda auditado.",
		guest:
			[
				refund ? `recibe reembolso forzado de ${refund}` : null,
				noShowWaived ? "no paga cargo de no presentación" : null,
				rebookingAmount ? `recibe crédito de reubicación ${rebookingAmount}` : null,
				rebookingPercent ? `recibe crédito de reubicación ${rebookingPercent}` : null,
			]
				.filter(Boolean)
				.join(" · ") || "sin cambio directo visible; aplica la condición vigente",
		provider:
			[
				payout ? `pago al proveedor ajustado a ${payout}` : null,
				action.payoutOverrideBasis ? `base: ${basisLabel(action.payoutOverrideBasis)}` : null,
				hostFeeAmount ? `cargo por cancelación del proveedor ${hostFeeAmount}` : null,
				hostFeePercent ? `cargo por cancelación del proveedor ${hostFeePercent}` : null,
			]
				.filter(Boolean)
				.join(" · ") || "sin ajuste directo de pago al proveedor",
		platform:
			[
				action.forceRefundBasis
					? `fuerza base de reembolso: ${basisLabel(action.forceRefundBasis)}`
					: null,
				action.payoutOverrideBasis === "platform_absorbs" ? "plataforma absorbe diferencia" : null,
				item.priority ? `prioridad ${item.priority}` : null,
			]
				.filter(Boolean)
				.join(" · ") || "mantiene cálculo estándar y trazabilidad",
		evidence:
			[
				item.reason,
				action.note,
				...(Array.isArray(action.evidenceAttachments)
					? action.evidenceAttachments.map((entry: any) => `${entry.label}: ${entry.value}`)
					: []),
			]
				.map((value) => String(value ?? "").trim())
				.filter(Boolean)
				.join(" · ") || "sin evidencia cargada",
	}
}

function approvalStatus(item: any): string {
	return String(item.action?.approval?.status ?? (item.isActive === false ? "pending" : "approved"))
}

function approvalLabel(item: any): string {
	const labels: Record<string, string> = {
		pending: "Pendiente aprobación",
		approved: "Aprobada",
		rejected: "Rechazada",
		rolled_back: "Rollback aplicado",
	}
	return labels[approvalStatus(item)] ?? "Pendiente aprobación"
}
---

<InternalAdminLayout title="Admin · Excepciones de condiciones">
	<section class="min-h-screen text-slate-200">
		<div class="mx-auto max-w-7xl space-y-6 px-6">
			<header class="space-y-2">
				<h1 class="text-2xl font-semibold text-white">Excepciones de condiciones</h1>
				<p class="text-sm text-slate-300">
					Excepciones legales y operativas aplicadas antes del cálculo final de reembolso, pago al
					proveedor, no presentación e instantáneas contractuales. Mantiene potencia técnica, pero
					cada excepción debe explicar impacto, vigencia y evidencia.
				</p>
			</header>

			{
				!isAdmin ? (
					<Card class="bg-slate-100">
						<p class="text-xl font-semibold text-slate-900">Acceso denegado</p>
					</Card>
				) : (
					<>
						<Card class="bg-slate-100">
							<div class="mb-5 rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm text-blue-950">
								<p class="font-semibold">Cómo usar excepciones</p>
								<p class="mt-1">
									Una excepción cambia el contrato resuelto para un caso legal, operativo o de
									soporte. Debe indicar a quién afecta: huésped, proveedor o plataforma; desde
									cuándo aplica; y qué evidencia o motivo justifica el cambio.
								</p>
							</div>
							<form
								method="get"
								class="mb-5 grid gap-3 rounded-lg border border-slate-300 bg-white p-4 lg:grid-cols-5"
							>
								<label class="space-y-1 text-sm text-slate-700 lg:col-span-2">
									<span class="font-semibold">Buscador soporte/admin</span>
									<input
										name="q"
										value={filters.q}
										class="w-full rounded border border-slate-300 p-2"
										placeholder="Buscar por motivo, evidencia, alcance, creador o ID"
										data-policy-exception-search
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Alcance</span>
									<select name="scope" class="w-full rounded border border-slate-300 p-2">
										<option value="all" selected={filters.scope === "all"}>
											Todos
										</option>
										{scopes.map((scope) => (
											<option value={scope.value} selected={filters.scope === scope.value}>
												{scope.label}
											</option>
										))}
									</select>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Tipo</span>
									<select name="type" class="w-full rounded border border-slate-300 p-2">
										<option value="all" selected={filters.type === "all"}>
											Todos
										</option>
										{POLICY_EXCEPTION_RULE_TYPES.map((type) => (
											<option value={type} selected={filters.type === type}>
												{exceptionTypeLabels[type] ?? type}
											</option>
										))}
									</select>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Estado</span>
									<select name="status" class="w-full rounded border border-slate-300 p-2">
										<option value="all" selected={filters.status === "all"}>
											Todos
										</option>
										<option value="active" selected={filters.status === "active"}>
											Activos
										</option>
										<option value="inactive" selected={filters.status === "inactive"}>
											Inactivos
										</option>
									</select>
								</label>
								<div class="flex items-end gap-3 lg:col-span-5">
									<Button type="submit" variant="secondary">
										Buscar
									</Button>
									<a href="/admin/policy-exceptions" class="text-sm font-semibold text-slate-600">
										Limpiar filtros
									</a>
									<p class="text-sm text-slate-500">{items.length} resultado(s)</p>
								</div>
							</form>
							<form id="policy-exception-form" class="grid gap-4 lg:grid-cols-4">
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Tipo de excepción</span>
									<select name="type" required class="w-full rounded border border-slate-300 p-2">
										{POLICY_EXCEPTION_RULE_TYPES.map((type) => (
											<option value={type}>{exceptionTypeLabels[type] ?? type}</option>
										))}
									</select>
								</label>
								<label class="space-y-1 text-sm text-slate-700 lg:col-span-2">
									<span class="font-semibold">Alcance real</span>
									<select
										name="scopeTarget"
										required
										class="w-full rounded border border-slate-300 p-2"
									>
										<option value="global::">Global: toda la plataforma</option>
										<optgroup label="Ofertas y hoteles">
											{Array.from(productOptions.entries()).map(([id, label]) => (
												<option value={`product::${id}`}>{label}</option>
											))}
										</optgroup>
										<optgroup label="Habitaciones">
											{Array.from(variantOptions.entries()).map(([id, label]) => (
												<option value={`variant::${id}`}>{label}</option>
											))}
										</optgroup>
										<optgroup label="Tarifas">
											{Array.from(ratePlanOptions.entries()).map(([id, label]) => (
												<option value={`rate_plan::${id}`}>{label}</option>
											))}
										</optgroup>
									</select>
									<span class="block text-xs text-slate-500">
										Elige el objeto real afectado. Los IDs quedan solo como detalle técnico.
									</span>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Categoría</span>
									<select name="category" class="w-full rounded border border-slate-300 p-2">
										<option value="">Todas</option>
										{categories.map((category) => (
											<option value={category.value}>{category.label}</option>
										))}
									</select>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Reembolso %</span>
									<input
										name="refundOverridePercent"
										type="number"
										min="0"
										max="100"
										class="w-full rounded border border-slate-300 p-2"
									/>
									<span class="block text-xs text-slate-500">
										Impacto huésped: fuerza el porcentaje reembolsable.
									</span>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Base de pago al proveedor</span>
									<input
										name="payoutOverrideBasis"
										class="w-full rounded border border-slate-300 p-2"
										placeholder="platform_absorbs / provider_absorbs"
									/>
									<span class="block text-xs text-slate-500">
										Impacto plataforma/proveedor: define quién absorbe el ajuste.
									</span>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Pago proveedor %</span>
									<input
										name="payoutOverridePercent"
										type="number"
										min="0"
										max="100"
										class="w-full rounded border border-slate-300 p-2"
									/>
									<span class="block text-xs text-slate-500">
										Impacto proveedor: reemplaza el pago calculado.
									</span>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Prioridad</span>
									<input
										name="priority"
										type="number"
										value="100"
										min="1"
										max="1000"
										class="w-full rounded border border-slate-300 p-2"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Desde</span>
									<input
										name="effectiveFrom"
										type="date"
										required
										class="w-full rounded border border-slate-300 p-2"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Hasta</span>
									<input
										name="effectiveTo"
										type="date"
										class="w-full rounded border border-slate-300 p-2"
									/>
								</label>
								<label class="flex items-center gap-2 pt-6 text-sm font-semibold text-slate-700">
									<input name="waiveNoShowCharge" type="checkbox" />
									Eximir cargo de no presentación
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Forzar base de reembolso</span>
									<input
										name="forceRefundBasis"
										class="w-full rounded border border-slate-300 p-2"
										placeholder="total_booking / room_rate / first_night / deposit"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Cargo por cancelación del proveedor</span>
									<input
										name="hostCancellationFeeAmount"
										type="number"
										min="0"
										class="w-full rounded border border-slate-300 p-2"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Cargo por cancelación del proveedor %</span>
									<input
										name="hostCancellationFeePercent"
										type="number"
										min="0"
										max="100"
										class="w-full rounded border border-slate-300 p-2"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Crédito reubicación</span>
									<input
										name="rebookingCreditAmount"
										type="number"
										min="0"
										class="w-full rounded border border-slate-300 p-2"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Crédito reubicación %</span>
									<input
										name="rebookingCreditPercent"
										type="number"
										min="0"
										max="100"
										class="w-full rounded border border-slate-300 p-2"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700 lg:col-span-2">
									<span class="font-semibold">Motivo operativo/legal</span>
									<input
										name="reason"
										class="w-full rounded border border-slate-300 p-2"
										required
										minlength="10"
										placeholder="Ej. evento disruptivo confirmado por soporte"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700 lg:col-span-2">
									<span class="font-semibold">Evidencia obligatoria</span>
									<input
										name="note"
										class="w-full rounded border border-slate-300 p-2"
										required
										minlength="8"
										placeholder="URL, ticket, resolución legal o referencia de soporte"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Ticket / caso</span>
									<input
										name="evidenceReference"
										class="w-full rounded border border-slate-300 p-2"
										required
										placeholder="SUP-1234 / LEGAL-2026-07"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">URL de evidencia</span>
									<input
										name="evidenceUrl"
										type="url"
										class="w-full rounded border border-slate-300 p-2"
										placeholder="https://..."
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Adjunto referenciado</span>
									<input
										name="evidenceFileName"
										class="w-full rounded border border-slate-300 p-2"
										placeholder="captura-soporte.pdf"
									/>
								</label>
								<label class="space-y-1 text-sm text-slate-700">
									<span class="font-semibold">Aprobación</span>
									<select name="approvalStatus" class="w-full rounded border border-slate-300 p-2">
										<option value="pending">Crear pendiente</option>
										<option value="approved">Crear aprobada</option>
									</select>
									<span class="block text-xs text-slate-500">
										Pendiente no afecta snapshots hasta aprobar.
									</span>
								</label>
								<div class="rounded-lg border border-slate-300 bg-slate-50 p-4 text-sm text-slate-700 lg:col-span-4">
									<p class="font-semibold text-slate-900">Impacto previsto</p>
									<div class="mt-3 grid gap-3 md:grid-cols-3">
										<div>
											<p class="text-xs font-semibold text-slate-500 uppercase">Huésped</p>
											<p data-impact-guest>Completa reembolso, no-show o reubicación.</p>
										</div>
										<div>
											<p class="text-xs font-semibold text-slate-500 uppercase">Proveedor</p>
											<p data-impact-provider>Completa payout o cargo al proveedor.</p>
										</div>
										<div>
											<p class="text-xs font-semibold text-slate-500 uppercase">Plataforma</p>
											<p data-impact-platform>Completa base, evidencia y prioridad.</p>
										</div>
									</div>
								</div>
								<div class="flex items-end gap-3 lg:col-span-4">
									<Button type="submit" variant="primary">
										Crear excepción
									</Button>
									<p id="policy-exception-feedback" class="text-sm text-slate-700" />
								</div>
							</form>
						</Card>

						<Card class="bg-slate-100">
							<div class="overflow-x-auto">
								<table class="min-w-full divide-y divide-slate-200">
									<thead>
										<tr class="text-left text-xs tracking-wide text-slate-600 uppercase">
											<th class="px-3 py-2">Tipo</th>
											<th class="px-3 py-2">Ámbito</th>
											<th class="px-3 py-2">Categoría</th>
											<th class="px-3 py-2">Impacto explicado</th>
											<th class="px-3 py-2">Estado</th>
											<th class="px-3 py-2">Acciones</th>
										</tr>
									</thead>
									<tbody class="divide-y divide-slate-200">
										{items.map((item) => {
											const impact = impactCopy(item)
											const approval = approvalStatus(item)
											return (
												<tr data-policy-exception-row>
													<td class="px-3 py-3 align-top text-sm font-semibold text-slate-900">
														{exceptionTypeLabels[item.type] ?? item.type}
														<p class="text-xs font-normal text-slate-500">
															Creada:{" "}
															{item.createdAt ? fmt.format(new Date(item.createdAt)) : "sin fecha"}
														</p>
														<p class="mt-1 text-xs font-normal text-slate-500">
															ID técnico: <code>{item.id}</code>
														</p>
													</td>
													<td class="px-3 py-3 align-top text-sm text-slate-700">
														{scopeLabels[item.scope || "global"] ?? item.scope ?? "Global"}
														<p class="text-xs text-slate-500">{item.scopeId || "todos"}</p>
													</td>
													<td class="px-3 py-3 align-top text-sm text-slate-700">
														{categoryLabels[item.category || ""] ?? "Todas"}
													</td>
													<td class="px-3 py-3 align-top text-xs text-slate-700">
														<div class="grid max-w-2xl gap-2 md:grid-cols-2">
															<div class="rounded bg-slate-200 p-2">
																<p class="font-semibold text-slate-900">Huésped</p>
																<p>{impact.guest}</p>
															</div>
															<div class="rounded bg-slate-200 p-2">
																<p class="font-semibold text-slate-900">Proveedor</p>
																<p>{impact.provider}</p>
															</div>
															<div class="rounded bg-slate-200 p-2">
																<p class="font-semibold text-slate-900">Plataforma</p>
																<p>{impact.platform}</p>
															</div>
															<div class="rounded bg-slate-200 p-2">
																<p class="font-semibold text-slate-900">Vigencia</p>
																<p>{effectiveWindow(item)}</p>
															</div>
															<div class="rounded bg-amber-50 p-2 md:col-span-2">
																<p class="font-semibold text-amber-950">Evidencia</p>
																<p class="text-amber-900">{impact.evidence}</p>
															</div>
															<div class="rounded bg-white p-2 md:col-span-2">
																<p class="font-semibold text-slate-900">Antes / después</p>
																<p>{impact.before}</p>
																<p class="mt-1">{impact.after}</p>
															</div>
														</div>
														<details class="mt-2">
															<summary class="cursor-pointer text-xs font-semibold text-slate-600">
																Ver acción técnica JSON
															</summary>
															<pre class="mt-2 max-w-xl rounded bg-slate-900 p-2 whitespace-pre-wrap text-slate-100">
																{JSON.stringify(item.action, null, 2)}
															</pre>
														</details>
													</td>
													<td class="px-3 py-3 align-top">
														<div class="space-y-2">
															{approval === "approved" && item.isActive !== false ? (
																<Badge variant="success">Aprobada y activa</Badge>
															) : approval === "rolled_back" ? (
																<Badge variant="error">Rollback aplicado</Badge>
															) : approval === "rejected" ? (
																<Badge variant="error">Rechazada</Badge>
															) : (
																<Badge variant="warning">Pendiente aprobación</Badge>
															)}
															<p class="text-xs text-slate-500">{approvalLabel(item)}</p>
															<p class="text-xs text-slate-500">
																{item.isActive === false
																	? "No afecta cálculos"
																	: "Afecta snapshots"}
															</p>
														</div>
													</td>
													<td class="px-3 py-3 align-top">
														<div class="flex flex-col gap-2">
															{approval !== "approved" && (
																<Button
																	type="button"
																	variant="primary"
																	data-exception-operation="approve"
																	data-exception-id={item.id}
																>
																	Aprobar
																</Button>
															)}
															{approval === "pending" && (
																<Button
																	type="button"
																	variant="secondary"
																	data-exception-operation="reject"
																	data-exception-id={item.id}
																>
																	Rechazar
																</Button>
															)}
															{approval === "approved" && item.isActive !== false && (
																<Button
																	type="button"
																	variant="secondary"
																	data-exception-operation="rollback"
																	data-exception-id={item.id}
																>
																	Rollback
																</Button>
															)}
															{approval === "approved" && (
																<Button
																	type="button"
																	variant="secondary"
																	data-toggle-exception={item.id}
																	data-next-active={item.isActive === false ? "true" : "false"}
																>
																	{item.isActive === false ? "Reactivar" : "Desactivar manual"}
																</Button>
															)}
														</div>
													</td>
												</tr>
											)
										})}
									</tbody>
								</table>
								{items.length === 0 && (
									<p class="px-3 py-6 text-sm text-slate-600">No hay excepciones creadas.</p>
								)}
							</div>
						</Card>
					</>
				)
			}
		</div>
	</section>
</InternalAdminLayout>

<script>
	const form = document.getElementById("policy-exception-form")
	const feedback = document.getElementById("policy-exception-feedback")
	const impactGuest = document.querySelector("[data-impact-guest]")
	const impactProvider = document.querySelector("[data-impact-provider]")
	const impactPlatform = document.querySelector("[data-impact-platform]")
	function fieldValue(name: string) {
		if (!(form instanceof HTMLFormElement)) return ""
		const field = form.elements.namedItem(name)
		if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement) {
			if (field instanceof HTMLInputElement && field.type === "checkbox") {
				return field.checked ? "true" : ""
			}
			return String(field.value || "").trim()
		}
		return ""
	}
	function updateImpactPreview() {
		const refund = fieldValue("refundOverridePercent")
		const payout = fieldValue("payoutOverridePercent")
		const payoutBasis = fieldValue("payoutOverrideBasis")
		const forceRefundBasis = fieldValue("forceRefundBasis")
		const noShow = fieldValue("waiveNoShowCharge")
		const hostFee =
			fieldValue("hostCancellationFeeAmount") || fieldValue("hostCancellationFeePercent")
		const rebooking = fieldValue("rebookingCreditAmount") || fieldValue("rebookingCreditPercent")
		const priority = fieldValue("priority")
		if (impactGuest) {
			impactGuest.textContent =
				[
					refund ? `reembolso forzado ${refund}%` : "",
					noShow ? "sin cargo no-show" : "",
					rebooking ? "crédito de reubicación activo" : "",
				]
					.filter(Boolean)
					.join(" · ") || "Sin impacto de huésped seleccionado."
		}
		if (impactProvider) {
			impactProvider.textContent =
				[
					payout ? `payout forzado ${payout}%` : "",
					payoutBasis ? `base ${payoutBasis}` : "",
					hostFee ? "cargo al proveedor configurado" : "",
				]
					.filter(Boolean)
					.join(" · ") || "Sin impacto de proveedor seleccionado."
		}
		if (impactPlatform) {
			impactPlatform.textContent =
				[
					forceRefundBasis ? `base de reembolso ${forceRefundBasis}` : "",
					payoutBasis === "platform_absorbs" ? "plataforma absorbe diferencia" : "",
					priority ? `prioridad ${priority}` : "",
				]
					.filter(Boolean)
					.join(" · ") || "Sin impacto de plataforma seleccionado."
		}
	}
	form?.addEventListener("input", updateImpactPreview)
	updateImpactPreview()
	form?.addEventListener("submit", async (event) => {
		event.preventDefault()
		if (!(form instanceof HTMLFormElement)) return
		const response = await fetch("/api/admin/policies/exceptions", {
			method: "POST",
			body: new FormData(form),
		})
		if (!feedback) return
		if (response.ok) {
			feedback.textContent = "Excepción creada."
			location.reload()
		} else {
			const payload = await response.json().catch(() => ({}))
			feedback.textContent = payload?.error || "No se pudo crear la excepción."
		}
	})
	document.querySelectorAll("[data-toggle-exception]").forEach((button) => {
		button.addEventListener("click", async () => {
			const id = button.getAttribute("data-toggle-exception")
			const isActive = button.getAttribute("data-next-active") === "true"
			const response = await fetch(`/api/admin/policies/exceptions/${id}`, {
				method: "PATCH",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ operation: "set_active", isActive }),
			})
			if (response.ok) location.reload()
		})
	})
	document.querySelectorAll("[data-exception-operation]").forEach((button) => {
		button.addEventListener("click", async () => {
			const id = button.getAttribute("data-exception-id")
			const operation = button.getAttribute("data-exception-operation")
			let reason = ""
			if (operation === "reject" || operation === "rollback") {
				reason = window.prompt("Indica razón de auditoría para esta acción") || ""
				if (reason.trim().length < 8) return
			}
			const response = await fetch(`/api/admin/policies/exceptions/${id}`, {
				method: "PATCH",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ operation, reason }),
			})
			if (response.ok) location.reload()
		})
	})
</script>
