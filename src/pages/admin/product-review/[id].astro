---
import { productRepository } from "@/container"
import InternalAdminLayout from "@/layouts/InternalAdminLayout.astro"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import { evaluateProductReadiness } from "@/modules/catalog/public"

const ADMIN_EMAILS = ["ellaggon@proton.me"]

const user = await getUserFromRequest(Astro.request)
if (!user) return Astro.redirect("/SignInPage")

const isAdmin = ADMIN_EMAILS.includes(user.email)

const productId = String(Astro.params.id ?? "")
if (!productId) return Astro.redirect("/admin/providers")

let readiness: Awaited<ReturnType<typeof evaluateProductReadiness>> | { error: string } | null =
	null

if (isAdmin) {
	try {
		readiness = await evaluateProductReadiness({ repo: productRepository }, { productId })
	} catch (error) {
		readiness = { error: error instanceof Error ? error.message : "internal_error" }
	}
}
---

<InternalAdminLayout title="Admin · Product Review">
	<main
		class="max-w-3xl space-y-4 rounded-xl border border-slate-800 bg-slate-900 p-6 text-slate-100"
	>
		<h1>Product: Review</h1>
		<p>Product: <code>{productId}</code></p>

		{
			!isAdmin ? (
				<div class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-4 text-sm text-amber-100">
					Forbidden: this internal review surface is restricted to platform admins.
				</div>
			) : readiness && "error" in readiness ? (
				<pre style="white-space: pre-wrap; margin-top: 16px;">{readiness.error}</pre>
			) : readiness ? (
				<pre style="white-space: pre-wrap; margin-top: 16px;">
					{`state=${readiness.state}
validationErrors:${
						readiness.validationErrors.length
							? `\n- ${readiness.validationErrors.map((error) => error.code).join("\n- ")}`
							: " []"
					}`}
				</pre>
			) : null
		}

		<p style="margin-top: 16px;">
			<a href="/admin/providers">Back to internal admin</a>
		</p>
	</main>
</InternalAdminLayout>
