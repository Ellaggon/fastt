---
import Button from "@/components/ui/Button.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { getProviderIdFromRequest } from "@/lib/auth/getProviderIdFromRequest"
import { getUserFromRequest } from "@/lib/auth/getUserFromRequest"
import {
	ADD_ROOM_PLAYBOOK_TITLE,
	getAddRoomStepById,
	getAddRoomStepPosition,
	getPreviousAddRoomStep,
} from "@/lib/playbook/add-room"
import { COMPLETE_TO_PUBLISH_PLAYBOOK_TITLE } from "@/lib/playbook/complete-to-publish"
import { evaluateAddRoomProgress } from "@/lib/playbook/evaluate-add-room-progress"
import { evaluateCompleteToPublishProgress } from "@/lib/playbook/evaluate-complete-to-publish-progress"
import { evaluateLaunchProgress } from "@/lib/playbook/evaluate-launch-progress"
import {
	getApplicableLaunchSteps,
	getLaunchStepById,
	getPreviousLaunchStep,
	LAUNCH_PLAYBOOK_TITLE,
	type LaunchStepId,
} from "@/lib/playbook/launch-accommodation"
import type { PlaybookId } from "@/lib/playbook/types"

interface Props {
	title?: string
	playbookId?: PlaybookId | null
	active?: boolean
	stepId?: LaunchStepId | string | null
	productId?: string
	variantId?: string
	ratePlanId?: string
	isHotel?: boolean
	continueHref?: string | null
	continueLabel?: string
	hideFooter?: boolean
}

const {
	title = "Workspace",
	playbookId = "launch",
	active = false,
	stepId = null,
	productId = "",
	variantId = "",
	ratePlanId = "",
	isHotel = false,
	continueHref = null,
	continueLabel = "Continuar →",
	hideFooter = false,
} = Astro.props

const isAddRoom = playbookId === "add-room"
const isComplete = playbookId === "complete-to-publish"
const launchCtx = {
	productId,
	isHotel,
	variantId: variantId || undefined,
	ratePlanId: ratePlanId || undefined,
}
const addRoomCtx = {
	productId,
	variantId: variantId || undefined,
	ratePlanId: ratePlanId || undefined,
}

let playbookTitle = LAUNCH_PLAYBOOK_TITLE
let stepLabel = ""
let stepGuestImpact = ""
let stepNumber: number | null = null
let totalSteps = 0
let progressPercent = 0
let previousHref: string | null = null
let resolvedContinueHref = continueHref?.trim() || null
let currentStepKnown = false

if (isComplete && active && productId) {
	playbookTitle = COMPLETE_TO_PUBLISH_PLAYBOOK_TITLE
	const user = await getUserFromRequest(Astro.request)
	const providerId = user ? await getProviderIdFromRequest(Astro.request, user) : null
	if (providerId) {
		const progress = await evaluateCompleteToPublishProgress(productId, providerId, {
			currentStepId: stepId,
			request: Astro.request,
			url: Astro.url,
		})
		if (progress) {
			progressPercent = progress.progress.progressPercent
			totalSteps = progress.progress.totalSteps
			const current = progress.steps.find((step) => step.isCurrent) ?? progress.steps[0]
			if (current) {
				currentStepKnown = true
				stepLabel = current.label
				stepGuestImpact = current.guestImpact
				stepNumber = progress.steps.findIndex((step) => step.isCurrent) + 1
				if (stepNumber === 0) stepNumber = 1
			}
			const previous = progress.steps
				.filter((step) => step.isBlocker && step.key !== stepId)
				.sort((a, b) => Number(a.isCurrent) - Number(b.isCurrent))[0]
			if (previous) previousHref = previous.href
			if (!resolvedContinueHref && progress.nextHref) {
				resolvedContinueHref = progress.nextHref
			}
		}
	}
} else {
	const currentStep = active
		? isAddRoom
			? getAddRoomStepById(stepId, addRoomCtx)
			: getLaunchStepById(stepId, launchCtx)
		: null
	const previousStep =
		active && stepId
			? isAddRoom
				? getPreviousAddRoomStep(stepId, addRoomCtx)
				: getPreviousLaunchStep(stepId, launchCtx)
			: null

	if (isAddRoom) {
		const position = getAddRoomStepPosition(stepId, addRoomCtx)
		stepNumber = position.stepNumber
		totalSteps = position.totalSteps
	} else {
		const applicableSteps = getApplicableLaunchSteps(launchCtx)
		const stepIndex = currentStep
			? applicableSteps.findIndex((step) => step.id === currentStep.id)
			: -1
		stepNumber = stepIndex >= 0 ? stepIndex + 1 : null
		totalSteps = applicableSteps.length
	}

	playbookTitle = isAddRoom ? ADD_ROOM_PLAYBOOK_TITLE : LAUNCH_PLAYBOOK_TITLE
	if (currentStep) {
		currentStepKnown = true
		stepLabel = currentStep.label
		stepGuestImpact = currentStep.guestImpact
	}
	if (previousStep) {
		previousHref = isAddRoom
			? (getPreviousAddRoomStep(stepId, addRoomCtx)?.buildHref(addRoomCtx) ?? null)
			: previousStep.id === "create" && productId
				? null
				: (getPreviousLaunchStep(stepId, launchCtx)?.buildHref(launchCtx) ?? null)
	}

	if (active && stepNumber && totalSteps > 0) {
		progressPercent = Math.round(((stepNumber - 1) / totalSteps) * 100)
	}

	if (active && productId) {
		const user = await getUserFromRequest(Astro.request)
		const providerId = user ? await getProviderIdFromRequest(Astro.request, user) : null
		if (providerId) {
			const progress = isAddRoom
				? await evaluateAddRoomProgress(productId, providerId, {
						variantId,
						ratePlanId,
						currentStepId: stepId,
					})
				: await evaluateLaunchProgress(productId, providerId, {
						isHotel,
						variantId,
						ratePlanId,
						currentStepId: stepId,
					})
			if (progress) {
				progressPercent = progress.progress.progressPercent
			}
		}
	}
}

const exitHref = productId
	? isAddRoom
		? `/product/${encodeURIComponent(productId)}/rooms`
		: `/product/${encodeURIComponent(productId)}`
	: "/dashboard"
const isTerminalStep = isAddRoom
	? stepId === "confirmation"
	: isComplete
		? stepId === "preview"
		: stepId === "preview"
const showFooter = active && currentStepKnown && !hideFooter
const stepPositionPercent =
	stepNumber && totalSteps ? Math.round((stepNumber / totalSteps) * 100) : 0
const visualProgressPercent = Math.min(100, Math.max(progressPercent, stepPositionPercent))
---

<WorkspaceLayout title={title}>
	{
		active && currentStepKnown ? (
			<div class="mb-5 space-y-2">
				<p class="text-xs font-semibold tracking-wide text-slate-400 uppercase">
					{stepNumber && totalSteps ? `Paso ${stepNumber} de ${totalSteps}` : "Progreso"}
				</p>
				<div
					class="fastt-progress-track h-1.5 overflow-hidden bg-slate-800"
					role="progressbar"
					aria-valuenow={progressPercent}
					aria-valuemin={0}
					aria-valuemax={100}
				>
					<div
						class="fastt-progress-value h-full"
						style={`width: ${visualProgressPercent}%; min-width: ${visualProgressPercent > 0 ? "0.75rem" : "0"}; background-color: var(--fastt-color-selection);`}
					/>
				</div>
			</div>
		) : null
	}

	<slot />

	{
		showFooter ? (
			<footer class="fastt-playbook-footer flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="min-h-10">
					{previousHref ? (
						<Button
							href={previousHref}
							variant="ghost"
							className="text-slate-300 hover:bg-slate-800 hover:text-white"
						>
							← Anterior
						</Button>
					) : null}
				</div>
				<div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
					<a
						href={exitHref}
						class="inline-flex h-10 items-center justify-center px-2 text-sm font-medium text-slate-500 transition hover:text-slate-200"
					>
						Salir del flujo
					</a>
					{isTerminalStep && isComplete ? (
						<p class="text-sm text-slate-400">Usa el botón Publicar en la vista previa.</p>
					) : isTerminalStep ? (
						<Button href={exitHref} className="fastt-playbook-cta">
							{isAddRoom ? "Ver habitaciones" : "Ir a la ficha"}
						</Button>
					) : resolvedContinueHref ? (
						<Button href={resolvedContinueHref} className="fastt-playbook-cta">
							{continueLabel}
						</Button>
					) : null}
				</div>
			</footer>
		) : null
	}
</WorkspaceLayout>
