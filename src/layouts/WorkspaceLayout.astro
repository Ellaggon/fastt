---
import DashboardSidebar from "@/components/dashboard/DashboardSidebar.astro"
import DashboardTopBar from "@/components/dashboard/DashboardTopBar.astro"
import Layout from "@/layouts/Layout.astro"
import {
	getBackofficeRouteClassification,
	getEnterpriseNavigationSection,
} from "@/lib/backoffice-governance"

interface Props {
	title?: string
}

const { title = "Workspace" } = Astro.props
const pathname = Astro.url.pathname
const classification = getBackofficeRouteClassification(pathname)
const activeSection = getEnterpriseNavigationSection(pathname)
---

<Layout title={title}>
	<div class="min-h-screen bg-black text-slate-100">
		<div class="flex min-h-screen">
			<aside class="hidden w-80 shrink-0 border-r border-slate-800 bg-slate-950 p-4 xl:block">
				<DashboardSidebar pathname={pathname} />
			</aside>

			<div class="flex min-h-screen flex-1 flex-col">
				<DashboardTopBar title={title} classification={classification} section={activeSection} />
				<main class="flex-1">
					<div class="mx-auto max-w-7xl px-6 py-8">
						<div class="mb-6 xl:hidden">
							<details class="rounded-2xl border border-slate-800 bg-slate-950 p-3">
								<summary class="cursor-pointer text-sm font-semibold text-slate-200">
									Enterprise navigation
								</summary>
								<div class="mt-4">
									<DashboardSidebar pathname={pathname} />
								</div>
							</details>
						</div>
						<slot />
					</div>
				</main>
			</div>
		</div>
	</div>
	<script is:inline>
		;(function () {
			if (typeof document === "undefined") return
			if (typeof window === "undefined") return
			if (!("startViewTransition" in document)) return

			document.addEventListener("click", (event) => {
				const target = event.target
				if (!(target instanceof Element)) return
				const anchor = target.closest("a[data-workspace-nav], a[data-astro-prefetch]")
				if (!(anchor instanceof HTMLAnchorElement)) return
				if (event.defaultPrevented) return
				if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return
				if (anchor.target && anchor.target !== "_self") return
				if (anchor.origin !== window.location.origin) return
				if (anchor.href === window.location.href) return

				event.preventDefault()
				document.startViewTransition(() => {
					window.location.assign(anchor.href)
				})
			})
		})()
	</script>
</Layout>
