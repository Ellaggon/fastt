---
import DashboardSidebar from "@/components/dashboard/DashboardSidebar.astro"
import DashboardTopBar from "@/components/dashboard/DashboardTopBar.astro"
import Layout from "@/layouts/Layout.astro"

interface Props {
	title?: string
}

const { title = "Workspace" } = Astro.props
const pathname = Astro.url.pathname
const currentPath = `${Astro.url.pathname}${Astro.url.search}`
---

<Layout title={title}>
	<div class="min-h-screen bg-black text-slate-100">
		<div class="flex min-h-screen">
			<aside
				class="sticky top-0 hidden h-screen w-68 shrink-0 overflow-y-auto bg-black px-3 py-4 text-slate-100 lg:block xl:w-72"
			>
				<div class="mb-3.5 px-2.5">
					<p class="truncate text-lg font-semibold text-white">Fastt</p>
				</div>
				<DashboardSidebar pathname={pathname} currentPath={currentPath} />
			</aside>

			<div class="flex min-h-screen min-w-0 flex-1 flex-col">
				<DashboardTopBar />
				<main class="min-w-0 flex-1">
					<div class="mx-auto max-w-7xl min-w-0 px-3 py-4 sm:px-6 sm:py-8">
						<div class="mb-4 sm:mb-6 lg:hidden">
							<details
								class="max-w-full overflow-hidden rounded-xl border border-white/[0.08] bg-black p-3 text-slate-100"
							>
								<summary class="cursor-pointer text-sm font-semibold text-white"> Menú </summary>
								<div class="mt-4">
									<DashboardSidebar pathname={pathname} currentPath={currentPath} />
								</div>
							</details>
						</div>
						<slot />
					</div>
				</main>
			</div>
		</div>
	</div>
</Layout>
