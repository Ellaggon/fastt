---
import ProviderSettingsSubnav from "@/components/provider/ProviderSettingsSubnav.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"

interface Props {
	title?: string
	eyebrow?: string
	heading?: string
	description?: string
}

const {
	title = "Configuración del proveedor",
	eyebrow = "Configuración del proveedor",
	heading = "Configuración",
	description = "Administra identidad, cumplimiento, fiscalidad e integraciones del proveedor.",
} = Astro.props
---

<WorkspaceLayout title={title}>
	<ProviderSettingsSubnav />

	<section class="space-y-6 text-slate-200">
		<header
			class="flex flex-col gap-4 border border-slate-800 bg-slate-950 p-6 shadow-sm lg:flex-row lg:items-end lg:justify-between"
		>
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
					{eyebrow}
				</p>
				<h1 class="mt-2 text-3xl font-semibold tracking-tight text-white">{heading}</h1>
				<p class="mt-3 text-sm leading-6 text-slate-300">{description}</p>
			</div>
			<slot name="actions" />
		</header>

		<slot />
	</section>
</WorkspaceLayout>
