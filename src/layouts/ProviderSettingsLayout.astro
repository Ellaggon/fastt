---
import ProviderSettingsSubnav from "@/components/provider/ProviderSettingsSubnav.astro"
import WorkspaceLayout from "@/layouts/WorkspaceLayout.astro"
import { Settings } from "@lucide/astro"

interface Props {
	title?: string
	eyebrow?: string
	heading?: string
	description?: string
}

const {
	title = "Configuración del proveedor",
	eyebrow = "Configuración del proveedor",
	heading = "Configuración",
	description = "Administra identidad, cumplimiento, fiscalidad e integraciones del proveedor.",
} = Astro.props
---

<WorkspaceLayout title={title}>
	<section class="space-y-8 text-slate-200">
		<header class="flex flex-wrap items-end justify-between gap-4 border-b border-slate-800 pb-5">
			<div class="max-w-3xl space-y-1.5">
				<p
					class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400"
				>
					<Settings class="h-4 w-4" />
					{eyebrow}
				</p>
				<h1 class="text-3xl font-semibold text-slate-100">{heading}</h1>
				<p class="max-w-2xl text-sm leading-6 text-slate-300">{description}</p>
			</div>
			<div class="flex flex-wrap items-center gap-3">
				<slot name="actions" />
			</div>
		</header>

		<section class="space-y-6 md:space-y-8">
			<ProviderSettingsSubnav />
			<slot />
		</section>
	</section>
</WorkspaceLayout>
