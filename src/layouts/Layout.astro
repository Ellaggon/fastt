---
import "@/styles/modals.css"
import "@/styles/global.css"
import { ClientRouter } from "astro:transitions"

interface Props {
	title: string
}
const { title } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon-sbg.webp" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
			integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
			crossorigin=""
		/>
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="font-sans">
		<slot />
		<script>
			const bootPageWorkspaces = () => {
				if (!window.location.pathname.startsWith("/financial")) return
				import("@/pages/financial/_client/financial-page-boot").then(
					({ bootFinancialExperience }) => {
						bootFinancialExperience()
					}
				)
			}

			document.addEventListener("astro:page-load", bootPageWorkspaces)
			bootPageWorkspaces()
		</script>
		<script is:inline>
			;(function () {
				const endpoint = "/api/internal/observability/rum"
				let lcpMs = null
				let inpMs = null
				let routeStartedAt = null
				let routeFrom = location.pathname

				function number(value) {
					return Number.isFinite(value) ? Math.round(value * 10) / 10 : null
				}

				function post(payload) {
					const body = JSON.stringify({
						...payload,
						pathname: location.pathname,
						visibilityState: document.visibilityState,
					})
					if (navigator.sendBeacon) {
						navigator.sendBeacon(endpoint, new Blob([body], { type: "application/json" }))
						return
					}
					fetch(endpoint, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body,
						keepalive: true,
					}).catch(function () {})
				}

				try {
					const nav = performance.getEntriesByType("navigation")[0]
					if (nav) {
						post({
							event: "navigation",
							ttfbMs: number(nav.responseStart),
							navigationType: nav.type,
						})
					}
				} catch {}

				try {
					new PerformanceObserver(function (list) {
						const entries = list.getEntries()
						const latest = entries[entries.length - 1]
						if (latest) lcpMs = number(latest.startTime)
					}).observe({ type: "largest-contentful-paint", buffered: true })
				} catch {}

				try {
					new PerformanceObserver(function (list) {
						for (const entry of list.getEntries()) {
							const duration = number(entry.duration)
							if (duration !== null) inpMs = Math.max(inpMs || 0, duration)
						}
					}).observe({ type: "event", buffered: true, durationThreshold: 40 })
				} catch {}

				document.addEventListener("astro:before-preparation", function () {
					routeStartedAt = performance.now()
					routeFrom = location.pathname
				})
				document.addEventListener("astro:page-load", function () {
					if (routeStartedAt === null) return
					post({
						event: "route-transition",
						referrerPathname: routeFrom,
						routeTransitionMs: number(performance.now() - routeStartedAt),
					})
					routeStartedAt = null
				})

				function flushVitals() {
					if (lcpMs === null && inpMs === null) return
					post({
						event: "web-vitals",
						lcpMs,
						inpMs,
					})
					lcpMs = null
					inpMs = null
				}

				document.addEventListener("visibilitychange", function () {
					if (document.visibilityState === "hidden") flushVitals()
				})
				window.addEventListener("pagehide", flushVitals)
				window.setTimeout(flushVitals, 8000)
			})()
		</script>
		<script is:inline>
			;(function () {
				// Supabase email confirmation can redirect to Site URL with tokens in the hash.
				// Forward them to /auth/callback so the server can persist them into httpOnly cookies.
				const h = window.location.hash || ""
				if (!h) return
				if (window.location.pathname.startsWith("/auth/callback")) return
				if (h.includes("access_token=") && h.includes("refresh_token=")) {
					window.location.replace("/auth/callback" + h)
				}
			})()
		</script>
	</body>
</html>

<style is:global>
	html {
		font-family: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif;

		/* background: linear-gradient(135deg, #101010, #151515, #101010); */
		background: black;
		background-size: 400% 400%;

		/* Animación de gradiente para el modo oscuro */
		animation: gradientFlowDark 20s ease infinite;

		color: #e0e0e0;
		min-height: 100vh;
	}

	body {
		font-family: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif;
		font-weight: 400;
	}

	h1,
	h2,
	h3 {
		font-weight: 700;
	}

	label {
		font-weight: 500;
	}

	button {
		font-weight: 600;
	}

	@keyframes gradientFlowDark {
		0% {
			background-position: 0% 50%;
		}
		50% {
			background-position: 100% 50%;
		}
		100% {
			background-position: 0% 50%;
		}
	}

	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}

	#map,
	.leaflet-pane,
	.leaflet-map-pane,
	.leaflet-tile-pane,
	.leaflet-overlay-pane,
	.leaflet-marker-pane,
	.leaflet-shadow-pane,
	.leaflet-tooltip-pane,
	.leaflet-popup-pane {
		z-index: 0 !important;
	}
</style>
