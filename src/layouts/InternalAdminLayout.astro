---
import Layout from "@/layouts/Layout.astro"

interface Props {
	title?: string
}

const { title = "Internal Admin" } = Astro.props
---

<Layout title={title}>
	<div class="min-h-screen bg-slate-950 text-slate-100">
		<header class="border-b border-slate-800 bg-slate-900/95">
			<div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-6">
				<a href="/admin/providers" class="text-sm font-semibold text-slate-200 hover:text-white">
					Fastt Internal Admin
				</a>
				<p class="text-xs font-medium uppercase tracking-[0.12em] text-amber-300">
					Internal-only surface
				</p>
			</div>
		</header>
		<main class="mx-auto max-w-7xl px-6 py-8">
			<slot />
		</main>
	</div>
</Layout>
