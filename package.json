{
  "name": "fast-store",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "astro dev",
    "seed:room-types": "astro db execute src/scripts/seed-room-types.ts",
    "seed:financial:demo": "astro db execute src/scripts/seed-financial-operational-demo.ts",
    "audit:r2-images": "astro db execute src/scripts/audit-r2-image-orphans.ts",
    "start": "astro dev --remote",
    "build": "astro build --remote",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "db:pg:generate-initial": "tsx scripts/db/generate-postgres-initial-migration.ts",
    "db:migrate:apply-one": "tsx scripts/db/apply-single-migration.ts",
    "db:backfill:surfaces": "tsx scripts/db/backfill-performance-surfaces.ts",
    "db:search:retention": "tsx scripts/db/apply-search-retention.ts",
    "db:verify:surfaces": "tsx scripts/db/verify-performance-surfaces.ts",
    "db:migrate:turso:export": "tsx scripts/db/turso-to-supabase/export-turso.ts",
    "db:migrate:turso:transform": "tsx scripts/db/turso-to-supabase/transform-for-postgres.ts",
    "db:migrate:supabase:apply-schema": "tsx scripts/db/turso-to-supabase/apply-supabase-schema.ts",
    "db:migrate:supabase:load": "tsx scripts/db/turso-to-supabase/load-supabase.ts",
    "db:migrate:supabase:validate": "tsx scripts/db/turso-to-supabase/validate-supabase-load.ts",
    "check:ui": "node scripts/check-ui-raw-objects.mjs --all",
    "check:ui:staged": "node scripts/check-ui-raw-objects.mjs --staged",
    "prepare": "husky",
    "test:search": "vitest tests/search tests/integration/search-v2.test.ts tests/integration/search-availability.test.ts",
    "test:search:synthetic": "vitest tests/search/search-synthetic-preprod-validation.test.ts",
    "test:postgres": "vitest run tests/postgres",
    "test:governance": "FASTT_ENFORCE_PROVIDER_GOVERNANCE=1 vitest run tests/integration/provider-governance.test.ts tests/integration/provider-payment-accounts.test.ts tests/integration/provider-admin-compliance.test.ts tests/integration/provider-phase2-maturity.test.ts",
    "perf:html-budget": "node scripts/perf/html-budget.mjs",
    "perf:infra-region": "node scripts/perf/infra-region-compare.mjs",
    "perf:pagespeed": "node scripts/perf/pagespeed-public.mjs",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@astrojs/check": "^0.9.8",
    "@astrojs/db": "^0.17.2",
    "@astrojs/node": "^10.0.6",
    "@astrojs/react": "^5.0.4",
    "@astrojs/vercel": "^10.0.5",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@libsql/client": "^0.15.10",
    "@lucide/astro": "^1.11.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.42.0",
    "leaflet": "^1.9.4",
    "postgres": "^3.4.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redis": "^5.12.1",
    "tailwindcss": "^4.2.4",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/leaflet": "^1.9.21",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "astro": "^6.1.9",
    "astro-eslint-parser": "1.2.2",
    "eslint": "9.32.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-define-config": "2.1.0",
    "eslint-plugin-astro": "1.3.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
